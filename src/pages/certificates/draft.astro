---
import OperationPageShell from '../../components/operations/OperationPageShell.astro';
---

<OperationPageShell
  pageKey="draft"
  title="Draft Olustur"
  description="Standart, dil ve kapsam tercihleriyle sertifika draft olusturma akisini izole eder; mobilde adimlar daha rahat yonetilir."
>
  <div class="space-y-6">
    <section class="grid grid-cols-1 xl:grid-cols-[1.1fr_0.9fr] gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Draft Ayarlari</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart</label>
            <select id="draft-standard" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main">
              <option>Seciniz...</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Dil</label>
            <div class="flex gap-3">
              <label class="flex-1 flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main">
                <input type="radio" name="draft-lang" value="TR" checked />
                TR
              </label>
              <label class="flex-1 flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main">
                <input type="radio" name="draft-lang" value="EN" />
                EN
              </label>
            </div>
          </div>
        </div>
        <div class="space-y-2">
          <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Kapsam</label>
          <textarea id="draft-kapsam" rows={8} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[220px]"></textarea>
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Onizleme Ozeti</h2>
        <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-3 text-sm">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted">Firma</p>
            <p id="draft-preview-firma" class="font-semibold text-main">—</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted">Yetkili</p>
            <p id="draft-preview-yetkili" class="font-semibold text-main">—</p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-muted">Iletisim</p>
            <p id="draft-preview-mail" class="font-semibold text-main">—</p>
          </div>
        </div>
        <div class="rounded-2xl border border-dashed border-border-main p-4 text-sm leading-relaxed text-muted">
          Bu ekran ikinci adimda `generateDraftCertificate` veya yeni bridge action ile dogrudan belge uretimine baglanacak.
        </div>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <button type="button" disabled class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-bold text-muted cursor-not-allowed">Payload Onizle (Yakinda)</button>
      <button type="button" disabled class="inline-flex items-center justify-center rounded-2xl bg-indigo-600/60 px-5 py-3 text-sm font-black text-white cursor-not-allowed">Draft Uret (Yakinda)</button>
    </div>
  </div>
</OperationPageShell>

<script>
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { loadCompanyOperationContext } from '../../features/operations/context';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/operations/definitions';

  const params = new URLSearchParams(location.search);
  let activeFirmaId = params.get('firmaId') || params.get('id') || '';

  function getCompanyValue(company: any, ...keys: string[]) {
    if (!company || typeof company !== 'object') return '';
    for (const key of keys) {
      const value = company[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    return '';
  }

  function getCompanyId(company: any) {
    return getCompanyValue(company, 'Firma No', 'FirmaNo', 'firmaNo', 'id', 'ID');
  }

  function getCompanyNick(company: any) {
    return getCompanyValue(company, 'Firma Adı', 'nickname', 'Nick', 'nick', 'FirmaAdi');
  }

  function getCompanyDisplayName(company: any) {
    return getCompanyNick(company) || getCompanyValue(company, 'Unvan', 'unvan');
  }

  function companyLabel(company: any) {
    const nick = getCompanyDisplayName(company) || 'Firma';
    const companyId = getCompanyId(company) || '—';
    return `${nick} (${companyId})`;
  }

  function renderPickerState(message = 'Bir firma seçip draft akışına devam edebilirsin.', isError = false) {
    const errorBox = document.getElementById('op-error');
    if (!errorBox) return;
    errorBox.innerHTML = `
      <div class="space-y-5">
        <div class="space-y-2">
          <p class="text-[10px] font-black uppercase tracking-[0.24em] ${isError ? 'text-rose-400' : 'text-indigo-400'}">Sertifika Merkezi</p>
          <h2 class="text-2xl font-extrabold tracking-tight text-main">Firma Seçerek Devam Et</h2>
          <p class="text-sm leading-relaxed ${isError ? 'text-rose-400' : 'text-muted'}">${message}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Seçimi</label>
            <input id="draft-company-search" list="draft-company-list" type="text" placeholder="Firma ara..." class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main" />
            <datalist id="draft-company-list"></datalist>
          </div>
          <button id="draft-company-continue" type="button" class="inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-colors">
            Draft ile Devam Et
          </button>
        </div>
        <p id="draft-company-status" class="text-xs font-semibold ${isError ? 'text-rose-400' : 'text-muted'}">${message}</p>
      </div>
    `;
  }

  function syncCompanyList() {
    const companyList = document.getElementById('draft-company-list');
    if (!companyList) return;
    const frag = document.createDocumentFragment();
    ($companies.get() as any[]).forEach((company) => {
      const option = document.createElement('option');
      option.value = companyLabel(company);
      frag.appendChild(option);
    });
    companyList.innerHTML = '';
    companyList.appendChild(frag);
  }

  function resolveCompanyFromInput() {
    const raw = (document.getElementById('draft-company-search') as HTMLInputElement | null)?.value.trim() || '';
    if (!raw) return null;
    return ($companies.get() as any[]).find((company) => {
      return companyLabel(company) === raw || getCompanyDisplayName(company) === raw || getCompanyId(company) === raw;
    }) || null;
  }

  async function preparePicker() {
    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.add('hidden');
    document.getElementById('op-error')?.classList.remove('hidden');
    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', '/certificates');
    renderPickerState();
    syncCompanyList();
    $companies.subscribe(() => syncCompanyList());
    await SyncManager.init();
    if (($companies.get() as any[]).length === 0) {
      const res = await api.getCompanies();
      if (res.success && Array.isArray(res.data)) {
        $companies.set(res.data);
      }
    }

    document.getElementById('draft-company-search')?.addEventListener('input', () => {
      const status = document.getElementById('draft-company-status');
      const selected = resolveCompanyFromInput();
      if (status) status.textContent = selected ? 'Firma seçildi. Devam edebilirsin.' : 'Listeden geçerli bir firma seç.';
    });

    document.getElementById('draft-company-continue')?.addEventListener('click', async () => {
      const status = document.getElementById('draft-company-status');
      const selected = resolveCompanyFromInput();
      const selectedId = selected ? getCompanyId(selected) : '';
      if (!selectedId) {
        if (status) status.textContent = 'Devam etmek için listeden geçerli bir firma seç.';
        return;
      }
      activeFirmaId = selectedId;
      await boot();
    });
  }

  async function boot() {
    if (!activeFirmaId) {
      await preparePicker();
      return;
    }

    const context = await loadCompanyOperationContext(activeFirmaId);
    if (!context) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.remove('hidden');
      renderPickerState('Firma bilgileri yüklenemedi. Lütfen başka bir firma seçip tekrar dene.', true);
      return;
    }

    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${activeFirmaId}`);
    document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
      const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
      const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
      if (definition) link.href = buildOperationHref(definition.href, activeFirmaId);
    });

    document.getElementById('op-company-id')!.textContent = `M${context.firmaId}`;
    document.getElementById('op-company-nick')!.textContent = context.nick || 'Firma';
    document.getElementById('op-company-dan')!.textContent = context.danisman || 'Danisman atanamamis';
    document.getElementById('op-company-unvan')!.textContent = context.unvan || context.nick || `Firma #${context.firmaId}`;
    document.getElementById('op-company-address')!.textContent = [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—';
    document.getElementById('op-company-kapsam')!.textContent = context.scope || context.kapsam || 'Kapsam bulunamadi.';
    document.getElementById('op-company-stats')!.textContent = `${context.certificates.length} sertifika kaydi icinden standart secimi baglanacak.`;

    const select = document.getElementById('draft-standard') as HTMLSelectElement | null;
    if (select) {
      const standards = new Set<string>();
      context.certificates.forEach((item: any) => {
        const value = Array.isArray(item) ? String(item[3] || '').trim() : String(item?.Standart || item?.standart || '').trim();
        if (value) standards.add(value);
      });
      if (standards.size === 0) standards.add('Genel Draft');
      Array.from(standards).forEach((value) => {
        const option = document.createElement('option');
        option.value = value;
        option.textContent = value;
        select.appendChild(option);
      });
    }

    (document.getElementById('draft-kapsam') as HTMLTextAreaElement | null)!.value = context.scope || context.kapsam;
    document.getElementById('draft-preview-firma')!.textContent = context.unvan || context.nick;
    document.getElementById('draft-preview-yetkili')!.textContent = [context.yetkiliAdi, context.yetkiliUnvani].filter(Boolean).join(' / ') || '—';
    document.getElementById('draft-preview-mail')!.textContent = context.mail || context.irtibatMail || '—';

    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-error')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.remove('hidden');
  }

  void boot();
</script>

