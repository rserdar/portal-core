---
import { getEntry } from 'astro:content';
import PageShell from '../../components/PageShell.astro';
import CompanyPicker from '../../components/CompanyPicker.astro';

const standardsReference = (await getEntry('reference', 'standards'))?.data.items ?? [];
---

<PageShell
  pageKey="draft"
  title="Taslak Oluştur"
  description="Standart, dil ve kapsam tercihlerini belirleyerek sertifika taslağı oluşturur. Firma bilgileri otomatik yüklenir."
>
  <script id="draft-standards-reference" type="application/json" set:html={JSON.stringify(standardsReference)}></script>

  <CompanyPicker
    slot="select"
    prefix="draft"
    eyebrow="Sertifika Taslağı"
    description="Taslak oluşturmak için önce bir firma seçmelisin."
  />

  <div class="space-y-6">

    <section class="space-y-6">

      <!-- Taslak Ayarları (Full Width) -->
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Taslak Ayarları</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Sol Sütun: Standart/Dil + Türkçe Kapsam -->
          <div class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-2">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart</label>
                <select id="draft-standard" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500">
                  <option value="">Seçiniz...</option>
                </select>
              </div>
              <div class="space-y-2">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Dil</label>
                <div class="flex gap-3">
                  <label class="flex-1 flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main cursor-pointer hover:bg-surface transition-colors">
                    <input type="radio" name="draft-lang" value="EN" checked class="accent-indigo-500" />
                    EN
                  </label>
                  <label class="flex-1 flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main cursor-pointer hover:bg-surface transition-colors">
                    <input type="radio" name="draft-lang" value="TR" class="accent-indigo-500" />
                    TR
                  </label>
                </div>
              </div>
            </div>

            <div class="space-y-2">
              <div class="flex items-center justify-between gap-3">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Türkçe Kapsam</label>
                <div class="flex gap-2">
                  <button id="draft-kapsam-upper" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors">BÜYÜK</button>
                  <button id="draft-kapsam-translate" type="button" class="rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors">EN Çevir</button>
                </div>
              </div>
              <textarea id="draft-kapsam" rows={8} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[220px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"></textarea>
            </div>
          </div>

          <!-- Sağ Sütun: Bilgi Notu + İngilizce Kapsam -->
          <div class="space-y-4">
            <div class="rounded-2xl border border-dashed border-border-main bg-surface-hover/30 p-4 min-h-[78px] flex items-center">
              <p class="text-xs leading-relaxed text-muted">
                Standart, dil ve kapsam verileri taslak şablonuna doğrudan basılır. 
                <span class="font-bold text-main">"Diğer"</span> seçiminde placeholder alanları da kullanılır.
              </p>
            </div>

            <div class="space-y-2">
              <div class="flex items-center justify-between gap-3">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">İngilizce Kapsam (Scope)</label>
                <div class="flex gap-2">
                  <button id="draft-scope-upper" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors">BÜYÜK</button>
                  <button id="draft-scope-translate" type="button" class="rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors">TR Çevir</button>
                </div>
              </div>
              <textarea id="draft-scope" rows={8} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[220px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"></textarea>
            </div>
          </div>
        </div>

        <!-- Diğer Standart Alanları — sadece "Diğer" seçilince görünür -->
        <div id="draft-other-wrap" class="hidden grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Özel Standart Adı</label>
            <input id="draft-other-full" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Örn. ISO 9001:2015" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart Açıklaması</label>
            <input id="draft-other-desc" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Örn. Quality Management System" />
          </div>
        </div>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <button id="draft-generate-button" type="button" class="inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
        Taslak Oluştur
      </button>
    </div>
  </div>
</PageShell>

<script>
  import { toast } from '../../lib/toast';
  import { api } from '../../lib/api';
  import { loadCompanyOperationContext } from '../../features/context';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/definitions';
  import { normalizeKey } from '../../lib/utils';
  import { setupOperationCompanyPicker } from '../../features/company-picker';
  import { normalizeStandards, type StandardOption } from '../../features/certificate-form';

  let cleanupFns: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }

  function runCleanups() {
    cleanupFns.forEach(fn => fn());
    cleanupFns = [];
  }

  function initPage() {
    runCleanups();

    const params = new URLSearchParams(location.search);
    let activeFirmaId = params.get('firmaId') || params.get('id') || '';
    let companyContext: Awaited<ReturnType<typeof loadCompanyOperationContext>> = null;
    let standards: StandardOption[] = [];

    const els = {
      standard: document.getElementById('draft-standard') as HTMLSelectElement | null,
      otherWrap: document.getElementById('draft-other-wrap'),
      otherFull: document.getElementById('draft-other-full') as HTMLInputElement | null,
      otherDesc: document.getElementById('draft-other-desc') as HTMLInputElement | null,
      kapsam: document.getElementById('draft-kapsam') as HTMLTextAreaElement | null,
      scope: document.getElementById('draft-scope') as HTMLTextAreaElement | null,
      opStats: document.getElementById('op-company-stats'),
      generateButton: document.getElementById('draft-generate-button') as HTMLButtonElement | null,
    };

  function pickObjectValue(record: Record<string, any>, aliases: string[]) {
    for (const key of aliases) {
      const value = record?.[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    const normalizedAliases = aliases.map((alias) => normalizeKey(alias));
    for (const [rawKey, rawValue] of Object.entries(record || {})) {
      if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') continue;
      if (normalizedAliases.includes(normalizeKey(rawKey))) return String(rawValue).trim();
    }
    return '';
  }

  function shouldShowOtherStandard(value: string) {
    const normalized = String(value || '')
      .trim()
      .toLocaleUpperCase('tr-TR')
      .replace(/[İI]/g, 'I')
      .replace(/[Ğ]/g, 'G')
      .replace(/[Ü]/g, 'U')
      .replace(/[Ş]/g, 'S')
      .replace(/[Ö]/g, 'O')
      .replace(/[Ç]/g, 'C');
    return normalized === 'DIGER' || normalized === 'CE';
  }

  function getSelectedLang() {
    const selectedLang = document.querySelector<HTMLInputElement>('input[name="draft-lang"]:checked');
    return selectedLang?.value === 'EN' ? 'EN' : 'TR';
  }

  function syncOtherStandardFields() {
    const text = els.standard?.selectedOptions[0]?.textContent?.trim() || '';
    const visible = shouldShowOtherStandard(text);
    if (els.otherWrap) {
      if (visible) {
        els.otherWrap.classList.remove('hidden');
        els.otherWrap.classList.add('grid');
      } else {
        els.otherWrap.classList.add('hidden');
        els.otherWrap.classList.remove('grid');
        if (els.otherFull) els.otherFull.value = '';
        if (els.otherDesc) els.otherDesc.value = '';
      }
    }
  }

  function renderStandards() {
    if (!els.standard) return;
    els.standard.innerHTML = '<option value="">Seçiniz...</option>';
    standards.forEach((item) => {
      const option = document.createElement('option');
      option.value = item.id;
      option.textContent = item.id;
      option.dataset.fullName = item.fullName;
      els.standard?.appendChild(option);
    });
  }

  async function loadStandards() {
    const res = await api.getMasterData('standards');
    const rows = res?.data?.dataset?.rows || [];
    standards = normalizeStandards(rows);
    if (standards.length === 0) {
      const fallbackRaw = document.getElementById('draft-standards-reference')?.textContent || '[]';
      const fallback = JSON.parse(fallbackRaw) as Array<{ id: string; prefix?: string; fullName?: string }>;
      standards = fallback.map((item) => ({
        id: item.id,
        prefix: item.prefix || 'ISO',
        fullName: item.fullName || item.id,
      }));
    }
    renderStandards();
  }

  function buildDraftPayloadPreview() {
    if (!companyContext || !els.standard) return null;
    const selectedOption = els.standard.selectedOptions[0];
    const standardId = selectedOption?.value?.trim() || '';
    const standardLabel = selectedOption?.textContent?.trim() || '';
    const lang = getSelectedLang();
    const kapsam = els.kapsam?.value.trim() || '';
    const scope = els.scope?.value.trim() || '';
    const isOther = shouldShowOtherStandard(standardLabel);
    const other = els.otherFull?.value.trim() || '';
    const aStandart = els.otherDesc?.value.trim() || '';

    return {
      standardId,
      standardLabel,
      lang,
      kapsam,
      scope,
      isOther,
      other,
      aStandart,
      nickname: companyContext.nick || '',
      firmaId: companyContext.firmaId || '',
    };
  }

  function hydratePreview() {
    if (!companyContext) return;
    const payload = buildDraftPayloadPreview();
    if (els.opStats) {
      if (!payload?.standardLabel) {
        els.opStats.textContent = 'Standart seçilmedi';
      } else if (payload.isOther) {
        const fullValue = payload.other || '{{Standart}}';
        const descValue = payload.aStandart || '{{aStandart}}';
        els.opStats.textContent = `${fullValue} / ${descValue} / ${payload.lang}`;
      } else {
        els.opStats.textContent = `${payload.standardLabel} / ${payload.lang}`;
      }
    }
  }

  async function generateDraft() {
    if (!companyContext || !els.standard || !els.generateButton) return;
    const payload = buildDraftPayloadPreview();
    if (!payload?.standardId || !payload.standardLabel) {
      toast.error('Lütfen bir standart seçin.');
      return;
    }
    if (!payload.kapsam || !payload.scope) {
      toast.error('Türkçe kapsam ve İngilizce scope alanlarını doldurun.');
      return;
    }
    if (payload.isOther && (!payload.other || !payload.aStandart)) {
      toast.error('Diğer standart için iki özel alanı da doldurun.');
      return;
    }

    const standardRes = await api.getStandardById(payload.standardId);
    if (!standardRes.success || !standardRes.data) {
      toast.error(`Standart bilgileri alınamadı: ${standardRes.error || 'Bilinmeyen hata'}`);
      return;
    }

    const standardInfo = standardRes.data as Record<string, any>;
    const tempId = payload.lang === 'EN'
      ? pickObjectValue(standardInfo, ['Themeid', 'ThemeID', 'themeid', 'EN Tema', 'İngilizce Tema ID'])
      : pickObjectValue(standardInfo, ['Temaid', 'TemaID', 'temaid', 'TR Tema', 'Türkçe Tema ID']);

    if (!tempId) {
      toast.error('Seçilen standart için tema ID bulunamadı.');
      return;
    }

    if (els.generateButton.disabled) return;
    els.generateButton.disabled = true;
    const originalText = els.generateButton.textContent || 'Taslak Oluştur';
    els.generateButton.textContent = 'Oluşturuluyor...';

    const certificate = {
      nickname: companyContext.nick,
      nick: companyContext.nick,
      id: companyContext.firmaId,
      firmaNo: companyContext.firmaId,
      standard: payload.standardLabel,
      standart: payload.standardLabel,
      other: payload.other,
      aStandart: payload.aStandart,
      not: payload.aStandart,
      unvan: companyContext.unvan,
      adres: companyContext.adres,
      sehir: companyContext.sehir,
      il: companyContext.sehir,
      ulke: companyContext.ulke,
      yazisma: (companyContext as any).yazismaAdresi,
      sube: (companyContext as any).yazismaAdresi,
      scope: payload.scope,
      kapsam: payload.kapsam,
      theme: tempId,
      tema: tempId,
      lang: payload.lang,
      logo: companyContext.logo,
    };

    const res = await api.generateDraftCertificate(certificate);
    els.generateButton.disabled = false;
    els.generateButton.textContent = originalText;

    if (!res.success) {
      toast.error(`Taslak oluşturulamadı: ${res.error || 'Bilinmeyen hata'}`);
      return;
    }

    const url = String((res.data as any)?.url || '');
    toast.success('Taslak sertifika Google Docs\'ta oluşturuldu.');
    if (url) window.open(url, '_blank', 'noopener,noreferrer');
  }

  async function preparePicker() {
    await setupOperationCompanyPicker({
      prefix: 'draft',
      registerCleanup,
      onShowPicker: () => {
        document.getElementById('op-skeleton')?.classList.add('hidden');
        document.getElementById('op-shell')?.classList.add('hidden');
        document.getElementById('op-select')?.classList.remove('hidden');
      },
      onSelected: async ({ id }) => {
        activeFirmaId = id;
        await boot();
      }
    });
  }

  async function boot() {
    if (!activeFirmaId) {
      await preparePicker();
      return;
    }

    const context = await loadCompanyOperationContext(activeFirmaId);
    if (!context) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-shell')?.classList.add('hidden');
      // Retry via picker if context fails
      await preparePicker();
      return;
    }
    companyContext = context;

    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${activeFirmaId}`);
    document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
      const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
      const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
      if (definition) link.href = buildOperationHref(definition.href, activeFirmaId);
    });

    document.getElementById('op-company-id')!.textContent = `M${context.firmaId}`;
    document.getElementById('op-company-nick')!.textContent = context.nick || 'Firma';
    document.getElementById('op-company-dan')!.textContent = context.danisman || 'Danışman atanmamış';
    document.getElementById('op-company-unvan')!.textContent = context.unvan || context.nick || `Firma #${context.firmaId}`;
    document.getElementById('op-company-address')!.textContent = [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—';
    
    // Use last certificate for scope and consultant if company record is empty
    const lastCert = context.certificates && context.certificates.length > 0 
      ? context.certificates[context.certificates.length - 1] 
      : null;
    
    const finalKapsam = context.kapsam || (lastCert ? pickObjectValue(lastCert, ['Türkçe Kapsam', 'Kapsam', 'kapsam', 'KAPSAM']) : '');
    const finalScope = context.scope || (lastCert ? pickObjectValue(lastCert, ['İngilizce Kapsam', 'Scope', 'scope', 'SCOPE']) : '');
    const finalDanisman = context.danisman || (lastCert ? pickObjectValue(lastCert, ['Danışman', 'Consultant', 'danisman', 'dan']) : '');

    document.getElementById('op-company-dan')!.textContent = finalDanisman || 'Danışman atanmamış';
    document.getElementById('op-company-kapsam')!.textContent = finalScope || finalKapsam || 'Kapsam bulunamadı.';
    
    // Set initial text for opStats
    if (els.opStats) {
      els.opStats.textContent = 'Standart seçilmedi';
    }

    await loadStandards();
    if (els.kapsam) els.kapsam.value = finalKapsam || '';
    if (els.scope) els.scope.value = finalScope || '';
    els.standard?.addEventListener('change', () => {
      syncOtherStandardFields();
      hydratePreview();
    });
    document.querySelectorAll<HTMLInputElement>('input[name="draft-lang"]').forEach((input) => {
      input.addEventListener('change', hydratePreview);
    });
    els.kapsam?.addEventListener('input', hydratePreview);
    els.scope?.addEventListener('input', hydratePreview);
    els.otherFull?.addEventListener('input', hydratePreview);
    els.otherDesc?.addEventListener('input', hydratePreview);

    document.getElementById('draft-kapsam-upper')?.addEventListener('click', () => {
      if (els.kapsam) els.kapsam.value = els.kapsam.value.toLocaleUpperCase('tr-TR');
    });
    document.getElementById('draft-scope-upper')?.addEventListener('click', () => {
      if (els.scope) els.scope.value = els.scope.value.toLocaleUpperCase('en-US');
    });

    const kapsamTransBtn = document.getElementById('draft-kapsam-translate') as HTMLButtonElement | null;
    if (kapsamTransBtn) {
      kapsamTransBtn.onclick = async () => {
        if (!els.kapsam || !els.scope || !els.kapsam.value.trim()) return;
        const res = await api.translate(els.kapsam.value, true);
        if (res.success && els.scope) els.scope.value = String(res.data || '');
        else toast.error(`Çeviri hatası: ${res.error}`);
      };
    }

    const scopeTransBtn = document.getElementById('draft-scope-translate') as HTMLButtonElement | null;
    if (scopeTransBtn) {
      scopeTransBtn.onclick = async () => {
        if (!els.scope || !els.kapsam || !els.scope.value.trim()) return;
        const res = await api.translate(els.scope.value, false);
        if (res.success && els.kapsam) els.kapsam.value = String(res.data || '');
        else toast.error(`Çeviri hatası: ${res.error}`);
      };
    }

    els.generateButton?.addEventListener('click', () => void generateDraft());
    syncOtherStandardFields();
    hydratePreview();

    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-select')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.remove('hidden');
  }

    void boot();
  }

  // Transition support & Initial load
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
