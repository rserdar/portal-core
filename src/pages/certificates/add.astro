        "Firma Adı": normalizeObjectValue(record, [
          "nick",
          "Firma Adı",
          "Nickname",
          "isim",
        ]),
        "Firma No": normalizeObjectValue(record, [
          "firma_no",
          "Firma No",
          "firmaNo",
          "firmano",
        ]),
        Standart: normalizeObjectValue(record, [
          "standart",
          "Standart",
          "standard",
        ]),
        "Denetim Tipi": normalizeObjectValue(record, [
          "denetim_tipi",
          "Denetim Tipi",
          "denetim",
          "denetimTipi",
        ]),
        "Sertifika No": normalizeObjectValue(record, [
          "sertifika_no",
          "Sertifika No",
          "sNo",
          "SNo",
          "sno",
        ]),
        "Sertifika Tarihi": normalizeObjectValue(record, [
          "sertifika_tarihi",
