<script>
  import { api } from "../../lib/api";
  import { $companies } from "../../lib/store";
  import { SyncManager } from "../../lib/sync";
  import { toast } from "../../lib/toast";
  import { normalizeKey } from "../../lib/utils";
  import { loadCompanyOperationContext } from "../../features/context";
  import { setupOperationCompanyPicker } from "../../features/company-picker";

  import {
    normalizeStandards,
    buildSuggestedCertPrefix,
    mergeCertNoSuggestion,
    addOneYearMinusOneDay,
    toDisplayDate,
    buildCertificateQrLink,
  } from "../../features/certificate-form";

  import {
    parseReferenceScript,
    recommendClassification,
    buildKapsamText,
    type EaReferenceItem,
    type NaceReferenceItem,
    type ClassificationSuggestion,
  } from "../../features/classification-reference";

  let cleanupFns: Array<() => void> = [];
  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }
  function runCleanups() {
    cleanupFns.forEach((fn) => fn());
    cleanupFns = [];
  }

  function initPage() {
    runCleanups();

    const params = new URLSearchParams(location.search);
    const initialFirmaId = params.get("firmaId") || params.get("id") || "";
    const editId = params.get("edit") || "";
    const cloneId = params.get("clone") || "";

    const els = {
      skeleton: document.getElementById("cert-page-skeleton"),
      select: document.getElementById("cert-page-select"),
      selectStatus: document.getElementById("cert-page-select-status"),
      companySearch: document.getElementById(
        "cert-company-search",
      ) as HTMLInputElement | null,
      companyList: document.getElementById(
        "cert-company-list",
      ) as HTMLDivElement | null,
      companyContinue: document.getElementById(
        "cert-company-continue",
      ) as HTMLButtonElement | null,
      error: document.getElementById("cert-page-error"),
      shell: document.getElementById("cert-page-shell"),
      form: document.getElementById(
        "certificate-form",
      ) as HTMLFormElement | null,
      backLink: document.getElementById(
        "cert-back-link",
      ) as HTMLAnchorElement | null,
      standSelect: document.getElementById(
        "cert-standart",
      ) as HTMLSelectElement | null,
      otherInput: document.getElementById(
        "cert-other",
      ) as HTMLInputElement | null,
      isoFull: document.getElementById(
        "cert-iso-full",
      ) as HTMLInputElement | null,
      gst: document.getElementById("cert-gst") as HTMLInputElement | null,
      goz: document.getElementById("cert-goz") as HTMLInputElement | null,
      stt: document.getElementById("cert-stt") as HTMLInputElement | null,
      sgt: document.getElementById("cert-sgt") as HTMLInputElement | null,
      sno: document.getElementById("cert-sno") as HTMLInputElement | null,
      suggested: document.getElementById(
        "cert-sno-suggested",
      ) as HTMLInputElement | null,
      kapsam: document.getElementById(
        "cert-kapsam",
      ) as HTMLTextAreaElement | null,
      scope: document.getElementById(
        "cert-scope",
      ) as HTMLTextAreaElement | null,
      logo: document.getElementById("cert-logo") as HTMLInputElement | null,
      dan: document.getElementById("cert-dan") as HTMLInputElement | null,
      consultantList: document.getElementById(
        "consultant-list",
      ) as HTMLDivElement | null,
      submit: document.getElementById(
        "cert-submit",
      ) as HTMLButtonElement | null,
      submitLabel: document.getElementById("cert-submit-label"),
      deleteBtn: document.getElementById(
        "cert-delete",
      ) as HTMLButtonElement | null,
      openRecent: document.getElementById(
        "cert-open-recent",
      ) as HTMLButtonElement | null,
      recentModal: document.getElementById("cert-recent-modal"),
      recentBackdrop: document.getElementById(
        "cert-recent-backdrop",
      ) as HTMLButtonElement | null,
      recentClose: document.getElementById(
        "cert-recent-close",
      ) as HTMLButtonElement | null,
      recentRefresh: document.getElementById(
        "cert-recent-refresh",
      ) as HTMLButtonElement | null,
      recentSummary: document.getElementById("cert-recent-summary"),
      recentEmpty: document.getElementById("cert-recent-empty"),
      recentList: document.getElementById("cert-recent-list"),
      denetim: document.getElementById(
        "cert-denetim",
      ) as HTMLSelectElement | null,
      kod: document.getElementById("cert-kod") as HTMLInputElement | null,
      akreditasyon: document.getElementById(
        "cert-akreditasyon",
      ) as HTMLInputElement | null,
      akredite: document.getElementById(
        "cert-akredite",
      ) as HTMLInputElement | null,
      durum: document.getElementById("cert-durum") as HTMLInputElement | null,
      not: document.getElementById("cert-not") as HTMLTextAreaElement | null,
      notLabel: document.getElementById("cert-not-label"),
      prevKapsamCard: document.getElementById("cert-prev-kapsam-card"),
      prevKapsam: document.getElementById("cert-prev-kapsam"),
      prevScopeCard: document.getElementById("cert-prev-scope-card"),
      prevScope: document.getElementById("cert-prev-scope"),
      gozetimRow: document.getElementById("cert-gozetim-row"),
      gozetimDone: document.getElementById(
        "cert-gozetim-done",
      ) as HTMLInputElement | null,
    };

    let companyContext: Awaited<
      ReturnType<typeof loadCompanyOperationContext>
    > = null;
    let standards: StandardOption[] = [];
    let editingCertificate: Record<string, any> | null = null;
    let editingCertificateUpdatedAt = "";
    let activeFirmaId = initialFirmaId;
    let selectedCompany: any = null;
    let formBindingsReady = false;
    let recentCertificates: Record<string, any>[] = [];
    let eaOptions: EaReferenceItem[] = [];
    let naceOptions: NaceReferenceItem[] = [];
    let iso22000Options: any[] = [];
    let iso13485Options: any[] = [];
    let iso50001Options: any[] = [];
    let classificationSuggestions: ClassificationSuggestion[] = [];
    let consultantOptions: string[] = [];
    let consultantSuggestions: string[] = [];
    let activeConsultantIndex = -1;
    let companySuggestions: any[] = [];
    let activeCompanyIndex = -1;

    function getCompanyValue(company: any, ...keys: string[]) {
      if (!company || typeof company !== "object") return "";
      for (const key of keys) {
        const value = company[key];
        if (
          value !== undefined &&
          value !== null &&
          String(value).trim() !== ""
        ) {
          return String(value).trim();
        }
      }
      return "";
    }

    function getCompanyId(company: any) {
      return getCompanyValue(
        company,
        "Firma No",
        "FirmaNo",
        "firmaNo",
        "id",
        "ID",
      );
    }

    function getCompanyNick(company: any) {
      return getCompanyValue(
        company,
        "Firma Adı",
        "nickname",
        "Nick",
        "nick",
        "FirmaAdi",
      );
    }

    function getCompanyDisplayName(company: any) {
      return (
        getCompanyNick(company) || getCompanyValue(company, "Unvan", "unvan")
      );
    }

    function companyLabel(company: any) {
      const nick = getCompanyDisplayName(company) || "Firma";
      const companyId = getCompanyId(company) || "—";
      return `${nick} (${companyId})`;
    }

    function setSelectStatus(message: string, isError = false) {
      if (!els.selectStatus) return;
      els.selectStatus.textContent = message;
      els.selectStatus.className = `text-xs font-semibold ${isError ? "text-rose-400" : "text-muted"}`;
    }

    function showCompanyPicker() {
      els.skeleton?.classList.add("hidden");
      els.error?.classList.add("hidden");
      els.shell?.classList.add("hidden");
      els.select?.classList.remove("hidden");
      if (els.backLink) els.backLink.href = "/certificates";
    }

    function syncCompanyList(companies: any[]) {
      if (companies.length > 0) {
        setSelectStatus("Bir firma seçip devam edebilirsin.");
      }
      if (
        document.activeElement === els.companySearch &&
        !els.companyList?.classList.contains("hidden")
      ) {
        renderCompanySuggestions(els.companySearch?.value || "", {
          forceOpen: true,
        });
      }
    }

    function resolveCompanyFromInput() {
      const raw = els.companySearch?.value.trim() || "";
      const companies = $companies.get() as any[];
      if (!raw) return null;
      return (
        companies.find((company) => {
          const label = companyLabel(company);
          return (
            label === raw ||
            getCompanyDisplayName(company) === raw ||
            getCompanyId(company) === raw
          );
        }) || null
      );
    }

    function closeCompanyList() {
      activeCompanyIndex = -1;
      companySuggestions = [];
      if (!els.companyList) return;
      els.companyList.classList.add("hidden");
      els.companyList.innerHTML = "";
      els.companySearch?.setAttribute("aria-expanded", "false");
    }

    function chooseCompany(company: any) {
      selectedCompany = company;
      if (els.companySearch) {
        els.companySearch.value = companyLabel(company);
        els.companySearch.dispatchEvent(new Event("change", { bubbles: true }));
      }
      setSelectStatus("Firma seçildi. Devam edebilirsin.");
      closeCompanyList();
    }

    function renderCompanySuggestions(
      query = "",
      options: { forceOpen?: boolean } = {},
    ) {
      if (!els.companyList || !els.companySearch) return;

      const companies = $companies.get() as any[];
      const normalizedQuery = normalizeSearchText(query);
      const suggestions = normalizedQuery
        ? companies.filter((company) => {
            const haystacks = [
              companyLabel(company),
              getCompanyDisplayName(company),
              getCompanyId(company),
            ];
            return haystacks.some((value) =>
              normalizeSearchText(value).includes(normalizedQuery),
            );
          })
        : companies.slice(0, 12);

      companySuggestions = suggestions.slice(0, 12);
      activeCompanyIndex = companySuggestions.length ? 0 : -1;

      if (!companySuggestions.length) {
        if (options.forceOpen && query.trim()) {
          els.companyList.innerHTML =
            '<p class="px-3 py-2 text-xs font-semibold text-muted">Eşleşen firma bulunamadı. Listeden bir firma seçmelisin.</p>';
          els.companyList.classList.remove("hidden");
          els.companySearch.setAttribute("aria-expanded", "true");
          return;
        }
        closeCompanyList();
        return;
      }

      els.companyList.innerHTML = "";
      const fragment = document.createDocumentFragment();
      companySuggestions.forEach((company, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.companyOption = getCompanyId(company);
        button.className = `company-option flex w-full flex-col items-start rounded-xl px-3 py-2 text-left text-sm font-semibold transition-colors ${
          index === activeCompanyIndex
            ? "bg-indigo-500/10 text-indigo-200"
            : "text-main hover:bg-surface-hover"
        }`;

        const primary = document.createElement("span");
        primary.textContent = getCompanyDisplayName(company) || "Firma";
        button.appendChild(primary);

        const secondary = document.createElement("span");
        secondary.className =
          "text-[11px] font-bold uppercase tracking-widest text-muted";
        secondary.textContent = `M${getCompanyId(company) || "—"}`;
        button.appendChild(secondary);

        fragment.appendChild(button);
      });
      els.companyList.appendChild(fragment);
      els.companyList.classList.remove("hidden");
      els.companySearch.setAttribute("aria-expanded", "true");
    }

    function moveCompanySelection(direction: 1 | -1) {
      if (!companySuggestions.length || !els.companyList) return;
      activeCompanyIndex =
        (activeCompanyIndex + direction + companySuggestions.length) %
        companySuggestions.length;
      const buttons = Array.from(
        els.companyList.querySelectorAll<HTMLButtonElement>(
          "[data-company-option]",
        ),
      );
      buttons.forEach((button, index) => {
        button.classList.toggle(
          "bg-indigo-500/10",
          index === activeCompanyIndex,
        );
        button.classList.toggle(
          "text-indigo-200",
          index === activeCompanyIndex,
        );
        button.classList.toggle("text-main", index !== activeCompanyIndex);
        button.classList.toggle(
          "hover:bg-surface-hover",
          index !== activeCompanyIndex,
        );
      });
      buttons[activeCompanyIndex]?.scrollIntoView({ block: "nearest" });
    }

    function setShellError() {
      els.select?.classList.add("hidden");
      els.skeleton?.classList.add("hidden");
      els.error?.classList.remove("hidden");
    }

    function showError(message: string, detail = "") {
      setShellError();
      const textEl = document.getElementById("cert-page-error-text");
      const detailEl = document.getElementById("cert-page-error-detail");
      if (textEl) textEl.textContent = message;
      if (detailEl) {
        if (detail) {
          detailEl.textContent = detail;
          detailEl.classList.remove("hidden");
        } else {
          detailEl.textContent = "";
          detailEl.classList.add("hidden");
        }
      }
    }

    function isEditMode() {
      return Boolean(editId);
    }

    function isCloneMode() {
      return !isEditMode() && Boolean(cloneId);
    }

    function hydrateHeader() {
      if (!companyContext) return;
      const editing = isEditMode();
      const cloning = isCloneMode();
      const setText = (id: string, value: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
      };
      setText(
        "cert-header-breadcrumb",
        editing
          ? "Sertifika Düzenle"
          : cloning
            ? "Sertifika Kopyala"
            : "Sertifika Ekle",
      );
      setText("cert-company-id", `M${companyContext.firmaId}`);
      setText("cert-company-nick", companyContext.nick || "Firma");
      setText(
        "cert-company-dan",
        companyContext.danisman || "Danışman atanmamış",
      );
      setText(
        "cert-company-unvan",
        companyContext.unvan ||
          companyContext.nick ||
          `Firma #${companyContext.firmaId}`,
      );
      setText(
        "cert-company-address",
        [
          companyContext.adres,
          [companyContext.sehir, companyContext.ulke]
            .filter(Boolean)
            .join(" / "),
        ]
          .filter(Boolean)
          .join(" - ") || "—",
      );
      setText(
        "cert-company-stats",
        editing
          ? `${companyContext.certificates.length} sertifika arasından #${editId} düzenleniyor.`
          : cloning
            ? `${companyContext.certificates.length} sertifika arasından #${cloneId} kopyalanıyor.`
            : `${companyContext.certificates.length} sertifika, ${companyContext.tests.length} test kaydı bulundu.`,
      );
      if (els.submitLabel) {
        els.submitLabel.textContent = editing
          ? "Sertifikayı Güncelle"
          : cloning
            ? "Gözetim Sertifikası Oluştur"
            : "Sertifika Ekle";
      }
      els.deleteBtn?.classList.toggle("hidden", !editing);
      document
        .getElementById("cert-gozetim-row")
        ?.classList.toggle("hidden", !editing);
      els.prevKapsamCard?.classList.toggle("hidden", !editing && !cloning);
      els.prevScopeCard?.classList.toggle("hidden", !editing && !cloning);
    }

    function renderStandards() {
      if (!els.standSelect) return;
      els.standSelect.innerHTML = '<option value="">Seçiniz...</option>';
      standards.forEach((item) => {
        const option = document.createElement("option");
        option.value = item.id;
        option.textContent = item.id;
        option.dataset.prefix = item.prefix;
        option.dataset.fullName = item.fullName;
        els.standSelect?.appendChild(option);
      });
      if (standards.length === 0) {
        [
          "9001",
          "14001",
          "45001",
          "22000",
          "27001",
          "13485",
          "10002",
          "50001",
          "CE",
          "Diğer",
        ].forEach((value) => {
          const option = document.createElement("option");
          option.value = value;
          option.textContent = value;
          option.dataset.prefix = value;
          option.dataset.fullName = value;
          els.standSelect?.appendChild(option);
        });
      }
    }

    function updateStandardMeta() {
      if (!els.standSelect) return;
      const selected = els.standSelect.selectedOptions[0];
      const standardText = selected?.textContent?.trim() || "";
      const prefix = selected?.dataset.prefix || standardText;
      const fullName = selected?.dataset.fullName || standardText;
      if (els.isoFull) els.isoFull.value = fullName;
      if (els.suggested)
        els.suggested.value = buildSuggestedCertPrefix(prefix, activeFirmaId);

      if (els.notLabel) {
        if (standardText.includes("27001")) {
          els.notLabel.textContent = "SoA Tarihi / Versiyonu";
          els.notLabel.classList.add("text-sky-400");
          if (els.not && !els.not.value.trim()) {
            els.not.placeholder = "Örn: SoA Tarihi: 01.01.2024, Versiyon: 1.0";
          }
        } else {
          els.notLabel.textContent = "Notlar";
          els.notLabel.classList.remove("text-sky-400");
          if (els.not) els.not.placeholder = "Notlar";
        }
      }

      syncOtherStandardVisibility(standardText);
    }

    function shouldShowOtherStandard(standardText: string) {
      const normalized = String(standardText || "")
        .trim()
        .toLocaleUpperCase("tr-TR")
        .replace(/[İI]/g, "I")
        .replace(/[Ä]/g, "G")
        .replace(/[Ü]/g, "U")
        .replace(/[Å]/g, "S")
        .replace(/[Ö]/g, "O")
        .replace(/[Ç]/g, "C");
      return normalized === "DIGER" || normalized === "CE";
    }

    function syncOtherStandardVisibility(
      standardText: string,
      options: { clearOnHide?: boolean } = {},
    ) {
      const { clearOnHide = true } = options;
      const visible = shouldShowOtherStandard(standardText);
      if (els.otherInput) {
        els.otherInput.readOnly = !visible;
        els.otherInput.classList.toggle("cursor-not-allowed", !visible);
        els.otherInput.classList.toggle("opacity-60", !visible);
        if (!visible && clearOnHide) els.otherInput.value = "";
      }
    }

    async function loadStandards() {
      const res = await api.getMasterData("standards");
      const rows = res?.data?.dataset?.rows || [];
      standards = normalizeStandards(rows);
      renderStandards();
    }

    function ensureClassificationReferences() {
      if (eaOptions.length === 0) {
        eaOptions = parseReferenceScript<EaReferenceItem>("cert-ea-reference");
      }
      if (naceOptions.length === 0) {
        naceOptions = parseReferenceScript<NaceReferenceItem>("cert-nace-reference");
      }
      if (iso22000Options.length === 0) {
        iso22000Options = parseReferenceScript<any>("cert-iso22000-reference");
      }
      if (iso13485Options.length === 0) {
        iso13485Options = parseReferenceScript<any>("cert-iso13485-reference");
      }
      if (iso50001Options.length === 0) {
        iso50001Options = parseReferenceScript<any>("cert-iso50001-reference");
      }
    }

    function buildClassificationInput() {
      const previousCert = companyContext?.certificates?.[companyContext.certificates.length - 1] || null;
      return {
        companyName: selectedCompany ? getCompanyNick(selectedCompany) : companyContext?.nick,
        companyTitle: selectedCompany ? getCompanyValue(selectedCompany, "Unvan", "unvan") : companyContext?.unvan,
        businessText: [
          companyContext?.yapilanIs,
          getCompanyValue(selectedCompany, "yapilan_is", "Yapılan İş", "Yapilan Is", "yapilanIs"),
        ]
          .filter(Boolean)
          .join(" "),
        facilityText: [companyContext?.alan, getCompanyValue(selectedCompany, "Alan", "alan")].filter(Boolean).join(" "),
        departmentText: [companyContext?.departman, getCompanyValue(selectedCompany, "Departman", "departman")].filter(Boolean).join(" "),
        currentEa: els.ea?.value.trim() || companyContext?.ea || "",
        currentNace: els.kod?.value.trim() || companyContext?.nace || "",
        currentKapsam: els.kapsam?.value.trim() || "",
        currentScope: els.scope?.value.trim() || "",
        previousKapsam: normalizeObjectValue(previousCert || {}, ["Kapsam", "kapsam"]) || "",
        previousScope: normalizeObjectValue(previousCert || {}, ["Scope", "scope"]) || "",
      };
    }

    async function applyClassificationSuggestion(
      suggestion: ClassificationSuggestion,
      options: { autoTranslate?: boolean } = {},
    ) {
      if (els.ea) els.ea.value = suggestion.ea || "";
      if (els.kod) els.kod.value = suggestion.nace || "";

      const kapsamText = buildKapsamText(suggestion.kapsamLines);
      if (els.kapsam && kapsamText) {
        const shouldReplace =
          !els.kapsam.value.trim() ||
          confirm("Mevcut kapsam alanı öneri ile güncellensin mi?");
        if (shouldReplace) {
          els.kapsam.value = kapsamText;
        }
      }

      if (options.autoTranslate && els.scope && els.kapsam?.value.trim() && !els.scope.value.trim()) {
        const res = await api.translate(els.kapsam.value, true);
        if (res.success) {
          els.scope.value = String(res.data || "");
        }
      }

      const selectedStandard = els.standSelect?.selectedOptions[0]?.textContent?.trim() || "";
      const labelType = selectedStandard.includes("22000") ? "Kategori" : selectedStandard.includes("13485") ? "MD Kodu" : selectedStandard.includes("50001") ? "Sektör" : "EA/NACE";
      toast.success(`${labelType} ${suggestion.ea ? `EA ${suggestion.ea} / ` : ""}${suggestion.nace} önerisi uygulandı.`);
    }

    function renderClassificationSuggestions() {
      ensureClassificationReferences();
      
      const selectedStandard = els.standSelect?.selectedOptions[0]?.textContent?.trim() || "";
      let targetNaceItems = naceOptions;
      let labelType = "NACE";

      if (selectedStandard.includes("22000")) {
        targetNaceItems = iso22000Options;
        labelType = "Kategori";
      } else if (selectedStandard.includes("13485")) {
        targetNaceItems = iso13485Options;
        labelType = "MD Kodu";
      } else if (selectedStandard.includes("50001")) {
        targetNaceItems = iso50001Options;
        labelType = "Teknik Sektör";
      }

      classificationSuggestions = recommendClassification(eaOptions, targetNaceItems, buildClassificationInput(), 6);

      if (!els.classificationPanel || !els.classificationSummary || !els.classificationList || !els.classificationApplyTop) {
        return;
      }

      if (classificationSuggestions.length === 0) {
        els.classificationPanel.classList.remove("hidden");
        els.classificationSummary.textContent =
          "Yeterli bağlam bulunamadı. Firma faaliyeti, kapsam veya mevcut NACE bilgisi eklendiğinde daha iyi öneri üretilebilir.";
        els.classificationList.innerHTML = "";
        els.classificationApplyTop.classList.add("hidden");
        return;
      }

      els.classificationPanel.classList.remove("hidden");
      els.classificationApplyTop.classList.remove("hidden");
      els.classificationSummary.textContent =
        `${classificationSuggestions.length} öneri bulundu. Skorlar referans tablo eşleşmesi ve mevcut bağlam üzerinden hesaplandı.`;

      els.classificationList.innerHTML = classificationSuggestions
        .map((suggestion, index) => {
          const reasonText = suggestion.reasons.slice(0, 2).join(" · ") || "Referans eşleşmesi";
          const lines = suggestion.kapsamLines
            .slice(0, 3)
            .map((line) => `<li class="text-xs text-muted leading-relaxed">${line}</li>`)
            .join("");

          return `
            <div class="rounded-2xl border ${index === 0 ? "border-indigo-500/30 bg-indigo-500/10" : "border-border-main bg-surface"} p-4 space-y-3">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                <div class="space-y-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="badge-status ${index === 0 ? "badge-status-success" : "badge-status-warning"}">Skor ${suggestion.score}</span>
                    <span class="badge-status border-border-main bg-surface-hover text-main">EA ${suggestion.ea || "—"}</span>
                    <span class="badge-status border-border-main bg-surface-hover text-main">${labelType} ${suggestion.nace}</span>
                  </div>
                  <p class="text-sm font-bold text-main">${suggestion.label}</p>
                  <p class="text-xs text-muted">${reasonText}</p>
                </div>
                <button
                  type="button"
                  class="classification-apply inline-flex items-center justify-center rounded-xl border border-border-main bg-surface px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface-hover transition-colors"
                  data-index="${index}"
                >
                  Uygula
                </button>
              </div>
              <ul class="space-y-1">${lines}</ul>
            </div>
          `;
        })
        .join("");

      els.classificationList.querySelectorAll<HTMLButtonElement>(".classification-apply").forEach((button) => {
        const handler = async () => {
          const index = Number(button.dataset.index || "-1");
          const suggestion = classificationSuggestions[index];
          if (!suggestion) return;
          await applyClassificationSuggestion(suggestion, { autoTranslate: true });
        };
        button.onclick = () => void handler();
      });
    }

    function normalizeConsultantName(entry: unknown) {
      if (typeof entry === "string") {
        return entry.trim();
      }
      if (!entry || typeof entry !== "object" || Array.isArray(entry)) {
        return "";
      }

      return normalizeObjectValue(entry as Record<string, any>, [
        "ad",
        "adı",
        "adi",
        "isim",
        "name",
        "fullName",
        "consultant",
        "danışman",
        "danisman",
      ]);
    }

    function normalizeSearchText(value: string) {
      return String(value || "")
        .toLocaleLowerCase("tr-TR")
        .replace(/ı/g, "i")
        .replace(/ğ/g, "g")
        .replace(/ü/g, "u")
        .replace(/ş/g, "s")
        .replace(/ö/g, "o")
        .replace(/ç/g, "c")
        .trim();
    }

    function closeConsultantList() {
      activeConsultantIndex = -1;
      consultantSuggestions = [];
      if (!els.consultantList) return;
      els.consultantList.classList.add("hidden");
      els.consultantList.innerHTML = "";
      els.dan?.setAttribute("aria-expanded", "false");
    }

    function chooseConsultant(name: string) {
      if (els.dan) {
        els.dan.value = name;
        els.dan.dispatchEvent(new Event("change", { bubbles: true }));
      }
      closeConsultantList();
    }

    function renderConsultantSuggestions(
      query = "",
      options: { forceOpen?: boolean } = {},
    ) {
      if (!els.consultantList || !els.dan) return;

      const normalizedQuery = normalizeSearchText(query);
      const suggestions = normalizedQuery
        ? consultantOptions.filter((name) =>
            normalizeSearchText(name).includes(normalizedQuery),
          )
        : consultantOptions.slice(0, 12);

      consultantSuggestions = suggestions.slice(0, 12);
      activeConsultantIndex = consultantSuggestions.length ? 0 : -1;

      if (!consultantSuggestions.length) {
        if (options.forceOpen && query.trim()) {
          els.consultantList.innerHTML =
            '<p class="px-3 py-2 text-xs font-semibold text-muted">Eşleşen danışman bulunamadı. Yazdığınız metin kaydedilebilir.</p>';
          els.consultantList.classList.remove("hidden");
          els.dan.setAttribute("aria-expanded", "true");
          return;
        }
        closeConsultantList();
        return;
      }

      els.consultantList.innerHTML = "";
      const fragment = document.createDocumentFragment();
      consultantSuggestions.forEach((name, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.dataset.consultantOption = name;
        button.className = `consultant-option flex w-full items-center rounded-xl px-3 py-2 text-left text-sm font-semibold transition-colors ${
          index === activeConsultantIndex
            ? "bg-indigo-500/10 text-indigo-200"
            : "text-main hover:bg-surface-hover"
        }`;
        button.textContent = name;
        fragment.appendChild(button);
      });
      els.consultantList.appendChild(fragment);

      els.consultantList.classList.remove("hidden");
      els.dan.setAttribute("aria-expanded", "true");
    }

    function moveConsultantSelection(direction: 1 | -1) {
      if (!consultantSuggestions.length || !els.consultantList) return;
      activeConsultantIndex =
        (activeConsultantIndex + direction + consultantSuggestions.length) %
        consultantSuggestions.length;
      const buttons = Array.from(
        els.consultantList.querySelectorAll<HTMLButtonElement>(
          "[data-consultant-option]",
        ),
      );
      buttons.forEach((button, index) => {
        button.classList.toggle(
          "bg-indigo-500/10",
          index === activeConsultantIndex,
        );
        button.classList.toggle(
          "text-indigo-200",
          index === activeConsultantIndex,
        );
        button.classList.toggle("text-main", index !== activeConsultantIndex);
        button.classList.toggle(
          "hover:bg-surface-hover",
          index !== activeConsultantIndex,
        );
      });
      buttons[activeConsultantIndex]?.scrollIntoView({ block: "nearest" });
    }

    async function loadConsultants() {
      const res = await api.getConsultants();
      consultantOptions = Array.isArray(res?.data)
        ? Array.from(
            new Set(
              res.data
                .map((entry) => normalizeConsultantName(entry))
                .filter(Boolean),
            ),
          ).sort((a, b) => a.localeCompare(b, "tr"))
        : [];
      closeConsultantList();
    }

    function normalizeObjectValue(
      record: Record<string, any>,
      aliases: string[],
    ) {
      for (const key of aliases) {
        const value = record?.[key];
        if (
          value !== undefined &&
          value !== null &&
          String(value).trim() !== ""
        ) {
          return String(value).trim();
        }
      }
      if (record && typeof record === "object") {
        const normalizedAliases = aliases.map((alias) => normalizeKey(alias));
        for (const [rawKey, rawValue] of Object.entries(record)) {
          if (
            rawValue === undefined ||
            rawValue === null ||
            String(rawValue).trim() === ""
          )
            continue;
          if (normalizedAliases.includes(normalizeKey(rawKey))) {
            return String(rawValue).trim();
          }
        }
      }
      return "";
    }

    function getCertificateRecordId(
      record: Record<string, any> | null | undefined,
    ) {
      if (!record || typeof record !== "object") return "";
      const direct = normalizeObjectValue(record, [
        "ID",
        "Id",
        "id",
        "Certificate ID",
        "certificateId",
        "sertifikaId",
      ]);
      if (direct) return direct;

      const entries = Object.entries(record);
      if (entries.length > 0) {
        const [firstKey, firstValue] = entries[0];
        const normalizedFirstKey = String(firstKey || "")
          .trim()
          .toLocaleLowerCase("tr-TR")
          .replace(/[ıİ]/g, "i")
          .replace(/[ğÄ]/g, "g")
          .replace(/[üÜ]/g, "u")
          .replace(/[şÅ]/g, "s")
          .replace(/[öÖ]/g, "o")
          .replace(/[çÇ]/g, "c")
          .replace(/[^a-z0-9]/g, "");
        const firstValueText = String(firstValue ?? "").trim();
        if (
          firstValueText &&
          (normalizedFirstKey === "" || entries.length > 0)
        ) {
          return firstValueText;
        }
      }

      return "";
    }

    function normalizeCertificateRecord(
      record: any,
