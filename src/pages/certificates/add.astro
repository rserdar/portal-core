---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { ArrowLeft, FilePlus2, X, RotateCw } from 'lucide-astro';
---

<DashboardLayout title="Sertifika Ekle">
  <div class="max-w-5xl mx-auto pb-24 space-y-6">
    <div id="toast-container" class="fixed inset-x-4 bottom-4 sm:inset-x-auto sm:right-6 sm:bottom-6 z-[100] flex flex-col gap-3 pointer-events-none sm:max-w-sm"></div>
    <div class="flex items-center gap-3">
      <a id="cert-back-link" href="/company" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
        Firma Profili
      </a>
      <span class="text-border-main">/</span>
      <span class="text-xs font-bold text-muted" id="cert-header-breadcrumb">Sertifika Ekle</span>
    </div>

    <section class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <div id="cert-page-skeleton">
        <!-- Spinner -->
        <div class="flex items-center gap-3 px-6 sm:px-8 pt-6 sm:pt-8 pb-4">
          <svg class="animate-spin h-4 w-4 shrink-0 text-indigo-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-xs font-bold text-muted">Firma ve sertifika bilgileri yükleniyor...</span>
        </div>

        <!-- Skeleton cards -->
        <div class="animate-pulse">
        <!-- Firma header -->
        <div class="p-6 sm:p-8 border-b border-border-main space-y-4">
          <div class="flex gap-2">
            <div class="h-5 w-12 rounded-full bg-surface-hover"></div>
            <div class="h-5 w-20 rounded-full bg-surface-hover"></div>
            <div class="h-5 w-24 rounded-full bg-surface-hover"></div>
          </div>
          <div class="space-y-2">
            <div class="h-8 w-64 rounded-lg bg-surface-hover"></div>
            <div class="h-4 w-full max-w-xl rounded bg-surface-hover"></div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="h-20 rounded-2xl bg-surface-hover"></div>
            <div class="h-20 rounded-2xl bg-surface-hover"></div>
            <div class="h-20 rounded-2xl bg-surface-hover"></div>
          </div>
        </div>

        <!-- Form sections -->
        <div class="p-6 sm:p-8 space-y-6">
          <!-- Temel + Tarihler -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-32 rounded bg-surface-hover"></div>
              <div class="grid grid-cols-2 gap-4">
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
              </div>
            </div>
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-24 rounded bg-surface-hover"></div>
              <div class="grid grid-cols-2 gap-4">
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
              </div>
            </div>
          </div>

          <!-- Sertifika Bilgileri + Ek Bilgiler -->
          <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-36 rounded bg-surface-hover"></div>
              <div class="grid grid-cols-2 gap-4">
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
                <div class="h-12 rounded-2xl bg-surface-hover"></div>
              </div>
            </div>
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-24 rounded bg-surface-hover"></div>
              <div class="h-48 rounded-2xl bg-surface-hover"></div>
            </div>
          </div>

          <!-- Kapsam + Scope -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-32 rounded bg-surface-hover"></div>
              <div class="h-56 rounded-2xl bg-surface-hover"></div>
            </div>
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="h-4 w-32 rounded bg-surface-hover"></div>
              <div class="h-56 rounded-2xl bg-surface-hover"></div>
            </div>
          </div>

          <!-- Submit buttons -->
          <div class="flex justify-end gap-3">
            <div class="h-11 w-32 rounded-2xl bg-surface-hover"></div>
            <div class="h-11 w-40 rounded-2xl bg-surface-hover"></div>
          </div>
        </div>
        </div>
      </div>

      <div id="cert-page-select" class="hidden p-6 sm:p-8 space-y-5">
        <div class="space-y-2">
          <p class="text-[10px] font-black uppercase tracking-[0.24em] text-indigo-400">Sertifika Merkezi</p>
          <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main">Firma Seçerek Devam Et</h1>
          <p class="text-sm leading-relaxed text-muted max-w-2xl">Bu ekranı doğrudan açtığında önce ilgili firmayı seçebilirsin. Firma profilinden geldiğinde bu adım otomatik geçilir.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Seçimi</label>
            <input id="cert-company-search" list="cert-company-list" type="text" placeholder="Firma ara..." class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
            <datalist id="cert-company-list"></datalist>
          </div>
          <button id="cert-company-continue" type="button" class="w-full md:w-auto inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-colors">
            Firma ile Devam Et
          </button>
        </div>

        <p id="cert-page-select-status" class="text-xs font-semibold text-muted">Firma listesi hazırlanıyor...</p>
      </div>

      <div id="cert-page-error" class="hidden p-8 space-y-2">
        <p id="cert-page-error-text" class="text-sm font-bold text-rose-400">Firma context'i yuklenemedi.</p>
        <p id="cert-page-error-detail" class="hidden text-xs font-semibold text-muted"></p>
      </div>

      <div id="cert-page-shell" class="hidden">
        <div class="p-6 sm:p-8 border-b border-border-main space-y-4">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-indigo-500/20 bg-indigo-500/10 text-indigo-400" id="cert-company-id">M0</span>
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted" id="cert-company-nick">Firma</span>
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400" id="cert-company-dan">Danisman</span>
          </div>

          <div class="space-y-2 min-w-0">
            <h1 class="truncate text-2xl sm:text-3xl font-extrabold tracking-tight text-main" id="cert-company-unvan">Firma yukleniyor...</h1>
            <p class="text-sm font-semibold text-muted" id="cert-company-stats">—</p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1">Adres</p>
              <p class="text-sm font-semibold text-main leading-relaxed" id="cert-company-address">—</p>
            </div>
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1">Mevcut Kapsam</p>
              <p class="text-sm font-semibold text-main leading-relaxed line-clamp-4" id="cert-company-kapsam">—</p>
            </div>
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-3">Aksiyonlar</p>
              <div class="flex flex-wrap gap-2">
                <a id="cert-add-audit-link" href="#" class="inline-flex items-center gap-2 rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors">Denetim Ekle</a>
                <button id="cert-fill-from-company" type="button" class="inline-flex items-center gap-2 rounded-2xl border border-border-main bg-surface px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface-hover transition-colors">Bilgileri Getir</button>
                <button id="cert-open-recent" type="button" class="inline-flex items-center gap-2 rounded-2xl border border-sky-500/20 bg-sky-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-sky-300 hover:bg-sky-500/15 transition-colors">Son 25 Sertifika</button>
              </div>
            </div>
          </div>
        </div>

        <form id="certificate-form" class="p-6 sm:p-8 space-y-6">
          <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Temel Alanlar</h2>
                <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 1</span>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Denetim Tipi</label>
                  <select id="cert-denetim" name="denetim" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500">
                    <option value="Belgelendirme">Belgelendirme</option>
                    <option value="Gozetim">Gozetim</option>
                    <option value="Transfer">Transfer</option>
                    <option value="Belge Yenileme">Belge Yenileme</option>
                    <option value="Kapsam Genisletme">Kapsam Genisletme</option>
                  </select>
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart</label>
                  <select id="cert-standart" name="standart" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500">
                    <option value="">Yukleniyor...</option>
                  </select>
                </div>
              </div>
              <div id="other-standard-wrap" class="space-y-2 hidden">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Diger Standart</label>
                <input id="cert-other" name="other" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Diger standart" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">ISO Tam Adi</label>
                  <input id="cert-iso-full" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed" readonly />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Kisa Adi</label>
                  <input id="cert-nick" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed" readonly />
                </div>
              </div>
            </div>

            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Tarihler</h2>
                <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 2</span>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Gecerli Sertifika Tarihi</label>
                  <div class="flex gap-2">
                    <input id="cert-gst" name="gstRaw" type="date" class="flex-1 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                    <button id="cert-auto-goz" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-[11px] font-black uppercase tracking-widest text-emerald-300 hover:bg-emerald-500/15 transition-colors">+1</button>
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Gozetim Tarihi</label>
                  <input id="cert-goz" name="gozRaw" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Tescil Tarihi</label>
                  <input id="cert-stt" name="sttRaw" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Gecerlilik Tarihi</label>
                  <input id="cert-sgt" name="sgtRaw" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
              </div>
            </div>
          </section>

          <section class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Sertifika Bilgileri</h2>
                <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 3</span>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Oneri sNo</label>
                  <div class="flex min-w-0 items-stretch gap-2">
                    <input id="cert-sno-suggested" type="text" class="min-w-0 flex-1 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed" readonly />
                    <button id="cert-apply-suggested" type="button" class="inline-flex h-[50px] w-[50px] shrink-0 items-center justify-center rounded-2xl border border-emerald-500/20 bg-emerald-500/10 text-emerald-300 hover:bg-emerald-500/15 transition-colors" aria-label="Öneri sertifika numarasını uygula" title="Öneri sertifika numarasını uygula">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14"></path>
                        <path d="m13 5 7 7-7 7"></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Sertifika No</label>
                  <input id="cert-sno" name="sno" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Sertifika numarasi" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Akreditasyon</label>
                  <input id="cert-akreditasyon" name="akreditasyon" type="text" value="IAKS" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Akredite Kurulus</label>
                  <input id="cert-akredite" name="akredite" type="text" value="Medicert" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Kod / NACE</label>
                  <input id="cert-kod" name="kod" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Danisman</label>
                  <input id="cert-dan" name="dan" list="consultant-list" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
                  <datalist id="consultant-list"></datalist>
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Durum</label>
                  <input id="cert-durum" name="durum" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Durum" />
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Logo</label>
                  <input id="cert-logo" name="logo" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Drive dosya ID veya URL" />
                </div>
              </div>
            </div>

            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <h2 class="text-sm font-black uppercase tracking-widest text-main">Ek Bilgiler</h2>
              <div class="space-y-2">
                <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Notlar</label>
                <textarea id="cert-not" name="not" rows={7} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[180px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" placeholder="Notlar"></textarea>
              </div>
              <label id="cert-gozetim-row" class="hidden flex items-center gap-3 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main">
                <input id="cert-gozetim-done" type="checkbox" class="h-4 w-4 rounded border-border-main bg-surface text-primary" />
                Gozetim yapildi mi?
              </label>
            </div>
          </section>

          <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Turkce Kapsam</h2>
                <div class="flex gap-2">
                  <button id="cert-kapsam-upper" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors">BUYUK</button>
                  <button id="cert-kapsam-translate" type="button" class="rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors">EN Cevir</button>
                </div>
              </div>
              <textarea id="cert-kapsam" name="kapsam" rows={9} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[220px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"></textarea>
            </div>

            <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Ingilizce Scope</h2>
                <div class="flex gap-2">
                  <button id="cert-scope-upper" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors">BIG</button>
                  <button id="cert-scope-translate" type="button" class="rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors">TR Cevir</button>
                </div>
              </div>
              <textarea id="cert-scope" name="scope" rows={9} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[220px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"></textarea>
            </div>
          </section>

          <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
            <button id="cert-clear" type="button" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-bold text-main hover:bg-surface-hover transition-colors">Formu Temizle</button>
            <a id="cert-cancel" href="/certificates" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm font-bold text-rose-400 hover:bg-rose-500/15 transition-colors">
              <X size={14} />
              İptal
            </a>
            <button id="cert-submit" type="submit" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              <FilePlus2 size={15} />
              <span id="cert-submit-label">Sertifika Ekle</span>
            </button>
          </div>
        </form>
      </div>
    </section>
  </div>

  <!-- Son 25 Sertifika Modal — backdrop ve panel doğrudan fixed/viewport-relative -->
  <div id="cert-recent-modal" class="hidden">
    <div class="fixed inset-0 z-[90] bg-slate-950/70 backdrop-blur-sm"></div>
    <button id="cert-recent-backdrop" type="button" class="fixed inset-0 z-[90] cursor-default" aria-label="Kapat" tabindex="-1"></button>
    <aside id="cert-recent-panel" class="fixed z-[91] inset-x-4 sm:inset-x-auto sm:left-1/2 sm:-translate-x-1/2 top-1/2 -translate-y-1/2 w-auto sm:w-full sm:max-w-5xl h-[85dvh] max-h-[720px] rounded-3xl border border-border-main bg-surface shadow-2xl overflow-hidden opacity-0 scale-95 transition-all duration-200 ease-out will-change-transform">
      <div class="flex h-full flex-col">
        <div class="flex items-center justify-between gap-3 border-b border-border-main px-5 py-4 sm:px-6 shrink-0">
          <div class="min-w-0 space-y-0.5">
            <p class="text-[10px] font-black uppercase tracking-[0.24em] text-sky-400">Referans</p>
            <h2 class="text-sm sm:text-base font-extrabold tracking-tight text-main truncate">Son Çıkan 25 Sertifika</h2>
            <p id="cert-recent-summary" class="text-xs font-semibold text-muted truncate">Yükleniyor...</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button id="cert-recent-refresh" type="button" class="inline-flex items-center gap-1.5 rounded-2xl border border-border-main bg-surface-hover px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors" aria-label="Yenile">
              <RotateCw size={12} />
              <span class="hidden sm:inline">Yenile</span>
            </button>
            <button id="cert-recent-close" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-2xl border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" aria-label="Kapat">
              <X size={16} />
            </button>
          </div>
        </div>
        <div class="min-h-0 flex-1 overflow-y-auto">
          <div id="cert-recent-empty" class="m-5 sm:m-6 rounded-2xl border border-dashed border-border-main px-4 py-5 text-sm font-semibold text-muted">
            Son sertifikalar yükleniyor...
          </div>
          <div id="cert-recent-list" class="hidden overflow-x-auto px-5 sm:px-6 pb-5 sm:pb-6"></div>
        </div>
      </div>
    </aside>
  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { setFlashToast, showToast } from '../../lib/toast';
  import { loadCompanyOperationContext } from '../../features/operations/context';
  import {
    normalizeLegacyIsoRows,
    buildSuggestedCertPrefix,
    mergeCertNoSuggestion,
    addOneYearMinusOneDay,
    toDisplayDate,
    buildCertificateQrLink,
    type LegacyIsoOption,
  } from '../../features/operations/certificate-form';

  const params = new URLSearchParams(location.search);
  const initialFirmaId = params.get('firmaId') || params.get('id') || '';
  const editId = params.get('edit') || '';
  const cloneId = params.get('clone') || '';

  const els = {
    skeleton: document.getElementById('cert-page-skeleton'),
    select: document.getElementById('cert-page-select'),
    selectStatus: document.getElementById('cert-page-select-status'),
    companySearch: document.getElementById('cert-company-search') as HTMLInputElement | null,
    companyList: document.getElementById('cert-company-list'),
    companyContinue: document.getElementById('cert-company-continue') as HTMLButtonElement | null,
    error: document.getElementById('cert-page-error'),
    shell: document.getElementById('cert-page-shell'),
    form: document.getElementById('certificate-form') as HTMLFormElement | null,
    backLink: document.getElementById('cert-back-link') as HTMLAnchorElement | null,
    standSelect: document.getElementById('cert-standart') as HTMLSelectElement | null,
    otherWrap: document.getElementById('other-standard-wrap'),
    otherInput: document.getElementById('cert-other') as HTMLInputElement | null,
    isoFull: document.getElementById('cert-iso-full') as HTMLInputElement | null,
    nick: document.getElementById('cert-nick') as HTMLInputElement | null,
    gst: document.getElementById('cert-gst') as HTMLInputElement | null,
    goz: document.getElementById('cert-goz') as HTMLInputElement | null,
    stt: document.getElementById('cert-stt') as HTMLInputElement | null,
    sgt: document.getElementById('cert-sgt') as HTMLInputElement | null,
    sno: document.getElementById('cert-sno') as HTMLInputElement | null,
    suggested: document.getElementById('cert-sno-suggested') as HTMLInputElement | null,
    kapsam: document.getElementById('cert-kapsam') as HTMLTextAreaElement | null,
    scope: document.getElementById('cert-scope') as HTMLTextAreaElement | null,
    logo: document.getElementById('cert-logo') as HTMLInputElement | null,
    dan: document.getElementById('cert-dan') as HTMLInputElement | null,
    consultantList: document.getElementById('consultant-list'),
    submit: document.getElementById('cert-submit') as HTMLButtonElement | null,
    submitLabel: document.getElementById('cert-submit-label'),
    openRecent: document.getElementById('cert-open-recent') as HTMLButtonElement | null,
    recentModal: document.getElementById('cert-recent-modal'),
    recentBackdrop: document.getElementById('cert-recent-backdrop') as HTMLButtonElement | null,
    recentClose: document.getElementById('cert-recent-close') as HTMLButtonElement | null,
    recentRefresh: document.getElementById('cert-recent-refresh') as HTMLButtonElement | null,
    recentSummary: document.getElementById('cert-recent-summary'),
    recentEmpty: document.getElementById('cert-recent-empty'),
    recentList: document.getElementById('cert-recent-list'),
    denetim: document.getElementById('cert-denetim') as HTMLSelectElement | null,
    kod: document.getElementById('cert-kod') as HTMLInputElement | null,
    akreditasyon: document.getElementById('cert-akreditasyon') as HTMLInputElement | null,
    akredite: document.getElementById('cert-akredite') as HTMLInputElement | null,
    durum: document.getElementById('cert-durum') as HTMLInputElement | null,
    not: document.getElementById('cert-not') as HTMLTextAreaElement | null,
    gozetimRow: document.getElementById('cert-gozetim-row'),
    gozetimDone: document.getElementById('cert-gozetim-done') as HTMLInputElement | null,
  };

  let companyContext: Awaited<ReturnType<typeof loadCompanyOperationContext>> = null;
  let standards: LegacyIsoOption[] = [];
  let editingCertificate: Record<string, any> | null = null;
  let activeFirmaId = initialFirmaId;
  let selectedCompany: any = null;
  let formBindingsReady = false;
  let recentCertificates: Record<string, any>[] = [];

  function isEditMode() {
    return Boolean(editId);
  }

  function isCloneMode() {
    return !isEditMode() && Boolean(cloneId);
  }

  function getCompanyValue(company: any, ...keys: string[]) {
    if (!company || typeof company !== 'object') return '';
    for (const key of keys) {
      const value = company[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    return '';
  }

  function getCompanyId(company: any) {
    return getCompanyValue(company, 'Firma No', 'FirmaNo', 'firmaNo', 'id', 'ID');
  }

  function getCompanyNick(company: any) {
    return getCompanyValue(company, 'Firma Adı', 'nickname', 'Nick', 'nick', 'FirmaAdi');
  }

  function getCompanyDisplayName(company: any) {
    return getCompanyNick(company) || getCompanyValue(company, 'Unvan', 'unvan');
  }

  function companyLabel(company: any) {
    const nick = getCompanyDisplayName(company) || 'Firma';
    const companyId = getCompanyId(company) || '—';
    return `${nick} (${companyId})`;
  }

  function setSelectStatus(message: string, isError = false) {
    if (!els.selectStatus) return;
    els.selectStatus.textContent = message;
    els.selectStatus.className = `text-xs font-semibold ${isError ? 'text-rose-400' : 'text-muted'}`;
  }

  function showCompanyPicker() {
    els.skeleton?.classList.add('hidden');
    els.error?.classList.add('hidden');
    els.shell?.classList.add('hidden');
    els.select?.classList.remove('hidden');
    if (els.backLink) els.backLink.href = '/certificates';
  }

  function syncCompanyList(companies: any[]) {
    if (!els.companyList) return;
    const frag = document.createDocumentFragment();
    companies.forEach((company) => {
      const option = document.createElement('option');
      option.value = companyLabel(company);
      frag.appendChild(option);
    });
    els.companyList.innerHTML = '';
    els.companyList.appendChild(frag);
    if (companies.length > 0) {
      setSelectStatus('Bir firma seçip devam edebilirsin.');
    }
  }

  function resolveCompanyFromInput() {
    const raw = els.companySearch?.value.trim() || '';
    const companies = $companies.get() as any[];
    if (!raw) return null;
    return companies.find((company) => {
      const label = companyLabel(company);
      return label === raw || getCompanyDisplayName(company) === raw || getCompanyId(company) === raw;
    }) || null;
  }

  function setShellError() {
    els.select?.classList.add('hidden');
    els.skeleton?.classList.add('hidden');
    els.error?.classList.remove('hidden');
  }

  function showError(message: string, detail = '') {
    setShellError();
    const textEl = document.getElementById('cert-page-error-text');
    const detailEl = document.getElementById('cert-page-error-detail');
    if (textEl) textEl.textContent = message;
    if (detailEl) {
      if (detail) {
        detailEl.textContent = detail;
        detailEl.classList.remove('hidden');
      } else {
        detailEl.textContent = '';
        detailEl.classList.add('hidden');
      }
    }
  }

  function hydrateHeader() {
    if (!companyContext) return;
    const editing = isEditMode();
    const cloning = isCloneMode();
    const setText = (id: string, value: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };
    setText(
      'cert-header-breadcrumb',
      editing ? 'Sertifika Duzenle' : cloning ? 'Sertifika Kopyala' : 'Sertifika Ekle',
    );
    setText('cert-company-id', `M${companyContext.firmaId}`);
    setText('cert-company-nick', companyContext.nick || 'Firma');
    setText('cert-company-dan', companyContext.danisman || 'Danisman atanamamis');
    setText('cert-company-unvan', companyContext.unvan || companyContext.nick || `Firma #${companyContext.firmaId}`);
    setText('cert-company-address', [companyContext.adres, [companyContext.sehir, companyContext.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—');
    setText('cert-company-kapsam', companyContext.kapsam || 'Kapsam bulunamadi.');
    setText(
      'cert-company-stats',
      editing
        ? `${companyContext.certificates.length} sertifika arasindan #${editId} duzenleniyor.`
        : cloning
          ? `${companyContext.certificates.length} sertifika arasindan #${cloneId} kopyalaniyor.`
          : `${companyContext.certificates.length} sertifika, ${companyContext.tests.length} test kaydi bulundu.`,
    );
    if (els.nick) els.nick.value = companyContext.nick;
    if (els.submitLabel) {
      els.submitLabel.textContent = editing
        ? 'Sertifikayi Guncelle'
        : cloning
          ? 'Gozetim Sertifikasi Olustur'
          : 'Sertifika Ekle';
    }
    document.getElementById('cert-gozetim-row')?.classList.toggle('hidden', !editing);
  }

  function renderStandards() {
    if (!els.standSelect) return;
    els.standSelect.innerHTML = '<option value="">Seciniz...</option>';
    standards.forEach((item) => {
      const option = document.createElement('option');
      option.value = item.id;
      option.textContent = item.id;
      option.dataset.prefix = item.prefix;
      option.dataset.fullName = item.fullName;
      els.standSelect?.appendChild(option);
    });
    if (standards.length === 0) {
      ['9001', '14001', '45001', '22000', '27001', '13485', '10002', '50001', 'CE', 'Diğer'].forEach((value) => {
        const option = document.createElement('option');
        option.value = value;
        option.textContent = value;
        option.dataset.prefix = value;
        option.dataset.fullName = value;
        els.standSelect?.appendChild(option);
      });
    }
  }

  function updateStandardMeta() {
    if (!els.standSelect) return;
    const selected = els.standSelect.selectedOptions[0];
    const standardText = selected?.textContent?.trim() || '';
    const prefix = selected?.dataset.prefix || standardText;
    const fullName = selected?.dataset.fullName || standardText;
    if (els.isoFull) els.isoFull.value = fullName;
    if (els.suggested) els.suggested.value = buildSuggestedCertPrefix(prefix, activeFirmaId);

    syncOtherStandardVisibility(standardText);
  }

  function shouldShowOtherStandard(standardText: string) {
    const normalized = String(standardText || '')
      .trim()
      .toLocaleUpperCase('tr-TR')
      .replace(/[İI]/g, 'I')
      .replace(/[Ğ]/g, 'G')
      .replace(/[Ü]/g, 'U')
      .replace(/[Ş]/g, 'S')
      .replace(/[Ö]/g, 'O')
      .replace(/[Ç]/g, 'C');
    return normalized === 'DIGER' || normalized === 'CE';
  }

  function syncOtherStandardVisibility(standardText: string, options: { clearOnHide?: boolean } = {}) {
    const { clearOnHide = true } = options;
    const visible = shouldShowOtherStandard(standardText);
    els.otherWrap?.classList.toggle('hidden', !visible);
    if (!visible && clearOnHide && els.otherInput) els.otherInput.value = '';
  }

  async function loadStandards() {
    const res = await api.getMasterData('standards');
    const rows = res?.data?.dataset?.rows || [];
    standards = normalizeLegacyIsoRows(rows);
    renderStandards();
  }

  async function loadConsultants() {
    const res = await api.call('getConsultants');
    const consultants: string[] = Array.isArray(res?.data) ? res.data : [];
    if (!els.consultantList) return;
    els.consultantList.innerHTML = '';
    consultants.forEach((name) => {
      const option = document.createElement('option');
      option.value = name;
      els.consultantList?.appendChild(option);
    });
  }

  function normalizeObjectValue(record: Record<string, any>, aliases: string[]) {
    for (const key of aliases) {
      const value = record?.[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    if (record && typeof record === 'object') {
      const normalizeKey = (value: any) => String(value || '')
        .trim()
        .toLocaleLowerCase('tr-TR')
        .replace(/[ıİ]/g, 'i')
        .replace(/[ğĞ]/g, 'g')
        .replace(/[üÜ]/g, 'u')
        .replace(/[şŞ]/g, 's')
        .replace(/[öÖ]/g, 'o')
        .replace(/[çÇ]/g, 'c')
        .replace(/[^a-z0-9]/g, '');
      const normalizedAliases = aliases.map((alias) => normalizeKey(alias));
      for (const [rawKey, rawValue] of Object.entries(record)) {
        if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') continue;
        if (normalizedAliases.includes(normalizeKey(rawKey))) {
          return String(rawValue).trim();
        }
      }
    }
    return '';
  }

  function getCertificateRecordId(record: Record<string, any> | null | undefined) {
    if (!record || typeof record !== 'object') return '';
    const direct = normalizeObjectValue(record, ['ID', 'Id', 'id', 'Certificate ID', 'certificateId', 'sertifikaId']);
    if (direct) return direct;

    const entries = Object.entries(record);
    if (entries.length > 0) {
      const [firstKey, firstValue] = entries[0];
      const normalizedFirstKey = String(firstKey || '')
        .trim()
        .toLocaleLowerCase('tr-TR')
        .replace(/[ıİ]/g, 'i')
        .replace(/[ğĞ]/g, 'g')
        .replace(/[üÜ]/g, 'u')
        .replace(/[şŞ]/g, 's')
        .replace(/[öÖ]/g, 'o')
        .replace(/[çÇ]/g, 'c')
        .replace(/[^a-z0-9]/g, '');
      const firstValueText = String(firstValue ?? '').trim();
      if (firstValueText && (normalizedFirstKey === '' || entries.length > 0)) {
        return firstValueText;
      }
    }

    return '';
  }

  function normalizeCertificateRecord(record: any): Record<string, any> | null {
    if (!record) return null;

    if (Array.isArray(record)) {
      const stt = String(record[8] ?? '').trim();
      const sgt = String(record[9] ?? '').trim();
      return {
        ID: String(record[0] ?? '').trim(),
        'Firma Adı': String(record[1] ?? '').trim(),
        'Firma No': String(record[2] ?? '').trim(),
        Standart: String(record[3] ?? '').trim(),
        'Denetim Tipi': String(record[4] ?? '').trim(),
        'Sertifika No': String(record[5] ?? '').trim(),
        'Sertifika Tarihi': String(record[6] ?? '').trim(),
        'Gözetim Tarihi': String(record[7] ?? '').trim(),
        // Legacy sheet stores a single STT/Tescil column at index 8.
        'Son Tetkik Tarihi': stt,
        'Tescil Tarihi': stt,
        'Sertifika Tescil Tarihi': stt,
        'Sertifika Geçerlilik Tarihi': sgt,
        Kapsam: String(record[10] ?? '').trim(),
        Scope: String(record[11] ?? '').trim(),
        Logo: String(record[12] ?? '').trim(),
        Kod: String(record[13] ?? '').trim(),
        Akreditasyon: String(record[14] ?? '').trim(),
        Akredite: String(record[15] ?? '').trim(),
        'Danışman': String(record[16] ?? '').trim(),
        Durum: String(record[17] ?? '').trim(),
        Not: String(record[18] ?? '').trim(),
        'Gözetim Conf.': String(record[19] ?? '').trim(),
        'Other Standard': String(record[20] ?? '').trim(),
        'Calendar ID': String(record[21] ?? '').trim(),
        'QR Code': String(record[22] ?? '').trim(),
        'Cert Link': String(record[23] ?? '').trim(),
      };
    }

    if (typeof record === 'object') {
      return {
        ID: normalizeObjectValue(record, ['ID', 'Id', 'id', 'certId', 'Certificate ID', 'certificateId', 'sertifikaId']),
        'Firma Adı': normalizeObjectValue(record, ['Firma Adı', 'Nickname', 'nick', 'isim']),
        'Firma No': normalizeObjectValue(record, ['Firma No', 'firmaNo', 'firmano']),
        Standart: normalizeObjectValue(record, ['Standart', 'standart', 'standard']),
        'Denetim Tipi': normalizeObjectValue(record, ['Denetim Tipi', 'Denetim', 'denetim', 'denetimTipi']),
        'Sertifika No': normalizeObjectValue(record, ['Sertifika No', 'sNo', 'SNo', 'sno']),
        'Sertifika Tarihi': normalizeObjectValue(record, ['Sertifika Tarihi', 'gst', 'GST', 'sTarihi']),
        'Gözetim Tarihi': normalizeObjectValue(record, ['Gözetim Tarihi', 'Sertifika Gözetim Tarihi', 'goz', 'GOZ', 'sGozetimT']),
        'Son Tetkik Tarihi': normalizeObjectValue(record, ['Tescil Tarihi', 'Sertifika Tescil Tarihi', 'Son Tetkik Tarihi', 'stt', 'STT', 'sTT']),
        'Tescil Tarihi': normalizeObjectValue(record, ['Tescil Tarihi', 'Sertifika Tescil Tarihi', 'Son Tetkik Tarihi', 'stt', 'STT', 'sTT']),
        'Sertifika Geçerlilik Tarihi': normalizeObjectValue(record, ['Sertifika Geçerlilik Tarihi', 'sgt', 'SGT', 'sGT']),
        Kapsam: normalizeObjectValue(record, ['Kapsam', 'kapsam']),
        Scope: normalizeObjectValue(record, ['Scope', 'scope']),
        Logo: normalizeObjectValue(record, ['Logo', 'logo']),
        Kod: normalizeObjectValue(record, ['Kod', 'kod', 'NACE', 'nace']),
        Akreditasyon: normalizeObjectValue(record, ['Akreditasyon', 'akreditasyon']),
        Akredite: normalizeObjectValue(record, ['Akredite', 'akredite']),
        'Danışman': normalizeObjectValue(record, ['Danışman', 'Danisman', 'dan', 'danisman']),
        Durum: normalizeObjectValue(record, ['Durum', 'durum']),
        Not: normalizeObjectValue(record, ['Not', 'not']),
        'Gözetim Conf.': normalizeObjectValue(record, ['Gözetim Conf.', 'gozetimConfirmed', 'gozetimConf', 'gozetim']),
        'Other Standard': normalizeObjectValue(record, ['Other Standard', 'Other', 'other', 'Diğer', 'diger', 'Diger', 'diğer', 'Diğer Standart', 'digerStandart']),
        'Calendar ID': normalizeObjectValue(record, ['Calendar ID', 'eventId', 'calendar']),
        'QR Code': normalizeObjectValue(record, ['QR Code', 'qr', 'search']),
        'Cert Link': normalizeObjectValue(record, ['Cert Link', 'certLink', 'certiLink']),
      };
    }

    return null;
  }

  function toInputDate(value: string) {
    if (!value) return '';
    const parts = value.split('.');
    if (parts.length === 3) return `${parts[2]}-${parts[1]}-${parts[0]}`;
    return value;
  }

  function escapeHtml(value: unknown) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function renderRecentCertificates() {
    if (!els.recentSummary || !els.recentEmpty || !els.recentList) return;
    els.recentSummary.textContent = `${recentCertificates.length} kayıt referans için hazır.`;

    if (!recentCertificates.length) {
      els.recentList.classList.add('hidden');
      els.recentList.innerHTML = '';
      els.recentEmpty.classList.remove('hidden');
      els.recentEmpty.textContent = 'Son sertifika kaydı bulunamadı.';
      return;
    }

    els.recentEmpty.classList.add('hidden');
    els.recentList.classList.remove('hidden');

    const cols = 'grid grid-cols-[100px_80px_1.5fr_1.5fr_1fr]';

    const header = `
      <div class="${cols} gap-px bg-border-main text-[10px] font-black uppercase tracking-widest text-muted">
        <div class="bg-surface-hover px-3 py-2.5 whitespace-nowrap">Tarih</div>
        <div class="bg-surface-hover px-3 py-2.5 whitespace-nowrap">Standart</div>
        <div class="bg-surface-hover px-3 py-2.5 whitespace-nowrap">Sertifika No</div>
        <div class="bg-surface-hover px-3 py-2.5 whitespace-nowrap">Firma</div>
        <div class="bg-surface-hover px-3 py-2.5 whitespace-nowrap">Denetim Tipi</div>
      </div>
    `;

    const rows = recentCertificates.map((record) => `
      <div class="${cols} gap-px border-t border-border-main bg-border-main">
        <div class="bg-surface px-3 py-2.5 text-xs font-semibold text-main whitespace-nowrap">${escapeHtml(normalizeObjectValue(record, ['Sertifika Tarihi', 'gst', 'GST', 'sTarihi']) || '—')}</div>
        <div class="bg-surface px-3 py-2.5 text-xs font-semibold text-main whitespace-nowrap">${escapeHtml(normalizeObjectValue(record, ['Standart', 'standart', 'standard']) || '—')}</div>
        <div class="bg-surface px-3 py-2.5 text-xs font-mono text-main">${escapeHtml(normalizeObjectValue(record, ['Sertifika No', 'sNo', 'SNo', 'sno']) || '—')}</div>
        <div class="bg-surface px-3 py-2.5 text-xs text-main">${escapeHtml(normalizeObjectValue(record, ['Firma Adı', 'Nickname', 'nick', 'isim']) || '—')}</div>
        <div class="bg-surface px-3 py-2.5 text-xs text-main whitespace-nowrap">${escapeHtml(normalizeObjectValue(record, ['Denetim Tipi', 'denetim', 'Denetim', 'denetimTipi']) || '—')}</div>
      </div>
    `).join('');

    els.recentList.innerHTML = `<div class="min-w-[540px] overflow-hidden rounded-2xl border border-border-main">${header}${rows}</div>`;
  }

  async function loadRecentCertificates() {
    if (els.recentSummary) els.recentSummary.textContent = 'Son sertifikalar yukleniyor...';
    if (els.recentEmpty) {
      els.recentEmpty.classList.remove('hidden');
      els.recentEmpty.textContent = 'Son sertifikalar yukleniyor...';
    }
    if (els.recentList) {
      els.recentList.classList.add('hidden');
      els.recentList.innerHTML = '';
    }

    const res = await api.getRecentCertificates(25);
    if (!res.success) {
      recentCertificates = [];
      if (els.recentSummary) els.recentSummary.textContent = 'Liste yuklenemedi.';
      if (els.recentEmpty) {
        els.recentEmpty.classList.remove('hidden');
        els.recentEmpty.textContent = res.error || 'Son sertifikalar getirilemedi.';
      }
      return;
    }

    recentCertificates = (Array.isArray(res.data) ? res.data : [])
      .map((item) => normalizeCertificateRecord(item))
      .filter(Boolean) as Record<string, any>[];
    renderRecentCertificates();
  }

  function openRecentCertificatesModal() {
    const panel = document.getElementById('cert-recent-panel');
    els.recentModal?.classList.remove('hidden');
    // Allow browser to paint before triggering transition
    requestAnimationFrame(() => requestAnimationFrame(() => {
      panel?.classList.remove('opacity-0', 'scale-95');
      panel?.classList.add('opacity-100', 'scale-100');
    }));
    document.body.classList.add('overflow-hidden');
  }

  function closeRecentCertificatesModal() {
    const panel = document.getElementById('cert-recent-panel');
    panel?.classList.remove('opacity-100', 'scale-100');
    panel?.classList.add('opacity-0', 'scale-95');
    setTimeout(() => {
      els.recentModal?.classList.add('hidden');
    }, 200);
    document.body.classList.remove('overflow-hidden');
  }

  function normalizeDenetimValue(value: string) {
    const trimmed = String(value || '').trim();
    if (trimmed === '1. Gozetim' || trimmed === '2. Gozetim') {
      return 'Gozetim';
    }
    return trimmed;
  }

  function isTruthyCheckboxValue(value: unknown) {
    const normalized = String(value ?? '').trim().toLowerCase();
    return ['true', '1', 'yes', 'on', 'evet'].includes(normalized);
  }

  function fillFromCompanyContext() {
    if (!companyContext) return;
    if (els.kapsam) els.kapsam.value = companyContext.kapsam || '';
    if (els.scope) els.scope.value = companyContext.scope || '';
    if (els.logo) els.logo.value = companyContext.logo || '';
    if (els.dan) els.dan.value = companyContext.danisman || '';
    const kodInput = document.getElementById('cert-kod') as HTMLInputElement | null;
    if (kodInput) kodInput.value = companyContext.nace || '';
  }

  function getEditingValue(...aliases: string[]) {
    return normalizeObjectValue(editingCertificate || {}, aliases);
  }

  async function refreshContextFromKv() {
    await SyncManager.checkAndSync();
    const refreshed = await loadCompanyOperationContext(activeFirmaId);
    if (refreshed) {
      companyContext = refreshed;
    }
    return refreshed;
  }

  async function resolveExistingCertificate(sourceId: string, options: { retryWithKv?: boolean } = {}) {
    if (!sourceId) return null;
    const { retryWithKv = true } = options;

    const res = await api.getCertificateById(sourceId);
    const apiRecord = normalizeCertificateRecord(res?.data);
    if (apiRecord) return apiRecord;

    const local = (companyContext?.certificates as any[] | undefined)?.find((item) => getCertificateRecordId(item as Record<string, any>) === sourceId) || null;
    const localRecord = normalizeCertificateRecord(local);
    if (localRecord) return localRecord;

    if (retryWithKv) {
      await refreshContextFromKv();
      return resolveExistingCertificate(sourceId, { retryWithKv: false });
    }

    return null;
  }

  async function loadExistingCertificate() {
    const sourceId = editId || cloneId;
    if (!sourceId) return;
    const cert = await resolveExistingCertificate(sourceId);
    if (!cert) {
      throw new Error(`Sertifika bulunamadi: ${sourceId}`);
    }

    editingCertificate = cert;

    const standardValue = normalizeObjectValue(cert, ['Standart', 'standart']);
    const otherValue = normalizeObjectValue(cert, ['Other Standard', 'Other', 'other', 'Diğer', 'diger', 'Diger', 'diğer', 'Diğer Standart', 'digerStandart', 'other']);

    if (els.standSelect) {
      let effectiveStandardValue = standardValue;
      if (!effectiveStandardValue && otherValue) {
        effectiveStandardValue = 'Diğer';
      }

      let option = Array.from(els.standSelect.options).find((item) => item.textContent?.trim() === effectiveStandardValue);
      if (!option && otherValue) {
        option = Array.from(els.standSelect.options).find((item) => shouldShowOtherStandard(item.textContent?.trim() || ''));
      }
      if (option) els.standSelect.value = option.value;
      else if (effectiveStandardValue) {
        const custom = document.createElement('option');
        custom.value = effectiveStandardValue;
        custom.textContent = effectiveStandardValue;
        custom.dataset.prefix = effectiveStandardValue;
        custom.dataset.fullName = effectiveStandardValue;
        els.standSelect.appendChild(custom);
        els.standSelect.value = effectiveStandardValue;
      }
      updateStandardMeta();
    }

    if (els.otherInput) els.otherInput.value = otherValue;
    syncOtherStandardVisibility(els.standSelect?.selectedOptions[0]?.textContent?.trim() || standardValue, { clearOnHide: false });
    if (els.isoFull && !els.isoFull.value) els.isoFull.value = standardValue;
    if (els.denetim) els.denetim.value = normalizeDenetimValue(
      normalizeObjectValue(cert, ['Denetim Tipi', 'denetim', 'Denetim', 'denetimTipi']),
    );
    if (els.sno) els.sno.value = normalizeObjectValue(cert, ['Sertifika No', 'sNo', 'SNo', 'sno']);
    if (els.gst) els.gst.value = toInputDate(normalizeObjectValue(cert, ['Sertifika Tarihi', 'gst', 'GST', 'sTarihi']));
    if (els.goz) els.goz.value = toInputDate(normalizeObjectValue(cert, ['Gözetim Tarihi', 'Sertifika Gözetim Tarihi', 'goz', 'GOZ', 'sGozetimT']));
    if (els.stt) els.stt.value = toInputDate(normalizeObjectValue(cert, ['Tescil Tarihi', 'Sertifika Tescil Tarihi', 'Son Tetkik Tarihi', 'stt', 'STT', 'sTT']));
    if (els.sgt) els.sgt.value = toInputDate(normalizeObjectValue(cert, ['Sertifika Geçerlilik Tarihi', 'sgt', 'SGT', 'sGT']));
    if (els.kapsam) els.kapsam.value = normalizeObjectValue(cert, ['Kapsam', 'kapsam']);
    if (els.scope) els.scope.value = normalizeObjectValue(cert, ['Scope', 'scope']);
    if (els.logo) els.logo.value = normalizeObjectValue(cert, ['Logo', 'logo']);
    if (els.kod) els.kod.value = normalizeObjectValue(cert, ['Kod', 'kod', 'NACE', 'nace']);
    if (els.akreditasyon) els.akreditasyon.value = normalizeObjectValue(cert, ['Akreditasyon', 'akreditasyon']) || 'IAKS';
    if (els.akredite) els.akredite.value = normalizeObjectValue(cert, ['Akredite', 'akredite']) || 'Medicert';
    if (els.dan) els.dan.value = normalizeObjectValue(cert, ['Danışman', 'Danisman', 'dan', 'danisman']);
    if (els.durum) els.durum.value = normalizeObjectValue(cert, ['Durum', 'durum']);
    if (els.not) els.not.value = normalizeObjectValue(cert, ['Not', 'not']);
    const gozetimValue = normalizeObjectValue(cert, ['Gözetim Conf.', 'gozetimConfirmed', 'gozetimConf', 'gozetim']);
    if (els.gozetimDone) els.gozetimDone.checked = isTruthyCheckboxValue(gozetimValue);

    if (cloneId) {
      if (els.denetim) els.denetim.value = 'Gozetim';
      if (els.gst) els.gst.value = '';
      if (els.goz) els.goz.value = '';
      if (els.sgt) els.sgt.value = '';
      if (els.gozetimDone) els.gozetimDone.checked = false;
    }
  }

  function bindActions() {
    if (formBindingsReady) return;
    formBindingsReady = true;

    const returnUrl = activeFirmaId ? `/company?id=${activeFirmaId}` : '/certificates';
    els.backLink && (els.backLink.href = returnUrl);
    const cancelBtn = document.getElementById('cert-cancel') as HTMLAnchorElement | null;
    if (cancelBtn) cancelBtn.href = returnUrl;
    const addAuditLink = document.getElementById('cert-add-audit-link') as HTMLAnchorElement | null;
    if (addAuditLink) addAuditLink.href = `/audits/add?firmaId=${encodeURIComponent(activeFirmaId)}&returnUrl=${encodeURIComponent(window.location.href)}`;

    els.standSelect?.addEventListener('change', updateStandardMeta);

    document.getElementById('cert-auto-goz')?.addEventListener('click', () => {
      if (els.goz && els.gst) els.goz.value = addOneYearMinusOneDay(els.gst.value);
    });

    document.getElementById('cert-fill-from-company')?.addEventListener('click', fillFromCompanyContext);
    els.openRecent?.addEventListener('click', () => {
      openRecentCertificatesModal();
      if (!recentCertificates.length) void loadRecentCertificates();
    });
    els.recentBackdrop?.addEventListener('click', closeRecentCertificatesModal);
    els.recentClose?.addEventListener('click', closeRecentCertificatesModal);
    els.recentRefresh?.addEventListener('click', () => void loadRecentCertificates());
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !els.recentModal?.classList.contains('hidden')) {
        closeRecentCertificatesModal();
      }
    });

    document.getElementById('cert-apply-suggested')?.addEventListener('click', () => {
      if (!els.sno || !els.suggested) return;
      els.sno.value = mergeCertNoSuggestion(els.suggested.value, els.sno.value);
    });

    document.getElementById('cert-kapsam-upper')?.addEventListener('click', () => {
      if (els.kapsam) els.kapsam.value = els.kapsam.value.toLocaleUpperCase('tr-TR');
    });

    document.getElementById('cert-scope-upper')?.addEventListener('click', () => {
      if (els.scope) els.scope.value = els.scope.value.toLocaleUpperCase('en-US');
    });

    document.getElementById('cert-kapsam-translate')?.addEventListener('click', async () => {
      if (!els.kapsam || !els.scope || !els.kapsam.value.trim()) return;
      const res = await api.translate(els.kapsam.value, true);
      if (res.success && els.scope) els.scope.value = String(res.data || '');
      else showToast(`Ceviri hatasi: ${res.error}`, 'error');
    });

    document.getElementById('cert-scope-translate')?.addEventListener('click', async () => {
      if (!els.scope || !els.kapsam || !els.scope.value.trim()) return;
      const res = await api.translate(els.scope.value, false);
      if (res.success && els.kapsam) els.kapsam.value = String(res.data || '');
      else showToast(`Ceviri hatasi: ${res.error}`, 'error');
    });

    document.getElementById('cert-clear')?.addEventListener('click', () => {
      els.form?.reset();
      if (companyContext) {
        hydrateHeader();
      }
      renderStandards();
      updateStandardMeta();
      if (editId || cloneId) {
        void loadExistingCertificate();
      } else {
        if (els.kapsam) els.kapsam.value = '';
        if (els.scope) els.scope.value = '';
        if (els.logo) els.logo.value = '';
        if (els.dan) els.dan.value = '';
        if (els.kod) els.kod.value = '';
      }
    });

    els.form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!companyContext || !els.standSelect || !els.submit) return;

      const selected = els.standSelect.selectedOptions[0];
      const standardText = selected?.textContent?.trim() || '';
      if (!standardText) {
        showToast('Lutfen bir standart secin.', 'error');
        return;
      }

      const certInfo = {
        nick: companyContext.nick || getEditingValue('Firma Adı', 'Nickname', 'nick', 'isim'),
        firmano: companyContext.firmaId || getEditingValue('Firma No', 'firmaNo', 'firmano'),
        standart: standardText,
        other: els.otherInput?.value.trim() || getEditingValue('Other Standard', 'Other', 'other'),
        denetim: normalizeDenetimValue(els.denetim?.value || ''),
        sno: els.sno?.value.trim() || '',
        gst: toDisplayDate(els.gst?.value || ''),
        goz: toDisplayDate(els.goz?.value || ''),
        stt: toDisplayDate(els.stt?.value || ''),
        sgt: toDisplayDate(els.sgt?.value || ''),
        kapsam: els.kapsam?.value.trim() || '',
        scope: els.scope?.value.trim() || '',
        logo: els.logo?.value.trim() || getEditingValue('Logo', 'logo'),
        kod: els.kod?.value.trim() || getEditingValue('Kod', 'kod', 'NACE', 'nace'),
        akreditasyon: els.akreditasyon?.value.trim() || getEditingValue('Akreditasyon', 'akreditasyon'),
        akredite: els.akredite?.value.trim() || getEditingValue('Akredite', 'akredite'),
        dan: els.dan?.value.trim() || getEditingValue('Danışman', 'Danisman', 'dan', 'danisman'),
        durum: els.durum?.value.trim() || getEditingValue('Durum', 'durum'),
        not: els.not?.value.trim() || getEditingValue('Not', 'not'),
        gozetimConfirmed: els.gozetimDone?.checked ? 'TRUE' : 'FALSE',
        qr: buildCertificateQrLink(companyContext.unvan || companyContext.nick, (els.isoFull?.value || standardText), els.sno?.value || ''),
        calendar: getEditingValue('Calendar ID', 'eventId', 'calendar'),
        certLink: getEditingValue('Cert Link', 'certLink', 'certiLink'),
      };

      els.submit.disabled = true;
      const originalText = els.submit.innerHTML;
      els.submit.innerHTML = 'Kaydediliyor...';

      const response = editId
        ? await api.updateCertificate(editId, certInfo)
        : await api.addCertificate(certInfo);
      if (response.success) {
        await SyncManager.checkAndSync();
        const successMessage = editId
          ? 'Sertifika basariyla guncellendi.'
          : cloneId
            ? 'Gozetim sertifikasi basariyla olusturuldu.'
            : 'Sertifika basariyla eklendi.';
        setFlashToast(successMessage, 'success');
        showToast(successMessage, 'success');
        setTimeout(() => {
          window.location.href = companyContext ? `/company?id=${encodeURIComponent(companyContext.firmaId)}` : '/certificates';
        }, 800);
        return;
      }

      showToast(`Hata: ${response.error}`, 'error');
      els.submit.disabled = false;
      els.submit.innerHTML = originalText;
    });
  }

  async function prepareCompanyPicker() {
    showCompanyPicker();
    syncCompanyList($companies.get() as any[]);
    $companies.subscribe((companies) => syncCompanyList(companies as any[]));
    await SyncManager.init();
    if (($companies.get() as any[]).length === 0) {
      const res = await api.getCompanies();
      if (res.success && Array.isArray(res.data)) {
        $companies.set(res.data);
      }
    }

    els.companySearch?.addEventListener('input', () => {
      selectedCompany = resolveCompanyFromInput();
      setSelectStatus(selectedCompany ? 'Firma seçildi. Devam edebilirsin.' : 'Listeden geçerli bir firma seç.');
    });

    els.companyContinue?.addEventListener('click', async () => {
      selectedCompany = resolveCompanyFromInput();
      const selectedId = selectedCompany ? getCompanyId(selectedCompany) : '';
      if (!selectedId) {
        setSelectStatus('Devam etmek için listeden geçerli bir firma seç.', true);
        return;
      }
      activeFirmaId = selectedId;
      await loadScreen();
    });
  }

  async function loadScreen() {
    if (!activeFirmaId) {
      showCompanyPicker();
      return;
    }

    try {
      // Tüm bağımsız istekleri aynı anda başlat.
      // api.call() inFlightRequests ile deduplicate ettiği için
      // loadExistingCertificate içindeki getCertificateById çağrısı
      // burada başlayan isteğin sonucunu kullanır, ekstra round-trip olmaz.
      if (editId || cloneId) {
        api.getCertificateById(editId || cloneId);
      }

      const [ctx] = await Promise.all([
        loadCompanyOperationContext(activeFirmaId),
        loadStandards(),
        loadConsultants(),
        loadRecentCertificates(),
      ]);

      companyContext = ctx;
      if (!companyContext) {
        showError('Firma contexti yuklenemedi.', `Firma ID: ${activeFirmaId}`);
        return;
      }

      els.select?.classList.add('hidden');
      hydrateHeader();
      await loadExistingCertificate();
      bindActions();

      els.skeleton?.classList.add('hidden');
      els.error?.classList.add('hidden');
      els.shell?.classList.remove('hidden');
    } catch (error: any) {
      console.error('Certificate add screen failed:', error);
      showError('Sertifika ekrani yuklenemedi.', error?.message || String(error || 'Bilinmeyen hata'));
    }
  }

  async function boot() {
    if (!activeFirmaId) {
      await prepareCompanyPicker();
      return;
    }

    try {
      await loadScreen();
    } catch (error: any) {
      console.error('Certificate boot failed:', error);
      showError('Sertifika sayfasi acilirken hata olustu.', error?.message || String(error || 'Bilinmeyen hata'));
    }
  }

  void boot();
</script>
