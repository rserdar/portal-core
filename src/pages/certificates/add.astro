    function normalizeDenetimValue(value: string) {
      const trimmed = String(value || "").trim();
      if (trimmed === "1. Gozetim" || trimmed === "2. Gozetim") {
        return "Gozetim";
      }
      return trimmed;
    }

    function isTruthyCheckboxValue(value: unknown) {
      const normalized = String(value ?? "")
        .trim()
        .toLowerCase();
      return ["true", "1", "yes", "on", "evet"].includes(normalized);
    }

    function fillFromCompanyContext() {
      if (!companyContext) return;
      if (els.logo) els.logo.value = companyContext.logo || "";
      if (els.dan) els.dan.value = companyContext.danisman || "";
      const kodInput = document.getElementById(
        "cert-kod",
      ) as HTMLInputElement | null;
      if (kodInput) kodInput.value = companyContext.nace || "";
    }

    function getEditingValue(...aliases: string[]) {
      return normalizeObjectValue(editingCertificate || {}, aliases);
    }

    async function refreshContextFromKv() {
      await SyncManager.checkAndSync({ force: true });
      const refreshed = await loadCompanyOperationContext(activeFirmaId);
      if (refreshed) {
        companyContext = refreshed;
      }
      return refreshed;
    }

    async function resolveExistingCertificate(
      sourceId: string,
      options: { retryWithKv?: boolean } = {},
    ) {
      if (!sourceId) return null;
      const { retryWithKv = true } = options;

      const res = await api.getCertificateById(sourceId);
      const apiRecord = normalizeCertificateRecord(res?.data);
      if (apiRecord) return apiRecord;

      const local =
        (companyContext?.certificates as any[] | undefined)?.find(
          (item) =>
            getCertificateRecordId(item as Record<string, any>) === sourceId,
        ) || null;
      const localRecord = normalizeCertificateRecord(local);
      if (localRecord) return localRecord;

      if (retryWithKv) {
        await refreshContextFromKv();
        return resolveExistingCertificate(sourceId, { retryWithKv: false });
      }

      return null;
    }

    async function loadExistingCertificate() {
      const sourceId = editId || cloneId;
      if (!sourceId) return;
      const cert = await resolveExistingCertificate(sourceId);
      if (!cert) {
        throw new Error(`Sertifika bulunamadı: ${sourceId}`);
      }

      editingCertificate = cert;
      editingCertificateUpdatedAt = String(
        normalizeObjectValue(cert, ["updated_at"]) || "",
      );

      const standardValue = normalizeObjectValue(cert, [
        "Standart",
        "standart",
      ]);
      const otherValue = normalizeObjectValue(cert, [
        "Other Standard",
        "Other",
        "other",
        "Diğer",
        "diger",
        "Diger",
        "diğer",
        "Diğer Standart",
        "digerStandart",
        "other",
      ]);

      if (els.standSelect) {
        let effectiveStandardValue = standardValue;
        if (!effectiveStandardValue && otherValue) {
          effectiveStandardValue = "Diğer";
        }

        let option = Array.from(els.standSelect.options).find(
          (item) => item.textContent?.trim() === effectiveStandardValue,
        );
        if (!option && otherValue) {
          option = Array.from(els.standSelect.options).find((item) =>
            shouldShowOtherStandard(item.textContent?.trim() || ""),
          );
        }
        if (option) els.standSelect.value = option.value;
        else if (effectiveStandardValue) {
          const custom = document.createElement("option");
          custom.value = effectiveStandardValue;
          custom.textContent = effectiveStandardValue;
          custom.dataset.prefix = effectiveStandardValue;
          custom.dataset.fullName = effectiveStandardValue;
          els.standSelect.appendChild(custom);
          els.standSelect.value = effectiveStandardValue;
        }
        updateStandardMeta();
      }

      if (els.otherInput) els.otherInput.value = otherValue;
      syncOtherStandardVisibility(
        els.standSelect?.selectedOptions[0]?.textContent?.trim() ||
          standardValue,
        { clearOnHide: false },
      );
      if (els.isoFull && !els.isoFull.value) els.isoFull.value = standardValue;
      if (els.denetim)
        els.denetim.value = normalizeDenetimValue(
          normalizeObjectValue(cert, [
            "Denetim Tipi",
            "denetim",
            "Denetim",
            "denetimTipi",
          ]),
        );
      if (els.sno)
        els.sno.value = normalizeObjectValue(cert, [
          "Sertifika No",
          "sNo",
          "SNo",
          "sno",
        ]);
      if (els.gst)
        els.gst.value = toInputDate(
          normalizeObjectValue(cert, [
            "Sertifika Tarihi",
            "gst",
            "GST",
            "sTarihi",
          ]),
        );
      if (els.goz)
        els.goz.value = toInputDate(
          normalizeObjectValue(cert, [
            "Gözetim Tarihi",
            "Sertifika Gözetim Tarihi",
            "goz",
            "GOZ",
            "sGozetimT",
          ]),
        );
      if (els.stt)
        els.stt.value = toInputDate(
          normalizeObjectValue(cert, [
            "Tescil Tarihi",
            "Sertifika Tescil Tarihi",
            "Son Tetkik Tarihi",
            "stt",
            "STT",
            "sTT",
          ]),
        );
      if (els.sgt)
        els.sgt.value = toInputDate(
          normalizeObjectValue(cert, [
            "Sertifika Geçerlilik Tarihi",
            "sgt",
            "SGT",
            "sGT",
          ]),
        );
      if (els.kapsam)
        els.kapsam.value = normalizeObjectValue(cert, ["Kapsam", "kapsam"]);
      if (els.prevKapsam)
        els.prevKapsam.textContent =
          normalizeObjectValue(cert, ["Kapsam", "kapsam"]) ||
          "Kapsam bulunamadı.";
      if (els.scope)
        els.scope.value = normalizeObjectValue(cert, ["Scope", "scope"]);
      if (els.prevScope)
        els.prevScope.textContent =
          normalizeObjectValue(cert, ["Scope", "scope"]) || "Scope bulunamadı.";
      if (els.logo)
        els.logo.value = normalizeObjectValue(cert, ["Logo", "logo"]);
      if (els.kod)
        els.kod.value = normalizeObjectValue(cert, [
          "Kod",
          "kod",
          "NACE",
          "nace",
        ]);
      if (els.akreditasyon)
        els.akreditasyon.value =
          normalizeObjectValue(cert, ["Akreditasyon", "akreditasyon"]) ||
          "IAKS";
      if (els.akredite)
        els.akredite.value =
          normalizeObjectValue(cert, ["Akredite", "akredite"]) || "Medicert";
      if (els.dan)
        els.dan.value = normalizeObjectValue(cert, [
          "Danışman",
          "Danisman",
          "dan",
          "danisman",
        ]);
      if (els.durum)
        els.durum.value = normalizeObjectValue(cert, ["Durum", "durum"]);
      if (els.not) els.not.value = normalizeObjectValue(cert, ["Not", "not"]);
      const gozetimValue = normalizeObjectValue(cert, [
        "Gözetim Conf.",
        "gozetimConfirmed",
        "gozetimConf",
        "gozetim",
      ]);
      if (els.gozetimDone)
        els.gozetimDone.checked = isTruthyCheckboxValue(gozetimValue);

      if (cloneId) {
        if (els.denetim) els.denetim.value = "Gozetim";
        if (els.gst) els.gst.value = "";
        if (els.goz) els.goz.value = "";
        if (els.sgt) els.sgt.value = "";
        if (els.gozetimDone) els.gozetimDone.checked = false;
      }
    }

    function bindActions() {
      if (formBindingsReady) return;
      formBindingsReady = true;

      const returnUrl = activeFirmaId
        ? `/company?id=${activeFirmaId}`
        : "/certificates";
      els.backLink && (els.backLink.href = returnUrl);
      const cancelBtn = document.getElementById(
        "cert-cancel",
      ) as HTMLAnchorElement | null;
      if (cancelBtn) cancelBtn.href = returnUrl;
      const addAuditLink = document.getElementById(
        "cert-add-audit-link",
      ) as HTMLAnchorElement | null;
      if (addAuditLink)
        addAuditLink.href = `/audits/add?firmaId=${encodeURIComponent(activeFirmaId)}&returnUrl=${encodeURIComponent(window.location.href)}`;

      els.standSelect?.addEventListener("change", updateStandardMeta);

      els.dan?.addEventListener("focus", () => {
        renderConsultantSuggestions(els.dan?.value || "", { forceOpen: true });
      });
      els.dan?.addEventListener("input", () => {
        renderConsultantSuggestions(els.dan?.value || "", { forceOpen: true });
      });
      els.dan?.addEventListener("keydown", (event) => {
        if (event.key === "ArrowDown") {
          event.preventDefault();
          if (els.consultantList?.classList.contains("hidden")) {
            renderConsultantSuggestions(els.dan?.value || "", {
              forceOpen: true,
            });
            return;
          }
          moveConsultantSelection(1);
          return;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          if (!els.consultantList?.classList.contains("hidden"))
            moveConsultantSelection(-1);
          return;
        }
        if (
          event.key === "Enter" &&
          activeConsultantIndex >= 0 &&
          consultantSuggestions[activeConsultantIndex]
        ) {
          event.preventDefault();
          chooseConsultant(consultantSuggestions[activeConsultantIndex]);
          return;
        }
        if (event.key === "Escape") {
          closeConsultantList();
        }
      });
      els.dan?.addEventListener("blur", () => {
        window.setTimeout(() => closeConsultantList(), 120);
      });
      els.consultantList?.addEventListener("mousedown", (event) => {
        const option = (event.target as HTMLElement).closest<HTMLButtonElement>(
          "[data-consultant-option]",
        );
        if (!option) return;
        event.preventDefault();
        chooseConsultant(option.dataset.consultantOption || "");
      });

      document
        .getElementById("cert-auto-goz")
        ?.addEventListener("click", () => {
          if (els.goz && els.gst)
            els.goz.value = addOneYearMinusOneDay(els.gst.value);
        });

      document
        .getElementById("cert-fill-from-company")
        ?.addEventListener("click", fillFromCompanyContext);
      els.openRecent?.addEventListener("click", () => {
        openRecentCertificatesModal();
        if (!recentCertificates.length) void loadRecentCertificates();
      });
      els.recentBackdrop?.addEventListener(
        "click",
        closeRecentCertificatesModal,
      );
      els.recentClose?.addEventListener("click", closeRecentCertificatesModal);
      els.recentRefresh?.addEventListener(
        "click",
        () => void loadRecentCertificates(),
      );
      document.addEventListener("keydown", (event) => {
        if (
          event.key === "Escape" &&
          !els.recentModal?.classList.contains("hidden")
        ) {
          closeRecentCertificatesModal();
        }
        if (event.key === "Escape") {
          closeConsultantList();
        }
      });
      document.addEventListener("click", (event) => {
        const target = event.target as Node | null;
        if (!target) return;
        if (
          els.dan?.contains(target as Node) ||
          els.consultantList?.contains(target as Node)
        )
          return;
        closeConsultantList();
      });

      document
        .getElementById("cert-apply-suggested")
        ?.addEventListener("click", () => {
          if (!els.sno || !els.suggested) return;
          els.sno.value = mergeCertNoSuggestion(
            els.suggested.value,
            els.sno.value,
          );
        });

      document
        .getElementById("cert-kapsam-upper")
        ?.addEventListener("click", () => {
          if (els.kapsam)
            els.kapsam.value = els.kapsam.value.toLocaleUpperCase("tr-TR");
        });

      document
        .getElementById("cert-scope-upper")
        ?.addEventListener("click", () => {
          if (els.scope)
            els.scope.value = els.scope.value.toLocaleUpperCase("en-US");
        });

      const kapsamTranslateBtn = document.getElementById(
        "cert-kapsam-translate",
      ) as HTMLButtonElement | null;
      if (kapsamTranslateBtn) {
        kapsamTranslateBtn.onclick = async () => {
          if (!els.kapsam || !els.scope || !els.kapsam.value.trim()) return;
          const res = await api.translate(els.kapsam.value, true);
          if (res.success && els.scope)
            els.scope.value = String(res.data || "");
          else toast.error(`Çeviri hatası: ${res.error}`);
        };
      }

      const scopeTranslateBtn = document.getElementById(
        "cert-scope-translate",
      ) as HTMLButtonElement | null;
      if (scopeTranslateBtn) {
        scopeTranslateBtn.onclick = async () => {
          if (!els.scope || !els.kapsam || !els.scope.value.trim()) return;
          const res = await api.translate(els.scope.value, false);
          if (res.success && els.kapsam)
            els.kapsam.value = String(res.data || "");
          else toast.error(`Çeviri hatası: ${res.error}`);
        };
      }

      if (els.classificationSuggest) {
        els.classificationSuggest.onclick = () => {
          renderClassificationSuggestions();
        };
      }

      if (els.classificationApplyTop) {
        els.classificationApplyTop.onclick = async () => {
          if (!classificationSuggestions[0]) {
            renderClassificationSuggestions();
          }
          if (classificationSuggestions[0]) {
            await applyClassificationSuggestion(classificationSuggestions[0], {
              autoTranslate: true,
            });
          }
        };
      }

      const rerenderClassification = () => {
        if (!els.classificationPanel?.classList.contains("hidden")) {
          renderClassificationSuggestions();
        }
      };

      els.ea?.addEventListener("input", rerenderClassification);
      registerCleanup(() => els.ea?.removeEventListener("input", rerenderClassification));
      els.kod?.addEventListener("input", rerenderClassification);
      registerCleanup(() => els.kod?.removeEventListener("input", rerenderClassification));
      els.kapsam?.addEventListener("input", rerenderClassification);
      registerCleanup(() => els.kapsam?.removeEventListener("input", rerenderClassification));
      els.scope?.addEventListener("input", rerenderClassification);
      registerCleanup(() => els.scope?.removeEventListener("input", rerenderClassification));

      document.getElementById("cert-clear")?.addEventListener("click", () => {
        els.form?.reset();
        if (companyContext) {
          hydrateHeader();
        }
        renderStandards();
        updateStandardMeta();
        if (editId || cloneId) {
          void loadExistingCertificate();
        } else {
          if (els.kapsam) els.kapsam.value = "";
          if (els.scope) els.scope.value = "";
          if (els.logo) els.logo.value = "";
          if (els.dan) els.dan.value = "";
          if (els.kod) els.kod.value = "";
          closeConsultantList();
        }
      });

      if (els.deleteBtn) {
        els.deleteBtn.onclick = async () => {
          if (!editId || !companyContext || !els.deleteBtn) return;
          if (
            !confirm(
              `Bu sertifika kaydını silmek istediğinizden emin misiniz? (#${editId})`,
            )
          )
            return;

          const original = els.deleteBtn.innerHTML;
          els.deleteBtn.disabled = true;
          els.deleteBtn.innerHTML = "Siliniyor...";

          const response = await api.deleteCertificate(editId);
          if (response.success) {
            await SyncManager.checkAndSync({ force: true });
            toast.success(
              "Sertifika kaydı silindi. Firma profiline yönlendiriliyorsunuz.",
              { duration: 2500 },
            );
            setTimeout(() => {
              window.location.href = `/company?id=${encodeURIComponent(companyContext.firmaId)}`;
            }, 1400);
            return;
          }

          toast.error(`Silme hatası: ${response.error}`);
          els.deleteBtn.disabled = false;
          els.deleteBtn.innerHTML = original;
        };
      }

      if (els.form)
        els.form.onsubmit = async (event) => {
          event.preventDefault();
          if (!companyContext || !els.standSelect || !els.submit) return;

          const selected = els.standSelect.selectedOptions[0];
          const standardText = selected?.textContent?.trim() || "";
          if (!standardText) {
            toast.error("Lütfen bir standart seçin.");
            return;
          }

          const certInfo = {
            nick: companyContext.nick || getEditingValue("Firma Adı", "nick"),
            firma_no:
              companyContext.firmaId ||
              getEditingValue("Firma No", "firma_no", "firmaNo"),
            standart: standardText,
            other_standart: els.otherInput?.value.trim() || "",
            denetim_tipi: normalizeDenetimValue(els.denetim?.value || ""),
            sertifika_no: els.sno?.value.trim() || "",
            sertifika_tarihi: toDisplayDate(els.gst?.value || ""),
            gozetim_tarihi: toDisplayDate(els.goz?.value || ""),
            tescil_tarihi: toDisplayDate(els.stt?.value || ""),
            gecerlilik_tarihi: toDisplayDate(els.sgt?.value || ""),
            kapsam: els.kapsam?.value.trim() || "",
            scope: els.scope?.value.trim() || "",
            logo: els.logo?.value.trim() || "",
            nace: els.kod?.value.trim() || "",
            akreditasyon: els.akreditasyon?.value.trim() || "IAKS",
            akredite: els.akredite?.value.trim() || "Medicert",
            consultant: els.dan?.value.trim() || "",
            durum: els.durum?.value.trim() || "",
            sertifika_not: els.not?.value.trim() || "",
            gozetim_confirmed: els.gozetimDone?.checked ? "TRUE" : "FALSE",
            qr: buildCertificateQrLink(
              companyContext.unvan || companyContext.nick,
              els.isoFull?.value || standardText,
              els.sno?.value || "",
            ),
            calendar_id: getEditingValue(
              "Calendar ID",
              "calendar_id",
              "calendar",
            ),
            cert_link: getEditingValue("Cert Link", "cert_link", "certLink"),
          };

          els.submit.disabled = true;
          const originalText = els.submit.innerHTML;
          els.submit.innerHTML = "Kaydediliyor...";

          const response = editId
            ? await api.updateCertificate(editId, certInfo, {
                expected_updated_at: editingCertificateUpdatedAt || undefined,
              })
            : await api.addCertificate(certInfo);
          if (response.success) {
            await SyncManager.checkAndSync({ force: true });
            const successMessage = editId
              ? "Sertifika başarıyla güncellendi."
              : cloneId
                ? "Gözetim sertifikası başarıyla oluşturuldu."
                : "Sertifika başarıyla eklendi.";
            els.submit.innerHTML = "Başarılı, yönlendiriliyor...";
            toast.success(
              `${successMessage} Firma profiline yönlendiriliyorsunuz.`,
              { duration: 2500 },
            );
            setTimeout(() => {
              window.location.href = companyContext
                ? `/company?id=${encodeURIComponent(companyContext.firmaId)}`
                : "/certificates";
            }, 1400);
            return;
          }

          if (response.error === "CONFLICT") {
            toast.error("Bu sertifika başka bir kullanıcı tarafından güncellendi. Sayfayı yenileyip tekrar deneyin.");
          } else {
            toast.error(`Hata: ${response.error}`);
          }
          els.submit.disabled = false;
          els.submit.innerHTML = originalText;
        };
    }

    async function prepareCompanyPicker() {
      await setupOperationCompanyPicker({
        prefix: 'cert',
        registerCleanup,
        onSelected: ({ id }) => {
          activeFirmaId = id;
          void loadScreen();
        },
        onShowPicker: () => {
          els.skeleton?.classList.add("hidden");
          els.error?.classList.add("hidden");
          els.shell?.classList.add("hidden");
          els.select?.classList.remove("hidden");
          if (els.backLink) els.backLink.href = "/certificates";
        }
      });
    }



    async function loadScreen() {
      if (!activeFirmaId) {
        await prepareCompanyPicker();

        return;
      }

      try {
        // Tüm bağımsız istekleri aynı anda başlat.
        // api.call() inFlightRequests ile deduplicate ettiği için
        // loadExistingCertificate içindeki getCertificateById çağrısı
        // burada başlayan isteğin sonucunu kullanır, ekstra round-trip olmaz.
        if (editId || cloneId) {
          api.getCertificateById(editId || cloneId);
        }

        const [ctx] = await Promise.all([
          loadCompanyOperationContext(activeFirmaId),
          loadStandards(),
          loadConsultants(),
          loadRecentCertificates(),
        ]);

        companyContext = ctx;
        if (!companyContext) {
          showError("Firma bağlamı yüklenemedi.", `Firma ID: ${activeFirmaId}`);
          return;
        }

        els.select?.classList.add("hidden");
        hydrateHeader();
        await loadExistingCertificate();
        bindActions();
        renderClassificationSuggestions();

        els.skeleton?.classList.add("hidden");
        els.error?.classList.add("hidden");
        els.shell?.classList.remove("hidden");
      } catch (error: any) {
        console.error("Certificate add screen failed:", error);
        showError(
          "Sertifika ekranı yüklenemedi.",
          error?.message || String(error || "Bilinmeyen hata"),
        );
      }
    }

    async function boot() {

      if (activeFirmaId) {
        await loadScreen();
        return;
      }

      await prepareCompanyPicker();
    }


    void boot();

  }

  // Initial load
  document.addEventListener("astro:page-load", initPage);
  // Cleanup away
  document.addEventListener("astro:before-preparation", runCleanups);
</script>

