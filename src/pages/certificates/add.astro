        ]),
        "Son Tetkik Tarihi": normalizeObjectValue(record, [
          "tescil_tarihi",
          "Tescil Tarihi",
          "Sertifika Tescil Tarihi",
          "Son Tetkik Tarihi",
          "stt",
          "STT",
        ]),
        "Tescil Tarihi": normalizeObjectValue(record, [
          "tescil_tarihi",
          "Tescil Tarihi",
          "Sertifika Tescil Tarihi",
          "Son Tetkik Tarihi",
          "stt",
          "STT",
        ]),
        "Sertifika Geçerlilik Tarihi": normalizeObjectValue(record, [
          "gecerlilik_tarihi",
          "Sertifika Geçerlilik Tarihi",
          "sgt",
