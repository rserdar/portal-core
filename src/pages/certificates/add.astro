    async function loadRecentCertificates() {
      if (els.recentSummary)
        els.recentSummary.textContent = "Son sertifikalar yükleniyor...";
      if (els.recentEmpty) {
        els.recentEmpty.classList.remove("hidden");
        els.recentEmpty.textContent = "Son sertifikalar yükleniyor...";
      }
      if (els.recentList) {
        els.recentList.classList.add("hidden");
        els.recentList.innerHTML = "";
      }

      const res = await api.getRecentCertificates(25);
      if (!res.success) {
        recentCertificates = [];
        if (els.recentSummary)
          els.recentSummary.textContent = "Liste yüklenemedi.";
        if (els.recentEmpty) {
          els.recentEmpty.classList.remove("hidden");
          els.recentEmpty.textContent =
            res.error || "Son sertifikalar getirilemedi.";
        }
        return;
      }

      recentCertificates = (Array.isArray(res.data) ? res.data : [])
        .map((item) => normalizeCertificateRecord(item))
        .filter(Boolean) as Record<string, any>[];
      renderRecentCertificates();
    }

