---
import { getEntry } from 'astro:content';
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { ArrowLeft, FilePlus2, X, RotateCw } from "lucide-astro";
import CompanyPicker from "../../components/CompanyPicker.astro";

const standardsReference = (await getEntry('reference', 'standards'))?.data.items ?? [];
const eaReference = (await getEntry('reference', 'ea-codes'))?.data.items ?? [];
const naceReference = (await getEntry('reference', 'nace-codes'))?.data.items ?? [];
const iso22000Reference = (await getEntry('reference', 'iso22000-categories'))?.data.items ?? [];
const iso13485Reference = (await getEntry('reference', 'iso13485-categories'))?.data.items ?? [];
const iso50001Reference = (await getEntry('reference', 'iso50001-categories'))?.data.items ?? [];
---

<DashboardLayout title="Sertifika Ekle">
  <script id="cert-standards-reference" type="application/json" set:html={JSON.stringify(standardsReference)}></script>
  <script id="cert-ea-reference" type="application/json" set:html={JSON.stringify(eaReference)}></script>
  <script id="cert-nace-reference" type="application/json" set:html={JSON.stringify(naceReference)}></script>
  <script id="cert-iso22000-reference" type="application/json" set:html={JSON.stringify(iso22000Reference)}></script>
  <script id="cert-iso13485-reference" type="application/json" set:html={JSON.stringify(iso13485Reference)}></script>
  <script id="cert-iso50001-reference" type="application/json" set:html={JSON.stringify(iso50001Reference)}></script>
  <div class="max-w-5xl mx-auto pb-24 space-y-6">
    <div class="flex items-center gap-3">
      <a
        id="cert-back-link"
        href="/company"
        class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group"
      >
        <ArrowLeft
          size={14}
          class="group-hover:-translate-x-1 transition-transform"
        />
        Firma Profili
      </a>
      <span class="text-border-main">/</span>
      <span class="text-xs font-bold text-muted" id="cert-header-breadcrumb"
        >Sertifika Ekle</span
      >
    </div>

    <section
      class="bg-surface border border-border-main shadow-xl rounded-[2rem]"
    >
      <div id="cert-page-skeleton">
        <!-- Spinner -->
        <div class="flex items-center gap-3 px-6 sm:px-8 pt-6 sm:pt-8 pb-4">
          <svg
            class="animate-spin h-4 w-4 shrink-0 text-indigo-400"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-xs font-bold text-muted"
            >Firma ve sertifika bilgileri yükleniyor...</span
          >
        </div>

        <!-- Skeleton cards -->
        <div class="animate-pulse">
          <!-- Firma header -->
          <div class="p-6 sm:p-8 border-b border-border-main space-y-4">
            <div class="flex gap-2">
              <div class="h-5 w-12 rounded-full bg-surface-hover"></div>
              <div class="h-5 w-20 rounded-full bg-surface-hover"></div>
              <div class="h-5 w-24 rounded-full bg-surface-hover"></div>
            </div>
            <div class="space-y-2">
              <div class="h-8 w-64 rounded-lg bg-surface-hover"></div>
              <div class="h-4 w-full max-w-xl rounded bg-surface-hover"></div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
              <div class="h-20 rounded-2xl bg-surface-hover"></div>
            </div>
          </div>

          <!-- Form sections -->
          <div class="p-6 sm:p-8 space-y-6">
            <!-- Temel + Tarihler -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-32 rounded bg-surface-hover"></div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                </div>
              </div>
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-24 rounded bg-surface-hover"></div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                </div>
              </div>
            </div>

            <!-- Sertifika Bilgileri + Ek Bilgiler -->
            <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-6">
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-36 rounded bg-surface-hover"></div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                  <div class="h-12 rounded-2xl bg-surface-hover"></div>
                </div>
              </div>
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-24 rounded bg-surface-hover"></div>
                <div class="h-48 rounded-2xl bg-surface-hover"></div>
              </div>
            </div>

            <!-- Kapsam + Scope -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-32 rounded bg-surface-hover"></div>
                <div class="h-56 rounded-2xl bg-surface-hover"></div>
              </div>
              <div
                class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
              >
                <div class="h-4 w-32 rounded bg-surface-hover"></div>
                <div class="h-56 rounded-2xl bg-surface-hover"></div>
              </div>
            </div>

            <!-- Submit buttons -->
            <div class="flex justify-end gap-3">
              <div class="h-11 w-32 rounded-2xl bg-surface-hover"></div>
              <div class="h-11 w-40 rounded-2xl bg-surface-hover"></div>
            </div>
          </div>
        </div>
      </div>

      <div id="cert-page-select" class="hidden p-6 sm:p-8">
        <CompanyPicker
          prefix="cert"
          eyebrow="Sertifika Merkezi"
          title="Firma Seçerek Devam Et"
          description="Sertifika eklemek veya düzenlemek istediğiniz firmayı seçin."
        />
      </div>

      <div id="cert-page-error" class="hidden p-8 space-y-2">
        <p id="cert-page-error-text" class="text-sm font-bold text-rose-400">
          Firma bağlamı yüklenemedi.
        </p>
        <p
          id="cert-page-error-detail"
          class="hidden text-xs font-semibold text-muted"
        >
        </p>
      </div>

      <div id="cert-page-shell" class="hidden">
        <div class="p-6 sm:p-8 border-b border-border-main space-y-4">
          <div class="flex flex-wrap items-center gap-2">
            <span
              class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-indigo-500/20 bg-indigo-500/10 text-indigo-400"
              id="cert-company-id">M0</span
            >
            <span
              class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted"
              id="cert-company-nick">Firma</span
            >
            <span
              class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400"
              id="cert-company-dan">Danışman</span
            >
          </div>

          <div class="space-y-2 min-w-0">
            <h1
              class="truncate text-2xl sm:text-3xl font-extrabold tracking-tight text-main"
              id="cert-company-unvan"
            >
              Firma yükleniyor...
            </h1>
            <p class="text-sm font-semibold text-muted" id="cert-company-stats">
              —
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div
              class="rounded-2xl border border-border-main bg-surface-hover p-4"
            >
              <p
                class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1"
              >
                Adres
              </p>
              <p
                class="text-sm font-semibold text-main leading-relaxed"
                id="cert-company-address"
              >
                —
              </p>
            </div>
            <div
              class="rounded-2xl border border-border-main bg-surface-hover p-4"
            >
              <div class="flex items-center justify-between gap-3 mb-3">
                <p
                  class="text-[10px] font-bold uppercase tracking-widest text-muted"
                >
                  Aksiyonlar
                </p>
                <span
                  class="text-[10px] font-bold uppercase tracking-widest text-muted"
                  >Hızlı Erişim</span
                >
              </div>
              <div class="flex flex-wrap gap-2">
                <a
                  id="cert-add-audit-link"
                  href="#"
                  class="inline-flex items-center gap-2 rounded-2xl border border-indigo-500/20 bg-indigo-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-indigo-300 hover:bg-indigo-500/15 transition-colors"
                  >Denetim Ekle</a
                >
                <button
                  id="cert-fill-from-company"
                  type="button"
                  class="inline-flex items-center gap-2 rounded-2xl border border-border-main bg-surface px-3 py-2 text-[11px] font-black uppercase tracking-widest text-main hover:bg-surface-hover transition-colors"
                  >Bilgileri Getir</button
                >
                <button
                  id="cert-open-recent"
                  type="button"
                  class="inline-flex items-center gap-2 rounded-2xl border border-sky-500/20 bg-sky-500/10 px-3 py-2 text-[11px] font-black uppercase tracking-widest text-sky-300 hover:bg-sky-500/15 transition-colors"
                  >Son 25 Sertifika</button
                >
              </div>
            </div>
            <div
              class="rounded-2xl border border-border-main bg-surface-hover p-4"
            >
              <div class="flex items-center justify-between gap-3 mb-3">
                <p
                  class="text-[10px] font-bold uppercase tracking-widest text-muted"
                >
                  Ek Bilgiler
                </p>
                <span
                  id="cert-not-label"
                  class="text-[10px] font-bold uppercase tracking-widest text-muted"
                  >Notlar</span
                >
              </div>
              <textarea
                id="cert-not"
                name="not"
                form="certificate-form"
                rows={5}
                class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm text-main min-h-[144px] resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                placeholder="Notlar"></textarea>
            </div>
          </div>
        </div>

        <form id="certificate-form" class="p-6 sm:p-8 space-y-6">
          <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div
              class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
            >
              <div class="flex items-center justify-between gap-3">
                <h2
                  class="text-sm font-black uppercase tracking-widest text-main"
                >
                  Temel Alanlar
                </h2>
                <span
                  class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted"
                  >Adım 1</span
                >
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Denetim Tipi</label
                  >
                  <select
                    id="cert-denetim"
                    name="denetim_tipi"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  >
                    <option value="Belgelendirme">İlk</option>
                    <option value="Gozetim">Gözetim</option>
                    <option value="Transfer">Özel</option>
                    <option value="Belge Yenileme">Yeniden</option>
                  </select>
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Standart</label
                  >
                  <select
                    id="cert-standart"
                    name="standart"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  >
                    <option value="">Yükleniyor...</option>
                  </select>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >ISO Tam Adı</label
                  >
                  <input
                    id="cert-iso-full"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed"
                    readonly
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Diğer Standart</label
                  >
                  <input
                    id="cert-other"
                    name="other_standart"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                    placeholder="Diğer standart"
                    readonly
                  />
                </div>
              </div>
            </div>

            <div
              class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
            >
              <div class="flex items-center justify-between gap-3">
                <h2
                  class="text-sm font-black uppercase tracking-widest text-main"
                >
                  Tarihler
                </h2>
                <span
                  class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted"
                  >Adım 2</span
                >
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Geçerli Sertifika Tarihi</label
                  >
                  <div class="flex gap-2">
                    <input
                      id="cert-gst"
                      name="sertifika_tarihi"
                      type="date"
                      class="flex-1 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                    />
                    <button
                      id="cert-auto-goz"
                      type="button"
                      class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-[11px] font-black uppercase tracking-widest text-emerald-300 hover:bg-emerald-500/15 transition-colors"
                      >+1</button
                    >
                  </div>
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Gözetim Tarihi</label
                  >
                  <input
                    id="cert-goz"
                    name="gozetim_tarihi"
                    type="date"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Tescil Tarihi</label
                  >
                  <input
                    id="cert-stt"
                    name="tescil_tarihi"
                    type="date"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Geçerlilik Tarihi</label
                  >
                  <input
                    id="cert-sgt"
                    name="gecerlilik_tarihi"
                    type="date"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
              </div>
            </div>
          </section>

          <section class="grid grid-cols-1 gap-6">
            <div
              class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4"
            >
              <div class="flex items-center justify-between gap-3">
                <h2
                  class="text-sm font-black uppercase tracking-widest text-main"
                >
                  Sertifika Bilgileri
                </h2>
                <span
                  class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted"
                  >Adım 3</span
                >
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Öneri SNo</label
                  >
                  <div class="flex min-w-0 items-stretch gap-2">
                    <input
                      id="cert-sno-suggested"
                      type="text"
                      class="min-w-0 flex-1 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main opacity-60 cursor-not-allowed"
                      readonly
                    />
                    <button
                      id="cert-apply-suggested"
                      type="button"
                      class="inline-flex h-[50px] w-[50px] shrink-0 items-center justify-center rounded-2xl border border-emerald-500/20 bg-emerald-500/10 text-emerald-300 hover:bg-emerald-500/15 transition-colors"
                      aria-label="Öneri sertifika numarasını uygula"
                      title="Öneri sertifika numarasını uygula"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M5 12h14"></path>
                        <path d="m13 5 7 7-7 7"></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Sertifika No</label
                  >
                  <input
                    id="cert-sno"
                    name="sno"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                    placeholder="Sertifika numarası"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Akreditasyon</label
                  >
                  <input
                    id="cert-akreditasyon"
                    name="akreditasyon"
                    type="text"
                    value="IAKS"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Akredite Kuruluş</label
                  >
                  <input
                    id="cert-akredite"
                    name="akredite"
                    type="text"
                    value="Medicert"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Kod / NACE</label
                  >
                  <input
                    id="cert-kod"
                    name="kod"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Danışman</label
                  >
                  <div class="relative">
                    <input
                      id="cert-dan"
                      name="dan"
                      type="text"
                      autocomplete="off"
                      aria-autocomplete="list"
                      aria-expanded="false"
                      aria-controls="consultant-list"
                      class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                      placeholder="Danışman ara veya yaz"
                    />
                    <div
                      id="consultant-list"
                      class="absolute left-0 right-0 top-[calc(100%+0.45rem)] z-20 hidden max-h-64 overflow-y-auto rounded-2xl border border-border-main bg-surface p-2 shadow-2xl shadow-slate-950/10"
                    >
                    </div>
                  </div>
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Durum</label
                  >
                  <input
                    id="cert-durum"
                    name="durum"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                    placeholder="Durum"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    class="text-[11px] font-bold uppercase tracking-widest text-muted"
                    >Logo</label
                  >
                  <input
                    id="cert-logo"
                    name="logo"
                    type="text"
                    class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500"
                    placeholder="Drive dosya ID veya URL"
                  />
                </div>
                <label
                  id="cert-gozetim-row"
