---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Sertifika Yönetimi">
  <div class="space-y-4">

    <!-- 🔍 Premium Arama & Aksiyon Çubuğu -->
    <div class="bg-surface border border-border-main shadow-lg p-3 sm:p-4 rounded-2xl flex flex-wrap items-center gap-3">
      <div class="relative flex-1 min-w-[200px]">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted w-4 h-4 pointer-events-none shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="search"
          id="global-search"
          placeholder="Firma, Standart veya Belge No ile ara..."
          autocomplete="off"
          class="w-full bg-surface-hover border border-border-main rounded-xl pl-10 pr-4 py-2.5 text-main placeholder:text-muted focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-sm"
        />
      </div>

      <div class="flex items-center gap-2 shrink-0">
        <select id="standard-filter" class="hidden md:block bg-surface-hover border border-border-main rounded-xl px-3 py-2.5 text-xs font-bold text-muted outline-none focus:ring-2 focus:ring-primary/50 transition-all cursor-pointer">
          <option value="">TÜM STANDARTLAR</option>
          <option value="9001">ISO 9001</option>
          <option value="14001">ISO 14001</option>
          <option value="45001">ISO 45001</option>
          <option value="22000">ISO 22000</option>
          <option value="27001">ISO 27001</option>
        </select>

        <span id="dataset-summary" class="text-xs font-black text-primary bg-primary/10 border border-primary/20 px-3 py-1.5 rounded-lg min-w-[2.75rem] text-center tabular-nums">0</span>
        
        <div id="sync-indicator" class="flex items-center gap-1.5 px-2.5 py-1.5 bg-surface-hover border border-border-main rounded-lg text-[10px] uppercase font-bold tracking-tight text-muted shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]"></span>
          <span class="hidden sm:inline sync-status-text">HAZIR</span>
        </div>

        <div class="h-8 w-px bg-border-main mx-1 hidden sm:block"></div>
        
        <button id="export-excel-btn" title="Excel Dışa Aktar" class="w-9 h-9 flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-emerald-400 hover:bg-emerald-500/10 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        </button>
      </div>

      <!-- ⚡ Toplu İşlemler Overlay (Search Bar içinde) -->
      <div id="bulk-actions" class="hidden flex-wrap items-center gap-3 w-full sm:w-auto bg-primary/10 border border-primary/30 px-3 py-1.5 rounded-xl animate-fade-in ml-auto">
        <span id="selected-count" class="text-[10px] font-black text-primary uppercase tracking-widest whitespace-nowrap">0 SEÇİLİ</span>
        <div class="h-4 w-px bg-primary/20 hidden sm:block"></div>
        <button id="bulk-done-btn" class="text-[10px] font-black text-emerald-400 hover:text-emerald-300 transition-colors uppercase tracking-widest px-2 py-1 rounded-lg hover:bg-emerald-500/10 whitespace-nowrap">
          ✓ GÖZETİM TAMAM
        </button>
        <button id="bulk-pending-btn" class="text-[10px] font-black text-amber-400 hover:text-amber-300 transition-colors uppercase tracking-widest px-2 py-1 rounded-lg hover:bg-amber-500/10 whitespace-nowrap">
          ⏸ BEKLET
        </button>
      </div>
    </div>

    <!-- 📊 Veri Tablosu Kartı -->
    <div class="bg-surface border border-border-main shadow-xl rounded-2xl overflow-hidden">
      <div class="w-full overflow-x-auto">
        <table class="w-full table-fixed border-collapse">
          <thead>
            <tr class="bg-surface-hover border-b border-border-main">
              <th class="w-10 px-3 py-3.5 text-center">
                <input type="checkbox" id="select-all" class="w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary">
              </th>
              <th class="w-24 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap">Sert. Tarihi</th>
              <th class="w-64 px-5 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Firma Adı</th>
              <th class="w-32 pl-6 pr-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left whitespace-nowrap">Standart</th>
              <th class="w-24 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap">Denetim</th>
              <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap">Sert. No</th>
              <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap italic">Gözetim Tarihi</th>
              <th class="w-24 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap">Akredite</th>
              <th class="w-40 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center whitespace-nowrap">Danışman</th>
              <th class="w-16 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Detay</th>
            </tr>
          </thead>
          <tbody id="cert-table-body" class="divide-y divide-border-main">
          </tbody>
        </table>
      </div>

      <!-- Durum Mesajları -->
      <div id="table-loader" class="py-24 flex flex-col items-center justify-center gap-3">
        <div class="w-10 h-10 border-2 border-primary/20 border-t-primary rounded-full animate-spin"></div>
        <p class="text-xs font-bold text-muted tracking-widest uppercase animate-pulse">Veriler Hazırlanıyor</p>
      </div>

      <div id="empty-state" class="hidden py-24 flex flex-col items-center justify-center gap-3 text-center px-6">
        <div class="w-14 h-14 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <p class="text-sm font-bold text-muted uppercase tracking-widest">Eşleşen sertifika bulunamadı</p>
      </div>

      <!-- Sayfalama (Premium Layout) -->
      <div id="pagination-bar" class="hidden bg-surface-hover border-t border-border-main px-4 sm:px-6 py-3 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span id="page-summary" class="text-xs font-black text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 tabular-nums">1 / 1</span>
          <div class="flex items-center gap-2 border-l border-border-main pl-3">
            <span class="text-[10px] font-bold text-muted uppercase tracking-widest hidden sm:inline">Göster:</span>
            <select id="page-size-select" class="bg-surface border border-border-main rounded-lg px-2 py-1 text-[11px] font-bold text-main outline-none focus:ring-1 focus:ring-primary/40 transition-all cursor-pointer">
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </div>
        </div>
        <div class="flex items-center gap-2">
           <button id="prev-page-btn" title="Önceki Sayfa" class="w-8 h-8 flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-primary/10 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
           </button>
           <div id="page-number-list" class="flex items-center gap-1.5"></div>
           <button id="next-page-btn" title="Sonraki Sayfa" class="w-8 h-8 flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-primary/10 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
           </button>
        </div>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { $certificates, $syncStatus } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { toast } from '../../lib/toast';

  let filters = { search: '', standard: '' };
  let currentPage = 1;
  let pageSize = 20;
  let fullCertificatesLoaded = false;
  let cleanupFns: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }

  function runCleanups() {
    cleanupFns.forEach(fn => fn());
    cleanupFns = [];
  }

  function initPage() {
    runCleanups();

    const tableBody = document.getElementById('cert-table-body');
    const tableLoader = document.getElementById('table-loader');
    const emptyState = document.getElementById('empty-state');
    const globalSearch = document.getElementById('global-search') as HTMLInputElement;
    const standardFilter = document.getElementById('standard-filter') as HTMLSelectElement;
    const statusFilter = document.getElementById('status-filter') as HTMLSelectElement | null;
    const syncIndicator = document.getElementById('sync-indicator');
    const exportCsvBtn = document.getElementById('export-csv-btn') as HTMLButtonElement | null;
    const exportExcelBtn = document.getElementById('export-excel-btn') as HTMLButtonElement | null;
    const datasetSummary = document.getElementById('dataset-summary');
    const pageSummary = document.getElementById('page-summary');
    const pageSizeSelect = document.getElementById('page-size-select') as HTMLSelectElement;
    const paginationBar = document.getElementById('pagination-bar');
    const paginationMeta = document.getElementById('pagination-meta');
    const pageNumberList = document.getElementById('page-number-list');
    const prevPageBtn = document.getElementById('prev-page-btn') as HTMLButtonElement;
    const nextPageBtn = document.getElementById('next-page-btn') as HTMLButtonElement;
    const selectAll = document.getElementById('select-all') as HTMLInputElement;
    const bulkActionsBar = document.getElementById('bulk-actions');
    const selectedCountDisplay = document.getElementById('selected-count');
    const bulkDoneBtn = document.getElementById('bulk-done-btn');
    const bulkPendingBtn = document.getElementById('bulk-pending-btn');

    function setTableState(state: 'loading' | 'empty' | 'ready') {
      if (state === 'loading') {
        tableLoader?.classList.remove('hidden');
        emptyState?.classList.add('hidden');
        paginationBar?.classList.add('hidden');
        return;
      }

      tableLoader?.classList.add('hidden');

      if (state === 'empty') {
        emptyState?.classList.remove('hidden');
        paginationBar?.classList.add('hidden');
        return;
      }

      emptyState?.classList.add('hidden');
    }

    function normalizeKey(value: any) {
    return String(value || '')
      .trim()
      .toLocaleLowerCase('tr-TR')
      .replace(/[ıİ]/g, 'i')
      .replace(/[ğĞ]/g, 'g')
      .replace(/[üÜ]/g, 'u')
      .replace(/[şŞ]/g, 's')
      .replace(/[öÖ]/g, 'o')
      .replace(/[çÇ]/g, 'c')
      .replace(/_/g, '') // Ensure snake_case matches compressed aliases
      .replace(/[^a-z0-9]+/g, '');
  }

  function pickValue(item: any, aliases: string[], fallback = '') {
    for (const key of aliases) {
      if (item && item[key] !== undefined && item[key] !== null && String(item[key]).trim() !== '') {
        return String(item[key]);
      }
    }

    if (item && typeof item === 'object') {
      const normalizedAliases = aliases.map((alias) => normalizeKey(alias));
      for (const [rawKey, rawValue] of Object.entries(item)) {
        if (rawValue === undefined || rawValue === null) continue;
        if (String(rawValue).trim() === '') continue;
        if (normalizedAliases.includes(normalizeKey(rawKey))) {
          return String(rawValue);
        }
      }
    }

    return fallback;
  }

  function hasFullCertificateDataset(data: readonly any[]) {
    if (!Array.isArray(data) || data.length === 0) return false;
    const checkKeys = ['akreditasyon', 'kapsam', 'durum'];
    return data.some((item: any) => {
      if (!item || typeof item !== 'object') return false;
      const keys = Object.keys(item).map(k => k.toLowerCase());
      return checkKeys.some(ck => keys.includes(ck));
    });
  }

  function pickExistingField(item: any, aliases: string[], fallback: string) {
    for (const key of aliases) {
      if (item && Object.prototype.hasOwnProperty.call(item, key)) return key;
    }

    if (item && typeof item === 'object') {
      const normalizedAliases = aliases.map((alias) => normalizeKey(alias));
      for (const rawKey of Object.keys(item)) {
        if (normalizedAliases.includes(normalizeKey(rawKey))) return rawKey;
      }
    }

    return fallback;
  }

  function escHtml(v: any) {
    return String(v ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function escAttr(v: any) {
    return escHtml(v).replace(/"/g, "&quot;");
  }

  function normalizeStandard(item: any) {
    const mainStandart = pickValue(item, ["Standart", "standard"], "-");
    const otherStandart = pickValue(item, ["Other Standard", "Other", "other", "Diğer", "diger", "Diger", "diğer", "Diğer Standart", "digerStandart"], "");
    const sLow = mainStandart.toLowerCase().trim();
    const isOther = sLow === 'diğer' || sLow === 'diger' || sLow === 'other';
    return (isOther && otherStandart) ? otherStandart : mainStandart;
  }

  function getDenetim(item: any) {
    return pickValue(item, ["Denetim Tipi", "Denetim", "denetim", "denetimTipi", "denetim_tipi", "denetimtipi"], "-");
  }

  function getOtherStandard(item: any) {
    return pickValue(item, ["Other Standard", "Other", "other", "Diğer", "diger", "Diger", "diğer", "Diğer Standart", "digerStandart"], "-");
  }

  function getStatusLabel(item: any) {
    const raw = pickValue(item, ["Durum", "durum", "Gözetim", "Gözetim Conf.", "gozetimConfirmed"], "");
    const normalized = String(raw).trim().toUpperCase();
    if (normalized === "TRUE") return "Aktif";
    if (normalized === "FALSE") return "Bekliyor";
    return raw || "-";
  }

  function getQueryLink(item: any) {
    return pickValue(item, ["Sorgulama Linki", "Sorgu Linki", "Query Link", "queryLink", "qr", "QR Code"], "");
  }

  function getCertificateLink(item: any) {
    return pickValue(item, ["Sertifika Linki", "Cert Link", "certLink", "certiLink"], "");
  }

  function normalizeLink(value: string) {
    const raw = String(value || '').trim();
    if (!raw) return '';
    if (/^https?:\/\//i.test(raw)) return raw;
    if (/^www\./i.test(raw)) return `https://${raw}`;
    return raw;
  }

  function getCertificateId(item: any, fallback = '-') {
    const direct = pickValue(item, ["ID", "Id", "id", "Certificate ID", "certificateId", "sertifikaId"], "");
    if (direct) return direct;

    if (item && typeof item === 'object') {
      const entries = Object.entries(item);
      if (entries.length > 0) {
        const [firstKey, firstValue] = entries[0];
        const keyLooksUnnamed = normalizeKey(firstKey) === '';
        const valueText = String(firstValue ?? '').trim();
        if ((keyLooksUnnamed || entries.length > 0) && valueText) {
          return valueText;
        }
      }
    }

    return fallback;
  }

  function parseDateValue(raw: string) {
    const value = String(raw || '').trim();
    if (!value) return null;

    const trMatch = value.match(/^(\d{1,2})[./-](\d{1,2})[./-](\d{4})(?:\s+(\d{1,2}):(\d{2}))?$/);
    if (trMatch) {
      const [, dd, mm, yyyy, hh = '00', min = '00'] = trMatch;
      const dt = new Date(Number(yyyy), Number(mm) - 1, Number(dd), Number(hh), Number(min));
      return Number.isNaN(dt.getTime()) ? null : dt;
    }

    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }

  function getCreatedAt(item: any) {
    return pickValue(item, [
      "Kayıt Tarihi", "Kayit Tarihi", "Created At", "createdAt", "created_at",
      "Timestamp", "timestamp", "Eklenme Tarihi", "Eklenme", "Date Created"
    ], "");
  }

  function getSortableTimestamp(item: any, originalIndex: number) {
    const candidates = [
      getCreatedAt(item),
      pickValue(item, ["Sertifika Tarihi", "gst", "GST"], ""),
      pickValue(item, ["Sertifika Gözetim Tarihi", "goz", "GOZ"], "")
    ];

    for (const candidate of candidates) {
      const parsed = parseDateValue(candidate);
      if (parsed) return parsed.getTime();
    }

    const idRaw = pickValue(item, ["ID", "id"], "");
    const idNumber = Number(String(idRaw).replace(/[^\d.-]/g, ''));
    if (!Number.isNaN(idNumber) && String(idRaw).trim() !== '') {
      return idNumber;
    }

    return originalIndex;
  }

  function getDetailedEntries(item: any) {
    return Object.entries(item || {})
      .filter(([key, value]) => {
        if (value === undefined || value === null) return false;
        const text = String(value).trim();
        return text !== '';
      })
      .sort(([a], [b]) => a.localeCompare(b, 'tr'));
  }

  function getVisiblePageNumbers(totalPages: number, page: number) {
    const pages = new Set<number>([1, totalPages, page - 1, page, page + 1]);
    return Array.from(pages).filter((p) => p >= 1 && p <= totalPages).sort((a, b) => a - b);
  }

    function updatePagination(totalItems: number) {
      const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
      const safePage = Math.min(currentPage, totalPages);
      currentPage = safePage;

      if (pageSummary) pageSummary.textContent = `${safePage} / ${totalPages}`;
      if (datasetSummary) datasetSummary.textContent = totalItems.toString();

      if (!paginationBar || !pageNumberList || !prevPageBtn || !nextPageBtn) return;

      if (totalItems === 0) {
        paginationBar.classList.add('hidden');
        pageNumberList.innerHTML = '';
        return;
      }

      paginationBar.classList.remove('hidden');
      prevPageBtn.disabled = safePage <= 1;
      nextPageBtn.disabled = safePage >= totalPages;

      const pages = getVisiblePageNumbers(totalPages, safePage);
      pageNumberList.innerHTML = '';
      pages.forEach((pageNum, index) => {
        if (index > 0 && pages[index - 1] !== pageNum - 1) {
          const dots = document.createElement('span');
          dots.className = 'px-1.5 text-xs text-muted';
          dots.textContent = '…';
          pageNumberList.appendChild(dots);
        }

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = String(pageNum);
        btn.className = `w-8 h-8 rounded-lg border text-xs font-black transition-all ${
          pageNum === currentPage
            ? 'bg-primary text-white border-primary shadow-md shadow-primary/20'
            : 'border-border-main text-muted hover:text-primary hover:bg-primary/10 hover:border-primary/30'
        }`;
        btn.addEventListener('click', () => {
          currentPage = pageNum;
          window.scrollTo({ top: 0, behavior: 'smooth' });
          renderTable($certificates.get());
        });
        pageNumberList.appendChild(btn);
      });
    }

    function getInitials(name: string): string {
      return String(name || '').trim().split(/\s+/).filter(Boolean).map(w => w[0]).join('').toUpperCase().slice(0, 2) || '??';
    }

    const unsubCerts = $certificates.subscribe(certs => {
      if (!fullCertificatesLoaded && (certs || []).length > 0 && !hasFullCertificateDataset(certs || [])) {
        setTableState('loading');
        return;
      }
      setTableState('ready');
      renderTable(certs || []);
    });
    registerCleanup(unsubCerts);

    const unsubSync = $syncStatus.subscribe(status => {
      if (!syncIndicator) return;
      const dot = syncIndicator.querySelector('span');
      const textEl = syncIndicator.querySelector('.sync-status-text');
      if (!dot) return;
      
      if (status === 'syncing') {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse';
        if (textEl) textEl.textContent = 'GÜNCELLENİYOR';
      } else if (status === 'error') {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]';
        if (textEl) textEl.textContent = 'HATA';
      } else {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]';
        if (textEl) textEl.textContent = 'HAZIR';
      }
    });
    registerCleanup(unsubSync);

  function getFilteredData(data: readonly any[]) {
    return data.filter((item: any) => {
      const firma = pickValue(item, ["Firma Adı", "Nickname", "nick", "nickname"]);
      const id = getCertificateId(item, "");
      const certNo = pickValue(item, ["Sertifika No", "sNo", "SNo", "sno", "sertifika_no"]);
      const standart = normalizeStandard(item);
      const denetim = getDenetim(item);
      const danisman = pickValue(item, ["Danışman", "Danisman", "dan", "danisman", "consultant"]);
      const gozetim = pickValue(item, ["Gözetim", "Gözetim Conf.", "gozetimConfirmed", "gozetim_confirmed"], "FALSE").toUpperCase();
      const matchSearch = `${firma}${id}${certNo}${standart}${denetim}${danisman}`.toLowerCase().includes(filters.search.toLowerCase());
      const matchStd = !filters.standard || standart.includes(filters.standard);
      const matchStatus = !filters.status || gozetim === filters.status;
      return matchSearch && matchStd && matchStatus;
    });
  }

  function renderTable(data: readonly any[]) {
    if (!tableBody) return;
    try {
      const filtered = getFilteredData(data)
        .map((item, originalIndex) => ({ item, originalIndex }))
        .sort((a, b) => getSortableTimestamp(b.item, b.originalIndex) - getSortableTimestamp(a.item, a.originalIndex));

      tableBody.innerHTML = '';
      updateBulkUI();

      if (filtered.length === 0) {
        setTableState('empty');
        updatePagination(0);
        return;
      }
      setTableState('ready');

      updatePagination(filtered.length);
      const startIndex = (currentPage - 1) * pageSize;
      const paged = filtered.slice(startIndex, startIndex + pageSize);

        paged.forEach(({ item, originalIndex }: any) => {
          const id = getCertificateId(item, String(originalIndex + 1));
          const firmaId = pickValue(item, ["Firma No", "firmaNo", "firmano", "firma_no"], "-");
          const idAttr = escAttr(id || String(originalIndex));
          const sertifikaTarihi = pickValue(item, ["Sertifika Tarihi", "gst", "GST", "sertifika_tarihi"], "-");
          const firma = pickValue(item, ["Firma Adı", "Nickname", "nick", "nickname"], "-");
          const standart = normalizeStandard(item);
          const certNo = pickValue(item, ["Sertifika No", "sNo", "SNo", "sno", "sertifika_no"], "-");
          const gozetimTarihi = pickValue(item, ["Sertifika Gözetim Tarihi", "goz", "GOZ", "gozetim_tarihi"], "-");
          const durum = getStatusLabel(item);
          const initials = getInitials(firma);
          const detailRowId = `cert-detail-${idAttr}`;
          
          const denetim = getDenetim(item);
          const akreditasyon = pickValue(item, ["akreditasyon", "Akreditasyon", "akredite", "Akredite", "akrn"], "-");
          const danisman = pickValue(item, ["Danışman", "Danisman", "danisman", "dan", "consultant"], "-");

          // Robust data picking for detail view
          const notlar = pickValue(item, ["Notlar", "Not", "not", "notes"], "-");
          const sorgulamaLinki = normalizeLink(getQueryLink(item));
          const sertifikaLinki = normalizeLink(getCertificateLink(item));

          const tr = document.createElement('tr');
          tr.className = 'hover:bg-surface-hover transition-colors group/row text-[11px]';
          tr.innerHTML = `
            <td class="px-3 py-4 text-center align-middle">
              <input type="checkbox" class="cert-checkbox w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary" data-id="${idAttr}">
            </td>
            <td class="px-4 py-4 text-center font-mono font-bold text-muted italic">
              ${escHtml(sertifikaTarihi)}
            </td>
            <td class="px-5 py-3">
               <div class="flex items-center gap-3">
                 <div class="w-8 h-8 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
                   <span class="text-[10px] font-black text-primary uppercase">${initials}</span>
                 </div>
                 <div class="min-w-0 flex-1">
                   <div class="font-bold text-main truncate uppercase tracking-tight leading-tight">${escHtml(firma)}</div>
                   <div class="text-[9px] text-muted font-bold mt-0.5 leading-tight truncate uppercase tracking-tight">ID: ${escHtml(id)}</div>
                 </div>
               </div>
            </td>
            <td class="pl-6 pr-4 py-4 text-left font-bold text-primary/70">${escHtml(standart.length > 30 ? standart.slice(0, 30) + '...' : standart)}</td>
            <td class="px-4 py-4 text-center font-bold text-muted">${escHtml(denetim)}</td>
            <td class="px-4 py-4 text-center font-mono font-bold text-main">${escHtml(certNo)}</td>
            <td class="px-4 py-4 text-center font-mono text-muted italic">${escHtml(gozetimTarihi)}</td>
            <td class="px-4 py-4 text-center font-medium text-muted">${escHtml(akreditasyon)}</td>
            <td class="px-4 py-4 text-center font-medium text-muted">${escHtml(danisman)}</td>
            <td class="px-4 py-4">
              <div class="flex items-center justify-center gap-1.5">
                <button
                  class="detail-toggle-btn w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-surface-hover transition-all duration-300"
                  data-target="${detailRowId}"
                  title="Detayları Gör"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
                </button>
              </div>
            </td>
          `;
          tableBody.appendChild(tr);

        const detailTr = document.createElement('tr');
        detailTr.id = detailRowId;
        detailTr.className = 'hidden border-b border-border-main bg-surface-hover';
        detailTr.innerHTML = `
          <td colspan="10" class="px-3 sm:px-6 pb-4 pt-1 align-middle">
            <div class="rounded-xl border border-border-main bg-surface p-3 shadow-inner">
              <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-2">
                <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                  <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Sertifika ID</div>
                  <div class="text-xs font-mono text-main break-all">${escHtml(id || '-')}</div>
                </div>
                <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                  <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Notlar</div>
                  <div class="text-xs text-main break-words">${escHtml(pickValue(item, ["Notlar", "Not", "not", "notes", "sertifika_not"], "-"))}</div>
                </div>
                <div class="col-span-2 md:col-span-1 xl:col-span-1 rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                  <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Sorgulama Linki</div>
                  <div class="text-xs break-all">
                    ${sorgulamaLinki ? `<a href="${escAttr(sorgulamaLinki)}" target="_blank" rel="noopener noreferrer" class="text-sky-400 hover:text-sky-300 underline underline-offset-2">${escHtml(sorgulamaLinki)}</a>` : '<span class="text-muted">—</span>'}
                  </div>
                </div>
                <div class="col-span-2 md:col-span-1 xl:col-span-1 rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                  <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Sertifika Linki</div>
                  <div class="text-xs break-all">
                    ${sertifikaLinki ? `<a href="${escAttr(sertifikaLinki)}" target="_blank" rel="noopener noreferrer" class="text-sky-400 hover:text-sky-300 underline underline-offset-2">${escHtml(sertifikaLinki)}</a>` : '<span class="text-muted">—</span>'}
                  </div>
                </div>
              </div>
            </div>
          </td>
        `;
        tableBody.appendChild(detailTr);
      });

      attachTableActions();
    } catch (error) {
      console.error('[certificates] renderTable failed:', error);
      tableBody.innerHTML = '';
      setTableState('empty');
      updatePagination(0);
    }
  }

  function updateBulkUI() {
    const checked = document.querySelectorAll('.cert-checkbox:checked');
    if (selectedCountDisplay) selectedCountDisplay.textContent = `${checked.length} SEÇİLİ`;
    if (checked.length > 0) {
      bulkActionsBar?.classList.remove('hidden');
      bulkActionsBar?.classList.add('flex');
    } else {
      bulkActionsBar?.classList.add('hidden');
      bulkActionsBar?.classList.remove('flex');
      if (selectAll) selectAll.checked = false;
    }
  }

  selectAll?.addEventListener('change', (e) => {
    const isChecked = (e.target as HTMLInputElement).checked;
    document.querySelectorAll('.cert-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = isChecked;
    });
    updateBulkUI();
  });

  tableBody?.addEventListener('change', (e) => {
    if ((e.target as HTMLElement).classList.contains('cert-checkbox')) {
      updateBulkUI();
    }
  });

  async function callBulkUpdate(status: boolean) {
    const checked = Array.from(document.querySelectorAll('.cert-checkbox:checked'))
      .map(cb => (cb as HTMLElement).dataset.id);
    if (checked.length === 0) return;
    if (!confirm(`${checked.length} adet belgenin gözetim durumunu güncellemek istediğinizden emin misiniz?`)) return;
    const res = await api.updateSurveillance(checked, status);
    if (res.success) {
      toast.success('İşlem başarılı!');
      window.location.reload();
    } else {
      toast.error(`Hata: ${res.error}`);
    }
  }

  bulkDoneBtn?.addEventListener('click', () => callBulkUpdate(true));
  bulkPendingBtn?.addEventListener('click', () => callBulkUpdate(false));

  function attachTableActions() {
    document.querySelectorAll('.detail-toggle-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const btnEl = e.currentTarget as HTMLElement;
        const targetId = btnEl.dataset.target;
        if (!targetId) return;
        const targetRow = document.getElementById(targetId);
        if (!targetRow) return;
        const isHidden = targetRow.classList.contains('hidden');
        targetRow.classList.toggle('hidden');
        
        // Animate icon rotation instead of wiping it
        const icon = btnEl.querySelector('svg');
        if (icon) {
          icon.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
        }
        btnEl.classList.toggle('bg-primary/20', isHidden);
        btnEl.classList.toggle('text-primary', isHidden);
        btnEl.classList.toggle('border-primary/30', isHidden);
      });
    });
  }

    async function ensureCertificatesLoaded() {
      const current = $certificates.get() || [];
      if (hasFullCertificateDataset(current)) {
        fullCertificatesLoaded = true;
        return;
      }

      setTableState('loading');

      try {
        const res = await api.getCertificates();

        if (res.success && Array.isArray(res.data)) {
          fullCertificatesLoaded = true;
          $certificates.set(res.data);
        } else if (!res.success) {
          console.warn('[certificates] getCertificates failed:', res.error);
        }
      } catch (error) {
        console.error('[certificates] ensureCertificatesLoaded failed:', error);
      } finally {
        if (!fullCertificatesLoaded) {
          setTableState(($certificates.get() || []).length ? 'ready' : 'empty');
        }
      }
    }

    async function boot() {
      await SyncManager.init();
      await ensureCertificatesLoaded();
    }

    // --- Events ---
    globalSearch?.addEventListener('input', (e) => {
      filters.search = (e.target as HTMLInputElement).value;
      currentPage = 1;
      renderTable($certificates.get());
    });
    standardFilter?.addEventListener('change', (e) => {
      filters.standard = (e.target as HTMLSelectElement).value;
      currentPage = 1;
      renderTable($certificates.get());
    });
    statusFilter?.addEventListener('change', (e) => {
      filters.status = (e.target as HTMLSelectElement).value;
      currentPage = 1;
      renderTable($certificates.get());
    });
    pageSizeSelect?.addEventListener('change', (e) => {
      pageSize = Number((e.target as HTMLSelectElement).value) || 20;
      currentPage = 1;
      renderTable($certificates.get());
    });
    prevPageBtn?.addEventListener('click', () => {
      if (currentPage <= 1) return;
      currentPage -= 1;
      renderTable($certificates.get());
    });
    nextPageBtn?.addEventListener('click', () => {
      currentPage += 1;
      renderTable($certificates.get());
    });

    if (exportCsvBtn) exportCsvBtn.onclick = () => {
      const rows = getExportRows();
      const headers = ['ID', 'Firma', 'Standart', 'Belge No', 'Gözetim', 'Gözetim Tarihi', 'Sertifika Tarihi', 'Not', 'Danışman'];
      const lines = [headers.join(',')];
      rows.forEach(r => {
        lines.push([
          toCsvValue(r.id),
          toCsvValue(r.firma),
          toCsvValue(r.standart),
          toCsvValue(r.belgeNo),
          toCsvValue(r.gozetim),
          toCsvValue(r.gozetimTarihi),
          toCsvValue(r.sertifikaTarihi),
          toCsvValue(r.not),
          toCsvValue(r.danisman)
        ].join(','));
      });
      downloadFile(`Sertifikalar_${new Date().toISOString().slice(0,10)}.csv`, '\uFEFF' + lines.join('\n'), 'text/csv;charset=utf-8;');
    };

    if (exportExcelBtn) exportExcelBtn.onclick = () => {
      const rows = getExportRows();
      const tableHtml = `
        <table>
          <thead>
            <tr>
              <th>ID</th><th>Firma</th><th>Standart</th><th>Belge No</th><th>Gözetim</th><th>Gözetim Tarihi</th><th>Sertifika Tarihi</th><th>Not</th><th>Danışman</th>
            </tr>
          </thead>
          <tbody>
            ${rows.map(r => `<tr><td>${r.id}</td><td>${r.firma}</td><td>${r.standart}</td><td>${r.belgeNo}</td><td>${r.gozetim}</td><td>${r.gozetimTarihi}</td><td>${r.sertifikaTarihi}</td><td>${r.not}</td><td>${r.danisman}</td></tr>`).join('')}
          </tbody>
        </table>
      `;
      const html = `<html><head><meta charset="utf-8" /></head><body>${tableHtml}</body></html>`;
      downloadFile(`Sertifikalar_${new Date().toISOString().slice(0,10)}.xls`, html, 'application/vnd.ms-excel;charset=utf-8;');
    };

    void boot();
  }

  // Initial load
  initPage();
  // Transition support
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups);
</script>
