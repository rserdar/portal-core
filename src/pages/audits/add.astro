---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Denetim Planla">
  <div class="max-w-6xl mx-auto pb-24 space-y-6">
    <div class="flex items-center gap-3">
      <a href="/audits" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"></path></svg>
        Denetim Merkezi
      </a>
      <span class="text-border-main">/</span>
      <span id="audit-breadcrumb-label" class="text-xs font-bold text-muted">Denetim Planla</span>
    </div>

    <!-- Ana Konteynır -->
    <div class="space-y-6">
      <section class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
        <!-- 1. ADIM: Firma Seçimi (Firma bağlamı yoksa görünür) -->
        <div id="audit-picker-section" class="p-6 sm:p-10 space-y-6">
          <div class="space-y-2">
            <p class="text-[10px] font-black uppercase tracking-[0.24em] text-indigo-400">Denetim Planlama</p>
            <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main">Firma Seçerek Başla</h1>
            <p class="text-sm leading-relaxed text-muted max-w-2xl">Denetim planlayabilmek için önce ilgili firmayı seçmelisin. Firma profilinden geliyorsan bu adım otomatik atlanır.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end bg-surface-hover p-6 rounded-[2rem] border border-border-main">
            <div class="space-y-2">
              <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Arama</label>
              <input id="audit-picker-search" list="audit-picker-list" type="text" placeholder="Firma adıyla veya ID ile ara..." class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50" />
              <datalist id="audit-picker-list"></datalist>
            </div>
            <button id="audit-picker-continue" type="button" class="w-full md:w-auto inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-6 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-500/20 disabled:opacity-50 disabled:cursor-not-allowed">
              Firma Bilgilerini Getir
            </button>
          </div>
          <p id="audit-picker-status" class="text-xs font-semibold text-muted">Mevcut firmalar taranıyor...</p>
        </div>

        <!-- 2. ADIM: Denetim Formu (Firma seçilince görünür) -->
        <div id="audit-form-section" class="hidden">
          <div class="p-6 sm:p-8 border-b border-border-main space-y-2">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted" id="audit-company-badge">Firma seçimi bekleniyor</span>
            </div>
            <h1 id="audit-page-title" class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main">Denetim Detayları</h1>
          </div>

          <div class="p-6 sm:p-8 space-y-6">
            <section class="rounded-[1.75rem] border border-border-main bg-surface-hover p-5 sm:p-6 space-y-5">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-2xl bg-indigo-500/10 text-indigo-400 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path><path d="M9 9v.01"></path><path d="M9 12v.01"></path><path d="M9 15v.01"></path><path d="M9 18v.01"></path></svg>
                </div>
                <div>
                  <h2 class="text-sm font-black uppercase tracking-widest text-main">Temel Bilgiler</h2>
                  <p class="text-xs text-muted">Firma, standart ve denetim tipi</p>
                </div>
              </div>

              <div id="audit-company-summary" class="rounded-[1.5rem] border border-indigo-500/20 bg-indigo-500/5 p-4 sm:p-5">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <div class="space-y-1.5">
                    <p class="text-[10px] font-black uppercase tracking-[0.24em] text-indigo-300">Seçili Firma</p>
                    <h3 id="audit-company-name" class="text-base sm:text-lg font-black text-main">—</h3>
                  </div>
                  <div class="rounded-2xl border border-indigo-500/20 bg-surface px-3 py-2 text-right">
                    <p class="text-[10px] font-black uppercase tracking-[0.24em] text-muted">Firma ID</p>
                    <p id="audit-company-id-pill" class="text-sm font-black text-indigo-300">—</p>
                  </div>
                </div>
              </div>

              <input id="audit-firma-id" type="hidden" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="space-y-2 block">
                  <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart Seçimi</span>
                  <select id="xstandartInput" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main">
                    <option>Yükleniyor...</option>
                  </select>
                </label>

                <label class="space-y-2 block">
                  <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Denetim Tipi</span>
                  <select id="denetimInput" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main">
                    <option value="İlk" selected>İlk</option>
                    <option value="Gözetim">Gözetim</option>
                    <option value="Yeniden">Yeniden</option>
                    <option value="Özel">Özel</option>
                  </select>
                </label>
              </div>

            </section>

            <section class="rounded-[1.75rem] border border-border-main bg-surface-hover p-5 sm:p-6 space-y-6">
              <div class="space-y-5">
                <div class="space-y-4">
                  <h2 class="text-base font-black text-main">Aşama 1</h2>
                  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[1.45fr_1fr_1fr_0.8fr] gap-4">
                    <div class="space-y-2">
                      <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Başlangıç Tarihi</span>
                      <div class="flex gap-2">
                        <input id="a1Basla" type="date" class="flex-1 rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
                        <button id="a1Equal" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">=</button>
                        <button id="a1Plus1" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+1</button>
                        <button id="a1Plus2" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+2</button>
                      </div>
                    </div>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bitiş Tarihi</span><input id="a1Bitis" type="date" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Tam Tarih</span><input id="a1Full" type="text" autocomplete="off" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Adam / Gün</span><input id="a1Manday" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  </div>
                  <input id="a1Md" type="hidden" />
                  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Baş Denetçi</span><select id="leadAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">2. Denetçi</span><select id="secondAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">3. Denetçi</span><select id="thirdAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">İsimler</span><input id="a1Denetciler" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Kısaltmalar</span><input id="a1KDenetci" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  </div>
                </div>

                <div class="border-t border-dashed border-border-main"></div>

                <div class="space-y-4">
                  <h2 id="stage2Title" class="text-base font-black text-main">Aşama 2</h2>
                  <div id="stage2AreaR1" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[1.45fr_1fr_1fr_0.8fr] gap-4">
                    <div class="space-y-2">
                      <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Başlangıç Tarihi</span>
                      <div class="flex gap-2">
                        <input id="a2Basla" type="date" class="flex-1 rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
                        <button id="a2Equal" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">=</button>
                        <button id="a2Plus1" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+1</button>
                        <button id="a2Plus2" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+2</button>
                      </div>
                    </div>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bitiş Tarihi</span><input id="a2Bitis" type="date" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Tam Tarih</span><input id="a2Full" type="text" autocomplete="off" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Adam / Gün</span><input id="a2Manday" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  </div>
                  <input id="a2Md" type="hidden" />
                  <div id="stage2AreaR2" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Baş Denetçi</span><select id="leadAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">2. Denetçi</span><select id="secondAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">3. Denetçi</span><select id="thirdAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Seçim yapın...</option></select></label>
                  </div>
                  <div id="stage2AreaR3" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">İsimler</span><input id="a2Denetciler" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                    <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Kısaltmalar</span><input id="a2KDenetci" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  </div>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end pt-2">
                <button id="clear-audit-button" type="button" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3.5 text-sm font-bold text-main hover:bg-surface-hover transition-colors sm:py-3">Formu Temizle</button>
                <a id="audit-back-btn" href="/certificates" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface px-4 py-3.5 text-sm font-bold text-main hover:bg-surface-hover transition-colors sm:py-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
                  Geri
                </a>
                <button id="add-audit-button" type="button" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-5 py-3.5 text-sm font-black text-white hover:bg-indigo-500 transition-colors disabled:opacity-60 disabled:cursor-not-allowed sm:py-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
                  <span id="audit-submit-label">Denetim Ekle</span>
                </button>
              </div>
            </section>
          </div>
        </div>
      </section>

      <!-- Denetim Takvimi -->
      <section id="audit-calendar" class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
        <div class="p-6 sm:p-8 border-b border-border-main">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex items-center gap-3 flex-1">
              <div class="w-10 h-10 rounded-2xl bg-sky-500/10 text-sky-400 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
              </div>
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="text-sm font-black uppercase tracking-widest text-main">Denetim Takvimi</h2>
                  <span id="cal-source-badge" class="inline-flex items-center rounded-full border border-border-main bg-surface px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-muted">Hazır</span>
                </div>
                <p class="text-xs text-muted">Planlı denetimler ve denetçi müsaitliği</p>
              </div>
            </div>
            <div class="flex items-center gap-2 self-start sm:self-auto">
              <button id="cal-prev" type="button" class="w-10 h-10 flex items-center justify-center rounded-2xl border border-border-main bg-surface hover:bg-surface-hover transition-colors text-muted hover:text-main shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
              </button>
              <span id="cal-title" class="text-sm font-black uppercase tracking-widest text-main w-[140px] text-center shrink-0"></span>
              <button id="cal-next" type="button" class="w-10 h-10 flex items-center justify-center rounded-2xl border border-border-main bg-surface hover:bg-surface-hover transition-colors text-muted hover:text-main shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px]">
          <div class="p-6 sm:p-8 lg:border-r border-b lg:border-b-0 border-border-main space-y-3">
            <div class="grid grid-cols-7 gap-1">
              {['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'].map(d => (
                <div class="text-center text-[10px] font-black uppercase tracking-widest text-muted py-1">{d}</div>
              ))}
            </div>
            <div id="cal-grid" class="grid grid-cols-7 gap-1"></div>
            <div id="cal-loader" class="flex items-center gap-2 pt-1 text-muted">
              <div class="w-3 h-3 border border-indigo-500/30 border-t-indigo-500 rounded-full animate-spin"></div>
              <span class="text-[11px]">Denetimler yükleniyor...</span>
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-2 pt-2 border-t border-border-main">
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full bg-amber-400 inline-block"></span>
                <span class="text-[11px] text-muted">Planlı Denetim</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full bg-rose-400 inline-block"></span>
                <span class="text-[11px] text-muted">Çakışma</span>
              </div>
            </div>
          </div>

          <div class="p-6 sm:p-8">
            <div id="cal-detail" class="overflow-y-auto max-h-[50vh] lg:max-h-none">
              <div class="py-10 text-center space-y-3">
                <div class="w-10 h-10 rounded-2xl bg-surface-hover flex items-center justify-center mx-auto text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
                </div>
                <p class="text-xs text-muted">Detayları görmek için bir güne tıklayın.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</DashboardLayout>

<script>
  import { toast } from '../../lib/toast';
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { toInputDateValue } from '../../features/operations/date-format';
  import { 
    uniqueColumnValues, 
    filterAuditorsByStandard, 
    buildAuditStagePayload,
    shiftIsoDate, 
    buildAuditRangeLabel, 
    buildAuditorSummary, 
    shouldHideStage2
  } from '../../features/operations/audit-form';

  let cleanupFns: Array<() => void> = [];
  function registerCleanup(fn: () => void) { cleanupFns.push(fn); }
  function runCleanups() { cleanupFns.forEach(fn => fn()); cleanupFns = []; }

  function initPage() {
    runCleanups();

    const params = new URLSearchParams(window.location.search);
    const preselectedFirmaId = params.get('firmaId') || params.get('id') || '';
    const editAuditId = params.get('edit') || '';
    const returnUrl = params.get('returnUrl') || '';

    // UI Referansları
    const pickerSection = document.getElementById('audit-picker-section');
    const formSection = document.getElementById('audit-form-section');
    const pickerSearch = document.getElementById('audit-picker-search') as HTMLInputElement | null;
    const pickerList = document.getElementById('audit-picker-list');
    const pickerContinue = document.getElementById('audit-picker-continue') as HTMLButtonElement | null;
    const pickerStatus = document.getElementById('audit-picker-status');

    const backBtn = document.getElementById('audit-back-btn') as HTMLAnchorElement | null;
    const firmaIdInput = document.getElementById('audit-firma-id') as HTMLInputElement | null;
    const companyBadge = document.getElementById('audit-company-badge');
    const companyNameEl = document.getElementById('audit-company-name');
    const companyIdPillEl = document.getElementById('audit-company-id-pill');
    const breadcrumbLabel = document.getElementById('audit-breadcrumb-label');
    const pageTitleEl = document.getElementById('audit-page-title');
    const xstandartInput = document.getElementById('xstandartInput') as HTMLSelectElement | null;
    const denetimInput = document.getElementById('denetimInput') as HTMLSelectElement | null;
    const saveBtn = document.getElementById('add-audit-button') as HTMLButtonElement | null;
    const saveLabel = document.getElementById('audit-submit-label');

    let selectedCompany: any = null;
    let auditorRows: any[][] = [];
    let reloadCalendarView: (() => Promise<void>) | null = null;
    let pendingEditAudit: any = null;

    function isEditMode() { return Boolean(editAuditId); }
    function getCompanyId(c: any) { 
        return String(c?.['Firma No'] || c?.FirmaNo || c?.firmaNo || c?.id || c?.ID || '').trim(); 
    }
    function getCompanyNick(c: any) { 
        return String(c?.['Firma Adı'] || c?.nickname || c?.Nick || c?.nick || c?.FirmaAdi || '').trim(); 
    }
    function companyLabel(c: any) {
      const id = getCompanyId(c);
      const nick = getCompanyNick(c) || 'Firma';
      return `${nick} (${id})`;
    }

    function setSelectedCompany(company: any) {
      selectedCompany = company || null;
      const id = company ? getCompanyId(company) : '';
      const nick = company ? getCompanyNick(company) : '';
      const unvan = company ? String(company?.Unvan || company?.unvan || '').trim() : '';
      const displayName = nick || unvan || (id ? `Firma #${id}` : '');

      if (firmaIdInput) firmaIdInput.value = id;
      if (companyBadge) companyBadge.textContent = company ? `${displayName} [${id}]` : 'Firma seçimi bekleniyor';
      if (companyNameEl) companyNameEl.textContent = displayName || '—';
      if (companyIdPillEl) companyIdPillEl.textContent = id || '—';

      if (company) {
        pickerSection?.classList.add('hidden');
        formSection?.classList.remove('hidden');
        if (backBtn) backBtn.href = returnUrl || `/company?id=${id}`;
      } else if (!preselectedFirmaId && !isEditMode()) {
        pickerSection?.classList.remove('hidden');
        formSection?.classList.add('hidden');
        if (backBtn) backBtn.href = '/audits';
      }
    }

    function resolveCompanyFromQuery(query: string) {
      const normalizedQuery = query.trim().toLowerCase();
      if (!normalizedQuery) return null;
      const companies = ($companies.get() as any[]) || [];
      return companies.find(c => {
        const id = getCompanyId(c).toLowerCase();
        const nick = getCompanyNick(c).toLowerCase();
        const label = companyLabel(c).toLowerCase();
        return id === normalizedQuery || nick === normalizedQuery || label === normalizedQuery;
      }) || null;
    }

    function syncCompanyList(companies: any[]) {
      if (!pickerList) return;
      const frag = document.createDocumentFragment();
      companies.forEach(c => {
        const opt = document.createElement('option');
        opt.value = companyLabel(c);
        frag.appendChild(opt);
      });
      pickerList.innerHTML = '';
      pickerList.appendChild(frag);
      if (pickerStatus && companies.length > 0) pickerStatus.textContent = 'Firma listesi güncellendi.';
    }

    function updateModeLabels() {
      const modeText = isEditMode() ? 'Denetim Düzenle' : 'Denetim Planla';
      if (breadcrumbLabel) breadcrumbLabel.textContent = modeText;
      if (pageTitleEl) pageTitleEl.textContent = modeText;
      if (saveLabel) saveLabel.textContent = isEditMode() ? 'Denetimi Güncelle' : 'Denetim Ekle';
    }

    function applyAuditToForm(audit: any) {
      if (!audit) return;
      const firmaId = String(audit.firma_no || audit.firmano || '').trim();
      if (firmaId) {
        const cMatch = ($companies.get() as any[]).find(c => getCompanyId(c) === firmaId);
        if (cMatch) setSelectedCompany(cMatch);
      }

      const fill = (id: string, v: any) => {
        const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
        if (el) el.value = String(v || '');
      };

      if (xstandartInput) { xstandartInput.value = audit.standart || ''; refreshAuditorDropdowns(); }
      if (denetimInput) { denetimInput.value = audit.denetim_tipi || audit.denetim || ''; toggleStage2(); }

      fill('a1Basla', toInputDate(audit.a1_baslangic || audit.a1Basla));
      fill('a1Bitis', toInputDate(audit.a1_bitis || audit.a1Bitis));
      fill('a1Full', audit.a1_full || audit.a1Full);
      fill('a1Manday', audit.a1_manday || audit.a1Md);
      fill('a1Md', audit.a1_manday || audit.a1Md);
      fill('leadAuditorInput1', audit.a1_bas_denetci || audit.a1La);
      fill('secondAuditorInput1', audit.a1_denetci_2 || audit.a1Fa);
      fill('thirdAuditorInput1', audit.a1_denetci_3 || audit.a1Sa);
      fill('a1Denetciler', audit.a1_auditor || audit.a1Denetci);
      fill('a1KDenetci', audit.a1_kapsam || audit.a1kDenet);

      fill('a2Basla', toInputDate(audit.a2_baslangic || audit.a2Basla));
      fill('a2Bitis', toInputDate(audit.a2_bitis || audit.a2Bitis));
      fill('a2Full', audit.a2_full || audit.a2Full);
      fill('a2Manday', audit.a2_manday || audit.a2Md);
      fill('a2Md', audit.a2_manday || audit.a2Md);
      fill('leadAuditorInput2', audit.a2_bas_denetci || audit.a2La);
      fill('secondAuditorInput2', audit.a2_denetci_2 || audit.a2Fa);
      fill('thirdAuditorInput2', audit.a2_denetci_3 || audit.a2Sa);
      fill('a2Denetciler', audit.a2_auditor || audit.a2Denetci);
      fill('a2KDenetci', audit.a2_kapsam || audit.a2kDenet);

      updateAuditors('a1'); updateAuditors('a2');
    }

    async function loadExistingAudit() {
      if (!isEditMode()) return;
      const res = await api.getAuditById(editAuditId);
      const match = res.data;
      if (!res.success || !match) return;
      
      const audit = normalizeAuditRecord(match);
      if (!audit) return;

      const firmaId = String(audit.firma_no || audit.firmano || '').trim();
      if (firmaId) {
        const cMatch = ($companies.get() as any[]).find(c => getCompanyId(c) === firmaId);
        if (cMatch) setSelectedCompany(cMatch);
        else {
          const cRes = await api.getCompanyById(firmaId);
          if (cRes.success) setSelectedCompany(cRes.data);
        }
      }

      pendingEditAudit = audit;
      if (auditorRows.length > 0) {
        applyAuditToForm(audit);
      }
    }

    function normalizeAuditRecord(r: any) {
      if (!r || typeof r !== 'object' || Array.isArray(r)) return null;
      return r;
    }

    function toInputDate(v: string) {
      return toInputDateValue(v);
    }

    function refreshAuditorDropdowns() {
      const rows = filterAuditorsByStandard(auditorRows, xstandartInput?.value || '');
      const names = Array.from(new Set(rows.map(r => `${r.ad || r[1] || ''} ${r.soyad || r[2] || ''}`.trim()).filter(Boolean)));
      ['leadAuditorInput1','secondAuditorInput1','thirdAuditorInput1','leadAuditorInput2','secondAuditorInput2','thirdAuditorInput2'].forEach(id => {
        const sel = document.getElementById(id) as HTMLSelectElement | null;
        if (!sel) return;
        sel.innerHTML = '<option value="">Seçim yapın...</option>' + names.map(n => `<option value="${n}">${n}</option>`).join('');
      });
    }

    function updateRange(stage: 'a1' | 'a2') {
      const start = (document.getElementById(`${stage}Basla`) as HTMLInputElement | null)?.value || '';
      const end = (document.getElementById(`${stage}Bitis`) as HTMLInputElement | null)?.value || '';
      const res = buildAuditRangeLabel(start, end);
      const full = document.getElementById(`${stage}Full`) as HTMLInputElement | null;
      if (full) full.value = res.fullLabel;
      
      // updateAuditors will now handle both visible and hidden manday fields
      updateAuditors(stage);
    }

    function updateAuditors(stage: 'a1' | 'a2') {
      const start = (document.getElementById(`${stage}Basla`) as HTMLInputElement | null)?.value || '';
      const end = (document.getElementById(`${stage}Bitis`) as HTMLInputElement | null)?.value || '';
      const res = buildAuditRangeLabel(start, end);
      const baseDays = Number(res.manDays) || 0;

      const l = (document.getElementById(stage === 'a1' ? 'leadAuditorInput1' : 'leadAuditorInput2') as HTMLSelectElement | null)?.value || '';
      const s = (document.getElementById(stage === 'a1' ? 'secondAuditorInput1' : 'secondAuditorInput2') as HTMLSelectElement | null)?.value || '';
      const t = (document.getElementById(stage === 'a1' ? 'thirdAuditorInput1' : 'thirdAuditorInput2') as HTMLSelectElement | null)?.value || '';
      
      const auditors = [l, s, t].filter(Boolean);
      const multiplier = auditors.length || 1;
      const totalManDays = String(baseDays * multiplier);

      const summary = buildAuditorSummary(auditorRows, [l,s,t], String(baseDays));
      const namesEl = document.getElementById(stage === 'a1' ? 'a1Denetciler' : 'a2Denetciler') as HTMLInputElement | null;
      const shortEl = document.getElementById(stage === 'a1' ? 'a1KDenetci' : 'a2KDenetci') as HTMLInputElement | null;
      const visibleMd = document.getElementById(stage === 'a1' ? 'a1Manday' : 'a2Manday') as HTMLInputElement | null;
      const mdHidden = document.getElementById(stage === 'a1' ? 'a1Md' : 'a2Md') as HTMLInputElement | null;

      if (namesEl) namesEl.value = summary.names;
      if (shortEl) shortEl.value = summary.shortNames;
      if (visibleMd) visibleMd.value = totalManDays;
      if (mdHidden) mdHidden.value = totalManDays;
    }

    function toggleStage2() {
      const hide = shouldHideStage2(denetimInput?.value || '');
      ['stage2Title','stage2AreaR1','stage2AreaR2','stage2AreaR3'].forEach(id => document.getElementById(id)?.classList.toggle('hidden', hide));
    }

    async function saveAudit() {
      if (!selectedCompany) return toast.error('Lütfen bir firma seçin.');
      if (!xstandartInput?.value) return toast.error('Lütfen standart seçin.');
      
      const auditType = denetimInput?.value || '';
      const la1 = (document.getElementById('leadAuditorInput1') as HTMLSelectElement)?.value;
      const la2 = (document.getElementById('leadAuditorInput2') as HTMLSelectElement)?.value;

      if (!la1) return toast.error('Aşama 1 Baş Denetçisi seçilmelidir.');
      
      if (!['Gözetim', 'Özel'].includes(auditType)) {
        if (!la2) return toast.error('Aşama 2 Baş Denetçisi seçilmelidir.');
      }

      if (!saveBtn) return;

      saveBtn.disabled = true;
      const orig = saveBtn.innerHTML;
      saveBtn.innerHTML = 'Kaydediliyor...';

      const val = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value || '';

      const info = {
        nick: getCompanyNick(selectedCompany),
        firmano: getCompanyId(selectedCompany),
        standart: val('xstandartInput'),
        denetim: val('denetimInput'),
        ...buildAuditStagePayload('a1', {
          start: val('a1Basla'),
          end: val('a1Bitis'),
          full: val('a1Full'),
          lead: val('leadAuditorInput1'),
          second: val('secondAuditorInput1'),
          third: val('thirdAuditorInput1'),
          manDay: val('a1Md'),
          names: val('a1Denetciler'),
          shortNames: val('a1KDenetci'),
        }),
        ...buildAuditStagePayload('a2', {
          start: val('a2Basla'),
          end: val('a2Bitis'),
          full: val('a2Full'),
          lead: val('leadAuditorInput2'),
          second: val('secondAuditorInput2'),
          third: val('thirdAuditorInput2'),
          manDay: val('a2Md'),
          names: val('a2Denetciler'),
          shortNames: val('a2KDenetci'),
        })
      };

      const res = isEditMode() ? await api.updateAudit(editAuditId, info) : await api.scheduleAudit(info);
      if (res.success) {
        toast.success(isEditMode() ? 'Başarıyla güncellendi.' : 'Başarıyla kaydedildi.');
        await SyncManager.checkAndSync();
        if (reloadCalendarView) await reloadCalendarView();
        if (preselectedFirmaId) setTimeout(() => window.location.href = returnUrl || `/company?id=${preselectedFirmaId}`, 1000);
        else if (!isEditMode()) initPage();
      } else toast.error(`Hata: ${res.error}`);

      saveBtn.disabled = false; saveBtn.innerHTML = orig;
    }

    // Event Bindings
    pickerSearch?.addEventListener('input', () => {
      const match = resolveCompanyFromQuery(pickerSearch.value);
      if (pickerStatus) {
        pickerStatus.textContent = match ? 'Firma bulundu. Devam edebilirsiniz.' : 'Listeden ya da ID ile geçerli bir firma seçin.';
        pickerStatus.className = `text-xs font-semibold ${match ? 'text-emerald-400' : 'text-muted'}`;
      }
    });

    pickerContinue?.addEventListener('click', () => {
      const match = resolveCompanyFromQuery(pickerSearch?.value || '');
      if (match) setSelectedCompany(match);
      else toast.error('Lütfen geçerli bir firma seçin.');
    });

    xstandartInput?.addEventListener('change', () => {
      refreshAuditorDropdowns();
    });
    denetimInput?.addEventListener('change', toggleStage2);
    ['a1Basla','a1Bitis','a2Basla','a2Bitis'].forEach(id => document.getElementById(id)?.addEventListener('change', () => updateRange(id.startsWith('a1') ? 'a1' : 'a2')));
    ['leadAuditorInput1','secondAuditorInput1','thirdAuditorInput1','leadAuditorInput2','secondAuditorInput2','thirdAuditorInput2'].forEach(id => {
        document.getElementById(id)?.addEventListener('change', () => updateAuditors(id.endsWith('1') ? 'a1' : 'a2'));
    });
    ['a1Manday','a2Manday'].forEach(id => document.getElementById(id)?.addEventListener('input', () => updateAuditors(id.startsWith('a1') ? 'a1' : 'a2')));
    
    document.getElementById('a1Equal')?.addEventListener('click', () => { (document.getElementById('a1Bitis') as any).value = (document.getElementById('a1Basla') as any).value; updateRange('a1'); });
    document.getElementById('a1Plus1')?.addEventListener('click', () => { (document.getElementById('a1Bitis') as any).value = shiftIsoDate((document.getElementById('a1Basla') as any).value, 1); updateRange('a1'); });
    document.getElementById('a1Plus2')?.addEventListener('click', () => { (document.getElementById('a1Bitis') as any).value = shiftIsoDate((document.getElementById('a1Basla') as any).value, 2); updateRange('a1'); });
    document.getElementById('a2Equal')?.addEventListener('click', () => { (document.getElementById('a2Bitis') as any).value = (document.getElementById('a2Basla') as any).value; updateRange('a2'); });
    document.getElementById('a2Plus1')?.addEventListener('click', () => { (document.getElementById('a2Bitis') as any).value = shiftIsoDate((document.getElementById('a2Basla') as any).value, 1); updateRange('a2'); });
    document.getElementById('a2Plus2')?.addEventListener('click', () => { (document.getElementById('a2Bitis') as any).value = shiftIsoDate((document.getElementById('a2Basla') as any).value, 2); updateRange('a2'); });
    document.getElementById('clear-audit-button')?.addEventListener('click', () => initPage());
    document.getElementById('add-audit-button')?.addEventListener('click', saveAudit);

    // Boot
    updateModeLabels();
    
    async function setupStore() {
        await SyncManager.init();
        let companies = ($companies.get() as any[]) || [];
        if (companies.length === 0) {
            const res = await api.getCompanies();
            if (res.success && Array.isArray(res.data)) {
                $companies.set(res.data);
                companies = res.data;
            }
        }
        syncCompanyList(companies);
        const sub = $companies.subscribe(c => syncCompanyList(c as any[]));
        registerCleanup(() => sub());

        // Edit mode takes precedence over firma preselection because the audit record
        // is the source of truth for all upper-form fields.
        if (isEditMode()) {
          await loadExistingAudit();
        } else if (preselectedFirmaId) {
          const match = companies.find(c => getCompanyId(c) === preselectedFirmaId);
          if (match) setSelectedCompany(match);
          else api.getCompanyById(preselectedFirmaId).then(r => r.success && setSelectedCompany(r.data));
        } else {
          setSelectedCompany(null);
        }
    }
    
    void setupStore();

    api.getAuditors().then(res => {
      auditorRows = Array.isArray(res.data) ? res.data : [];
      if (xstandartInput) {
        const stds = ['9001', '13485', '14001', '22000', '27001', '45001', '50001', 'GMP'];
        xstandartInput.innerHTML = '<option value="">Standart seçin...</option>' + stds.map(s => `<option value="${s}">${s}</option>`).join('');
      }
      refreshAuditorDropdowns();
      if (pendingEditAudit) {
        applyAuditToForm(pendingEditAudit);
      }
    });

    // --- CALENDAR LOGIC ---
    (async function initCalendar() {
      const grid = document.getElementById('cal-grid');
      const title = document.getElementById('cal-title');
      const detail = document.getElementById('cal-detail');
      const loader = document.getElementById('cal-loader') as HTMLElement | null;
      const prevBtn = document.getElementById('cal-prev') as HTMLButtonElement | null;
      const nextBtn = document.getElementById('cal-next') as HTMLButtonElement | null;
      const sourceBadge = document.getElementById('cal-source-badge') as HTMLElement | null;
      const MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
      
      let year = new Date().getFullYear();
      let month = new Date().getMonth();
      let audits: any[] = [];
      let byDate = new Map<string, any[]>();
      let selDate: string | null = null;
      const monthCache = new Map<string, any[]>();

      function toIso(d: Date) { return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
      function parse(s: string) {
        if (!s) return null;
        const iso = toInputDateValue(s);
        return iso ? new Date(iso) : new Date(s);
      }

      function getMonthBounds(targetYear: number, targetMonth: number) {
        return {
          start: new Date(targetYear, targetMonth, 1),
          end: new Date(targetYear, targetMonth + 1, 0),
        };
      }

      function buildMap() {
        byDate.clear();
        const { start: monthStart, end: monthEnd } = getMonthBounds(year, month);
        audits.forEach(a => {
          [1,2].forEach(stg => {
            const startStr = stg === 1 ? (a.a1Baslav2 || a.a1_baslangic || a.a1Basla || a[9]) : (a.a2Baslav2 || a.a2_baslangic || a.a2Basla || a[15]);
            const endStr = stg === 1 ? (a.a1Bitisv2 || a.a1_bitis || a.a1Bitis || a[10]) : (a.a2Bitisv2 || a.a2_bitis || a.a2Bitis || a[16]);
            const s = parse(startStr); const e = parse(endStr) || s;
            if (!s) return;
            const rangeStart = s > monthStart ? s : monthStart;
            const rangeEnd = e < monthEnd ? e : monthEnd;
            if (rangeStart > rangeEnd) return;
            let cur = new Date(rangeStart);
            while(cur <= rangeEnd) {
              const k = toIso(cur);
              if (!byDate.has(k)) byDate.set(k, []);
              byDate.get(k)!.push({ audit: a, stage: stg });
              cur.setDate(cur.getDate()+1);
            }
          });
        });
      }

      function render() {
        if (!grid || !title) return;
        title.textContent = `${MONTHS[month]} ${year}`;
        const first = new Date(year, month, 1);
        const offset = (first.getDay() + 6) % 7;
        const days = new Date(year, month + 1, 0).getDate();
        const today = toIso(new Date());

        let html = '';
        for (let i = 0; i < offset; i++) html += '<div class="h-12"></div>';
        for (let d = 1; d <= days; d++) {
          const iso = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
          const ent = byDate.get(iso) || [];
          const active = iso === selDate;
          const isToday = iso === today;
          
          html += `
            <div data-date="${iso}" class="h-12 flex flex-col items-center justify-center rounded-xl cursor-pointer hover:bg-surface-hover ${active ? 'bg-indigo-600 text-white' : isToday ? 'border border-indigo-500' : ''}">
              <span class="text-xs font-bold">${d}</span>
              <div class="flex gap-0.5 mt-0.5">${ent.slice(0,3).map(() => '<span class="w-1 h-1 rounded-full bg-amber-400"></span>').join('')}</div>
            </div>`;
        }
        grid.innerHTML = html;
      }

      grid?.addEventListener('click', (e) => {
        const cell = (e.target as HTMLElement).closest('[data-date]') as HTMLElement | null;
        if (!cell) return;
        const dStr = cell.dataset.date;
        if (!dStr) return;

        selDate = dStr;
        render(); // refresh highlight
        const ent = byDate.get(dStr) || [];
        if (!detail) return;
        if (ent.length === 0) {
          detail.innerHTML = '<div class="py-10 text-center text-xs text-muted">Bu tarihte denetim yok.</div>';
          return;
        }
        detail.innerHTML = `
          <div class="space-y-3">
            <p class="text-[10px] font-black uppercase text-muted">${dStr}</p>
            ${ent.map(e => {
              const a = e.audit;
              const firma = a.nickname || a.unvan || a.nick || a.firma_no || '—';
              const std = a.standart || '—';
              const auditors = e.stage === 1
                ? [a.a1_bas_denetci, a.a1_denetci_2, a.a1_denetci_3]
                : [a.a2_bas_denetci, a.a2_denetci_2, a.a2_denetci_3];
              const auditorStr = auditors.filter(Boolean).join(', ') || '—';
              return `
                <div class="p-3 rounded-xl border border-border-main bg-surface-hover space-y-1">
                  <p class="text-xs font-bold text-main">${firma}</p>
                  <p class="text-[10px] text-muted">${std} · Aşama ${e.stage}</p>
                  <p class="text-[10px] text-indigo-400">${auditorStr}</p>
                </div>`;
            }).join('')}
          </div>`;
      });

      function setCalendarBusy(isBusy: boolean) {
        if (loader) loader.style.display = isBusy ? 'flex' : 'none';
        prevBtn && (prevBtn.disabled = isBusy);
        nextBtn && (nextBtn.disabled = isBusy);
      }

      function setCalendarSourceState(state: 'idle' | 'network' | 'cache' | 'error') {
        if (!sourceBadge) return;
        sourceBadge.className = 'inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.2em]';
        if (state === 'network') {
          sourceBadge.classList.add('border-sky-500/20', 'bg-sky-500/10', 'text-sky-300');
          sourceBadge.textContent = 'Ağ';
          return;
        }
        if (state === 'cache') {
          sourceBadge.classList.add('border-emerald-500/20', 'bg-emerald-500/10', 'text-emerald-300');
          sourceBadge.textContent = 'Önbellek';
          return;
        }
        if (state === 'error') {
          sourceBadge.classList.add('border-rose-500/20', 'bg-rose-500/10', 'text-rose-300');
          sourceBadge.textContent = 'Hata';
          return;
        }
        sourceBadge.classList.add('border-border-main', 'bg-surface', 'text-muted');
        sourceBadge.textContent = 'Hazır';
      }

      function activeMonthKey() {
        return `${year}-${String(month + 1).padStart(2, '0')}`;
      }

      async function refresh(invalidate = false) {
        const key = activeMonthKey();
        if (invalidate) monthCache.delete(key);
        const cached = monthCache.get(key);
        if (cached) {
          audits = cached;
          buildMap();
          render();
          setCalendarSourceState('cache');
          return;
        }
        setCalendarSourceState('network');
        setCalendarBusy(true);
        const r = await api.getAuditCalendar(year, month + 1);
        setCalendarBusy(false);
        if (r.success) {
          audits = Array.isArray(r.data) ? r.data : [];
          monthCache.set(key, audits);
          buildMap();
          render();
          setCalendarSourceState('network');
          if (selDate) {
            const selectedEntries = byDate.get(selDate) || [];
            if (selectedEntries.length === 0 && detail) {
              detail.innerHTML = '<div class="py-10 text-center text-xs text-muted">Bu tarihte denetim yok.</div>';
            }
          }
          return;
        }
        audits = [];
        byDate.clear();
        render();
        setCalendarSourceState('error');
        if (detail) detail.innerHTML = '<div class="py-10 text-center text-xs text-rose-400">Takvim verisi yüklenemedi.</div>';
      }

      reloadCalendarView = () => refresh(true);
      prevBtn?.addEventListener('click', () => {
        month--;
        if (month < 0) { month = 11; year--; }
        void refresh();
      });
      nextBtn?.addEventListener('click', () => {
        month++;
        if (month > 11) { month = 0; year++; }
        void refresh();
      });

      void refresh();
    })();
  }

  document.addEventListener('astro:page-load', initPage);
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>

