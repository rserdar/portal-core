---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Denetim Planla">
  <div class="max-w-6xl mx-auto pb-24 space-y-6">
    <div id="toast-container" class="fixed inset-x-4 bottom-4 sm:inset-x-auto sm:right-6 sm:bottom-6 z-[100] flex flex-col gap-3 pointer-events-none sm:max-w-sm"></div>
    <div class="flex items-center gap-3">
      <a href="/audits" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"></path></svg>
        Denetim Merkezi
      </a>
      <span class="text-border-main">/</span>
      <span id="audit-breadcrumb-label" class="text-xs font-bold text-muted">Denetim Planla</span>
    </div>

    <section class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <div class="p-6 sm:p-8 border-b border-border-main space-y-2">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted" id="audit-company-badge">Firma Seçimi Bekleniyor</span>
        </div>
        <h1 id="audit-page-title" class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main">Denetim Planla</h1>
      </div>

      <div class="p-6 sm:p-8 space-y-6">
          <section class="rounded-[1.75rem] border border-border-main bg-surface-hover p-5 sm:p-6 space-y-5">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-2xl bg-indigo-500/10 text-indigo-400 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path><path d="M9 9v.01"></path><path d="M9 12v.01"></path><path d="M9 15v.01"></path><path d="M9 18v.01"></path></svg>
              </div>
              <div>
                <h2 class="text-sm font-black uppercase tracking-widest text-main">Temel Bilgiler</h2>
                <p class="text-xs text-muted">Firma, standart ve denetim tipi</p>
              </div>
            </div>

            <div id="audit-company-summary" class="hidden rounded-[1.5rem] border border-indigo-500/20 bg-indigo-500/5 p-4 sm:p-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="space-y-1.5">
                  <p class="text-[10px] font-black uppercase tracking-[0.24em] text-indigo-300">Secili Firma</p>
                  <h3 id="audit-company-name" class="text-base sm:text-lg font-black text-main">—</h3>
                </div>
                <div class="rounded-2xl border border-indigo-500/20 bg-surface px-3 py-2 text-right">
                  <p class="text-[10px] font-black uppercase tracking-[0.24em] text-muted">Firma ID</p>
                  <p id="audit-company-id-pill" class="text-sm font-black text-indigo-300">—</p>
                </div>
              </div>
            </div>

            <div id="audit-company-picker" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="space-y-2 block">
                <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Secimi</span>
                <input id="company-search" list="company-list" type="text" autocomplete="off" placeholder="Firma arayin..." class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
                <datalist id="company-list"></datalist>
              </label>

              <label class="space-y-2 block">
                <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma ID</span>
                <input id="audit-firma-id" type="text" readonly placeholder="Firma secildiginde dolar" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
              </label>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="space-y-2 block">
                <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Standart Secimi</span>
                <select id="xstandartInput" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main">
                  <option>Yukleniyor...</option>
                </select>
              </label>

              <label class="space-y-2 block">
                <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Denetim Tipi</span>
                <select id="denetimInput" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main">
                  <option value="İlk" selected>İlk</option>
                  <option value="Gözetim 1">Gözetim 1</option>
                  <option value="Gözetim 2">Gözetim 2</option>
                  <option value="Yeniden">Yeniden</option>
                  <option value="Özel">Özel</option>
                  <option value="Tekrar">Tekrar</option>
                </select>
              </label>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {[
                { id: '9C', label: '9001' },
                { id: '13C', label: '13485' },
                { id: '14C', label: '14001' },
                { id: '22C', label: '22000' },
                { id: '27C', label: '27001' },
                { id: '45C', label: '45001' },
                { id: '50C', label: '50001' },
                { id: 'GMPC', label: 'GMP' },
              ].map((item) => (
                <label class="flex items-center gap-2 rounded-2xl border border-border-main bg-surface px-3 py-3 text-sm font-semibold text-main">
                  <input id={item.id} type="checkbox" class="h-4 w-4 rounded border-border-main bg-surface text-indigo-500" />
                  <span>{item.label}</span>
                </label>
              ))}
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-border-main bg-surface-hover p-5 sm:p-6 space-y-6">
            <div class="space-y-5">
              <div class="space-y-4">
                <h2 class="text-base font-black text-main">Asama 1</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[1.45fr_1fr_1fr_0.8fr] gap-4">
                  <div class="space-y-2">
                    <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Baslangic Tarihi</span>
                    <div class="flex gap-2">
                      <input id="a1Basla" type="date" class="flex-1 rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
                      <button id="a1Equal" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">=</button>
                      <button id="a1Plus1" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+1</button>
                      <button id="a1Plus2" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+2</button>
                    </div>
                  </div>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bitis Tarihi</span><input id="a1Bitis" type="date" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Tam Tarih</span><input id="a1Full" type="text" autocomplete="off" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Adam / Gun</span><input id="a1Manday" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                </div>
                <input id="a1Md" type="hidden" />
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bas Denetci</span><select id="leadAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">2. Denetci</span><select id="secondAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">3. Denetci</span><select id="thirdAuditorInput1" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Isimler</span><input id="a1Denetciler" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Kisaltmalar</span><input id="a1KDenetci" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                </div>
              </div>

              <div class="border-t border-dashed border-border-main"></div>

              <div class="space-y-4">
                <h2 id="stage2Title" class="text-base font-black text-main">Asama 2</h2>
                <div id="stage2AreaR1" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[1.45fr_1fr_1fr_0.8fr] gap-4">
                  <div class="space-y-2">
                    <span class="text-[11px] font-bold uppercase tracking-widest text-muted">Baslangic Tarihi</span>
                    <div class="flex gap-2">
                      <input id="a2Basla" type="date" class="flex-1 rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" />
                      <button id="a2Equal" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">=</button>
                      <button id="a2Plus1" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+1</button>
                      <button id="a2Plus2" type="button" class="shrink-0 rounded-2xl border border-emerald-500/20 bg-emerald-500/10 px-3 py-3 text-xs font-black text-emerald-300">+2</button>
                    </div>
                  </div>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bitis Tarihi</span><input id="a2Bitis" type="date" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Tam Tarih</span><input id="a2Full" type="text" autocomplete="off" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Adam / Gun</span><input id="a2Manday" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                </div>
                <input id="a2Md" type="hidden" />
                <div id="stage2AreaR2" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Bas Denetci</span><select id="leadAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">2. Denetci</span><select id="secondAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">3. Denetci</span><select id="thirdAuditorInput2" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main"><option value="">Secim Yapiniz...</option></select></label>
                </div>
                <div id="stage2AreaR3" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Isimler</span><input id="a2Denetciler" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                  <label class="space-y-2 block"><span class="text-[11px] font-bold uppercase tracking-widest text-muted">Kisaltmalar</span><input id="a2KDenetci" type="text" class="w-full rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-semibold text-main" /></label>
                </div>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end pt-2">
              <button id="clear-audit-button" type="button" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3.5 text-sm font-bold text-main hover:bg-surface-hover transition-colors sm:py-3">Formu Temizle</button>
              <a id="audit-back-btn" href="/certificates" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-border-main bg-surface px-4 py-3.5 text-sm font-bold text-main hover:bg-surface-hover transition-colors sm:py-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
                Geri
              </a>
              <button id="add-audit-button" type="button" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-5 py-3.5 text-sm font-black text-white hover:bg-indigo-500 transition-colors disabled:opacity-60 disabled:cursor-not-allowed sm:py-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
                <span id="audit-submit-label">Denetim Ekle</span>
              </button>
            </div>
          </section>
        </div>
    </section>

    <!-- Denetim Takvimi -->
    <section id="audit-calendar" class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <!-- Baslik + Navigasyon -->
      <div class="p-6 sm:p-8 border-b border-border-main">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex items-center gap-3 flex-1">
            <div class="w-10 h-10 rounded-2xl bg-sky-500/10 text-sky-400 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
            </div>
            <div>
              <h2 class="text-sm font-black uppercase tracking-widest text-main">Denetim Takvimi</h2>
              <p class="text-xs text-muted">Planlı denetimler ve denetçi müsaitliği</p>
            </div>
          </div>
          <div class="flex items-center gap-2 self-start sm:self-auto">
            <button id="cal-prev" type="button" class="w-10 h-10 flex items-center justify-center rounded-2xl border border-border-main bg-surface hover:bg-surface-hover transition-colors text-muted hover:text-main shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
            </button>
            <span id="cal-title" class="text-sm font-black uppercase tracking-widest text-main w-[140px] text-center shrink-0"></span>
            <button id="cal-next" type="button" class="w-10 h-10 flex items-center justify-center rounded-2xl border border-border-main bg-surface hover:bg-surface-hover transition-colors text-muted hover:text-main shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px]">
        <!-- Takvim Grid -->
        <div class="p-6 sm:p-8 lg:border-r border-b lg:border-b-0 border-border-main space-y-3">
          <div class="grid grid-cols-7 gap-1">
            {['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'].map(d => (
              <div class="text-center text-[10px] font-black uppercase tracking-widest text-muted py-1">{d}</div>
            ))}
          </div>
          <div id="cal-grid" class="grid grid-cols-7 gap-1"></div>
          <div id="cal-loader" class="flex items-center gap-2 pt-1">
            <div class="w-3 h-3 border border-indigo-500/30 border-t-indigo-500 rounded-full animate-spin shrink-0"></div>
            <span class="text-[11px] text-muted">Denetimler yükleniyor...</span>
          </div>
          <div class="flex flex-wrap gap-x-4 gap-y-2 pt-2 border-t border-border-main">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-amber-400 inline-block"></span>
              <span class="text-[11px] text-muted">Planlı Denetim</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-rose-400 inline-block"></span>
              <span class="text-[11px] text-muted">Denetçi Çakışması</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="w-4 h-4 rounded-lg bg-indigo-600 inline-block"></span>
              <span class="text-[11px] text-muted">Bugün</span>
            </div>
          </div>
        </div>

        <!-- Detay Paneli -->
        <div class="p-6 sm:p-8">
          <div id="cal-detail" class="overflow-y-auto max-h-[50vh] lg:max-h-none">
            <div class="py-10 text-center space-y-3">
              <div class="w-10 h-10 rounded-2xl bg-surface-hover flex items-center justify-center mx-auto text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
              </div>
              <p class="text-xs text-muted">Detay için bir güne tıklayın</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</DashboardLayout>

<script lang="ts">
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { setFlashToast, showToast } from '../../lib/toast';
  import {
    uniqueColumnValues,
    filterAuditorsByStandard,
    formatDateToDots,
    shiftIsoDate,
    buildAuditRangeLabel,
    buildAuditorSummary,
    shouldHideStage2,
    checkboxIdForStandard,
  } from '../../features/operations/audit-form';

  const params = new URLSearchParams(window.location.search);
  const preselectedFirmaId = params.get('firmaId') || params.get('id') || '';
  const editAuditId = params.get('edit') || '';
  const returnUrl = params.get('returnUrl') || '';

  const backBtn = document.getElementById('audit-back-btn') as HTMLAnchorElement | null;
  if (backBtn) {
    backBtn.href = returnUrl
      ? returnUrl
      : preselectedFirmaId
        ? `/company?id=${encodeURIComponent(preselectedFirmaId)}`
        : '/certificates';
  }

  const companySearch = document.getElementById('company-search') as HTMLInputElement | null;
  const companyList = document.getElementById('company-list');
  const firmaIdInput = document.getElementById('audit-firma-id') as HTMLInputElement | null;
  const companyBadge = document.getElementById('audit-company-badge');
  const companyPicker = document.getElementById('audit-company-picker');
  const companySummary = document.getElementById('audit-company-summary');
  const companyNameEl = document.getElementById('audit-company-name');
  const companyIdPillEl = document.getElementById('audit-company-id-pill');
  const breadcrumbLabel = document.getElementById('audit-breadcrumb-label');
  const pageTitleEl = document.getElementById('audit-page-title');
  const xstandartInput = document.getElementById('xstandartInput') as HTMLSelectElement | null;
  const denetimInput = document.getElementById('denetimInput') as HTMLSelectElement | null;
  const saveBtn = document.getElementById('add-audit-button') as HTMLButtonElement | null;
  const saveLabel = document.getElementById('audit-submit-label');

  let selectedCompany: any = null;
  let auditorRows: any[][] = [];
  let editingAudit: Record<string, any> | null = null;
  let reloadCalendarView: (() => Promise<void>) | null = null;

  function isEditMode() {
    return Boolean(editAuditId);
  }

  function getCompanyValue(company: any, ...keys: string[]) {
    if (!company || typeof company !== 'object') return '';
    for (const key of keys) {
      const value = company[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    return '';
  }

  function getCompanyId(company: any) {
    return getCompanyValue(company, 'Firma No', 'FirmaNo', 'firmaNo', 'id', 'ID');
  }

  function getCompanyNick(company: any) {
    return getCompanyValue(company, 'Firma Adı', 'nickname', 'Nick', 'nick', 'FirmaAdi');
  }

  function getCompanyDisplayName(company: any) {
    return getCompanyNick(company) || getCompanyValue(company, 'Unvan', 'unvan');
  }

  function normalizeAuditLookupKey(value: any): string {
    return String(value || '')
      .trim()
      .toLocaleLowerCase('tr-TR')
      .replace(/[ıİ]/g, 'i')
      .replace(/[ğĞ]/g, 'g')
      .replace(/[üÜ]/g, 'u')
      .replace(/[şŞ]/g, 's')
      .replace(/[öÖ]/g, 'o')
      .replace(/[çÇ]/g, 'c')
      .replace(/[^a-z0-9]/g, '');
  }

  function getAuditValue(record: any, aliases: string[], fallback = ''): string {
    if (Array.isArray(record)) {
      return fallback;
    }
    const source = record && typeof record === 'object' ? record : {};
    for (const alias of aliases) {
      const value = source[alias];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    const normalizedAliases = aliases.map((alias) => normalizeAuditLookupKey(alias));
    for (const [rawKey, rawValue] of Object.entries(source)) {
      if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') continue;
      if (normalizedAliases.includes(normalizeAuditLookupKey(rawKey))) {
        return String(rawValue).trim();
      }
    }
    return fallback;
  }

  function getAuditRecordId(record: any): string {
    if (Array.isArray(record)) return String(record[0] ?? '').trim();
    return getAuditValue(record, ['id', 'ID']);
  }

  function normalizeAuditRecord(record: any): Record<string, any> | null {
    if (!record) return null;
    if (Array.isArray(record)) {
      return {
        id: String(record[0] ?? '').trim(),
        nick: String(record[1] ?? '').trim(),
        firmano: String(record[2] ?? '').trim(),
        standart: String(record[3] ?? '').trim(),
        denetim: String(record[4] ?? '').trim(),
        a1Full: String(record[5] ?? '').trim(),
        a1Denetci: String(record[6] ?? '').trim(),
        a2Full: String(record[7] ?? '').trim(),
        a2Denetci: String(record[8] ?? '').trim(),
        a1Basla: String(record[9] ?? '').trim(),
        a1Bitis: String(record[10] ?? '').trim(),
        a1Md: String(record[11] ?? '').trim(),
        a1La: String(record[12] ?? '').trim(),
        a1Fa: String(record[13] ?? '').trim(),
        a1Sa: String(record[14] ?? '').trim(),
        a2Basla: String(record[15] ?? '').trim(),
        a2Bitis: String(record[16] ?? '').trim(),
        a2Md: String(record[17] ?? '').trim(),
        a2La: String(record[18] ?? '').trim(),
        a2Fa: String(record[19] ?? '').trim(),
        a2Sa: String(record[20] ?? '').trim(),
        qms: String(record[21] ?? '').trim(),
        mdd: String(record[22] ?? '').trim(),
        ems: String(record[23] ?? '').trim(),
        ohs: String(record[24] ?? '').trim(),
        fsms: String(record[25] ?? '').trim(),
        isms: String(record[26] ?? '').trim(),
        engy: String(record[27] ?? '').trim(),
        gmp: String(record[28] ?? '').trim(),
        a1kDenet: String(record[29] ?? '').trim(),
        a2kDenet: String(record[30] ?? '').trim(),
        a1EventId: String(record[31] ?? '').trim(),
        a2EventId: String(record[32] ?? '').trim(),
      };
    }

    return {
      id: getAuditValue(record, ['id', 'ID']),
      nick: getAuditValue(record, ['nick', 'nickname']),
      firmano: getAuditValue(record, ['firmano', 'firmaNo']),
      standart: getAuditValue(record, ['standart', 'standard', 'Standart']),
      denetim: getAuditValue(record, ['denetim', 'denetimTipi', 'Denetim Tipi']),
      a1Full: getAuditValue(record, ['a1Full', 'A1 Full']),
      a1Denetci: getAuditValue(record, ['a1Auditor', 'a1Denetci', 'A1 Auditors']),
      a2Full: getAuditValue(record, ['a2Full', 'A2 Full']),
      a2Denetci: getAuditValue(record, ['a2Auditor', 'a2Denetci', 'A2 Auditors']),
      a1Basla: getAuditValue(record, ['a1Basla', 'a1Baslav2']),
      a1Bitis: getAuditValue(record, ['a1Bitis', 'a1Bitisv2']),
      a1Md: getAuditValue(record, ['a1Md']),
      a1La: getAuditValue(record, ['a1La', 'a1Lead']),
      a1Fa: getAuditValue(record, ['a1Fa']),
      a1Sa: getAuditValue(record, ['a1Sa']),
      a2Basla: getAuditValue(record, ['a2Basla', 'a2Baslav2']),
      a2Bitis: getAuditValue(record, ['a2Bitis', 'a2Bitisv2']),
      a2Md: getAuditValue(record, ['a2Md']),
      a2La: getAuditValue(record, ['a2La', 'a2Lead']),
      a2Fa: getAuditValue(record, ['a2Fa']),
      a2Sa: getAuditValue(record, ['a2Sa']),
      qms: getAuditValue(record, ['qms']),
      mdd: getAuditValue(record, ['mdd']),
      ems: getAuditValue(record, ['ems']),
      ohs: getAuditValue(record, ['ohs']),
      fsms: getAuditValue(record, ['fsms']),
      isms: getAuditValue(record, ['isms']),
      engy: getAuditValue(record, ['engy']),
      gmp: getAuditValue(record, ['gmp']),
      a1kDenet: getAuditValue(record, ['a1kDenet']),
      a2kDenet: getAuditValue(record, ['a2kDenet']),
