---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import DataTable from "../../components/DataTable.astro";
import FilterBar from "../../components/FilterBar.astro";
---

<DashboardLayout title="Denetim Takvimi">
  <div class="space-y-4 sm:space-y-6">
    <FilterBar placeholder="Firma veya denetçi ara...">
      <select
        slot="filters"
        id="audit-type-filter"
        class="hidden md:block bg-surface-hover border border-border-main rounded-xl px-3 py-2.5 text-xs font-bold text-muted outline-none focus:ring-2 focus:ring-primary/50 transition-all cursor-pointer uppercase"
      >
        <option value="">TÜM DENETİM TİPLERİ</option>
        <option value="Gözetim">GÖZETİM</option>
        <option value="Yenileme">YENİLEME</option>
        <option value="İlk Belgelendirme">İLK BELGELENDİRME</option>
      </select>

      <a slot="actions" href="/audits/add" title="Yeni Denetim Ekle" class="btn-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </a>
    </FilterBar>

    <DataTable emptyMessage="Planlanmış denetim bulunamadı" loadingMessage="Takvim Alınıyor">
      <Fragment slot="header">
        <th class="w-10 px-3 py-3.5 text-center">
          <input type="checkbox" id="select-all-audits" class="w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary">
        </th>
        <th class="w-64 px-5 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Firma Adı</th>
        <th class="w-32 pl-6 pr-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Standart</th>
        <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Denetçi(ler)</th>
        <th class="w-32 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Aşama 1 Tarihi</th>
        <th class="w-32 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Aşama 2 Tarihi</th>
        <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Denetim Tipi</th>
        <th class="w-16 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Detay</th>
      </Fragment>
    </DataTable>
  </div>
</DashboardLayout>

<script>
  import { api } from "../../lib/api";
  import { pickValue, getInitials, escHtml, escAttr, parseDateValue } from "../../lib/utils";
  import { $companies } from "../../lib/store";
  import { useCleanup, initPageCleanup } from "../../lib/composables/useCleanup";
  import { useTableFilter } from "../../lib/composables/useTableFilter";

  const { registerCleanup, runCleanups } = useCleanup();

  function init() {
    runCleanups();

    const tableBody = document.getElementById("table-body");
    const tableLoader = document.getElementById("table-loader");
    const emptyState = document.getElementById("empty-state");
    const searchInput = document.getElementById("global-search") as HTMLInputElement | null;
    const filterType = document.getElementById("audit-type-filter") as HTMLSelectElement | null;
    const pageSizeSelect = document.getElementById("page-size-select") as HTMLSelectElement | null;
    const prevPageBtn = document.getElementById("prev-page-btn") as HTMLButtonElement | null;
    const nextPageBtn = document.getElementById("next-page-btn") as HTMLButtonElement | null;
    const selectAllAudits = document.getElementById("select-all-audits") as HTMLInputElement | null;

    if (!tableBody || !searchInput || !filterType || !pageSizeSelect || !prevPageBtn || !nextPageBtn || !selectAllAudits) {
      return;
    }

    const setTableState = (state: "loading" | "empty" | "ready") => {
      if (state === "loading") {
        tableLoader.classList.remove("hidden");
        emptyState?.classList.add("hidden");
        return;
      }

      tableLoader.classList.add("hidden");
      emptyState?.classList.toggle("hidden", state !== "empty");
    };

    const findCompanyByFirmaNo = (firmaNo: string) =>
      ($companies.get() as any[]).find((company) => {
        const companyId = pickValue(company, ["id", "ID", "firma_no", "firmaNo", "firmano"], "");
        return String(companyId) === String(firmaNo);
      });

    const getCompanyDisplayName = (firmaNo: string) => {
      const company = findCompanyByFirmaNo(firmaNo);
      if (!company) return firmaNo;
      return pickValue(company, ["nickname", "nick", "firma_adi", "Firma Adı", "FirmaAdi", "unvan"], firmaNo);
    };

    const getAuditStagePeople = (audit: any, stage: 1 | 2) => {
      const keys =
        stage === 1
          ? ["a1_bas_denetci", "a1Lead", "a1_lead", "a1_denetci_2", "a1Auditor", "a1_auditor", "a1_denetci_3"]
          : ["a2_bas_denetci", "a2Lead", "a2_lead", "a2_denetci_2", "a2Auditor", "a2_auditor", "a2_denetci_3"];

      return keys
        .map((key) => String(pickValue(audit, [key], "") || "").trim())
        .filter((value, index, list) => value && value !== "Atanmadı" && list.indexOf(value) === index);
    };

    const getAuditPeopleText = (audit: any) => {
      const people = [...getAuditStagePeople(audit, 1), ...getAuditStagePeople(audit, 2)].filter(
        (value, index, list) => list.indexOf(value) === index,
      );
      return people.join(", ") || "-";
    };

    const renderRows = (items: any[]) => {
      selectAllAudits.checked = false;
      tableBody.innerHTML = items
        .map((audit, index) => {
          const firmaNo = pickValue(audit, ["firma_no", "firmaNo"], "-");
          const nick = getCompanyDisplayName(firmaNo);
          const standart = pickValue(audit, ["standart", "standard"], "-");
          const denetimTipi = pickValue(audit, ["denetim_tipi", "denetimTipi"], "-");
          const a1Tarih = pickValue(audit, ["a1_baslangic", "a1Basla"], "-");
          const a2Tarih = pickValue(audit, ["a2_baslangic", "a2Basla"], "-");
          const a1People = getAuditStagePeople(audit, 1);
          const a2People = getAuditStagePeople(audit, 2);
          const denetci1 = a1People.join(", ") || "-";
          const denetci2 = a2People.join(", ") || "-";
          const a1Lead = pickValue(audit, ["a1_bas_denetci", "a1Lead", "a1_lead"], "");
          const a2Lead = pickValue(audit, ["a2_bas_denetci", "a2Lead", "a2_lead"], "");
          const denetciler = getAuditPeopleText(audit);
          const initials = getInitials(nick);
          const auditId = pickValue(audit, ["id", "ID"], String(index + 1));
          const detailRowId = `audit-detail-${escAttr(auditId)}`;

          return `
            <tr class="hover:bg-surface-hover transition-colors group/row text-[11px]">
              <td class="px-3 py-4 text-center align-middle">
                <input type="checkbox" class="audit-checkbox w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary" data-id="${escAttr(auditId)}">
              </td>
              <td class="px-6 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
                    <span class="text-[10px] font-black text-primary uppercase">${escHtml(initials)}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="font-bold text-main truncate uppercase tracking-tight leading-tight">${escHtml(nick)}</div>
                    <div class="text-[9px] text-muted font-bold mt-0.5 leading-tight truncate uppercase tracking-tight italic">ID: ${escHtml(firmaNo)}</div>
                  </div>
                </div>
              </td>
              <td class="pl-6 pr-4 py-4 text-left font-bold text-primary/70">${escHtml(standart.length > 25 ? `${standart.slice(0, 25)}...` : standart)}</td>
              <td class="px-4 py-4 text-center text-muted font-medium">${escHtml(denetciler.length > 25 ? `${denetciler.slice(0, 25)}...` : denetciler)}</td>
              <td class="px-4 py-4 text-center text-muted italic">${escHtml(a1Tarih)}</td>
              <td class="px-4 py-4 text-center font-bold text-main italic underline underline-offset-2 decoration-primary/30">${escHtml(a2Tarih)}</td>
              <td class="px-4 py-4 text-center font-black uppercase tracking-widest text-muted">${escHtml(denetimTipi)}</td>
              <td class="px-3 py-4 text-center">
                <div class="flex items-center justify-center gap-1.5">
                  <a
                    href="/audits/add?firmaId=${encodeURIComponent(firmaNo)}&edit=${encodeURIComponent(auditId)}"
                    class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-emerald-400 hover:bg-emerald-500/10 transition-all duration-300"
                    title="Düzenle"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
                  </a>
                  <button
                    type="button"
                    class="audit-detail-toggle w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-surface-hover transition-all duration-300"
                    data-target="${detailRowId}"
                    title="Detaylar"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
              </td>
            </tr>
            <tr id="${detailRowId}" class="hidden border-b border-border-main bg-surface-hover">
              <td colspan="8" class="px-3 sm:px-6 pb-4 pt-1 align-middle">
                <div class="rounded-xl border border-border-main bg-surface p-3 shadow-inner">
                  <div class="grid grid-cols-2 xl:grid-cols-4 gap-2">
                    <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                      <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 1 Tarihi</div>
                      <div class="text-xs text-main">${escHtml(a1Tarih)}</div>
                    </div>
                    <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                      <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 1 Denetçi</div>
                      <div class="text-xs text-main">${escHtml(denetci1)}</div>
                      ${a1Lead ? `<div class="text-[10px] text-muted mt-0.5">Lead: ${escHtml(a1Lead)}</div>` : ""}
                    </div>
                    <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                      <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 2 Tarihi</div>
                      <div class="text-xs text-main">${escHtml(a2Tarih)}</div>
                    </div>
                    <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                      <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 2 Denetçi</div>
                      <div class="text-xs text-main">${escHtml(denetci2)}</div>
                      ${a2Lead ? `<div class="text-[10px] text-muted mt-0.5">Lead: ${escHtml(a2Lead)}</div>` : ""}
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");

      document.querySelectorAll(".audit-detail-toggle").forEach((button) => {
        const handler = (event: Event) => {
          const current = event.currentTarget as HTMLElement;
          const targetId = current.dataset.target;
          if (!targetId) return;
          const row = document.getElementById(targetId);
          if (!row) return;
          const isHidden = row.classList.contains("hidden");
          row.classList.toggle("hidden");

          const icon = current.querySelector("svg");
          if (icon) icon.style.transform = isHidden ? "rotate(180deg)" : "rotate(0deg)";
          current.classList.toggle("bg-primary/20", isHidden);
          current.classList.toggle("text-primary", isHidden);
          current.classList.toggle("border-primary/30", isHidden);
        };

        button.addEventListener("click", handler);
        registerCleanup(() => button.removeEventListener("click", handler));
      });
    };

    const auditTable = useTableFilter<any>({
      data: [],
      pageSize: Number(pageSizeSelect.value) || 20,
      filterFn: (audit, filters) => {
        const firmaNo = pickValue(audit, ["firma_no", "firmaNo"], "");
        const nick = getCompanyDisplayName(firmaNo);
        const auditors = getAuditPeopleText(audit);
        const denetimTipi = pickValue(audit, ["denetim_tipi", "denetimTipi"], "");
        const search = String(filters.search || "").toLocaleLowerCase("tr-TR");
        const selectedType = String(filters.type || "");

        const matchSearch = !search || `${nick}${firmaNo}${auditors}`.toLocaleLowerCase("tr-TR").includes(search);
        const matchType = !selectedType || denetimTipi === selectedType;
        return matchSearch && matchType;
      },
      sortFn: (a, b) => {
        const dateA = parseDateValue(pickValue(a, ["a2_baslangic", "a2Basla", "a1_baslangic", "a1Basla"], ""))?.getTime() || 0;
        const dateB = parseDateValue(pickValue(b, ["a2_baslangic", "a2Basla", "a1_baslangic", "a1Basla"], ""))?.getTime() || 0;
        return dateB - dateA;
      },
      onStateChange: setTableState,
      onRender: renderRows,
    });

    const searchHandler = () => auditTable.setFilters({ search: searchInput.value });
    searchInput.addEventListener("input", searchHandler);
    registerCleanup(() => searchInput.removeEventListener("input", searchHandler));

    const typeHandler = () => auditTable.setFilters({ type: filterType.value });
    filterType.addEventListener("change", typeHandler);
    registerCleanup(() => filterType.removeEventListener("change", typeHandler));

    const pageSizeHandler = (event: Event) => auditTable.setPageSize(Number((event.target as HTMLSelectElement).value) || 20);
    pageSizeSelect.addEventListener("change", pageSizeHandler);
    registerCleanup(() => pageSizeSelect.removeEventListener("change", pageSizeHandler));

    const prevHandler = () => auditTable.prevPage();
    prevPageBtn.addEventListener("click", prevHandler);
    registerCleanup(() => prevPageBtn.removeEventListener("click", prevHandler));

    const nextHandler = () => auditTable.nextPage();
    nextPageBtn.addEventListener("click", nextHandler);
    registerCleanup(() => nextPageBtn.removeEventListener("click", nextHandler));

    const selectAllHandler = (event: Event) => {
      const checked = (event.target as HTMLInputElement).checked;
      document.querySelectorAll<HTMLInputElement>(".audit-checkbox").forEach((checkbox) => {
        checkbox.checked = checked;
      });
    };
    selectAllAudits.addEventListener("change", selectAllHandler);
    registerCleanup(() => selectAllAudits.removeEventListener("change", selectAllHandler));

    setTableState("loading");

    void (async () => {
      if (!(($companies.get() as any[]) || []).length) {
        const companiesRes = await api.getCompanies();
        if (companiesRes.success && Array.isArray(companiesRes.data)) {
          $companies.set(companiesRes.data);
        }
      }

      const res = await api.getAudits();
      if (res.success && Array.isArray(res.data)) {
        auditTable.updateData(res.data);
      } else {
        auditTable.updateData([]);
      }
    })();
  }

  initPageCleanup(init, runCleanups);
</script>
