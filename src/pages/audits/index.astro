---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

/**
 * 📊 Denetim Takvimi & Planlama
 * 
 * Yaklaşan denetimleri listeleyen, denetçi atamalarını ve 
 * Aşama 1-2 süreçlerini takip eden ana modül.
 */
---

<DashboardLayout title="Denetim Takvimi">
  <div class="space-y-4 sm:space-y-6">

    <!-- 🔍 Premium Arama & Filtre Çubuğu -->
    <div class="bg-surface border border-border-main shadow-lg p-3 sm:p-4 rounded-2xl flex flex-wrap items-center gap-3">
      <div class="relative flex-1 min-w-[200px]">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted w-4 h-4 pointer-events-none shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="search"
          id="audit-search"
          placeholder="Firma veya denetçi ara..."
          autocomplete="off"
          class="w-full bg-surface-hover border border-border-main rounded-xl pl-10 pr-4 py-2.5 text-main placeholder:text-muted focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-sm"
        />
      </div>

      <div class="flex items-center gap-2 shrink-0">
        <select id="filter-type" class="hidden md:block bg-surface-hover border border-border-main rounded-xl px-3 py-2.5 text-xs font-bold text-muted outline-none focus:ring-2 focus:ring-primary/50 transition-all cursor-pointer uppercase">
          <option value="">TÜM DENETİM TİPLERİ</option>
          <option value="Gözetim">GÖZETİM</option>
          <option value="Yenileme">YENİLEME</option>
          <option value="İlk Belgelendirme">İLK BELGELENDİRME</option>
        </select>

        <span id="audit-count" class="text-xs font-black text-primary bg-primary/10 border border-primary/20 px-3 py-1.5 rounded-lg min-w-[2.75rem] text-center tabular-nums">0</span>
        
        <div class="h-8 w-px bg-border-main mx-1 hidden sm:block"></div>
        
        <a href="/audits/add" title="Yeni Denetim Ekle" class="w-9 h-9 flex items-center justify-center rounded-lg bg-primary text-white hover:bg-primary-hover shadow-lg shadow-primary/20 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        </a>
      </div>
    </div>

    <!-- 📊 Denetim Tablosu Kartı -->
    <div class="bg-surface border border-border-main shadow-xl rounded-2xl overflow-hidden">
      <div class="w-full overflow-x-auto">
        <table class="w-full table-fixed border-collapse">
          <thead>
            <tr class="bg-surface-hover border-b border-border-main">
              <th class="w-10 px-3 py-3.5 text-center">
                <input type="checkbox" id="select-all-audits" class="w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary">
              </th>
              <th class="w-64 px-5 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Firma Adı</th>
              <th class="w-32 pl-6 pr-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Standart</th>
              <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Denetçi(ler)</th>
              <th class="w-32 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Aşama 1 Tarihi</th>
              <th class="w-32 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Aşama 2 Tarihi</th>
              <th class="w-28 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Denetim Tipi</th>
              <th class="w-16 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Detay</th>
            </tr>
          </thead>
          <tbody id="audit-table-body" class="divide-y divide-border-main"></tbody>
        </table>
      </div>

      <!-- Durum Mesajları -->
      <div id="table-loader" class="py-24 flex flex-col items-center justify-center gap-3">
        <div class="w-10 h-10 border-2 border-primary/20 border-t-primary rounded-full animate-spin"></div>
        <p class="text-xs font-bold text-muted tracking-widest uppercase animate-pulse">Takvim Alınıyor</p>
      </div>

      <div id="no-results" class="hidden py-24 flex flex-col items-center justify-center gap-3 text-center px-6">
        <div class="w-14 h-14 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        </div>
        <p class="text-sm font-bold text-muted uppercase tracking-widest">Planlanmış denetim bulunamadı</p>
      </div>

      <!-- Sayfalama (Premium Layout) -->
      <div id="audit-pagination-bar" class="hidden bg-surface-hover border-t border-border-main px-4 sm:px-6 py-3 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span id="audit-page-summary" class="text-xs font-black text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 tabular-nums">1 / 1</span>
          <div class="flex items-center gap-2 border-l border-border-main pl-3">
            <span class="text-[10px] font-bold text-muted uppercase tracking-widest hidden sm:inline">Göster:</span>
            <select id="audit-page-size" class="bg-surface border border-border-main rounded-lg px-2 py-1 text-[11px] font-bold text-main outline-none focus:ring-1 focus:ring-primary/40 transition-all cursor-pointer">
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </div>
        </div>
        <div class="flex items-center gap-2">
           <button id="audit-prev-page" title="Önceki Sayfa" class="w-8 h-8 flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-primary/10 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
           </button>
           <div id="audit-page-number-list" class="flex items-center gap-1.5"></div>
           <button id="audit-next-page" title="Sonraki Sayfa" class="w-8 h-8 flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-primary/10 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
           </button>
        </div>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { pickValue, getVisiblePageNumbers, getInitials } from '../../lib/utils';
  import { $companies } from '../../lib/store';

  function init() {
  const tableBody = document.getElementById('audit-table-body');
  const tableLoader = document.getElementById('table-loader');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('audit-search') as HTMLInputElement;
  const filterType = document.getElementById('filter-type') as HTMLSelectElement;
  const auditCount = document.getElementById('audit-count');
  const auditSummary = document.getElementById('audit-summary');
  const auditPageSummary = document.getElementById('audit-page-summary');
  const auditPageSize = document.getElementById('audit-page-size') as HTMLSelectElement;
  const auditPaginationBar = document.getElementById('audit-pagination-bar');
  const auditPaginationMeta = document.getElementById('audit-pagination-meta');
  const auditPageNumberList = document.getElementById('audit-page-number-list');
  const auditPrevPage = document.getElementById('audit-prev-page') as HTMLButtonElement;
  const auditNextPage = document.getElementById('audit-next-page') as HTMLButtonElement;
  const selectAllAudits = document.getElementById('select-all-audits') as HTMLInputElement;

  let allAudits: any[] = [];
  let currentPage = 1;
  let pageSize = 20;
  }

  function getSortableAuditValue(audit: any, originalIndex: number) {
    const id = Number(pickValue(audit, ['id', 'ID'], ''));
    if (!Number.isNaN(id) && id > 0) return id;

    const a2 = pickValue(audit, ['a2_baslangic', 'a2Basla'], '');
    const a1 = pickValue(audit, ['a1_baslangic', 'a1Basla'], '');
    const raw = a2 || a1;
    const match = raw.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
    if (match) {
      const [, dd, mm, yyyy] = match;
      return new Date(Number(yyyy), Number(mm) - 1, Number(dd)).getTime();
    }

    return originalIndex;
  }


    function updatePagination(totalItems: number) {
      const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
      const safePage = Math.min(currentPage, totalPages);
      currentPage = safePage;

      if (auditPageSummary) auditPageSummary.textContent = `${safePage} / ${totalPages}`;
      if (auditCount) auditCount.textContent = totalItems.toString();

      if (!auditPaginationBar || !auditPageNumberList || !auditPrevPage || !auditNextPage) return;

      if (totalItems === 0) {
        auditPaginationBar.classList.add('hidden');
        auditPageNumberList.innerHTML = '';
        return;
      }

      auditPaginationBar.classList.remove('hidden');
      auditPrevPage.disabled = safePage <= 1;
      auditNextPage.disabled = safePage >= totalPages;

      const pages = getVisiblePageNumbers(totalPages, safePage);
      auditPageNumberList.innerHTML = '';
      pages.forEach((pageNum, index) => {
        if (index > 0 && pages[index - 1] !== pageNum - 1) {
          const dots = document.createElement('span');
          dots.className = 'px-1.5 text-xs text-muted';
          dots.textContent = '…';
          auditPageNumberList.appendChild(dots);
        }

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = String(pageNum);
        btn.className = `w-8 h-8 rounded-lg border text-xs font-black transition-all ${
          pageNum === currentPage
            ? 'bg-primary text-white border-primary shadow-md shadow-primary/20'
            : 'border-border-main text-muted hover:text-primary hover:bg-primary/10 hover:border-primary/30'
        }`;
        btn.addEventListener('click', () => {
          currentPage = pageNum;
          window.scrollTo({ top: 0, behavior: 'smooth' });
          renderTable(allAudits);
        });
        auditPageNumberList.appendChild(btn);
      });
    }


    function attachTableActions() {
      document.querySelectorAll('.audit-detail-toggle').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const button = e.currentTarget as HTMLElement;
          const targetId = button.dataset.target;
          if (!targetId) return;
          const row = document.getElementById(targetId);
          if (!row) return;
          const isHidden = row.classList.contains('hidden');
          row.classList.toggle('hidden');
          
          // Animate icon rotation instead of wiping it
          const icon = button.querySelector('svg');
          if (icon) {
            icon.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
          }
          button.classList.toggle('bg-primary/20', isHidden);
          button.classList.toggle('text-primary', isHidden);
          button.classList.toggle('border-primary/30', isHidden);
        });
      });
    }

  // 📡 Verileri Yükle
  async function loadAudits() {
    if (!tableBody || !tableLoader || !noResults) return;

    const res = await api.getAudits();
    tableLoader.classList.add('hidden');

    if (res.success && Array.isArray(res.data) && res.data.length > 0) {
      allAudits = res.data;
      renderTable(allAudits);
    } else {
      noResults.classList.remove('hidden');
    }
  }

  function renderTable(data: any[]) {
    if (!tableBody || !auditCount) return;

    const searchTerm = searchInput.value.toLowerCase();
    const selectedType = filterType.value;

    const filtered = data.filter(audit => {
      const firmaNo = pickValue(audit, ['firma_no', 'firmaNo'], '');
      const company = ($companies.get() as any[])?.find(c => String(c.firma_no || c.id || '') === String(firmaNo));
      const nick = company ? (company.nick || company.firma_adi || firmaNo) : firmaNo;
            const auditor1 = pickValue(audit, ['a1_auditor', 'a1Auditor'], '');
      const auditor2 = pickValue(audit, ['a2_auditor', 'a2Auditor'], '');
      const denetimTipi = pickValue(audit, ['denetim_tipi', 'denetimTipi'], '');

      const matchSearch = `${nick}${firmaNo}${auditor1}${auditor2}`.toLowerCase().includes(searchTerm);
      const matchType = !selectedType || denetimTipi === selectedType;
      return matchSearch && matchType;
    }).map((audit, originalIndex) => ({ audit, originalIndex }))
      .sort((a, b) => getSortableAuditValue(b.audit, b.originalIndex) - getSortableAuditValue(a.audit, a.originalIndex));

    tableBody.innerHTML = '';
    auditCount.textContent = filtered.length.toString();
    updatePagination(filtered.length);
    selectAllAudits.checked = false;

    if (filtered.length === 0) {
      noResults?.classList.remove('hidden');
      return;
    }
    noResults?.classList.add('hidden');

    const startIndex = (currentPage - 1) * pageSize;
    const paged = filtered.slice(startIndex, startIndex + pageSize);

    paged.forEach(({ audit, originalIndex }) => {
      const firmaNo = pickValue(audit, ['firma_no', 'firmaNo'], '-');
      const company = ($companies.get() as any[])?.find(c => String(c.firma_no || c.id || '') === String(firmaNo));
      const nick = company ? (company.nick || company.firma_adi || firmaNo) : firmaNo;
            const standart = pickValue(audit, ['standart', 'standard'], '-');
      const denetimTipi = pickValue(audit, ['denetim_tipi', 'denetimTipi'], '-');
      const a1Tarih = pickValue(audit, ['a1_baslangic', 'a1Basla'], '-');
      const a2Tarih = pickValue(audit, ['a2_baslangic', 'a2Basla'], '-');
      const denetci1 = pickValue(audit, ['a1_auditor', 'a1Auditor'], '');
      const denetci2 = pickValue(audit, ['a2_auditor', 'a2Auditor'], '');
      const a1Lead = pickValue(audit, ['a1_lead', 'a1_bas_denetci', 'a1Lead'], '');
      const a2Lead = pickValue(audit, ['a2_lead', 'a2_bas_denetci', 'a2Lead'], '');
      const denetciler = [denetci1, denetci2].filter(v => v && v !== 'Atanmadı').join(', ') || '-';
      
      const initials = getInitials(nick);
      const auditId = pickValue(audit, ['id', 'ID'], String(originalIndex + 1));
      const detailRowId = `audit-detail-${auditId}`;

      const tr = document.createElement('tr');
      tr.className = 'hover:bg-surface-hover transition-colors group/row text-[11px]';

      tr.innerHTML = `
        <td class="px-3 py-4 text-center align-middle">
          <input type="checkbox" class="audit-checkbox w-4 h-4 rounded border-gray-700 text-primary bg-transparent cursor-pointer focus:ring-offset-0 focus:ring-primary" data-id="${auditId}">
        </td>
        <td class="px-6 py-3">
           <div class="flex items-center gap-3">
             <div class="w-8 h-8 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
               <span class="text-[10px] font-black text-primary uppercase">${initials}</span>
             </div>
             <div class="min-w-0 flex-1">
               <div class="font-bold text-main truncate uppercase tracking-tight leading-tight">${nick}</div>
               <div class="text-[9px] text-muted font-bold mt-0.5 leading-tight truncate uppercase tracking-tight italic">ID: ${firmaNo}</div>
             </div>
           </div>
        </td>
        <td class="pl-6 pr-4 py-4 text-left font-bold text-primary/70">${standart.length > 25 ? standart.slice(0, 25) + '...' : standart}</td>
        <td class="px-4 py-4 text-center text-muted font-medium">${denetciler.length > 25 ? denetciler.slice(0, 25) + '...' : denetciler}</td>
        <td class="px-4 py-4 text-center text-muted italic">${a1Tarih}</td>
        <td class="px-4 py-4 text-center font-bold text-main italic underline underline-offset-2 decoration-primary/30">${a2Tarih}</td>
        <td class="px-4 py-4 text-center font-black uppercase tracking-widest text-muted">${denetimTipi}</td>
        <td class="px-3 py-4 text-center">
          <div class="flex items-center justify-center gap-1.5">
            <a
              href="/audits/add?firmaId=${encodeURIComponent(firmaNo)}&edit=${encodeURIComponent(auditId)}"
              class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-emerald-400 hover:bg-emerald-500/10 transition-all duration-300"
              title="Düzenle"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            </a>
            <button
              type="button"
              class="audit-detail-toggle w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-surface-hover transition-all duration-300"
              data-target="${detailRowId}"
              title="Detaylar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
        </td>
      `;
      tableBody.appendChild(tr);

      const detailTr = document.createElement('tr');
      detailTr.id = detailRowId;
      detailTr.className = 'hidden border-b border-border-main bg-surface-hover';
      detailTr.innerHTML = `
        <td colspan="8" class="px-3 sm:px-6 pb-4 pt-1 align-middle">
          <div class="rounded-xl border border-border-main bg-surface p-3 shadow-inner">
            <div class="grid grid-cols-2 xl:grid-cols-4 gap-2">
              <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 1 Tarihi</div>
                <div class="text-xs text-main">${a1Tarih}</div>
              </div>
              <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 1 Denetçi</div>
                <div class="text-xs text-main">${denetci1}</div>
                ${a1Lead ? `<div class="text-[10px] text-muted mt-0.5">Lead: ${a1Lead}</div>` : ''}
              </div>
              <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 2 Tarihi</div>
                <div class="text-xs text-main">${a2Tarih}</div>
              </div>
              <div class="rounded-lg border border-border-main bg-surface-hover px-3 py-2 min-w-0">
                <div class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Aşama 2 Denetçi</div>
                <div class="text-xs text-main">${denetci2}</div>
                ${a2Lead ? `<div class="text-[10px] text-muted mt-0.5">Lead: ${a2Lead}</div>` : ''}
              </div>
            </div>
          </div>
        </td>
      `;
      tableBody.appendChild(detailTr);
    });

    attachTableActions();
  }

  // ⌨️ Event Listeners
  searchInput?.addEventListener('input', () => {
    currentPage = 1;
    renderTable(allAudits);
  });
  filterType?.addEventListener('change', () => {
    currentPage = 1;
    renderTable(allAudits);
  });
  auditPageSize?.addEventListener('change', (e) => {
    pageSize = Number((e.target as HTMLSelectElement).value) || 20;
    currentPage = 1;
    renderTable(allAudits);
  });
  auditPrevPage?.addEventListener('click', () => {
    if (currentPage <= 1) return;
    currentPage -= 1;
    renderTable(allAudits);
  });
  auditNextPage?.addEventListener('click', () => {
    currentPage += 1;
    renderTable(allAudits);
  });
  selectAllAudits?.addEventListener('change', (e) => {
    const checked = (e.target as HTMLInputElement).checked;
    document.querySelectorAll('.audit-checkbox').forEach((cb) => {
      (cb as HTMLInputElement).checked = checked;
    });
  });

  // Başlat
  loadAudits();
  } // end init

  document.addEventListener('astro:page-load', init);
</script>

