---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Yeni Firma Ekle">
  <div class="max-w-5xl mx-auto pb-20">
    <form id="add-company-form" class="space-y-8" autocomplete="off">

      <!-- section: Genel Bilgiler -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M3 7V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/><path d="M5 21V7"/><path d="M19 21V7"/></svg>
          </div>
          <div class="flex-1 flex items-center justify-between">
            <h2 class="text-xl font-bold">Genel Bilgiler</h2>
            <button id="unvan-upper-btn" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50">BÜYÜK YAP</button>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Firma Kısa Adı (Klasör Adı)</label>
              <input type="text" name="nickname" id="nickname-input" required class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Örn: ABC Teknoloji">
              <p class="text-[10px] text-indigo-400/70 mt-1 italic leading-tight">* Bu isim Google Drive'da otomatik klasör oluşturmak için kullanılacaktır.</p>
            </div>
            
            <!-- Logo & Kaşe (NEW) -->
            <div class="grid grid-cols-1 gap-4">
              <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Logo</label>
                <div class="flex gap-2">
                  <input type="text" id="f-logo" name="logo" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold text-sm" placeholder="Drive ID" />
                  <button type="button" id="btn-logo-select" title="Drive'dan Seç"
                    class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-amber-500/10 border border-amber-500/20 hover:bg-amber-500/15 rounded-xl text-[10px] font-black uppercase tracking-widest text-amber-400 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    Seç
                  </button>
                  <input type="file" id="logo-file-input" accept="image/png,image/jpeg,image/gif" class="hidden" />
                  <button type="button" id="btn-logo-upload" title="Bilgisayardan Yükle"
                    class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-indigo-500/10 border border-indigo-500/20 hover:bg-indigo-500/15 rounded-xl text-[10px] font-black uppercase tracking-widest text-indigo-400 transition-all">
                    <svg id="logo-upload-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <span id="logo-upload-text">Yükle</span>
                  </button>
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Kaşe & İmza</label>
                <div class="flex gap-2">
                  <input type="text" id="f-kase" name="kase" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold text-sm" placeholder="Drive ID" />
                  <button type="button" id="btn-kase-select" title="Drive'dan Seç"
                    class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-amber-500/10 border border-amber-500/20 hover:bg-amber-500/15 rounded-xl text-[10px] font-black uppercase tracking-widest text-amber-400 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    Seç
                  </button>
                  <input type="file" id="kase-file-input" accept="image/png,image/jpeg,image/gif" class="hidden" />
                  <button type="button" id="btn-kase-upload" title="Bilgisayardan Yükle"
                    class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-indigo-500/10 border border-indigo-500/20 hover:bg-indigo-500/15 rounded-xl text-[10px] font-black uppercase tracking-widest text-indigo-400 transition-all">
                    <svg id="kase-upload-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <span id="kase-upload-text">Yükle</span>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Drive Picker Modal -->
        <div id="drive-picker-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm transition-all">
          <div class="w-full max-w-2xl bg-surface border border-border-main rounded-[2.5rem] shadow-2xl flex flex-col max-h-[80vh] overflow-hidden">
            <div class="p-6 border-b border-border-main flex items-center justify-between bg-surface-hover/50">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-400">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div>
                  <h3 class="text-lg font-black text-main uppercase tracking-tight">Drive Dosya Seçici</h3>
                  <p class="text-xs font-bold text-muted uppercase tracking-widest" id="drive-picker-subtitle">Klasör taranıyor...</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <button id="drive-picker-refresh" onclick="openDrivePicker(pickerTargetId, 'Dosya', true)" class="w-10 h-10 rounded-2xl flex items-center justify-center text-muted hover:bg-amber-500/10 hover:text-amber-400 transition-all group" title="Listeyi Yenile">
                  <svg id="drive-refresh-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-active:rotate-180 transition-transform duration-500"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
                </button>
                <button type="button" onclick="closeDrivePicker()" class="w-10 h-10 rounded-2xl flex items-center justify-center text-muted hover:bg-rose-500/10 hover:text-rose-400 transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
              </div>
            </div>
            
            <div id="drive-file-list" class="flex-1 overflow-y-auto p-4 space-y-2 min-h-[300px] bg-surface">
              <div class="flex flex-col items-center justify-center py-12 space-y-4">
                <div class="w-12 h-12 border-4 border-amber-500/20 border-t-amber-500 rounded-full animate-spin"></div>
                <p class="text-sm font-bold text-muted uppercase tracking-widest">Dosyalar getiriliyor...</p>
              </div>
            </div>

            <div class="p-6 border-t border-border-main bg-surface-hover/30 flex justify-end gap-3">
              <button type="button" onclick="closeDrivePicker()" class="px-6 py-2.5 rounded-2xl text-xs font-black uppercase tracking-widest text-muted hover:bg-surface-hover transition-all">Vazgeç</button>
            </div>
          </div>
        </div>
      </section>

      <!-- section: Adres -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6 animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="flex-1 flex items-center justify-between">
            <h2 class="text-xl font-bold">Adres</h2>
            <button id="address-upper-btn" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50">BÜYÜK YAP</button>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-2 space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Tam Adres</label>
            <input type="text" name="adres" id="adres-input" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Merkez Adres Bilgisi">
          </div>
          <div class="md:col-span-1 space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Şehir</label>
            <input type="text" name="city" id="city-input" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Şehir">
            <label class="flex items-center gap-2 mt-1 cursor-pointer select-none">
              <input type="checkbox" id="yurtdisi-cb" class="w-4 h-4 rounded accent-indigo-500">
              <span class="text-xs font-semibold text-gray-500">Yurt Dışı Firma</span>
            </label>
            <div id="ulke-row" class="hidden">
              <input type="text" name="ulke" id="ulke-input" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Ülke">
            </div>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Şube / Yazışma Adresi</label>
          <input type="text" name="yazisma" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Şube veya yazışma adresi (farklıysa)">
        </div>
      </section>

      <!-- section: İletişim & Vergi -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6 animate-fade-in" style="animation-delay: 0.3s;">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.68 9.82a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2 class="text-xl font-bold">İletişim & Vergi</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Telefon</label>
            <input type="text" name="tel" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="+90 ...">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Faks</label>
            <input type="text" name="faks" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="+90 ...">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">E-Posta</label>
            <input type="email" name="mail" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="info@firma.com">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">Web Sitesi</label>
            <input type="text" name="www" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="www.firma.com">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Vergi Dairesi</label>
            <input type="text" name="vergi_dairesi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden">
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Vergi Numarası</label>
            <input type="text" name="vergi_no" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Yönetim Temsilcisi</label>
            <input type="text" name="kyt" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Ad Soyad">
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Yetkili Adı</label>
            <input type="text" name="yetkili_adi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Ad Soyad">
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Yetkili Ünvanı</label>
            <input type="text" name="yetkili_unvani" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Genel Müdür, vb.">
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">İrtibat Kişisi</label>
            <input type="text" name="irtibat_kisi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Ad Soyad">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">İrtibat Ünvanı</label>
            <input type="text" name="irtibat_unvani" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Ünvan">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">İrtibat Telefonu</label>
            <input type="text" name="irtibat_tel" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="+90 ...">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider ml-1">İrtibat E-Posta</label>
            <input type="email" name="irtibat_mail" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="irtibat@firma.com">
          </div>
        </div>
      </section>

      <!-- section: Operasyonel Veriler -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6 animate-fade-in" style="animation-delay: 0.4s;">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/></svg>
          </div>
          <h2 class="text-xl font-bold">Operasyonel Veriler</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Alan (m²)</label>
            <input type="text" name="alan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Vardiya</label>
            <input type="number" name="vardiya" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="1">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Departman Sayısı</label>
            <input type="number" name="departman" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Toplam Çalışan</label>
            <input type="number" name="tcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Yönetim</label>
            <input type="number" name="ycs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Üretim</label>
            <input type="number" name="ucs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Aynı İşte Çalışan</label>
            <input type="number" name="acs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Yarı Zamanlı</label>
            <input type="number" name="yzcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase">Taşeron</label>
            <input type="number" name="tascs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" value="0">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Yapılan İşler</label>
            <textarea name="yapilan_is" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden min-h-[80px]" placeholder="Firmanın faaliyetlerini kısaca özetleyin..."></textarea>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Firma Notları</label>
            <textarea name="firma_not" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden min-h-[80px]" placeholder="Özel notlar veya hatırlatıcılar..."></textarea>
          </div>
        </div>
      </section>

      <!-- section: Doküman & Teknik Dosya -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6 animate-fade-in" style="animation-delay: 0.5s;">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h2 class="text-xl font-bold">Doküman & Teknik Dosya</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Firma Sınıfı</label>
            <input type="text" name="sinif" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden" placeholder="Sınıf bilgisi">
          </div>
          <div class="flex items-center gap-3 bg-surface-hover border border-border-main rounded-xl px-4 py-3">
            <input type="checkbox" name="dokuman" id="dokuman-cb" class="w-4 h-4 rounded accent-rose-500">
            <label for="dokuman-cb" class="text-sm font-semibold cursor-pointer select-none">Firma Dokümanları mevcut</label>
          </div>
          <div class="flex items-center gap-3 bg-surface-hover border border-border-main rounded-xl px-4 py-3">
            <input type="checkbox" name="teknik" id="teknik-cb" class="w-4 h-4 rounded accent-rose-500">
            <label for="teknik-cb" class="text-sm font-semibold cursor-pointer select-none">Teknik Dosyası var</label>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider ml-1">Teknik Dosya Kapsamı</label>
          <textarea name="tkapsam" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold shadow-sm overflow-hidden min-h-[100px]" placeholder="CE kapsamı veya teknik dosya içeriği..."></textarea>
        </div>
      </section>

      <!-- sticky: Footer Actions -->
      <div class="sticky bottom-8 z-50 bg-surface border border-border-main shadow-2xl p-4 rounded-2xl flex items-center justify-between">
        <button type="button" id="cancel-btn" class="px-6 py-2 rounded-xl text-gray-400 hover:text-white hover:bg-surface-hover transition font-bold text-sm">İPTAL</button>
        <button type="submit" id="submit-btn" class="px-8 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl font-bold text-sm transition-all shadow-lg shadow-indigo-600/20 flex items-center gap-2">
          <svg id="submit-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <svg id="loading-icon" class="animate-spin hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          KAYDET
        </button>
      </div>

    </form>
  </div>
</DashboardLayout>

<script>
  import { toast } from '../../lib/toast';
  import { api } from '../../lib/api';
  import { DB } from '../../lib/db';
  import { SyncManager } from '../../lib/sync';

  let cleanupFns: Array<() => void> = [];
  function registerCleanup(fn: () => void) { cleanupFns.push(fn); }
  function runCleanups() { cleanupFns.forEach(fn => fn()); cleanupFns = []; }

  function initPage() {
    runCleanups();

    const form = document.getElementById('add-company-form') as HTMLFormElement;
    const unvanInput = document.getElementById('unvan-input') as HTMLInputElement;
    const nicknameInput = document.getElementById('nickname-input') as HTMLInputElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitIcon = document.getElementById('submit-icon');
    const loadingIcon = document.getElementById('loading-icon');
    const adresInput = document.getElementById('adres-input') as HTMLInputElement;
    const cityInput = document.getElementById('city-input') as HTMLInputElement;
    const addressUpperBtn = document.getElementById('address-upper-btn');
    const unvanUpperBtn = document.getElementById('unvan-upper-btn');

    // Yurt Dışı toggle
    const yurtdisiCb = document.getElementById('yurtdisi-cb') as HTMLInputElement | null;
    const ulkeRow = document.getElementById('ulke-row');
    const ulkeInput = document.getElementById('ulke-input') as HTMLInputElement | null;
    if (yurtdisiCb && ulkeRow && ulkeInput) {
      const handleYurtdisi = () => {
        ulkeRow.classList.toggle('hidden', !yurtdisiCb.checked);
        if (!yurtdisiCb.checked) ulkeInput.value = '';
      };
      yurtdisiCb.addEventListener('change', handleYurtdisi);
      registerCleanup(() => yurtdisiCb.removeEventListener('change', handleYurtdisi));
    }

    // Adres & Şehir Büyük Yap (Türkçe)
    if (addressUpperBtn && adresInput && cityInput) {
      const handleUpper = () => {
        adresInput.value = adresInput.value.toLocaleUpperCase('tr-TR');
        cityInput.value = cityInput.value.toLocaleUpperCase('tr-TR');
      };
      addressUpperBtn.addEventListener('click', handleUpper);
      registerCleanup(() => addressUpperBtn.removeEventListener('click', handleUpper));
    }

    // Unvan Büyük Yap (Türkçe)
    if (unvanUpperBtn && unvanInput) {
      const handleUpperUnvan = () => {
        unvanInput.value = unvanInput.value.toLocaleUpperCase('tr-TR');
      };
      unvanUpperBtn.addEventListener('click', handleUpperUnvan);
      registerCleanup(() => unvanUpperBtn.removeEventListener('click', handleUpperUnvan));
    }

    // Otomatik Kısa Ad (Nickname) Üretimi
    if (unvanInput && nicknameInput) {
      const handleUnvanInput = (e: Event) => {
        const val = (e.target as HTMLInputElement).value;
        if (val.length > 0) {
          const parts = val.replace(/[.,;:!?(){}[\]'"-]/g, '').replace(/\s+/g, ' ').trim().split(' ');
          nicknameInput.value = parts.slice(0, 3).map(p =>
            p.length > 1 ? p.charAt(0).toLocaleUpperCase('tr-TR') + p.substring(1).toLocaleLowerCase('tr-TR') : p.toLocaleUpperCase('tr-TR')
          ).join(' ');
        }
      };
      unvanInput.addEventListener('input', handleUnvanInput);
      registerCleanup(() => unvanInput.removeEventListener('input', handleUnvanInput));
    }

    // --- FILE & DRIVE LOGIC ---
    let pickerTargetId: string | null = null;

    (window as any).openDrivePicker = async (targetId: string, title: string, forceRefresh = false) => {
      pickerTargetId = targetId;
      const modal = document.getElementById('drive-picker-modal')!;
      const subtitle = document.getElementById('drive-picker-subtitle')!;
      const listEl = document.getElementById('drive-file-list')!;
      const refreshBtn = document.getElementById('drive-picker-refresh') as HTMLButtonElement;
      const refreshIcon = document.getElementById('drive-refresh-icon');
      
      modal.classList.remove('hidden');
      modal.classList.add('flex');

      if (forceRefresh && refreshIcon) {
        refreshIcon.classList.add('animate-spin');
        if (refreshBtn) refreshBtn.disabled = true;
      }

      subtitle.textContent = `${title} için seçiliyor...`;
      listEl.innerHTML = `
        <div class="flex flex-col items-center justify-center py-12 space-y-4">
          <div class="w-12 h-12 border-4 border-amber-500/20 border-t-amber-500 rounded-full animate-spin"></div>
          <p class="text-sm font-bold text-muted uppercase tracking-widest">Klasör taranıyor...</p>
        </div>
      `;

      const nick = nicknameInput?.value?.trim() || '';
      if (!nick) {
        toast.error('Önce firma kısa adını (Klasör adı) girmelisiniz.');
        (window as any).closeDrivePicker();
        return;
      }

      const companyId = (window as any).createdCompanyId;
      if (!companyId) {
        toast.warning('Henüz bir firma ID oluşmadı. Lütfen önce firmayı kaydedin veya bir görsel yükleyin.');
        (window as any).closeDrivePicker();
        return;
      }

      try {
        const res = await api.call('getRecentFiles', { 
          id: companyId, 
          mimeTypes: ['image/png', 'image/jpeg', 'image/gif'],
          forceRefresh: forceRefresh 
        });
        if (res?.success && Array.isArray(res.data)) {
          if (res.data.length === 0) {
            listEl.innerHTML = `
              <div class="flex flex-col items-center justify-center py-12 text-center space-y-3">
                <div class="w-16 h-16 rounded-3xl bg-surface-hover flex items-center justify-center text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><path d="M12 11v6"/><path d="M9 14h6"/></svg>
                </div>
                <p class="text-sm font-bold text-muted uppercase tracking-widest">Klasörde uygun dosya bulunamadı.</p>
              </div>
            `;
            return;
          }

          listEl.innerHTML = res.data.map((file: any) => `
            <button type="button" onclick="selectDriveFile('${file.id}')" class="w-full flex items-center gap-4 p-3 rounded-2xl hover:bg-amber-500/5 border border-transparent hover:border-amber-500/20 transition-all group text-left">
              <div class="w-12 h-12 rounded-xl bg-surface-hover flex items-center justify-center text-muted group-hover:bg-amber-500/10 group-hover:text-amber-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold text-main truncate uppercase tracking-tight">${file.name}</p>
                <p class="text-[10px] font-black text-muted uppercase tracking-widest">${new Date(file.dateCreated).toLocaleDateString('tr-TR')}</p>
              </div>
              <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                 <span class="px-3 py-1 rounded-full bg-amber-500/10 text-[10px] font-black text-amber-400 uppercase tracking-widest border border-amber-500/20">Seç</span>
              </div>
            </button>
          `).join('');
        } else {
          throw new Error(res.error || 'Dosyalar listelenemedi.');
        }
      } catch (e: any) {
        toast.error('Drive hatası: ' + e.message);
      } finally {
        if (refreshIcon) refreshIcon.classList.remove('animate-spin');
        if (refreshBtn) refreshBtn.disabled = false;
      }
    };

    (window as any).closeDrivePicker = () => {
      const modal = document.getElementById('drive-picker-modal')!;
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      pickerTargetId = null;
    };

    (window as any).selectDriveFile = (fileId: string) => {
      if (pickerTargetId) {
        const input = document.getElementById(pickerTargetId) as HTMLInputElement;
        if (input) input.value = fileId;
        toast.success('Dosya seçildi.');
      }
      closeDrivePicker();
    };

    const handleFileUpload = async (inputId: string, targetId: string, uploadBtnId: string) => {
      const fileInput = document.getElementById(inputId) as HTMLInputElement | null;
      const targetInput = document.getElementById(targetId) as HTMLInputElement | null;
      const uploadBtn = document.getElementById(uploadBtnId) as HTMLButtonElement | null;
      
      if (!fileInput || !targetInput || !uploadBtn) return;

      fileInput.onchange = async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        const nick = nicknameInput?.value?.trim() || '';
        if (!nick) {
          toast.error('Önce firma kısa adını (Klasör adı) girmelisiniz.');
          return;
        }

        const prefix = targetId.includes('logo') ? 'logo' : 'kase';
        const textEl = document.getElementById(`${prefix}-upload-text`)!;
        const iconEl = document.getElementById(`${prefix}-upload-icon`)!;

        try {
          uploadBtn.disabled = true;
          uploadBtn.classList.add('opacity-50', 'pointer-events-none');
          textEl.textContent = 'Yükleniyor...';
          iconEl.classList.add('animate-spin');
          iconEl.innerHTML = `<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>`;
          
          const base64 = await new Promise<string>((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve((reader.result as string).split(',')[1]);
            reader.onerror = reject;
            reader.readAsDataURL(file);
          });

          toast.info('Görsel buluta gönderiliyor...');
          const res = await api.uploadFile({ fileName: file.name, mimeType: file.type, data: base64 }, nick);
          const fileId = (res as any).data?.id || (res as any).data?.fileId || (res as any).fileId;

          if (res?.success && fileId) {
            targetInput.value = fileId;
            toast.success('Görsel başarıyla yüklendi.');
          } else {
            toast.error('Yükleme başarısız: ' + (res?.error || 'Bilinmeyen hata'));
          }
        } catch (err: any) {
          toast.error('Hata: ' + err.message);
        } finally {
          fileInput.value = '';
          uploadBtn.disabled = false;
          uploadBtn.classList.remove('opacity-50', 'pointer-events-none');
          textEl.textContent = 'Yükle';
          iconEl.classList.remove('animate-spin');
          iconEl.innerHTML = `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>`;
        }
      };
      fileInput.click();
    };

    const btnLogoSelect = document.getElementById('btn-logo-select');
    const btnKaseSelect = document.getElementById('btn-kase-select');
    const btnLogoUpload = document.getElementById('btn-logo-upload');
    const btnKaseUpload = document.getElementById('btn-kase-upload');

    if (btnLogoSelect) btnLogoSelect.onclick = () => (window as any).openDrivePicker('f-logo', 'Logo');
    if (btnKaseSelect) btnKaseSelect.onclick = () => (window as any).openDrivePicker('f-kase', 'Kaşe & İmza');
    if (btnLogoUpload) btnLogoUpload.onclick = () => handleFileUpload('logo-file-input', 'f-logo', 'btn-logo-upload');
    if (btnKaseUpload) btnKaseUpload.onclick = () => handleFileUpload('kase-file-input', 'f-kase', 'btn-kase-upload');

    // Kaydetme
    if (form) {
      const handleSubmit = async (e: Event) => {
        e.preventDefault();
        const formData = new FormData(form);
        const companyInfo = Object.fromEntries(formData.entries());
        companyInfo.dokuman = formData.has('dokuman') ? 'TRUE' : 'FALSE';
        companyInfo.teknik  = formData.has('teknik')  ? 'TRUE' : 'FALSE';

        if (submitBtn) submitBtn.disabled = true;
        if (submitIcon) submitIcon.classList.add('hidden');
        if (loadingIcon) loadingIcon.classList.remove('hidden');

        const response = await api.addCompany(companyInfo);

        if (response.success) {
          const createdId = String((response as any)?.data?.id || (response as any)?.id || '').trim();
          const createdCompany = (response as any)?.data?.company;

          if (createdCompany && createdId) {
            try {
              const companies = (await DB.get<any[]>(DB.COMPANIES)) || [];
              const nextCompanies = companies.filter(item =>
                String(item?.id || item?.ID || item?.['Firma No'] || item?.firmaNo || '').trim() !== createdId
              );
              nextCompanies.push(createdCompany);
              await DB.save(DB.COMPANIES, nextCompanies);
            } catch (e) {
              console.warn('Company cache update skipped:', e);
            }
          }

          await SyncManager.checkAndSync({ force: true });
          toast.success('Firma başarıyla eklendi. Firma profiline yönlendiriliyorsunuz.', { duration: 2500 });
          window.setTimeout(() => {
            window.location.href = createdId ? `/company?id=${encodeURIComponent(createdId)}` : '/search';
          }, 1400);
        } else {
          toast.error(`Hata: ${response.error}`);
          if (submitBtn) submitBtn.disabled = false;
          if (submitIcon) submitIcon.classList.remove('hidden');
          if (loadingIcon) loadingIcon.classList.add('hidden');
        }
      };
      form.addEventListener('submit', handleSubmit);
      registerCleanup(() => form.removeEventListener('submit', handleSubmit));
    }
  }

  document.addEventListener('astro:page-load', initPage);
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
