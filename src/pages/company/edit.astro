<script>
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';

  const firmaId = new URLSearchParams(window.location.search).get('id');
  const el = (id: string) => document.getElementById(id);

  function setText(id: string, value: any) {
    const node = el(id);
    if (node) node.textContent = value || 'Bilgi Yok';
  }

  function setInput(id: string, value: any) {
    const node = el(id);
    if (node instanceof HTMLInputElement || node instanceof HTMLTextAreaElement) {
      node.value = value || '';
    }
  }

  function initCarousel(rootId: string) {
    const root = el(rootId);
    if (!root) return;

    const slides = Array.from(root.querySelectorAll('[data-slide]'));
    const dots = Array.from(root.querySelectorAll('[data-indicator]'));
    if (!slides.length) return;

    let index = 0;

    const render = () => {
      slides.forEach((slide, i) => {
        slide.classList.toggle('hidden', i !== index);
        slide.classList.toggle('block', i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-slate-800', i === index);
        dot.classList.toggle('bg-slate-300', i !== index);
      });
    };

    root.querySelectorAll('[data-next]').forEach((btn) => {
      btn.addEventListener('click', () => {
        index = (index + 1) % slides.length;
        render();
      });
    });

    root.querySelectorAll('[data-prev]').forEach((btn) => {
      btn.addEventListener('click', () => {
        index = (index - 1 + slides.length) % slides.length;
        render();
      });
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        index = i;
        render();
      });
    });

    render();
    return { goTo: (toIndex: number) => { index = Math.max(0, Math.min(toIndex, slides.length - 1)); render(); } };
  }

  function bindMainCarousel(mainCarousel: any) {
    el('nextCard')?.addEventListener('click', () => mainCarousel?.goTo(1));
    el('prevCard')?.addEventListener('click', () => mainCarousel?.goTo(0));
    el('cancel-company-changes')?.addEventListener('click', () => mainCarousel?.goTo(0));

    el('edit-form')?.addEventListener('submit', (event) => {
      event.preventDefault();
      alert('UI kart yapısı taşındı. Kayıt API aksiyonu ayrıca bağlanacak.');
    });
  }

  function ensureLegacyHooks() {
    const dataEl = el('legacy-ids-data');
    const ids = dataEl?.textContent ? JSON.parse(dataEl.textContent) : [];
    const hookRoot = el('legacy-hooks');
    if (!hookRoot) return;

    ids.forEach((id: string) => {
      if (!el(id)) {
        const span = document.createElement('span');
        span.id = id;
        hookRoot.appendChild(span);
      }
    });
  }

