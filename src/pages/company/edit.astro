---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { readFileSync } from 'node:fs';

const legacyCompanyInfoHtml = readFileSync('src/gas/client/companyinfo.html', 'utf-8');
const legacyIds = Array.from(new Set(Array.from(legacyCompanyInfoHtml.matchAll(/id="([^"]+)"/g)).map((match: any) => match[1]))).sort();
---

<DashboardLayout title="Firma Kontrol Merkezi">
  <div class="legacy-dark mx-auto max-w-6xl space-y-10 px-4 pb-16">
    <div id="companyCarousel" class="stack-card rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="carousel-track relative overflow-hidden">
        <section data-slide class="block">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <div class="flex items-center gap-2">
              <h5 id="nickText" class="text-base italic text-slate-700">Firma Bilgileri</h5>
              <span id="firma-id-badge" class="rounded-full bg-rose-100 px-2 py-0.5 font-mono text-xs text-rose-700">ID: -</span>
            </div>
            <button id="nextCard" type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700">Düzenle</button>
          </div>
          <div class="relative px-4 py-4 text-sm text-slate-700">
            <div id="loading-company" class="card-loading-wrapper absolute inset-0 z-10 hidden items-center justify-center bg-white/80">
              <div class="h-7 w-7 animate-spin rounded-full border-2 border-amber-500 border-r-transparent"></div>
            </div>
            <div id="content-company" class="space-y-2">
              <div class="flex flex-wrap items-start gap-2"><span class="font-semibold">Unvan:</span><span id="unvanText"></span></div>
              <div class="flex flex-wrap items-start gap-2"><span class="font-semibold">Adres:</span><span><span id="adresText"></span> - <span id="sehirText"></span> / <span id="ulkeText"></span></span></div>
              <div id="sube-adres-view" class="hidden flex flex-wrap items-start gap-2"><span class="font-semibold">Şube Adresi:</span><span id="yazismaText"></span></div>
              <div class="flex flex-wrap items-start gap-2"><span class="font-semibold">Kapsam:</span><span id="kapsamText" class="italic"></span></div>
              <div class="flex flex-wrap items-start gap-2"><span class="font-semibold">Scope:</span><span id="scopeText" class="italic"></span></div>

              <div class="grid grid-cols-1 gap-2 pt-1 md:grid-cols-4">
                <div id="btel"><span class="font-semibold">Telefon:</span> <span id="TelText"></span></div>
                <div id="bfax"><span class="font-semibold">Fax:</span> <span id="FaxText"></span></div>
                <div id="bvd"><span class="font-semibold">Vergi Dairesi:</span> <span id="VDText"></span></div>
                <div id="bvn"><span class="font-semibold">Vergi No:</span> <span id="VNText"></span></div>
              </div>

              <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
                <div id="bmail"><span class="font-semibold">E-posta:</span> <span id="MailText"></span></div>
                <div id="bweb"><span class="font-semibold">Web Sayfası:</span> <span id="WebText"></span></div>
              </div>

              <div class="grid grid-cols-1 gap-2 md:grid-cols-3">
                <div id="bkyt"><span class="font-semibold">KYT:</span> <span id="KYTText"></span></div>
                <div id="byadi"><span class="font-semibold">Yetkili Adı:</span> <span id="YadiText"></span></div>
                <div id="byunvan"><span class="font-semibold">Yetkili Unvanı:</span> <span id="YUnvanText"></span></div>
              </div>

              <div class="grid grid-cols-1 gap-2 md:grid-cols-4">
                <div id="birtK"><span class="font-semibold">İrtibat Kişisi:</span> <span id="irtKText"></span></div>
                <div id="birtU"><span class="font-semibold">Unvanı:</span> <span id="irtUnText"></span></div>
                <div id="bitel"><span class="font-semibold">Telefonu:</span> <span id="ItelText"></span></div>
                <div id="bimail"><span class="font-semibold">E-Posta:</span> <span id="ImailText"></span></div>
              </div>

              <div class="grid grid-cols-1 gap-2 md:grid-cols-3">
                <div id="bdan"><span class="font-semibold">Danışman:</span> <span id="danText"></span></div>
                <div id="blogo"><span class="font-semibold">Logo:</span> <span id="logoText"></span></div>
                <div id="bkase"><span class="font-semibold">İmza & Kaşe:</span> <span id="kaseText"></span></div>
              </div>
            </div>
          </div>
        </section>

        <section data-slide class="hidden">
          <form id="edit-form">
            <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
              <h5 class="text-base font-medium text-slate-700">Düzenle</h5>
              <button id="prevCard" type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700">Bilgiler</button>
            </div>
            <div id="content-edit" class="relative space-y-3 px-4 py-4">
              <div id="loading-edit" class="card-loading-wrapper absolute inset-0 z-10 hidden items-center justify-center bg-white/80">
                <div class="h-7 w-7 animate-spin rounded-full border-2 border-amber-500 border-r-transparent"></div>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-12">
                <label class="relative md:col-span-1">
                  <input id="firma-id" disabled class="peer w-full rounded-md border border-slate-300 bg-slate-100 px-3 pb-2 pt-5 text-sm" />
                  <span class="floating-label">ID</span>
                </label>
                <label class="relative md:col-span-11">
                  <input id="unvanInput" class="peer field" />
                  <span class="floating-label">Unvan</span>
                </label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                <div class="flex items-stretch">
                  <label class="relative grow">
                    <input id="adresInput" class="peer field" />
                    <span class="floating-label">Adres</span>
                  </label>
                  <span class="inline-flex items-center px-2 text-slate-400">-</span>
                </div>
                <div class="flex items-stretch">
                  <label class="relative grow">
                    <input id="sehirInput" class="peer field" />
                    <span class="floating-label">Şehir</span>
                  </label>
                  <span class="inline-flex items-center px-2 text-slate-400">/</span>
                </div>
                <div class="flex items-stretch gap-1">
                  <label class="relative grow">
                    <input id="ulkeInput" class="peer field" />
                    <span class="floating-label">Ülke</span>
                  </label>
                  <button type="button" id="adresBuyuk" class="rounded-md border border-slate-500 px-2 text-[11px]">TR BÜYÜK</button>
                  <button type="button" id="addressBig" class="rounded-md border border-slate-500 px-2 text-[11px]">EN BÜYÜK</button>
                  <button type="button" id="addTurkiye" class="rounded-md border border-rose-500 px-2 text-[11px] text-rose-400">TR Ekle</button>
                </div>
              </div>

              <label class="relative block">
                <input id="yazismaInput" class="peer field" />
                <span class="floating-label">Şube Adresi</span>
              </label>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                <div class="flex items-stretch gap-1">
                  <label class="relative grow">
                    <textarea id="kapsamInput" class="peer min-h-[110px] w-full rounded-md border border-slate-300 px-3 pb-2 pt-5 text-sm"></textarea>
                    <span class="floating-label">Türkçe Kapsam</span>
                  </label>
                  <div class="flex flex-col gap-1">
                    <button type="button" id="kapsamBuyuk" class="rounded-md border border-slate-500 px-2 py-1 text-[11px]">BÜYÜK</button>
                    <button type="button" id="kapsamToScope" class="rounded-md border border-sky-500 px-2 py-1 text-[11px] text-sky-300">EN Çevir</button>
                  </div>
                </div>
                <div class="flex items-stretch gap-1">
                  <label class="relative grow">
                    <textarea id="scopeInput" class="peer min-h-[110px] w-full rounded-md border border-slate-300 px-3 pb-2 pt-5 text-sm"></textarea>
                    <span class="floating-label">İngilizce Kapsam</span>
                  </label>
                  <div class="flex flex-col gap-1">
                    <button type="button" id="scopeBig" class="rounded-md border border-slate-500 px-2 py-1 text-[11px]">BÜYÜK</button>
                    <button type="button" id="scopeToKapsam" class="rounded-md border border-sky-500 px-2 py-1 text-[11px] text-sky-300">TR Çevir</button>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                <label class="relative"><input id="telefonInput" class="peer field" /><span class="floating-label">Telefon</span></label>
                <label class="relative"><input id="faxInput" class="peer field" /><span class="floating-label">Faks</span></label>
                <label class="relative"><input id="emailInput" class="peer field" /><span class="floating-label">E-Posta</span></label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                <label class="relative"><input id="wwwInput" class="peer field" /><span class="floating-label">İnternet</span></label>
                <label class="relative"><input id="vergiDInput" class="peer field" /><span class="floating-label">Vergi Dairesi</span></label>
                <label class="relative"><input id="vergiNInput" class="peer field" /><span class="floating-label">Vergi Numarası</span></label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                <label class="relative"><input id="kytInput" class="peer field" /><span class="floating-label">Yönetim Temsilcisi</span></label>
                <label class="relative"><input id="yetkiliInput" class="peer field" /><span class="floating-label">Yetkili Adı</span></label>
                <label class="relative"><input id="yetkiliUnInput" class="peer field" /><span class="floating-label">Yetkili Ünvanı</span></label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
                <label class="relative"><input id="irtibatInput" class="peer field" /><span class="floating-label">İrtibat</span></label>
                <label class="relative"><input id="iUnvanInput" class="peer field" /><span class="floating-label">İrtibat Ünvan</span></label>
                <label class="relative"><input id="iTelInput" class="peer field" /><span class="floating-label">İrtibat Tel</span></label>
                <label class="relative"><input id="iMailInput" class="peer field" /><span class="floating-label">İrtibat Mail</span></label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-12">
                <div class="md:col-span-3">
                  <label class="relative block">
                    <input id="nickInput" class="peer field" aria-describedby="nickInputHelp" />
                    <span class="floating-label">Firma Kısa Adı</span>
                  </label>
                  <p id="nickInputHelp" class="mt-1 text-[11px] text-slate-400">Bu alan klasör adı olarak kullanılır.</p>
                </div>
                <label class="relative md:col-span-9">
                  <textarea id="notInput" class="peer min-h-[100px] w-full rounded-md border border-slate-300 px-3 pb-2 pt-5 text-sm"></textarea>
                  <span class="floating-label">Firma Notları</span>
                </label>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                <div class="flex items-stretch gap-1">
                  <label class="relative grow"><input id="logoInput" class="peer field" /><span class="floating-label">Logo</span></label>
                  <button id="logoSelect" type="button" class="rounded-md border border-emerald-500 px-2 text-[11px] text-emerald-300">Seç</button>
                  <input type="file" id="logoInput_file" hidden />
                  <button id="logoUpload" type="button" class="rounded-md border border-emerald-500 px-2 text-[11px] text-emerald-300">Yükle</button>
                </div>
                <div class="flex items-stretch gap-1">
                  <label class="relative grow"><input id="imzaInput" class="peer field" /><span class="floating-label">Kaşe & İmza</span></label>
                  <button id="imzaSelect" type="button" class="rounded-md border border-emerald-500 px-2 text-[11px] text-emerald-300">Seç</button>
                  <input type="file" id="imzaInput_file" hidden />
                  <button id="imzaUpload" type="button" class="rounded-md border border-emerald-500 px-2 text-[11px] text-emerald-300">Yükle</button>
                </div>
                <label class="relative">
                  <input id="fDanInput" class="peer field" list="danList" />
                  <span class="floating-label">Danışman</span>
                  <datalist id="danList"></datalist>
                </label>
              </div>

              <div id="accordionExample" class="space-y-3 rounded-lg border border-slate-700/70 p-3">
                <details open class="rounded-md border border-slate-700/60 bg-slate-900/40">
                  <summary id="headingOne" class="cursor-pointer px-3 py-2 text-sm font-semibold text-sky-300">Çalışma Düzeni</summary>
                  <div id="collapseOne" class="grid grid-cols-1 gap-3 px-3 pb-3 pt-1 md:grid-cols-10">
                    <label class="relative md:col-span-4"><input id="alanInput" class="peer field" /><span class="floating-label">Alan m2</span></label>
                    <label class="relative md:col-span-3"><input id="vardiyaInput" class="peer field" /><span class="floating-label">Vardiya</span></label>
                    <label class="relative md:col-span-3"><input id="departmanInput" class="peer field" /><span class="floating-label">Departman</span></label>
                    <label class="relative md:col-span-2"><input id="tcsInput" class="peer field" /><span class="floating-label">Toplam Çalışan</span></label>
                    <label class="relative md:col-span-2"><input id="ycsInput" class="peer field" /><span class="floating-label">Yönetim</span></label>
                    <label class="relative md:col-span-2"><input id="ucsInput" class="peer field" /><span class="floating-label">Üretim</span></label>
                    <label class="relative md:col-span-2"><input id="acsInput" class="peer field" /><span class="floating-label">Aynı İş</span></label>
                    <label class="relative md:col-span-1"><input id="yzcsInput" class="peer field" /><span class="floating-label">Yarı Z.</span></label>
                    <label class="relative md:col-span-1"><input id="tacsInput" class="peer field" /><span class="floating-label">Taşeron</span></label>
                  </div>
                </details>

                <details class="rounded-md border border-slate-700/60 bg-slate-900/40">
                  <summary id="headingTwo" class="cursor-pointer px-3 py-2 text-sm font-semibold text-sky-300">Sınıflandırma</summary>
                  <div id="collapseTwo" class="grid grid-cols-1 gap-3 px-3 pb-3 pt-1 md:grid-cols-4">
                    <label class="relative"><input id="eaInput" class="peer field" /><span class="floating-label">EA</span></label>
                    <label class="relative"><input id="naceInput" class="peer field" /><span class="floating-label">NACE</span></label>
                    <label class="relative"><input id="medikalInput" class="peer field" /><span class="floating-label">Medikal</span></label>
                    <label class="relative"><input id="gidaInput" class="peer field" /><span class="floating-label">Gıda</span></label>
                    <label class="relative md:col-span-4">
                      <textarea id="yapisInput" class="peer min-h-[90px] w-full rounded-md border border-slate-300 px-3 pb-2 pt-5 text-sm"></textarea>
                      <span class="floating-label">Yapılan İşler</span>
                    </label>
                  </div>
                </details>

                <details class="rounded-md border border-slate-700/60 bg-slate-900/40">
                  <summary id="headingThree" class="cursor-pointer px-3 py-2 text-sm font-semibold text-sky-300">Doküman ve Teknik Dosya</summary>
                  <div id="collapseThree" class="grid grid-cols-1 gap-3 px-3 pb-3 pt-1 md:grid-cols-4">
                    <label class="relative"><input id="sinifInput" class="peer field" /><span class="floating-label">Firma Sınıfı</span></label>
                    <label class="inline-flex items-center gap-2 pt-2 text-sm text-slate-300"><input id="dokumanCB" type="checkbox" class="h-4 w-4" />Firma Dokümanları mevcut mu?</label>
                    <label class="inline-flex items-center gap-2 pt-2 text-sm text-slate-300"><input id="teknikCB" type="checkbox" class="h-4 w-4" />Teknik Dosyası var mı?</label>
                    <label class="relative md:col-span-4">
                      <textarea id="tdInput" class="peer min-h-[90px] w-full rounded-md border border-slate-300 px-3 pb-2 pt-5 text-sm"></textarea>
                      <span class="floating-label">Teknik Dosya Kapsamı</span>
                    </label>
                  </div>
                </details>
              </div>

              <div class="flex justify-end gap-2 border-t border-slate-200 pt-3">
                <button data-bs-target="#companyCarousel" data-bs-slide="prev" type="button" class="rounded-md border border-sky-400 px-3 py-1.5 text-xs font-semibold text-sky-300">Geri</button>
                <button id="cancel-company-changes" type="button" class="rounded-md border border-rose-400 px-3 py-1.5 text-xs font-semibold text-rose-300">İptal</button>
                <button id="save-company-changes" type="submit" class="rounded-md bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-700">Kaydet</button>
              </div>
            </div>
          </form>
        </section>
      </div>
      <div class="flex items-center justify-center gap-2 border-t border-slate-200 px-4 py-3">
        <button data-indicator class="h-2 w-2 rounded-full bg-slate-800"></button>
        <button data-indicator class="h-2 w-2 rounded-full bg-slate-300"></button>
      </div>
    </div>

    <div id="auditCarousel" class="stack-card rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="carousel-track relative overflow-hidden">
        <section data-slide class="block">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <h5 class="text-sm font-semibold text-slate-700">Kısayollar</h5>
            <button data-next type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700">Denetim Planla</button>
          </div>
          <div class="grid grid-cols-2 gap-3 px-4 py-4 md:grid-cols-5">
            <button id="addDocs" class="rounded-lg border border-slate-200 p-3 text-sm text-slate-700 hover:bg-slate-50">Döküman Hazırla</button>
            <button id="doctopdf" class="rounded-lg border border-slate-200 p-3 text-sm text-slate-700 hover:bg-slate-50">Docs to PDF</button>
            <button id="add-certificate-button" class="rounded-lg border border-slate-200 p-3 text-sm text-slate-700 hover:bg-slate-50">Sertifika Ekle</button>
            <button id="add-tests" class="rounded-lg border border-slate-200 p-3 text-sm text-slate-700 hover:bg-slate-50">Test Ekle</button>
            <button id="add-audit-button" class="rounded-lg border border-slate-200 p-3 text-sm text-slate-700 hover:bg-slate-50">Denetim Ekle</button>
          </div>
          <div class="grid grid-cols-1 gap-3 border-t border-slate-200 px-4 py-4 md:grid-cols-3">
            <input id="convertPdfInput" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Google Docs Linki" />
            <input id="googleDocFilename" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Dosya Adı" />
            <button id="convertPDF" class="rounded-md bg-slate-700 px-3 py-2 text-xs font-semibold text-white">Dönüştür</button>
          </div>
        </section>

        <section data-slide class="hidden">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <h5 class="text-sm font-semibold text-slate-700">Denetim Planla</h5>
            <div class="flex gap-2">
              <button data-prev type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white">Kısayollar</button>
              <button data-next type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white">Takvim</button>
            </div>
          </div>
          <div id="content-addAudit" class="relative grid grid-cols-1 gap-3 px-4 py-4 md:grid-cols-4">
            <div id="loading-addAudit" class="card-loading-wrapper absolute inset-0 z-10 hidden items-center justify-center bg-white/80"><div class="h-7 w-7 animate-spin rounded-full border-2 border-amber-500 border-r-transparent"></div></div>
            <input id="cNickName" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Firma" />
            <input id="cstandartInput" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Standart" />
            <input id="cDenetimInput" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="Denetim" />
            <input id="a1Basla" type="date" class="rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <input id="a1Bitis" type="date" class="rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <input id="a1Manday" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="A1 Manday" />
            <input id="a1KDenetci" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="A1 Başdenetçi" />
            <input id="a2Basla" type="date" class="rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <input id="a2Bitis" type="date" class="rounded-md border border-slate-300 px-3 py-2 text-sm" />
            <input id="a2Manday" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="A2 Manday" />
            <input id="a2KDenetci" class="rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="A2 Başdenetçi" />
            <button id="clear-audit-button" class="rounded-md border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700">Temizle</button>
          </div>
        </section>

        <section data-slide class="hidden">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <h5 class="text-sm font-semibold text-slate-700">Takvim</h5>
            <button data-prev type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white">Geri</button>
          </div>
          <div class="px-4 py-4 text-sm text-slate-600">Takvim görünümü bu kartta listelenecek.</div>
        </section>
      </div>
      <div class="flex items-center justify-center gap-2 border-t border-slate-200 px-4 py-3">
        <button data-indicator class="h-2 w-2 rounded-full bg-slate-800"></button>
        <button data-indicator class="h-2 w-2 rounded-full bg-slate-300"></button>
        <button data-indicator class="h-2 w-2 rounded-full bg-slate-300"></button>
      </div>
    </div>

    <div id="certificateCarousel" class="stack-card rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="carousel-track relative overflow-hidden">
        <section data-slide class="block">
          <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
            <h5 class="text-sm font-semibold text-slate-700">Sertifikalar</h5>
            <div class="flex items-center gap-2">
              <p id="certificateCounter" class="text-xs text-slate-500"></p>
              <button id="btn-refresh-certs" class="rounded-md border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">Getir / Yenile</button>
