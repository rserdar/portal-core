---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { ArrowLeft, Save, RefreshCw } from 'lucide-astro';

/**
 * ✏️ Firma Düzenleme Sayfası
 * URL: /company/edit?id=42
 *
 * CompanyService.update() ile kayıt günceller.
 * Alan isimlerini _buildRowByHeaders ile eşleşecek şekilde gönderir.
 */
---

<DashboardLayout title="Firma Düzenle">
  <div class="max-w-5xl mx-auto pb-24">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <a id="btn-back" href="/company" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
          <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
          Geri
        </a>
        <span class="text-border-main">/</span>
        <span class="text-xs font-bold text-muted" id="header-nick">Yükleniyor...</span>
      </div>
      <div class="flex items-center gap-2">
        <a id="btn-view" href="#" class="px-4 py-2 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-xs font-bold rounded-xl transition-all">
          Profil Görüntüle
        </a>
        <button id="btn-save" type="button" class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-2xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all disabled:opacity-60 disabled:cursor-not-allowed">
          <Save size={14} />
          <span id="save-label">Kaydet</span>
        </button>
      </div>
    </div>

    <!-- Loading overlay (before data arrives) -->
    <div id="form-skeleton" class="space-y-6">
      {[1,2,3,4].map(() => (
        <div class="bg-surface border border-border-main rounded-3xl p-8 animate-pulse">
          <div class="h-4 bg-surface-hover rounded w-48 mb-6"></div>
          <div class="grid grid-cols-3 gap-4">
            <div class="h-10 bg-surface-hover rounded-xl col-span-2"></div>
            <div class="h-10 bg-surface-hover rounded-xl"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Toast -->
    <div id="toast-container" class="fixed inset-x-4 bottom-4 sm:inset-x-auto sm:right-6 sm:bottom-6 z-[100] flex flex-col gap-3 pointer-events-none sm:max-w-sm"></div>

    <form id="edit-form" class="hidden space-y-8" autocomplete="off">
      <!-- Hidden ID -->
      <input type="hidden" id="f-id" name="id" />

      <!-- ── 1. Genel Bilgiler ─────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M3 7V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/><path d="M5 21V7"/><path d="M19 21V7"/></svg>
          </div>
          <h2 class="text-base font-bold">Genel Bilgiler</h2>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Ünvanı</label>
          <input type="text" id="f-unvan" name="unvan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Örn: ABC Teknolojileri Ltd. Şti." />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Kısa Adı (Nick / Klasör Adı)</label>
            <input type="text" id="f-nick" name="nickname" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Örn: ABC Teknoloji" />
            <p class="text-[10px] text-indigo-400/70 italic leading-tight">* Google Drive klasör adı olarak kullanılır.</p>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Danışman</label>
            <select id="f-dan" name="dan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold appearance-none">
              <option value="">Seçiniz...</option>
            </select>
          </div>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Notları</label>
          <textarea id="f-not" name="not" rows={3} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[80px]" placeholder="Dahili notlar..."></textarea>
        </div>
      </section>

      <!-- ── 2. Adres & Kapsam ────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h2 class="text-base font-bold">Adres & Kapsam</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Şehir / Ülke</label>
            <div class="flex gap-2">
              <input type="text" id="f-sehir" name="sehir" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Şehir" />
              <input type="text" id="f-ulke" name="ulke" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ülke" />
            </div>
          </div>
          <div class="md:col-span-2 space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Tam Adres</label>
            <input type="text" id="f-adres" name="adres" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Merkez Adres" />
          </div>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Şube / Yazışma Adresi</label>
          <input type="text" id="f-yazisma" name="yazisma" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Varsa şube adresi..." />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Türkçe Kapsam</label>
              <div class="flex gap-2">
                <button type="button" id="btn-kapsam-big" class="px-3 py-1 bg-surface border border-border-main rounded-lg text-[10px] font-bold hover:bg-surface-hover transition-all">BÜYÜK</button>
                <button type="button" id="btn-kapsam-translate" class="px-3 py-1 bg-surface border border-indigo-500/30 rounded-lg text-[10px] font-bold text-indigo-400 hover:bg-surface-hover transition-all">İngilizceye Çevir</button>
              </div>
            </div>
            <textarea id="f-kapsam" name="kapsam" rows={4} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[100px]" placeholder="Sertifika kapsamı (TR)..."></textarea>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">İngilizce Scope</label>
              <div class="flex gap-2">
                <button type="button" id="btn-scope-big" class="px-3 py-1 bg-surface border border-border-main rounded-lg text-[10px] font-bold hover:bg-surface-hover transition-all">BIG</button>
                <button type="button" id="btn-scope-translate" class="px-3 py-1 bg-surface border border-indigo-500/30 rounded-lg text-[10px] font-bold text-indigo-400 hover:bg-surface-hover transition-all">Türkçeye Çevir</button>
              </div>
            </div>
            <textarea id="f-scope" name="scope" rows={4} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[100px]" placeholder="Certificate scope (EN)..."></textarea>
          </div>
        </div>
      </section>

      <!-- ── 3. İletişim ──────────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.68 9.82a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2 class="text-base font-bold">İletişim</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Telefon</label>
            <input type="text" id="f-tel" name="tel" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Faks</label>
            <input type="text" id="f-faks" name="faks" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">E-Posta</label>
            <input type="email" id="f-mail" name="mail" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Web Sitesi</label>
            <input type="text" id="f-www" name="www" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vergi Dairesi</label>
            <input type="text" id="f-vergiD" name="vergiD" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vergi Numarası</label>
            <input type="text" id="f-vergiN" name="vergiN" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
      </section>

      <!-- ── 4. Yetkililer ────────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h2 class="text-base font-bold">Yetkililer & Kişiler</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">KYT / Yönetim Temsilcisi</label>
            <input type="text" id="f-kyt" name="kyt" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yetkili Adı</label>
            <input type="text" id="f-yetA" name="yetA" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yetkili Ünvanı</label>
            <input type="text" id="f-yetU" name="yetU" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">İrtibat Kişisi</label>
            <input type="text" id="f-irtA" name="irtA" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">İrtibat Ünvanı</label>
            <input type="text" id="f-irtU" name="irtU" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">İrtibat Tel</label>
            <input type="text" id="f-irtN" name="irtN" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">İrtibat Mail</label>
            <input type="email" id="f-irtM" name="irtM" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
      </section>

      <!-- ── 5. Çalışma Düzeni ────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-sky-500/10 flex items-center justify-center text-sky-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h2 class="text-base font-bold">Çalışma Düzeni</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Toplam Çalışan</label>
            <input type="number" id="f-tcs" name="tcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yönetim</label>
            <input type="number" id="f-ycs" name="ycs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Üretim</label>
            <input type="number" id="f-ucs" name="ucs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yarı Zamanlı</label>
            <input type="number" id="f-yzcs" name="yzcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Taşeron</label>
            <input type="number" id="f-tascs" name="tascs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Alan (m²)</label>
            <input type="text" id="f-alan" name="alan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vardiya</label>
            <input type="text" id="f-vardiya" name="vardiya" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Departman Sayısı</label>
            <input type="text" id="f-dept" name="dept" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
      </section>

      <!-- ── 6. Sınıflandırma ─────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </div>
          <h2 class="text-base font-bold">Sınıflandırma</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">NACE</label>
            <input type="text" id="f-nace" name="nace" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">EA</label>
            <input type="text" id="f-ea" name="ea" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2 md:col-span-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yapılan İşler</label>
            <input type="text" id="f-yapis" name="yapis" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
      </section>

    </form>

    <!-- Sticky Save Footer -->
    <div id="save-footer" class="fixed bottom-0 left-0 right-0 z-40 pointer-events-none hidden">
      <div class="max-w-5xl mx-auto px-4 lg:px-8 pb-6 pointer-events-auto">
        <div class="bg-surface/90 backdrop-blur-xl border border-border-main shadow-2xl rounded-2xl px-6 py-4 flex items-center justify-between">
          <p class="text-xs font-bold text-muted" id="footer-company-name">Değişiklikler kaydedilmedi</p>
          <div class="flex items-center gap-3">
            <button type="button" id="btn-cancel" class="px-4 py-2 bg-surface-hover border border-border-main hover:border-rose-500/30 text-rose-400 text-xs font-bold rounded-xl transition-all">
              İptal
            </button>
            <button type="button" id="btn-save-footer" class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all">
              <Save size={14} />
              Değişiklikleri Kaydet
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { showToast } from '../../lib/toast';

  // ─── Helpers ─────────────────────────────────────────────────────────────────

  function g(obj: Record<string, any>, ...keys: string[]): string {
    for (const k of keys) {
      const v = obj?.[k];
      if (v !== undefined && v !== null && String(v).trim() !== '') return String(v).trim();
    }
    return '';
  }

  function val(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null)?.value?.trim() || '';
  }

  function setVal(id: string, value: string) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (el) el.value = value;
  }

  // ─── URL Param ────────────────────────────────────────────────────────────────

  const params = new URLSearchParams(location.search);
  const firmaId = params.get('id') || '';
  let companyEtag = '';

  // Update back/view links
  const btnBack = document.getElementById('btn-back') as HTMLAnchorElement | null;
  const btnView = document.getElementById('btn-view') as HTMLAnchorElement | null;
  if (btnBack) btnBack.href = firmaId ? `/company?id=${firmaId}` : '/search';
  if (btnView) btnView.href = firmaId ? `/company?id=${firmaId}` : '/search';

  // ─── Load Consultants ─────────────────────────────────────────────────────────

  async function loadConsultants(currentDan: string) {
    const res = await api.call('getConsultants');
    const select = document.getElementById('f-dan') as HTMLSelectElement | null;
    if (!select || !res?.data) return;
    const consultants: string[] = res.data;
    select.innerHTML = '<option value="">Seçiniz...</option>';
    consultants.forEach(d => {
      const opt = document.createElement('option');
      opt.value = d;
      opt.textContent = d;
      if (d === currentDan) opt.selected = true;
      select.appendChild(opt);
    });
  }

  // ─── Populate Form ────────────────────────────────────────────────────────────

  async function loadCompany() {
    if (!firmaId) {
      document.getElementById('form-skeleton')!.innerHTML = '<p class="text-sm text-rose-400 font-bold p-8">Geçersiz firma ID.</p>';
      return;
    }

    const res = await api.call('getCompanyById', { id: firmaId });
    const c = res?.data;
    if (!c) {
      document.getElementById('form-skeleton')!.innerHTML = `<p class="text-sm text-rose-400 font-bold p-8">Firma bulunamadı (ID: ${firmaId})</p>`;
      return;
    }

    // Field mappings (API key → form field id)
    const fields: [string, string[]][] = [
      ['f-unvan',   ['Unvan', 'unvan']],
      ['f-nick',    ['Firma Adı', 'Nick', 'nick', 'FirmaAdi']],
      ['f-not',     ['Firma Not', 'Not', 'not']],
      ['f-adres',   ['Adres', 'adres']],
      ['f-sehir',   ['İl', 'Il', 'Şehir', 'Sehir', 'il']],
      ['f-ulke',    ['Ülke', 'Ulke', 'ulke']],
      ['f-yazisma', ['Yazışma Adresi', 'YazismaAdresi', 'yazisma', 'Şube Adresi']],
      ['f-kapsam',  ['Türkçe Kapsam', 'Sertifika Kapsamı (TR)', 'Kapsam', 'kapsam']],
      ['f-scope',   ['İngilizce Kapsam', 'Sertifika Kapsamı (EN)', 'Scope', 'scope']],
      ['f-tel',     ['Telefon', 'Tel', 'tel']],
      ['f-faks',    ['Faks', 'faks']],
      ['f-mail',    ['Mail', 'mail', 'E-Posta']],
      ['f-www',     ['İnternet', 'Web', 'www', 'web']],
      ['f-vergiD',  ['Vergi Dairesi', 'VergiDairesi', 'vergiD']],
      ['f-vergiN',  ['Vergi Numarası', 'VergiNumarasi', 'vergiN']],
      ['f-kyt',     ['KYT', 'Kalite Yönetim Temsilcisi', 'kyt']],
      ['f-yetA',    ['Yetkili Adı', 'YetkiliAdi', 'yetA']],
      ['f-yetU',    ['Yetkili Ünvanı', 'YetkiliUnvani', 'yetU']],
      ['f-irtA',    ['İrtibat Kişisi', 'IrtibatKisi', 'irtA']],
      ['f-irtU',    ['İrtibat Ünvanı', 'IrtibatUnvani', 'irtU']],
      ['f-irtN',    ['İrtibat Tel', 'IrtibatKisiNumarasi', 'irtN']],
      ['f-irtM',    ['İrtibat Mail', 'IrtibatKisisMail', 'irtM']],
      ['f-tcs',     ['Toplam Çalışan Sayısı', 'TCS', 'tcs']],
      ['f-ycs',     ['Yönetim Çalışan Sayısı', 'YCS', 'ycs']],
      ['f-ucs',     ['Üretim Çalışan Sayısı', 'UCS', 'ucs']],
      ['f-yzcs',    ['Yarı Zamanlı Çalışan Sayısı', 'YZCS', 'yzcs']],
      ['f-tascs',   ['Taşeron Çalışan Sayısı', 'TASCS', 'tascs']],
      ['f-alan',    ['Alan', 'alan']],
      ['f-vardiya', ['Vardiya', 'vardiya']],
      ['f-dept',    ['Departman', 'departman', 'dept']],
      ['f-nace',    ['NACE', 'nace']],
      ['f-ea',      ['EA', 'ea']],
      ['f-yapis',   ['Yapılan İş', 'YapilanIs', 'yapis']],
    ];

    fields.forEach(([id, keys]) => setVal(id, g(c, ...keys)));
    setVal('f-id', firmaId);
    companyEtag = g(c, '__etag');

    const dan = g(c, 'Danışman', 'Danisman', 'dan', 'danisman');
    await loadConsultants(dan);

    const nick = g(c, 'Firma Adı', 'Nick', 'nick');
    const headerNick = document.getElementById('header-nick');
    if (headerNick) headerNick.textContent = nick || `Firma #${firmaId}`;

    const footerName = document.getElementById('footer-company-name');
    if (footerName) footerName.textContent = nick || `Firma #${firmaId}`;

    document.title = `${nick || 'Firma'} Düzenle | Astro Portal`;

    // Show form
    document.getElementById('form-skeleton')?.classList.add('hidden');
    document.getElementById('edit-form')?.classList.remove('hidden');
    document.getElementById('save-footer')?.classList.remove('hidden');
  }

  // ─── Kapsam Buttons ───────────────────────────────────────────────────────────

  document.getElementById('btn-kapsam-big')?.addEventListener('click', () => {
    const el = document.getElementById('f-kapsam') as HTMLTextAreaElement | null;
    if (el) el.value = el.value.toLocaleUpperCase('tr-TR');
  });

  document.getElementById('btn-scope-big')?.addEventListener('click', () => {
    const el = document.getElementById('f-scope') as HTMLTextAreaElement | null;
    if (el) el.value = el.value.toUpperCase();
  });

  document.getElementById('btn-kapsam-translate')?.addEventListener('click', async () => {
    const text = val('f-kapsam');
    if (!text) return;
    showToast('Çeviriliyor...', 'info');
    const res = await api.translate(text, true);
    if (res?.data) {
      setVal('f-scope', res.data);
      showToast('Çeviri tamamlandı.', 'success');
    } else {
      showToast('Çeviri başarısız.', 'error');
    }
  });

  document.getElementById('btn-scope-translate')?.addEventListener('click', async () => {
    const text = val('f-scope');
    if (!text) return;
    showToast('Çeviriliyor...', 'info');
    const res = await api.translate(text, false);
    if (res?.data) {
      setVal('f-kapsam', res.data);
      showToast('Çeviri tamamlandı.', 'success');
    } else {
      showToast('Çeviri başarısız.', 'error');
    }
  });

  // ─── Save ─────────────────────────────────────────────────────────────────────

  async function saveForm() {
    const btnSave = document.getElementById('btn-save') as HTMLButtonElement | null;
    const btnSaveFooter = document.getElementById('btn-save-footer') as HTMLButtonElement | null;
    const saveLabel = document.getElementById('save-label');

    const disable = (d: boolean) => {
      if (btnSave)       btnSave.disabled = d;
      if (btnSaveFooter) btnSaveFooter.disabled = d;
      if (saveLabel) saveLabel.textContent = d ? 'Kaydediliyor...' : 'Kaydet';
    };

    disable(true);

    const companyInfo = {
      nickname: val('f-nick'),
      unvan:    val('f-unvan'),
      adres:    val('f-adres'),
      sehir:    val('f-sehir'),
      ulke:     val('f-ulke'),
      yazisma:  val('f-yazisma'),
      kapsam:   val('f-kapsam'),
      scope:    val('f-scope'),
      tel:      val('f-tel'),
      faks:     val('f-faks'),
      mail:     val('f-mail'),
      www:      val('f-www'),
      vergiD:   val('f-vergiD'),
      vergiN:   val('f-vergiN'),
      kyt:      val('f-kyt'),
      yetA:     val('f-yetA'),
      yetU:     val('f-yetU'),
      irtA:     val('f-irtA'),
      irtU:     val('f-irtU'),
      irtN:     val('f-irtN'),
      irtM:     val('f-irtM'),
      dan:      val('f-dan'),
      not:      val('f-not'),
      tcs:      val('f-tcs'),
      ycs:      val('f-ycs'),
      ucs:      val('f-ucs'),
      yzcs:     val('f-yzcs'),
      tascs:    val('f-tascs'),
      alan:     val('f-alan'),
      vardiya:  val('f-vardiya'),
      dept:     val('f-dept'),
      nace:     val('f-nace'),
      ea:       val('f-ea'),
      yapis:    val('f-yapis'),
    };

    try {
      const res = await api.call('updateCompany', { id: firmaId, companyInfo, expectedEtag: companyEtag || undefined });
      if (res?.success) {
        companyEtag = String((res as any)?.data?.etag || companyEtag || '');
        showToast('✓ Firma başarıyla güncellendi.', 'success');
      } else if (res?.error === 'CONFLICT') {
        showToast('✕ Bu kayıt başka bir kullanıcı tarafından güncellendi. Lütfen sayfayı yenileyip tekrar deneyin.', 'error');
      } else {
        showToast(`✕ Kayıt başarısız: ${res?.error || 'Bilinmeyen hata.'}`, 'error');
      }
    } catch (e: any) {
      showToast(`✕ Bağlantı hatası: ${e?.message || e}`, 'error');
    } finally {
      disable(false);
    }
  }

  document.getElementById('btn-save')?.addEventListener('click', saveForm);
  document.getElementById('btn-save-footer')?.addEventListener('click', saveForm);

  document.getElementById('btn-cancel')?.addEventListener('click', () => {
    if (firmaId) location.href = `/company?id=${firmaId}`;
    else history.back();
  });

  // ─── Boot ─────────────────────────────────────────────────────────────────────
  loadCompany();
</script>
