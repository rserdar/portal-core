  async function loadCertificates() {
    const grid = el('cert-list');
    if (!grid) return;

    grid.innerHTML = '<tr><td colspan="9" class="p-8 text-center text-slate-500">Yükleniyor...</td></tr>';

    try {
      if (!firmaId) return;
      const res = await api.getCertificatesByFirmaId(firmaId);
      if (!res.success || !Array.isArray(res.data)) {
        grid.innerHTML = '<tr><td colspan="9" class="p-8 text-center text-rose-600">Sertifika verileri alınamadı.</td></tr>';
        return;
      }

      const rows = res.data;
      const counter = el('certificateCounter');
      if (counter) counter.textContent = `Sertifika Sayısı: ${rows.length}`;

      if (!rows.length) {
        grid.innerHTML = '<tr><td colspan="9" class="p-8 text-center text-slate-500">Sertifika kaydı bulunamadı.</td></tr>';
        return;
      }

      grid.innerHTML = rows.map((row) => {
        const standard = row[3] === 'Diğer' ? (row[20] || 'Diğer') : (row[3] || '-');
        return `
          <tr class="border-t border-slate-200 text-slate-700">
            <td class="p-3">${row[0] || '-'}</td>
            <td class="p-3">${row[6] || '-'}</td>
            <td class="p-3">${standard}</td>
            <td class="p-3">${row[5] || '-'}</td>
            <td class="p-3">${row[14] || '-'}</td>
            <td class="p-3">${row[7] || '-'}</td>
            <td class="p-3">${row[16] || '-'}</td>
            <td class="p-3">${row[17] || '-'}</td>
            <td class="p-3 text-right"><button class="rounded border border-slate-300 px-2 py-1 text-[11px] text-slate-600">Detay</button></td>
          </tr>
        `;
      }).join('');
    } catch (error) {
      console.error(error);
      grid.innerHTML = '<tr><td colspan="9" class="p-8 text-center text-rose-600">Sistem hatası oluştu.</td></tr>';
    }
  }

  async function loadTests() {
    const grid = el('test-list');
    if (!grid) return;

    grid.innerHTML = '<tr><td colspan="4" class="p-6 text-center text-slate-500">Yükleniyor...</td></tr>';

    try {
      if (!firmaId) return;
      const res = await api.getTestsByFirmaId(firmaId);
      if (!res.success || !Array.isArray(res.data)) {
        grid.innerHTML = '<tr><td colspan="4" class="p-6 text-center text-rose-600">Test verileri alınamadı.</td></tr>';
        return;
      }

      const rows = res.data;
      const counter = el('testCounter');
      if (counter) counter.textContent = `Test Sayısı: ${rows.length}`;

      if (!rows.length) {
        grid.innerHTML = '<tr><td colspan="4" class="p-6 text-center text-slate-500">Test kaydı bulunamadı.</td></tr>';
        return;
      }

      grid.innerHTML = rows.map((row) => {
        return `
          <tr class="border-t border-slate-200 text-slate-700">
            <td class="p-3">${row[0] || '-'}</td>
            <td class="p-3">${row[13] || '-'}</td>
            <td class="p-3 font-medium">${row[3] || '-'}</td>
            <td class="p-3">${row[4] || '-'}</td>
            <td class="p-3">${row[5] || '-'}</td>
          </tr>
        `;
      }).join('');
    } catch (error) {
      console.error(error);
      grid.innerHTML = '<tr><td colspan="4" class="p-6 text-center text-rose-600">Sistem hatası oluştu.</td></tr>';
    }
  }

  async function init() {
    if (!firmaId) {
      window.location.href = '/search';
      return;
    }

    const mainCarousel = initCarousel('companyCarousel');
    initCarousel('auditCarousel');
    initCarousel('certificateCarousel');
    initCarousel('testCarousel');
    initCarousel('formCarousel');
    bindMainCarousel(mainCarousel);
    ensureLegacyHooks();

    el('btn-refresh-certs')?.addEventListener('click', () => {
      loadCertificates();
    });

    el('btn-refresh-tests')?.addEventListener('click', () => {
      loadTests();
    });

    console.time('⚡ Full Page Load');
    
    // 🚀 ZERO LATENCY STRATEGY: Local-First Render
    const localFirma = $companies.get().find((f: any) => String(f.id || f['Firma No']) === String(firmaId));
    if (localFirma) {
      console.log('✨ Instant Render from Local Store');
      renderCompany(localFirma);
      // Temel bilgiler geldiği an sayfa INTERAKTİF (0ms)
    }

    // 🚀 ASENKRON ARKA PLAN YÜKLEME (Non-Blocking Background Refresh)
    // AwaiT KALDIRILDI: Bunlar bağımsız şekilde dolacak
    api.getCompanyById(firmaId).then(res => {
      if (res.success && res.data) {
        renderCompany(res.data);
        console.log('✅ Company refreshed from KV:', res.fromCache || false);
      }
    });

    loadCertificates(); // Arka planda başlar, tabloyu kendi doldurur
    loadTests();        // Arka planda başlar, tabloyu kendi doldurur

    console.timeEnd('⚡ Full Page Load');
  }

  init();
</script>

