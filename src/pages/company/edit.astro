---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { ArrowLeft, Save } from 'lucide-astro';

/**
 * ✏️ Firma Düzenleme Sayfası
 * URL: /company/edit?id=42
 *
 * CompanyService.update() ile kayıt günceller.
 * Alan isimlerini _buildRowByHeaders ile eşleşecek şekilde gönderir.
 */
---

<DashboardLayout title="Firma Düzenle">
  <div class="max-w-5xl mx-auto pb-24">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <a id="btn-back" href="/company" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
          <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
          Geri
        </a>
        <span class="text-border-main">/</span>
        <span class="text-xs font-bold text-muted" id="header-nick">Yükleniyor...</span>
      </div>
      <div class="flex items-center gap-2">
        <a id="btn-view" href="#" class="px-4 py-2 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-xs font-bold rounded-xl transition-all">
          Profil Görüntüle
        </a>
        <button id="btn-save" type="button" class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-2xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all disabled:opacity-60 disabled:cursor-not-allowed">
          <Save size={14} />
          <span id="save-label">Kaydet</span>
        </button>
      </div>
    </div>

    <!-- Loading overlay (before data arrives) -->
    <div id="form-skeleton" class="space-y-6">
      {[1,2,3,4].map(() => (
        <div class="bg-surface border border-border-main rounded-3xl p-8 animate-pulse">
          <div class="h-4 bg-surface-hover rounded w-48 mb-6"></div>
          <div class="grid grid-cols-3 gap-4">
            <div class="h-10 bg-surface-hover rounded-xl col-span-2"></div>
            <div class="h-10 bg-surface-hover rounded-xl"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Toast -->
    <!-- form -->

    <form id="edit-form" class="hidden space-y-8" autocomplete="off">
      <!-- Hidden ID -->
      <input type="hidden" id="f-id" name="id" />

      <!-- ── 1. Genel Bilgiler ─────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M3 7V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/><path d="M5 21V7"/><path d="M19 21V7"/></svg>
          </div>
          <h2 class="text-base font-bold">Genel Bilgiler</h2>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Ünvanı</label>
          <input type="text" id="f-unvan" name="unvan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Örn: ABC Teknolojileri Ltd. Şti." />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Kısa Adı (Nick / Klasör Adı)</label>
            <input type="text" id="f-nick" name="nickname" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Örn: ABC Teknoloji" />
            <p class="text-[10px] text-indigo-400/70 italic leading-tight">* Google Drive klasör adı olarak kullanılır.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
          <!-- Logo -->
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Logo</label>
            <div class="flex gap-2">
              <input type="text" id="f-logo" name="logo" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold text-sm" placeholder="Drive dosya ID'si" />
              <button type="button" id="btn-logo-select" title="Drive'dan Seç"
                class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-surface border border-border-main hover:border-indigo-500/40 rounded-xl text-[11px] font-bold text-indigo-400 hover:text-indigo-300 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5"/></svg>
                Seç
              </button>
              <input type="file" id="logo-file-input" accept="image/png,image/jpeg,image/gif" class="hidden" />
              <button type="button" id="btn-logo-upload" title="Bilgisayardan Yükle"
                class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-surface border border-border-main hover:border-emerald-500/40 rounded-xl text-[11px] font-bold text-emerald-400 hover:text-emerald-300 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Yükle
              </button>
            </div>
          </div>
          <!-- Kaşe & İmza -->
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Kaşe & İmza</label>
            <div class="flex gap-2">
              <input type="text" id="f-kase" name="kase" class="flex-1 bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold text-sm" placeholder="Drive dosya ID'si" />
              <button type="button" id="btn-kase-select" title="Drive'dan Seç"
                class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-surface border border-border-main hover:border-indigo-500/40 rounded-xl text-[11px] font-bold text-indigo-400 hover:text-indigo-300 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5"/></svg>
                Seç
              </button>
              <input type="file" id="kase-file-input" accept="image/png,image/jpeg,image/gif" class="hidden" />
              <button type="button" id="btn-kase-upload" title="Bilgisayardan Yükle"
                class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-surface border border-border-main hover:border-emerald-500/40 rounded-xl text-[11px] font-bold text-emerald-400 hover:text-emerald-300 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Yükle
              </button>
            </div>
          </div>
        </div>

        <!-- Drive Dosya Seçici Mini Panel -->
        <div id="drive-picker-panel" class="hidden mt-3 bg-surface-hover border border-border-main rounded-2xl p-4 space-y-3">
          <div class="flex items-center justify-between">
            <p class="text-xs font-bold text-muted" id="drive-picker-title">Drive'dan Dosya Seç</p>
            <button type="button" id="btn-picker-close" class="text-muted hover:text-main transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
          <div id="drive-picker-list" class="space-y-1 max-h-48 overflow-y-auto text-sm">
            <p class="text-xs text-muted italic">Yükleniyor...</p>
          </div>
        </div>
      </section>

      <!-- ── 2. Adres & Kapsam ────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="flex-1 flex items-center justify-between">
            <h2 class="text-base font-bold">Adres</h2>
            <button id="address-upper-btn" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-main hover:bg-surface transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary/50">BÜYÜK YAP</button>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="md:col-span-2 space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Tam Adres</label>
            <input type="text" id="f-adres" name="adres" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Merkez Adres" />
          </div>
          <div class="md:col-span-1 space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Şehir</label>
            <input type="text" id="f-city" name="city" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Şehir" />
            <label class="flex items-center gap-2 mt-1 cursor-pointer select-none">
              <input type="checkbox" id="yurtdisi-cb" class="w-4 h-4 rounded accent-indigo-500">
              <span class="text-xs font-semibold text-gray-500">Yurt Dışı Firma</span>
            </label>
            <div id="ulke-row" class="hidden">
              <input type="text" id="f-ulke" name="ulke" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ülke" />
            </div>
          </div>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Şube / Yazışma Adresi</label>
          <input type="text" id="f-yazisma" name="yazisma" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Varsa şube adresi..." />
        </div>
      </section>

      <!-- ── 3. İletişim & Vergi ────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.68 9.82a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2 class="text-base font-bold">İletişim & Vergi</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Telefon</label>
            <input type="text" id="f-tel" name="tel" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="+90 ..." />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Faks</label>
            <input type="text" id="f-faks" name="faks" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="+90 ..." />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">E-Posta</label>
            <input type="email" id="f-mail" name="mail" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="info@firma.com" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Web Sitesi</label>
            <input type="text" id="f-www" name="www" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="www.firma.com" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vergi Dairesi</label>
            <input type="text" id="f-vergi_dairesi" name="vergi_dairesi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vergi Numarası</label>
            <input type="text" id="f-vergi_no" name="vergi_no" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yönetim Temsilcisi</label>
            <input type="text" id="f-kyt" name="kyt" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ad Soyad" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yetkili Adı</label>
            <input type="text" id="f-yetkili_adi" name="yetkili_adi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ad Soyad" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yetkili Ünvanı</label>
            <input type="text" id="f-yetkili_unvani" name="yetkili_unvani" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Genel Müdür, vb." />
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-4">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">İrtibat Kişisi</label>
            <input type="text" id="f-irtibat_kisi" name="irtibat_kisi" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ad Soyad" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">İrtibat Ünvanı</label>
            <input type="text" id="f-irtibat_unvani" name="irtibat_unvani" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="Ünvan" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">İrtibat Telefonu</label>
            <input type="text" id="f-irtibat_tel" name="irtibat_tel" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="+90 ..." />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">İrtibat E-Posta</label>
            <input type="email" id="f-irtibat_mail" name="irtibat_mail" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" placeholder="irtibat@firma.com" />
          </div>
        </div>
      </section>

      <!-- ── 5. Çalışma Düzeni ────────────────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h2 class="text-base font-bold">Operasyonel Veriler</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Alan (m²)</label>
            <input type="text" id="f-alan" name="alan" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vardiya</label>
            <input type="number" id="f-vardiya" name="vardiya" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Departman Sayısı</label>
            <input type="number" id="f-dept" name="departman" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Toplam Çalışan</label>
            <input type="number" id="f-tcs" name="tcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yönetim</label>
            <input type="number" id="f-ycs" name="ycs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Üretim</label>
            <input type="number" id="f-ucs" name="ucs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Aynı İşte Çalışan</label>
            <input type="number" id="f-acs" name="acs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yarı Zamanlı</label>
            <input type="number" id="f-yzcs" name="yzcs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Taşeron</label>
            <input type="number" id="f-tascs" name="tascs" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Yapılan İşler</label>
            <textarea id="f-yapilan_is" name="yapilan_is" rows={3} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[80px]"></textarea>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Notları</label>
            <textarea id="f-firma_not" name="firma_not" rows={3} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[80px]" placeholder="Özel notlar veya hatırlatıcılar..."></textarea>
          </div>
        </div>
      </section>


      <!-- ── 7. Doküman & Teknik Dosya ─────────────────────────────── -->
      <section class="bg-surface border border-border-main shadow-xl p-8 rounded-3xl space-y-6">
        <div class="flex items-center gap-3 border-b border-border-main pb-4">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h2 class="text-base font-bold">Doküman & Teknik Dosya</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Firma Sınıfı</label>
            <input type="text" id="f-sinif" name="sinif" class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold" />
          </div>
          <label class="flex items-center gap-3 bg-surface-hover border border-border-main rounded-xl px-4 py-3">
            <input type="checkbox" id="f-dokuman" name="dokuman" class="w-4 h-4 rounded accent-rose-500">
            <span class="text-sm font-semibold cursor-pointer select-none">Firma Dokümanları mevcut</span>
          </label>
          <label class="flex items-center gap-3 bg-surface-hover border border-border-main rounded-xl px-4 py-3">
            <input type="checkbox" id="f-teknik" name="teknik" class="w-4 h-4 rounded accent-rose-500">
            <span class="text-sm font-semibold cursor-pointer select-none">Teknik Dosyası var</span>
          </label>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Teknik Dosya Kapsamı</label>
          <textarea id="f-tkapsam" name="tkapsam" rows={4} class="w-full bg-surface-hover border border-border-main rounded-xl px-4 py-2.5 text-main focus:ring-2 focus:ring-primary/50 transition-all font-semibold min-h-[100px]"></textarea>
        </div>
      </section>

    </form>

    <!-- Sticky Save Footer -->
    <div id="save-footer" class="fixed bottom-0 left-0 right-0 z-40 pointer-events-none hidden">
      <div class="max-w-5xl mx-auto px-4 lg:px-8 pb-6 pointer-events-auto">
        <div class="bg-surface/90 backdrop-blur-xl border border-border-main shadow-2xl rounded-2xl px-6 py-4 flex items-center justify-between">
          <p class="text-xs font-bold text-muted" id="footer-company-name">Değişiklikler kaydedilmedi</p>
          <div class="flex items-center gap-3">
            <button type="button" id="btn-cancel" class="px-4 py-2 bg-surface-hover border border-border-main hover:border-rose-500/30 text-rose-400 text-xs font-bold rounded-xl transition-all">
              İptal
            </button>
            <button type="button" id="btn-save-footer" class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all">
              <Save size={14} />
              Değişiklikleri Kaydet
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { toast } from '../../lib/toast';
  import { DB } from '../../lib/db';
  import { $companies } from '../../lib/store';

  // ─── Lifecycle & Cleanup ─────────────────────────────────────────────────────

  let cleanupTasks: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupTasks.push(fn);
  }

  function runCleanups() {
    cleanupTasks.forEach(fn => { try { fn(); } catch(e) { console.error('Cleanup error:', e); } });
    cleanupTasks = [];
  }

  // ─── Helpers ─────────────────────────────────────────────────────────────────

  function g(obj: Record<string, any>, ...keys: string[]): string {
    for (const k of keys) {
      const v = obj?.[k];
      if (v !== undefined && v !== null && String(v).trim() !== '') return String(v).trim();
    }
    return '';
  }

  function val(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null)?.value?.trim() || '';
  }

  function setVal(id: string, value: string) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (el) el.value = value;
  }

  function setChecked(id: string, value: any) {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (!el) return;
    const normalized = String(value ?? '').trim().toLocaleLowerCase('tr-TR');
    el.checked = ['true', '1', 'evet', 'yes', 'var', 'x'].includes(normalized);
  }

  // ─── URL Param ────────────────────────────────────────────────────────────────

  const params = new URLSearchParams(location.search);
  const firmaId = params.get('id') || '';
  let companyEtag = '';
  let companyUpdatedAt = '';

  // Update back/view links
  const btnBack = document.getElementById('btn-back') as HTMLAnchorElement | null;
  const btnView = document.getElementById('btn-view') as HTMLAnchorElement | null;
  if (btnBack) btnBack.href = firmaId ? `/company?id=${firmaId}` : '/search';
  if (btnView) btnView.href = firmaId ? `/company?id=${firmaId}` : '/search';

  // ─── Populate Form ────────────────────────────────────────────────────────────

  async function loadCompany() {
    if (!firmaId) {
      document.getElementById('form-skeleton')!.innerHTML = '<p class="text-sm text-rose-400 font-bold p-8">Geçersiz firma ID.</p>';
      return;
    }

    const res = await api.getCompanyById(firmaId);
    const c = res?.data;
    if (!c) {
      const skelEl = document.getElementById('form-skeleton');
      if (skelEl) {
        skelEl.innerHTML = `<p class="text-sm text-rose-400 font-bold p-8">Firma bulunamadı (ID: ${firmaId})</p>`;
      }
      return;
    }

    // Field mappings (API key → form field id)
    const fields: [string, string[]][] = [
      ['f-unvan',          ['unvan']],
      ['f-nick',           ['nickname', 'nick']],
      ['f-firma_not',      ['firma_not', 'not']],
      ['f-adres',          ['adres']],
      ['f-city',           ['city', 'sehir', 'il']],
      ['f-ulke',           ['ulke']],
      ['f-yazisma',        ['yazisma']],
      ['f-tel',            ['tel']],
      ['f-faks',           ['faks']],
      ['f-mail',           ['mail']],
      ['f-www',            ['www']],
      ['f-vergi_dairesi',  ['vergi_dairesi', 'vergiD']],
      ['f-vergi_no',       ['vergi_no', 'vergiN']],
      ['f-kyt',            ['kyt']],
      ['f-yetkili_adi',    ['yetkili_adi', 'yetA']],
      ['f-yetkili_unvani', ['yetkili_unvani', 'yetU']],
      ['f-irtibat_kisi',   ['irtibat_kisi', 'irtA']],
      ['f-irtibat_unvani', ['irtibat_unvani', 'irtU']],
      ['f-irtibat_tel',    ['irtibat_tel', 'irtN']],
      ['f-irtibat_mail',   ['irtibat_mail', 'irtM']],
      ['f-tcs',            ['tcs']],
      ['f-ycs',            ['ycs']],
      ['f-ucs',            ['ucs']],
      ['f-yzcs',           ['yzcs']],
      ['f-tascs',          ['tascs']],
      ['f-acs',            ['acs']],
      ['f-alan',           ['alan']],
      ['f-vardiya',        ['vardiya']],
      ['f-dept',           ['departman']],
      ['f-yapilan_is',     ['yapilan_is', 'yapis']],
      ['f-logo',           ['logo']],
      ['f-kase',           ['kase']],
      ['f-sinif',          ['sinif']],
      ['f-tkapsam',        ['tkapsam']],
    ];

    fields.forEach(([id, keys]) => setVal(id, g(c, ...keys)));
    setVal('f-id', firmaId);
    setChecked('f-dokuman', g(c, 'dokuman'));
    setChecked('f-teknik', g(c, 'teknik'));

    // Yurt dışı toggle: ulke değeri varsa ve TÜRKİYE değilse göster
    const ulkeVal = g(c, 'ulke');
    const yurtdisiCb = document.getElementById('yurtdisi-cb') as HTMLInputElement | null;
    const ulkeRow = document.getElementById('ulke-row');
    if (yurtdisiCb && ulkeRow) {
      const isYurtdisi = !!ulkeVal && ulkeVal.toUpperCase().replace('İ','I') !== 'TURKIYE';
      yurtdisiCb.checked = isYurtdisi;
      ulkeRow.classList.toggle('hidden', !isYurtdisi);
      if (!isYurtdisi) setVal('f-ulke', '');
    }
    companyEtag = g(c, '__etag');
    companyUpdatedAt = g(c, 'updated_at');

    const nick = g(c, 'nickname', 'nick');
    const headerNick = document.getElementById('header-nick');
    if (headerNick) headerNick.textContent = nick || `Firma #${firmaId}`;

    const footerName = document.getElementById('footer-company-name');
    if (footerName) footerName.textContent = nick || `Firma #${firmaId}`;
    document.title = `${nick || 'Firma'} Düzenle | Medicert Portal`;

    // Show form
    document.getElementById('form-skeleton')?.classList.add('hidden');
    document.getElementById('edit-form')?.classList.remove('hidden');
    document.getElementById('save-footer')?.classList.remove('hidden');
  }

  // ─── File & Drive ─────────────────────────────────────────────────────────────

  let pickerTargetId: string | null = null;

  async function openDrivePicker(targetInputId: string, title: string) {
    pickerTargetId = targetInputId;
    const panel = document.getElementById('drive-picker-panel');
    const titleEl = document.getElementById('drive-picker-title');
    const listEl = document.getElementById('drive-picker-list');
    const nickInput = document.getElementById('f-nick') as HTMLInputElement | null;
    
    if (panel) panel.classList.remove('hidden');
    if (titleEl) titleEl.textContent = `${title} için seçiliyor...`;
    if (listEl) listEl.innerHTML = '<p class="text-xs text-muted italic animate-pulse">Son yüklenen dosyalar getiriliyor...</p>';

    const nick = nickInput?.value?.trim() || '';
    if (!nick) {
      if (listEl) listEl.innerHTML = '<p class="text-xs text-rose-400">Firma kısa adı (Klasör adı) gereklidir.</p>';
      return;
    }

    try {
      const res = await api.call('getRecentFiles', {
        nickname: nick,
        mimeTypes: ['image/png', 'image/jpeg', 'image/gif']
      });
      
      if (res?.success && Array.isArray(res.data)) {
        if (res.data.length === 0) {
          if (listEl) listEl.innerHTML = '<p class="text-xs text-muted">Drive klasöründe uygun dosya bulunamadı.</p>';
          return;
        }

        let html = '';
        res.data.forEach((file: any) => {
          html += `
            <button type="button" class="w-full flex items-center justify-between px-3 py-2 hover:bg-surface rounded-xl transition-colors text-left group" data-file-id="${file.id}">
              <div class="min-w-0 pr-3">
                <p class="text-xs font-semibold text-main truncate">${file.name}</p>
              </div>
              <span class="text-[10px] font-bold text-indigo-400 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">Seç</span>
            </button>
          `;
        });
        
        if (listEl) {
          listEl.innerHTML = html;
          listEl.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', () => {
              const fileId = btn.getAttribute('data-file-id');
              if (fileId && pickerTargetId) {
                setVal(pickerTargetId, fileId);
                toast.success('Dosya seçildi.');
                if (panel) panel.classList.add('hidden');
              }
            });
          });
        }
      } else {
        console.error('[Picker] Failed:', res);
        if (listEl) listEl.innerHTML = `<p class="text-xs text-rose-400">Hata: ${res?.error || 'Dosyalar alınamadı'}</p>`;
      }
    } catch (e) {
      console.error('[Picker] Critical Error:', e);
      if (listEl) listEl.innerHTML = '<p class="text-xs text-rose-400">Bir hata oluştu.</p>';
    }
  }

  async function handleFileUpload(inputId: string, targetId: string, uploadBtnId: string) {
    const fileInput = document.getElementById(inputId) as HTMLInputElement | null;
    const targetInput = document.getElementById(targetId) as HTMLInputElement | null;
    const uploadBtn = document.getElementById(uploadBtnId) as HTMLButtonElement | null;
    const nickInput = document.getElementById('f-nick') as HTMLInputElement | null;
    
    if (!fileInput || !targetInput || !uploadBtn) return;

    fileInput.onchange = async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const nick = nickInput?.value?.trim() || '';
      if (!nick) {
        toast.error('Firma kısa adı (Klasör adı) gereklidir.');
        return;
      }

      try {
        uploadBtn.disabled = true;
        uploadBtn.innerHTML = '<span class="animate-pulse">Yükleniyor...</span>';
        
        const base64 = await new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const res = reader.result as string;
            resolve(res.split(',')[1]);
          };
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });

        const res = await api.uploadFile({
          fileName: file.name,
          mimeType: file.type,
          data: base64
        }, nick);

        const fileId = (res as any).data?.id || (res as any).data?.fileId || (res as any).fileId;

        if (res?.success && fileId) {
          targetInput.value = fileId;
          toast.success('Dosya başarıyla yüklendi.');
        } else {
          console.error('[Upload] Failed:', res);
          toast.error('Dosya yüklenemedi: ' + (res?.error || 'Bilinmeyen hata'));
        }
      } catch (err) {
        console.error('[Upload] Critical Error:', err);
        toast.error('Yükleme sırasında hata oluştu.');
      } finally {
        fileInput.value = '';
        uploadBtn.disabled = false;
        uploadBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Yükle`;
      }
    };

    fileInput.click();
  }

  // ─── Save ─────────────────────────────────────────────────────────────────────

  async function saveForm() {
    const btnSave = document.getElementById('btn-save') as HTMLButtonElement | null;
    const btnSaveFooter = document.getElementById('btn-save-footer') as HTMLButtonElement | null;
    const saveLabel = document.getElementById('save-label');

    const disable = (d: boolean) => {
      if (btnSave)       btnSave.disabled = d;
      if (btnSaveFooter) btnSaveFooter.disabled = d;
      if (saveLabel) saveLabel.textContent = d ? 'Kaydediliyor...' : 'Kaydet';
    };

    disable(true);

    const companyInfo = {
      nickname:        val('f-nick'),
      unvan:           val('f-unvan'),
      adres:           val('f-adres'),
      city:            val('f-city'),
      ulke:            val('f-ulke'),
      yazisma:         val('f-yazisma'),
      tel:             val('f-tel'),
      faks:            val('f-faks'),
      mail:            val('f-mail'),
      www:             val('f-www'),
      vergi_dairesi:   val('f-vergi_dairesi'),
      vergi_no:        val('f-vergi_no'),
      kyt:             val('f-kyt'),
      yetkili_adi:     val('f-yetkili_adi'),
      yetkili_unvani:  val('f-yetkili_unvani'),
      irtibat_kisi:    val('f-irtibat_kisi'),
      irtibat_unvani:  val('f-irtibat_unvani'),
      irtibat_tel:     val('f-irtibat_tel'),
      irtibat_mail:    val('f-irtibat_mail'),
      firma_not:       val('f-firma_not'),
      tcs:             val('f-tcs'),
      ycs:             val('f-ycs'),
      ucs:             val('f-ucs'),
      acs:             val('f-acs'),
      yzcs:            val('f-yzcs'),
      tascs:           val('f-tascs'),
      alan:            val('f-alan'),
      vardiya:         val('f-vardiya'),
      departman:       val('f-dept'),
      yapilan_is:      val('f-yapilan_is'),
      logo:            val('f-logo'),
      kase:            val('f-kase'),
      sinif:           val('f-sinif'),
      tkapsam:         val('f-tkapsam'),
      dokuman:  (document.getElementById('f-dokuman') as HTMLInputElement | null)?.checked ? 'TRUE' : 'FALSE',
      teknik:   (document.getElementById('f-teknik') as HTMLInputElement | null)?.checked ? 'TRUE' : 'FALSE',
    };

    try {
      const res = await api.updateCompany(firmaId, companyInfo, {
        expectedEtag: companyEtag || undefined,
        expected_updated_at: companyUpdatedAt || undefined,
      });
      if (res?.success) {
        const updatedData = (res as any)?.data?.company || { ...companyInfo, id: firmaId };
        companyEtag = String((res as any)?.data?.etag || companyEtag || '');
        companyUpdatedAt = String((res as any)?.data?.updated_at || companyUpdatedAt || '');
        
        // 🔄 Yerel cache'i (Nanostore & IndexedDB) güncelle — yalnızca search alanları
        const currentList = $companies.get();
        const newList = currentList.map(c => {
          if (String(c.id) !== String(firmaId)) return c;
          return {
            id:       String(firmaId),
            nickname: String(updatedData.nickname || c.nickname || ''),
            unvan:    String(updatedData.unvan    || c.unvan    || ''),
            city:     String(updatedData.city     || c.city     || ''),
          };
        });
        $companies.set(newList);
        await DB.save(DB.COMPANIES, newList);

        toast.success('✓ Firma başarıyla güncellendi.');
        
        // Redirect to profile page after a short delay
        setTimeout(() => {
          window.location.href = `/company?id=${firmaId}`;
        }, 1500);
      } else if (res?.error === 'CONFLICT') {
        toast.error('✕ Bu kayıt başka bir kullanıcı tarafından güncellendi. Lütfen sayfayı yenileyip tekrar deneyin.');
      } else {
        toast.error(`✕ Kayıt başarısız: ${res?.error || 'Bilinmeyen hata.'}`);
      }
    } catch (e: any) {
      toast.error(`✕ Bağlantı hatası: ${e?.message || e}`);
    } finally {
      disable(false);
    }
  }

  function initPage() {
    runCleanups();

    const addEv = (id: string, ev: string, fn: any) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener(ev, fn);
      registerCleanup(() => el.removeEventListener(ev, fn));
    };

    // Yurt dışı toggle
    const yurtdisiCb = document.getElementById('yurtdisi-cb') as HTMLInputElement | null;
    const ulkeRow = document.getElementById('ulke-row');
    if (yurtdisiCb && ulkeRow) {
      const handleYurtdisi = () => {
        ulkeRow.classList.toggle('hidden', !yurtdisiCb.checked);
        if (!yurtdisiCb.checked) setVal('f-ulke', '');
      };
      yurtdisiCb.addEventListener('change', handleYurtdisi);
      registerCleanup(() => yurtdisiCb.removeEventListener('change', handleYurtdisi));
    }

    // Adres & Şehir Büyük Yap (Türkçe)
    const addressUpperBtn = document.getElementById('address-upper-btn');
    if (addressUpperBtn) {
      const handleUpper = () => {
        const adres = document.getElementById('f-adres') as HTMLInputElement;
        const city = document.getElementById('f-city') as HTMLInputElement;
        if (adres) adres.value = adres.value.toLocaleUpperCase('tr-TR');
        if (city) city.value = city.value.toLocaleUpperCase('tr-TR');
      };
      addressUpperBtn.addEventListener('click', handleUpper);
      registerCleanup(() => addressUpperBtn.removeEventListener('click', handleUpper));
    }

    addEv('btn-save', 'click', saveForm);
    addEv('btn-save-footer', 'click', saveForm);
    addEv('btn-cancel', 'click', () => {
      if (firmaId) window.location.href = `/company?id=${firmaId}`;
      else history.back();
    });

    addEv('btn-logo-select', 'click', () => openDrivePicker('f-logo', 'Logo'));
    addEv('btn-kase-select', 'click', () => openDrivePicker('f-kase', 'Kaşe & İmza'));
    addEv('btn-picker-close', 'click', () => {
      document.getElementById('drive-picker-panel')?.classList.add('hidden');
      pickerTargetId = null;
    });

    addEv('btn-logo-upload', 'click', () => handleFileUpload('logo-file-input', 'f-logo', 'btn-logo-upload'));
    addEv('btn-kase-upload', 'click', () => handleFileUpload('kase-file-input', 'f-kase', 'btn-kase-upload'));

    loadCompany();
  }

  // Initial load
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
