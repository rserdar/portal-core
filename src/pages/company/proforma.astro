---
import OperationPageShell from '../../components/operations/OperationPageShell.astro';
---

<OperationPageShell
  pageKey="proforma"
  title="Proforma"
  description="Proforma listeleme ve yeni kayit hazirlama akisini, mobilde de rahat kullanilacak sekilde ayri bir operasyon sayfasina tasir."
>
  <div slot="select" class="space-y-5">
    <div class="space-y-2">
      <p class="text-[10px] font-black uppercase tracking-[0.24em] text-indigo-400">Proforma</p>
      <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main">Firma Secerek Devam Et</h1>
      <p class="text-sm leading-relaxed text-muted max-w-2xl">Bu ekran headerdan dogrudan acildiginda once ilgili firmayi secersin. Firma profilinden geliyorsan proforma akisina direkt gecilir.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
      <div class="space-y-2">
        <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Firma Secimi</label>
        <input id="proforma-company-search" list="proforma-company-list" type="text" placeholder="Firma ara..." class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500" />
        <datalist id="proforma-company-list"></datalist>
      </div>
      <button id="proforma-company-continue" type="button" class="w-full md:w-auto inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-colors">
        Firma ile Devam Et
      </button>
    </div>

    <p id="proforma-page-select-status" class="text-xs font-semibold text-muted">Firma listesi hazirlaniyor...</p>
  </div>

  <div class="space-y-6">
    <section class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Kayitlar</h2>
          <p class="text-sm text-muted">Bu alanda firmaya ait proforma kayitlari listelenecek.</p>
        </div>
        <button type="button" disabled class="rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-bold text-muted cursor-not-allowed">Yenile (Yakinda)</button>
      </div>
      <div class="rounded-2xl border border-dashed border-border-main p-5 text-sm text-muted" id="proforma-list-placeholder">
        Henuz API baglantisi yapilmadi. Bu alan `getProformaByFirmaId` ile doldurulacak.
      </div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Tutarlar</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input id="pro-kdv-haric" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Haric" />
          <input id="pro-kdv-oran" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Orani" />
          <input id="pro-kdv-tutar" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Tutari" />
          <input id="pro-toplam" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Toplam Fiyat" />
          <input id="pro-para" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Para Birimi" />
          <input id="pro-tarih" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" />
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Konu</h2>
        <textarea id="pro-konu" rows={10} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[240px]" placeholder="Proforma konusu"></textarea>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <button type="button" disabled class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-bold text-muted cursor-not-allowed">Taslak Kaydet (Yakinda)</button>
      <button type="button" disabled class="inline-flex items-center justify-center rounded-2xl bg-indigo-600/60 px-5 py-3 text-sm font-black text-white cursor-not-allowed">Proforma Uret (Yakinda)</button>
    </div>
  </div>
</OperationPageShell>

<script>
  import { api } from '../../lib/api';
  import { $companies } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';
  import { loadCompanyOperationContext } from '../../features/operations/context';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/operations/definitions';

  const params = new URLSearchParams(location.search);
  let firmaId = params.get('id') || params.get('firmaId') || '';

  const companySearch = document.getElementById('proforma-company-search') as HTMLInputElement | null;
  const companyList = document.getElementById('proforma-company-list');
  const companyContinue = document.getElementById('proforma-company-continue') as HTMLButtonElement | null;
  const selectStatus = document.getElementById('proforma-page-select-status');

  function companyLabel(company: any) {
    const id = String(company?.['Firma No'] || company?.FirmaNo || company?.firmaNo || company?.id || company?.ID || '').trim();
    const nick = String(company?.['Firma Adı'] || company?.nickname || company?.Nick || company?.nick || company?.FirmaAdi || company?.Unvan || company?.unvan || 'Firma').trim();
    return `${nick} (${id || '—'})`;
  }

  function getCompanyId(company: any) {
    return String(company?.['Firma No'] || company?.FirmaNo || company?.firmaNo || company?.id || company?.ID || '').trim();
  }

  function setSelectStatus(message: string, isError = false) {
    if (!selectStatus) return;
    selectStatus.textContent = message;
    selectStatus.className = `text-xs font-semibold ${isError ? 'text-rose-400' : 'text-muted'}`;
  }

  function showCompanyPicker() {
    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-error')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.add('hidden');
    document.getElementById('op-select')?.classList.remove('hidden');
    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', '/search');
  }

  function syncCompanyList(companies: any[]) {
    if (!companyList) return;
    const frag = document.createDocumentFragment();
    companies.forEach((company) => {
      const option = document.createElement('option');
      option.value = companyLabel(company);
      frag.appendChild(option);
    });
    companyList.innerHTML = '';
    companyList.appendChild(frag);
    if (companies.length > 0) setSelectStatus('Bir firma secip devam edebilirsin.');
  }

  function resolveCompanyFromInput() {
    const raw = companySearch?.value.trim() || '';
    const companies = $companies.get() as any[];
    if (!raw) return null;
    return companies.find((company) => {
      const label = companyLabel(company);
      const id = getCompanyId(company);
      const nick = String(company?.['Firma Adı'] || company?.nickname || company?.Nick || company?.nick || company?.FirmaAdi || '').trim();
      return raw === label || raw === id || raw === nick;
    }) || null;
  }

  async function loadScreen() {
    if (!firmaId) {
      return;
    }

    const context = await loadCompanyOperationContext(firmaId);
    if (!context) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.remove('hidden');
      return;
    }

    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${firmaId}`);
    document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
      const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
      const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
      if (definition) link.href = buildOperationHref(definition.href, firmaId);
    });

    document.getElementById('op-company-id')!.textContent = `M${context.firmaId}`;
    document.getElementById('op-company-nick')!.textContent = context.nick || 'Firma';
    document.getElementById('op-company-dan')!.textContent = context.danisman || 'Danisman atanamamis';
    document.getElementById('op-company-unvan')!.textContent = context.unvan || context.nick || `Firma #${context.firmaId}`;
    document.getElementById('op-company-address')!.textContent = [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—';
    document.getElementById('op-company-kapsam')!.textContent = context.scope || context.kapsam || 'Kapsam bulunamadi.';
    document.getElementById('op-company-stats')!.textContent = `${context.certificates.length} sertifika, ${context.tests.length} test kaydi uzerinden fiyatlandirma baglanabilir.`;

    const placeholder = document.getElementById('proforma-list-placeholder');
    if (placeholder) {
      placeholder.textContent = `Bu firma icin ${context.certificates.length} sertifika ve ${context.tests.length} test kaydi bulundu. Proforma listesi ikinci adimda API'den yüklenecek.`;
    }

    document.getElementById('op-select')?.classList.add('hidden');
    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.remove('hidden');
  }

  async function prepareCompanyPicker() {
    showCompanyPicker();
    syncCompanyList($companies.get() as any[]);
    $companies.subscribe((companies) => syncCompanyList(companies as any[]));
    await SyncManager.init();
    if (($companies.get() as any[]).length === 0) {
      const res = await api.getCompanies();
      if (res.success && Array.isArray(res.data)) {
        $companies.set(res.data);
      }
    }

    companySearch?.addEventListener('input', () => {
      const selected = resolveCompanyFromInput();
      setSelectStatus(selected ? 'Firma secildi. Devam edebilirsin.' : 'Listeden gecerli bir firma sec.');
    });

    companyContinue?.addEventListener('click', async () => {
      const selected = resolveCompanyFromInput();
      const selectedId = selected ? getCompanyId(selected) : '';
      if (!selectedId) {
        setSelectStatus('Devam etmek icin listeden gecerli bir firma sec.', true);
        return;
      }
      firmaId = selectedId;
      await loadScreen();
    });
  }

  async function boot() {
    if (!firmaId) {
      await prepareCompanyPicker();
      return;
    }
    await loadScreen();
  }

  void boot();
</script>
