---
import PageShell from '../../components/shared/PageShell.astro';
import CompanyPicker from '../../components/CompanyPicker.astro';
---


<PageShell
  pageKey="proforma"
  title="Proforma"
  description="Proforma listeleme ve yeni kayıt hazırlama akışını, mobilde de rahat kullanılacak şekilde ayrı bir operasyon sayfasına taşır."
>
  <CompanyPicker
    slot="select"
    prefix="proforma"
    eyebrow="Proforma"
    description="Bu ekran header'dan doğrudan açıldığında önce ilgili firmayı seçersin. Firma profilinden geliyorsan proforma akışına direkt geçilir."
  />

  <div class="space-y-6">
    <section class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Kayıtlar</h2>
          <p class="text-sm text-muted">Bu alanda firmaya ait proforma kayıtları listelenir ve yenilenir.</p>
        </div>
        <button id="proforma-refresh" type="button" class="rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-bold text-main hover:border-indigo-500/40 hover:text-indigo-300 transition-colors">Getir / Yenile</button>
      </div>
      <div class="rounded-2xl border border-dashed border-border-main p-5 text-sm text-muted" id="proforma-list-placeholder">
        Kayıtlar bu firma seçildiğinde D1 üzerinden yüklenecek.
      </div>
      <p id="proforma-counter" class="text-xs font-semibold text-muted">Kayıtlar yüklenmedi.</p>
      <div id="proforma-list" class="hidden overflow-hidden rounded-2xl border border-border-main"></div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <div class="space-y-1">
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Tutarlar</h2>
          <p class="text-xs text-muted">Legacy akıştaki gibi KDV hariç, toplam veya KDV tutarı değiştiğinde diğer alanlar otomatik hesaplanır.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input id="pro-kdv-haric" type="text" inputmode="decimal" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Hariç" />
          <input id="pro-kdv-oran" type="text" inputmode="decimal" value="20" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Oranı" />
          <input id="pro-kdv-tutar" type="text" inputmode="decimal" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="KDV Tutarı" />
          <input id="pro-toplam" type="text" inputmode="decimal" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Toplam Fiyat" />
          <input id="pro-para" type="text" value="TL" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Para Birimi" />
          <input id="pro-tarih" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" />
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <h2 class="text-sm font-black uppercase tracking-widest text-main">Konu</h2>
        <textarea id="pro-konu" rows={10} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[240px]" placeholder="Proforma konusu"></textarea>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <button id="proforma-clear" type="button" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-bold text-main hover:border-amber-500/40 hover:text-amber-300 transition-colors">Formu Temizle</button>
      <button id="proforma-save" type="button" class="inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 text-sm font-black text-white hover:bg-indigo-500 disabled:cursor-not-allowed disabled:bg-indigo-600/40 transition-colors">Proforma Kaydet</button>
    </div>
  </div>
</PageShell>

<script>
  import { api } from '../../lib/api';
  import { toast } from '../../lib/toast';
  import { setupOperationCompanyPicker } from '../../features/company-picker';
  import { loadCompanyOperationContext } from '../../features/context';
  import { toDotsDate, toInputDateValue, todayIso } from '../../features/date-format';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/definitions';

  interface ProformaRow {
    id: string;
    nick: string;
    firmaNo: string;
    kdvsiz: string;
    kdvOran: string;
    kdv: string;
    toplam: string;
    birim: string;
    tarih: string;
    konu: string;
  }

  let activeContext: Awaited<ReturnType<typeof loadCompanyOperationContext>> = null;
  let formHandlersBound = false;
  let editingProformaId = '';
  let currentRows: ProformaRow[] = [];
  let cleanupFns: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }

  function runCleanups() {
    cleanupFns.forEach(fn => fn());
    cleanupFns = [];
  }

  function initPage() {
    runCleanups();

    const params = new URLSearchParams(location.search);
    let firmaId = params.get('id') || params.get('firmaId') || '';

    const listBox = document.getElementById('proforma-list');
    const listPlaceholder = document.getElementById('proforma-list-placeholder');
    const counterEl = document.getElementById('proforma-counter');
    const saveButton = document.getElementById('proforma-save') as HTMLButtonElement | null;
    const clearButton = document.getElementById('proforma-clear') as HTMLButtonElement | null;
    const refreshButton = document.getElementById('proforma-refresh') as HTMLButtonElement | null;
    const amountInputs = {
      kdvsiz: document.getElementById('pro-kdv-haric') as HTMLInputElement | null,
      oran: document.getElementById('pro-kdv-oran') as HTMLInputElement | null,
      kdv: document.getElementById('pro-kdv-tutar') as HTMLInputElement | null,
      toplam: document.getElementById('pro-toplam') as HTMLInputElement | null,
      birim: document.getElementById('pro-para') as HTMLInputElement | null,
      tarih: document.getElementById('pro-tarih') as HTMLInputElement | null,
      konu: document.getElementById('pro-konu') as HTMLTextAreaElement | null,
    };

    // Helper to allow nested functions to see the variables
  function parseDecimal(value: string) {
    if (!value) return NaN;
    return Number.parseFloat(value.replace(/\s+/g, '').replace(',', '.'));
  }

  function formatMoney(value: number, digits = 2) {
    if (!Number.isFinite(value)) return '';
    return value.toFixed(digits).replace(/\.00$/, '');
  }

  function setSaveButtonState() {
    if (!saveButton) return;
    saveButton.textContent = editingProformaId ? 'Proforma Güncelle' : 'Proforma Kaydet';
  }

  function fillAmountDefaults() {
    if (amountInputs.oran && !amountInputs.oran.value.trim()) amountInputs.oran.value = '20';
    if (amountInputs.birim && !amountInputs.birim.value.trim()) amountInputs.birim.value = 'TL';
    if (amountInputs.tarih && !amountInputs.tarih.value) amountInputs.tarih.value = todayIso();
  }

  function clearForm() {
    editingProformaId = '';
    if (amountInputs.kdvsiz) amountInputs.kdvsiz.value = '';
    if (amountInputs.kdv) amountInputs.kdv.value = '';
    if (amountInputs.toplam) amountInputs.toplam.value = '';
    if (amountInputs.konu) amountInputs.konu.value = '';
    if (amountInputs.oran) amountInputs.oran.value = '20';
    if (amountInputs.birim) amountInputs.birim.value = 'TL';
    if (amountInputs.tarih) amountInputs.tarih.value = todayIso();
    setSaveButtonState();
  }

  function recomputeFrom(source: 'kdvsiz' | 'toplam' | 'kdv') {
    const oran = parseDecimal(amountInputs.oran?.value || '20');
    const safeRate = Number.isFinite(oran) && oran >= 0 ? oran : 20;
    const kdvsiz = parseDecimal(amountInputs.kdvsiz?.value || '');
    const toplam = parseDecimal(amountInputs.toplam?.value || '');
    const kdv = parseDecimal(amountInputs.kdv?.value || '');

    if (!amountInputs.kdvsiz || !amountInputs.kdv || !amountInputs.toplam || !amountInputs.oran) return;
    amountInputs.oran.value = formatMoney(safeRate, 2);

    if (source === 'kdvsiz' && Number.isFinite(kdvsiz)) {
      const nextKdv = kdvsiz * safeRate / 100;
      amountInputs.kdvsiz.value = formatMoney(kdvsiz);
      amountInputs.kdv.value = formatMoney(nextKdv);
      amountInputs.toplam.value = formatMoney(kdvsiz + nextKdv);
      return;
    }

    if (source === 'toplam' && Number.isFinite(toplam)) {
      const nextKdvsiz = toplam * 100 / (100 + safeRate);
      const nextKdv = nextKdvsiz * safeRate / 100;
      amountInputs.kdvsiz.value = formatMoney(nextKdvsiz);
      amountInputs.kdv.value = formatMoney(nextKdv);
      amountInputs.toplam.value = formatMoney(toplam);
      return;
    }

    if (source === 'kdv' && Number.isFinite(kdv)) {
      const nextKdvsiz = safeRate === 0 ? kdv : (100 * kdv / safeRate);
      amountInputs.kdvsiz.value = formatMoney(nextKdvsiz);
      amountInputs.kdv.value = formatMoney(kdv);
      amountInputs.toplam.value = formatMoney(nextKdvsiz + kdv);
    }
  }

  function renderProformaList(rows: ProformaRow[]) {
    if (!counterEl || !listBox || !listPlaceholder) return;
    currentRows = rows;
    counterEl.textContent = `Firmaya ait proforma sayısı: ${rows.length}`;

    if (!rows.length) {
      listBox.classList.add('hidden');
      listBox.innerHTML = '';
      listPlaceholder.classList.remove('hidden');
      listPlaceholder.textContent = 'Bu firmaya ait proforma bulunamadı.';
      return;
    }

    listPlaceholder.classList.add('hidden');
    listBox.classList.remove('hidden');

    const header = `
      <div class="grid grid-cols-[110px_1.5fr_100px_1fr_1fr_120px_164px] gap-px bg-border-main text-[11px] font-black uppercase tracking-widest text-muted">
        <div class="bg-surface-hover px-4 py-3">Tarih</div>
        <div class="bg-surface-hover px-4 py-3">Konu</div>
        <div class="bg-surface-hover px-4 py-3">KDV %</div>
        <div class="bg-surface-hover px-4 py-3">KDV Hariç</div>
        <div class="bg-surface-hover px-4 py-3">KDV</div>
        <div class="bg-surface-hover px-4 py-3">Toplam</div>
        <div class="bg-surface-hover px-4 py-3">Aksiyon</div>
      </div>
    `;

    const items = [...rows]
      .sort((a, b) => String(b.tarih || '').localeCompare(String(a.tarih || '')))
      .map((row) => {
        const birim = row.birim || '';
        const rowId = row.id || '';
        return `
          <div class="grid grid-cols-[110px_1.5fr_100px_1fr_1fr_120px_164px] gap-px bg-border-main border-t border-border-main first:border-t-0">
            <div class="bg-surface px-4 py-3 text-sm font-semibold text-main">${row.tarih || '—'}</div>
            <div class="bg-surface px-4 py-3 text-sm text-main leading-relaxed">${row.konu || '—'}</div>
            <div class="bg-surface px-4 py-3 text-sm font-semibold text-main">${row.kdvOran || '0'}</div>
            <div class="bg-surface px-4 py-3 text-sm font-semibold text-main">${row.kdvsiz || '0'} ${birim}</div>
            <div class="bg-surface px-4 py-3 text-sm font-semibold text-main">${row.kdv || '0'} ${birim}</div>
            <div class="bg-surface px-4 py-3 text-sm font-bold text-indigo-300">${row.toplam || '0'} ${birim}</div>
            <div class="bg-surface px-3 py-2">
              <div class="flex items-center justify-center gap-2">
                <button type="button" class="proforma-print inline-flex h-9 w-9 items-center justify-center rounded-lg border border-sky-500/20 bg-sky-500/5 text-sky-300 hover:bg-sky-500/15 transition-colors" data-id="${rowId}" title="Yazdır">
                  <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="2"><path d="M6 9V4h12v5"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v6H6z"/><path d="M18 11h.01"/></svg>
                </button>
                <button type="button" class="proforma-edit inline-flex h-9 w-9 items-center justify-center rounded-lg border border-amber-500/20 bg-amber-500/5 text-amber-300 hover:bg-amber-500/15 transition-colors" data-id="${rowId}" title="Düzenle">
                  <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                </button>
                <button type="button" class="proforma-delete inline-flex h-9 w-9 items-center justify-center rounded-lg border border-rose-500/20 bg-rose-500/5 text-rose-400 hover:bg-rose-500/15 transition-colors" data-id="${rowId}" title="Sil">
                  <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="2"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                </button>
              </div>
            </div>
          </div>
        `;
      })
      .join('');

    listBox.innerHTML = `${header}${items}`;
  }

  function setListLoading(message: string) {
    if (!listPlaceholder || !listBox || !counterEl) return;
    listBox.classList.add('hidden');
    listBox.innerHTML = '';
    listPlaceholder.classList.remove('hidden');
    listPlaceholder.textContent = message;
    counterEl.textContent = 'Kayıtlar yükleniyor...';
  }

  async function loadProformas() {
    if (!firmaId) return;
    setListLoading('Proforma kayıtları yükleniyor...');

    const res = await api.getProformasByFirmaId(firmaId);
    if (!res.success) {
      if (listPlaceholder) listPlaceholder.textContent = res.error || 'Proforma listesi yüklenemedi.';
      if (counterEl) counterEl.textContent = 'Liste yüklenemedi.';
      toast.error(res.error || 'Proforma listesi yüklenemedi.');
      return;
    }

    renderProformaList((Array.isArray(res.data) ? res.data : []) as ProformaRow[]);
  }

  function buildProformaPayload() {
    const kdvsiz = amountInputs.kdvsiz?.value.trim() || '';
    const kdvOran = amountInputs.oran?.value.trim() || '20';
    const kdv = amountInputs.kdv?.value.trim() || '';
    const toplam = amountInputs.toplam?.value.trim() || '';
    const birim = amountInputs.birim?.value.trim() || 'TL';
    const tarih = toDotsDate(amountInputs.tarih?.value || '');
    const konu = amountInputs.konu?.value.trim() || '';

    if (!activeContext?.firmaId) return { error: 'Firma bağlamı hazır değil.' };
    if (!kdvsiz || !toplam || !tarih || !konu) return { error: 'KDV hariç, toplam, tarih ve konu alanlarını doldur.' };

    return {
      proInfo: {
        nick: activeContext.nick || activeContext.unvan || 'Firma',
        firmaNo: activeContext.firmaId,
        kdvsiz,
        kdvOran,
        kdv,
        toplam,
        birim,
        tarih,
        konu,
      }
    };
  }

  async function saveProforma() {
    const payload = buildProformaPayload();
    if ('error' in payload) {
      toast.error(payload.error);
      return;
    }

    if (saveButton) saveButton.disabled = true;
    const res = editingProformaId
      ? await api.updateProforma(editingProformaId, payload.proInfo)
      : await api.addProforma(payload.proInfo);
    if (saveButton) saveButton.disabled = false;

    if (!res.success) {
      toast.error(res.error || 'Proforma kaydedilemedi.');
      return;
    }

    toast.success(
      editingProformaId
        ? `${payload.proInfo.nick} için proforma güncellendi.`
        : `${payload.proInfo.nick} için proforma kaydedildi.`
    );
    clearForm();
    await loadProformas();
  }

  function startEditProforma(id: string) {
    const row = currentRows.find((item) => String(item.id || '') === String(id));
    if (!row) {
      toast.error('Düzenlenecek proforma bulunamadı.');
      return;
    }
    editingProformaId = id;
    if (amountInputs.kdvsiz) amountInputs.kdvsiz.value = row.kdvsiz || '';
    if (amountInputs.oran) amountInputs.oran.value = row.kdvOran || '20';
    if (amountInputs.kdv) amountInputs.kdv.value = row.kdv || '';
    if (amountInputs.toplam) amountInputs.toplam.value = row.toplam || '';
    if (amountInputs.birim) amountInputs.birim.value = row.birim || 'TL';
    if (amountInputs.tarih) amountInputs.tarih.value = toInputDateValue(row.tarih || '') || todayIso();
    if (amountInputs.konu) amountInputs.konu.value = row.konu || '';
    setSaveButtonState();
    amountInputs.konu?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  async function deleteProforma(id: string) {
    const row = currentRows.find((item) => String(item.id || '') === String(id));
    const konu = row?.konu || 'bu proforma';
    const confirmed = window.confirm(`"${konu}" kaydını silmek istiyor musun?`);
    if (!confirmed) return;

    const res = await api.deleteProforma(id);
    if (!res.success) {
      toast.error(res.error || 'Proforma silinemedi.');
      return;
    }

    if (editingProformaId === id) clearForm();
    toast.success('Proforma kaydı silindi.');
    await loadProformas();
  }

  async function printProforma(id: string, btn?: HTMLButtonElement) {
    const row = currentRows.find((item) => String(item.id || '') === String(id));
    if (!row) {
      toast.error('Yazdırılacak proforma bulunamadı.');
      return;
    }

    if (btn) {
      btn.disabled = true;
      btn.classList.add('opacity-50', 'cursor-not-allowed');
    }

    toast.info('Proforma dokümanı hazırlanıyor, lütfen bekleyin...');

    try {
      const res = await api.generateProforma(id);
      if (!res.success) {
        toast.error(res.error || 'Proforma dokümanı oluşturulamadı.');
        return;
      }

      const url = String((res.data as any)?.url || '');
      toast.success('Proforma dokümanı Google Docs üzerinde oluşturuldu.');
      if (url) window.open(url, '_blank', 'noopener,noreferrer');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
    }
  }

  function bindListHandlers() {
    listBox?.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const printButton = target?.closest('.proforma-print') as HTMLButtonElement | null;
      const editButton = target?.closest('.proforma-edit') as HTMLButtonElement | null;
      const deleteButton = target?.closest('.proforma-delete') as HTMLButtonElement | null;
      if (printButton?.dataset.id) {
        void printProforma(printButton.dataset.id, printButton);
        return;
      }
      if (editButton?.dataset.id) {
        startEditProforma(editButton.dataset.id);
        return;
      }
      if (deleteButton?.dataset.id) {
        void deleteProforma(deleteButton.dataset.id);
      }
    });
  }

  function bindFormHandlers() {
    if (formHandlersBound) return;
    formHandlersBound = true;

    bindListHandlers();
    clearButton?.addEventListener('click', clearForm);
    refreshButton?.addEventListener('click', () => void loadProformas());
    saveButton?.addEventListener('click', () => void saveProforma());
    amountInputs.kdvsiz?.addEventListener('input', () => recomputeFrom('kdvsiz'));
    amountInputs.toplam?.addEventListener('input', () => recomputeFrom('toplam'));
    amountInputs.kdv?.addEventListener('input', () => recomputeFrom('kdv'));
    amountInputs.oran?.addEventListener('change', () => {
      if (amountInputs.kdvsiz?.value.trim()) recomputeFrom('kdvsiz');
      else if (amountInputs.toplam?.value.trim()) recomputeFrom('toplam');
      else if (amountInputs.kdv?.value.trim()) recomputeFrom('kdv');
    });
    setSaveButtonState();
  }

  function showCompanyPicker() {
    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-error')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.add('hidden');
    document.getElementById('op-select')?.classList.remove('hidden');
    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', '/search');
  }

  async function loadScreen() {
    if (!firmaId) return;

    const context = await loadCompanyOperationContext(firmaId);
    activeContext = context;
    if (!context) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.remove('hidden');
      return;
    }

    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${firmaId}`);
    document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
      const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
      const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
      if (definition) link.href = buildOperationHref(definition.href, firmaId);
    });

    const setText = (id: string, text: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };
    
    setText('op-company-id', `M${context.firmaId}`);
    setText('op-company-nick', context.nick || 'Firma');
    setText('op-company-dan', context.danisman || 'Danışman atanamamış');
    setText('op-company-unvan', context.unvan || context.nick || `Firma #${context.firmaId}`);
    setText('op-company-address', [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—');
    setText('op-company-kapsam', context.scope || context.kapsam || 'Kapsam bulunamadı.');
    setText('op-company-stats', `${context.certificates.length} sertifika, ${context.tests.length} test kaydı üzerinden fiyatlandırma bağlanabilir.`);

    fillAmountDefaults();
    bindFormHandlers();
    setListLoading(`Bu firma için ${context.certificates.length} sertifika ve ${context.tests.length} test kaydı bulundu. Proforma listesi yükleniyor.`);

    document.getElementById('op-select')?.classList.add('hidden');
    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.remove('hidden');
    await loadProformas();
  }

    async function prepareCompanyPicker() {
      await setupOperationCompanyPicker({
        prefix: 'proforma',
        registerCleanup,
        onShowPicker: showCompanyPicker,
        onSelected: async ({ id }) => {
          firmaId = id;
          await loadScreen();
        },
      });
    }

    async function boot() {
      if (!firmaId) {
        await prepareCompanyPicker();
        return;
      }
      await loadScreen();
    }

    void boot();
  }

  // Initial load
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
