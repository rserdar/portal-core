  async function generateSelectedCertificates() {
    if (selectedCertIds.size === 0 || !firmaId) return;

    const button = document.getElementById('cert-generate-selected') as HTMLButtonElement | null;
    const original = button?.innerHTML || '';
    const certIds = Array.from(selectedCertIds);
    const total = certIds.length;
    let successCount = 0;
    let failedCount = 0;

    certGenerationInFlight = true;
    if (button) {
      button.disabled = true;
      button.innerHTML = `<span class="inline-flex items-center gap-2"><span class="h-3.5 w-3.5 rounded-full border-2 border-current border-t-transparent animate-spin"></span>Üretiliyor...</span>`;
    }
    refreshCertActionButtons();
    updateCertGenerationProgress(0, total, 0, 0, `${total} belge için üretim hazırlanıyor...`, `Dil: ${certLang} • Çıktı: ${certSign === 'S' ? 'İmzalı' : 'İmzasız'}`);
    toast.info(`${total} sertifika için üretim başlatıldı.`);

    try {
      const folderRes = await api.call('getFolderId', { id: firmaId });
      if (!folderRes?.success) {
        throw new Error(folderRes?.error || 'Firma klasörü sorgulanamadı.');
      }
      const folderId = folderRes?.data;
      if (!folderId) throw new Error('Firma klasörü bulunamadı.');

      for (let index = 0; index < certIds.length; index += 1) {
        const certId = certIds[index];
        try {
          updateCertGenerationProgress(
            index,
            total,
            successCount,
            failedCount,
            `${index + 1}. belge hazırlanıyor...`,
            `Sertifika ID: ${certId}`
          );

          const payloadRes = await api.buildCertPayload(certId, certLang, certSign);
          if (!payloadRes.success || !payloadRes.data) {
            throw new Error(payloadRes.error || `Payload oluşturulamadı: ${certId}`);
          }

          const genRes = await api.call('generateIso', { cert: payloadRes.data, folderId });
          if (!genRes.success) {
            throw new Error(genRes.error || `Belge üretilemedi: ${certId}`);
          }

          successCount += 1;
          updateCertGenerationProgress(
            index + 1,
            total,
            successCount,
            failedCount,
            `${index + 1} / ${total} belge işlendi`,
            `Basarili: ${certId}`
          );
        } catch (itemError: any) {
          failedCount += 1;
          const message = itemError?.message || `Belge üretilemedi: ${certId}`;
          updateCertGenerationProgress(
            index + 1,
            total,
            successCount,
            failedCount,
            `${index + 1} / ${total} belge işlendi`,
            `Hata: ${message}`
          );
          toast.error(message);
        }
      }

      const finalMessage = failedCount === 0
        ? `${successCount} / ${total} belge başarıyla üretildi.`
        : `${successCount} başarılı, ${failedCount} başarısız, toplam ${total} belge işlendi.`;

      updateCertGenerationProgress(total, total, successCount, failedCount, 'Üretim tamamlandı', finalMessage);
      toast[failedCount === 0 ? 'success' : 'info'](finalMessage);
    } catch (error) {
      console.error('Certificate generation failed:', error);
      const message = error instanceof Error ? error.message : 'Toplu üretim başlatılamadı.';
      updateCertGenerationProgress(0, total, successCount, failedCount, 'Üretim başlatılamadı', message);
      toast.error(message);
    } finally {
      certGenerationInFlight = false;
      if (button) {
        button.innerHTML = original;
      }
      refreshCertActionButtons();
    }
  }

  function setupCertificateActionBar() {
    const addSafeEv = (id: string, ev: string, fn: any) => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener(ev, fn);
        registerCleanup(() => el.removeEventListener(ev, fn));
      }
    };

    const toggle = document.getElementById('cert-actions-toggle') as HTMLButtonElement | null;
    const panel = document.getElementById('cert-actions-panel');
    const chevron = document.getElementById('cert-actions-chevron');

    if (toggle && panel && chevron) {
      const toggleFn = () => {
        panel.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180');
      };
      toggle.addEventListener('click', toggleFn);
      registerCleanup(() => toggle.removeEventListener('click', toggleFn));
    }

    document.querySelectorAll<HTMLButtonElement>('[data-cert-select]').forEach((button) => {
      const fn = () => applyCertPreset(button.dataset.certSelect || 'none');
      button.addEventListener('click', fn);
      registerCleanup(() => button.removeEventListener('click', fn));
    });

    document.querySelectorAll<HTMLButtonElement>('[data-cert-lang]').forEach((button) => {
      const fn = () => {
        certLang = (button.dataset.certLang as 'TR' | 'EN') || 'EN';
        syncCertProductionToggleUI();
      };
      button.addEventListener('click', fn);
      registerCleanup(() => button.removeEventListener('click', fn));
    });

    document.querySelectorAll<HTMLButtonElement>('[data-cert-sign]').forEach((button) => {
      const fn = () => {
        certSign = (button.dataset.certSign as 'S' | 'NS') || 'S';
        syncCertProductionToggleUI();
      };
      button.addEventListener('click', fn);
      registerCleanup(() => button.removeEventListener('click', fn));
    });

    addSafeEv('cert-refresh', 'click', () => void refreshCertificates());
    
    const selectAll = document.getElementById('cert-select-all') as HTMLInputElement | null;
    if (selectAll) {
      const fn = () => {
        if (selectAll.checked) {
          currentCertRows.forEach((row) => selectedCertIds.add(row.id));
        } else {
          selectedCertIds.clear();
        }
        syncCertCheckboxes();
      };
      selectAll.addEventListener('change', fn);
      registerCleanup(() => selectAll.removeEventListener('change', fn));
    }

    addSafeEv('cert-generate-selected', 'click', () => void generateSelectedCertificates());
    addSafeEv('cert-mark-passive', 'click', () => void updateSelectedSurveillance('TRUE'));
    addSafeEv('cert-mark-active', 'click', () => void updateSelectedSurveillance('FALSE'));

    syncCertProductionToggleUI();
  }

