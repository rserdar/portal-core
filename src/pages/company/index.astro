  async function revealSection(sectionId: string, retryCount = 0) {
    const find = (id: string) => Array.from(document.querySelectorAll(`#${id}`)) as HTMLElement[];
    const skeletons = find(`${sectionId}-skeleton`);
    const contents  = find(`${sectionId}-content`);
    const cards     = find(`${sectionId}-card`);

    // If components not in DOM yet, retry a few times (Astro/SPA transition sync)
    if (skeletons.length === 0 && contents.length === 0 && retryCount < 15) {
      setTimeout(() => revealSection(sectionId, retryCount + 1), 100);
      return;
    }

    skeletons.forEach(s => {
      s.classList.add('hidden');
      s.style.setProperty('display', 'none', 'important');
    });
    
    contents.forEach(c => {
      c.classList.remove('hidden');
      c.style.removeProperty('display');
    });

    cards.forEach(c => {
      c.classList.remove('hidden');
      c.style.removeProperty('display');
    });

    if (sectionId === 'test') {
      find('test-list-wrapper').forEach(w => w.classList.remove('hidden'));
    }
    if (sectionId === 'cert') {
      find('cert-list-wrapper').forEach(w => w.classList.remove('hidden'));
    }
    
    if (!hydratedSections.has(sectionId)) {
      hydratedSections.add(sectionId);
    }
  }

  function hideAllSkeletons() {
    ['hero', 'contact', 'people', 'ops', 'test', 'cert'].forEach(s => revealSection(s));
  }

