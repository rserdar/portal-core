  function loadCompanyFromStore() {
    if (hasFullData) return; // Never overwrite full data with partial store data

    const localCompanies = $companies.get() || [];
    const localCompany = localCompanies.find(c => String(c.id) === String(firmaId) || String(c.FirmaNo) === String(firmaId));
    if (localCompany) {
      renderCompany(localCompany);
    }
  }

