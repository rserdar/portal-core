              </div>
              <div class="flex flex-wrap gap-2">
                <button type="button" data-cert-lang="EN" class="cert-lang-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 text-[11px] font-bold transition-colors">EN</button>
                <button type="button" data-cert-lang="TR" class="cert-lang-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover text-main text-[11px] font-bold transition-colors">TR</button>
                <button type="button" data-cert-sign="NS" class="cert-sign-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 text-[11px] font-bold transition-colors">Imzasiz</button>
                <button type="button" data-cert-sign="S" class="cert-sign-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover text-main text-[11px] font-bold transition-colors">Imzali</button>
              </div>
              <button type="button" id="cert-generate-selected" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-black transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <Printer size={13} />
                Secilileri Uret
              </button>
            </div>

            <div class="rounded-2xl border border-border-main bg-surface p-4 space-y-3">
              <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em] text-muted">
                <ShieldCheck size={12} />
                Bakim
              </div>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="cert-mark-passive" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                  <ShieldCheck size={13} />
                  Gozetimde
                </button>
                <button type="button" id="cert-mark-active" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                  <ShieldOff size={13} />
                  Aktife Al
                </button>
              </div>
              <p class="text-[11px] text-muted leading-relaxed">Secili kayitlar icin durum guncellemesi ve toplu belge uretimi burada yonetilir.</p>
            </div>
          </div>
