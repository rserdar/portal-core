  function updateCertGenerationProgress(
    processed: number,
    total: number,
    success: number,
    failed: number,
    status: string,
    lastResult?: string
  ) {
    const panel = document.getElementById('cert-generate-progress');
    const statusEl = document.getElementById('cert-generate-status');
    const countsEl = document.getElementById('cert-generate-counts');
    const barEl = document.getElementById('cert-generate-progress-bar');
    const successEl = document.getElementById('cert-generate-success');
    const failedEl = document.getElementById('cert-generate-failed');
    const remainingEl = document.getElementById('cert-generate-remaining');
    const lastResultEl = document.getElementById('cert-generate-last-result');

    if (!panel || !statusEl || !countsEl || !barEl || !successEl || !failedEl || !remainingEl || !lastResultEl) return;

    panel.classList.remove('hidden');
    statusEl.textContent = status;
    countsEl.textContent = `${processed} / ${total}`;
    barEl.style.width = `${total > 0 ? Math.round((processed / total) * 100) : 0}%`;
    successEl.textContent = String(success);
    failedEl.textContent = String(failed);
    remainingEl.textContent = String(Math.max(total - processed, 0));
    if (lastResult) lastResultEl.textContent = lastResult;
  }

  function resetCertGenerationProgress() {
    const panel = document.getElementById('cert-generate-progress');
    const barEl = document.getElementById('cert-generate-progress-bar') as HTMLDivElement | null;
    if (panel) panel.classList.add('hidden');
    if (barEl) barEl.style.width = '0%';
  }

  function syncCertCheckboxes() {
    document.querySelectorAll<HTMLInputElement>('.cert-select-row').forEach((input) => {
      input.checked = selectedCertIds.has(input.value);
    });

    const selectAll = document.getElementById('cert-select-all') as HTMLInputElement | null;
    if (selectAll) {
      const total = currentCertRows.length;
      const selected = selectedCertIds.size;
      selectAll.checked = total > 0 && selected === total;
      selectAll.indeterminate = selected > 0 && selected < total;
    }

    refreshCertSelectionSummary();
    refreshCertActionButtons();
  }

  function applyCertPreset(preset: string) {
    selectedCertIds.clear();

    if (preset !== 'none') {
      currentCertRows.forEach((row) => {
        if (preset === 'all' || row.status === preset) {
          selectedCertIds.add(row.id);
        }
      });
    }

    syncCertCheckboxes();
  }

