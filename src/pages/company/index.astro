    <!-- Denetimler -->
    <div class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <div class="flex items-center justify-between p-4 sm:p-7 border-b border-border-main">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 flex-shrink-0">
            <ClipboardList size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Denetimler</h3>
          <span id="audit-count" class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20"></span>
        </div>
        <a id="btn-audit-link" href="/audits/add" class="flex items-center gap-2 px-4 py-2 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-[11px] font-bold rounded-xl transition-all">
          + Denetim Planla
        </a>
