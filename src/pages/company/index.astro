  // ─── Load Certificates ────────────────────────────────────────────────────────

  function parseCertDate(dateStr: string): number {
    if (!dateStr) return 0;
    const parts = dateStr.split('.');
    if (parts.length !== 3) return 0;
    return new Date(`${parts[2]}-${parts[1]}-${parts[0]}`).getTime();
  }

  function getCertDateStr(c: any): string {
    if (Array.isArray(c)) return String(c[6] || '');
    return g(c, 'Sertifika Tarihi', 'Belge Tarihi', 'gst', 'GST', 'sTarihi');
  }

  function renderCerts(certData: any[]) {
    const skeleton = document.getElementById('cert-skeleton');
    const wrapper  = document.getElementById('cert-list-wrapper');
    const empty    = document.getElementById('cert-empty');
    const count    = document.getElementById('cert-count');

    skeleton?.classList.add('hidden');
    wrapper?.classList.add('hidden');
    empty?.classList.add('hidden');

    if (!certData.length) {
      allCertData = [];
      currentCertRows = [];
      selectedCertIds.clear();
      refreshCertSelectionSummary();
      refreshCertActionButtons();
      empty?.classList.remove('hidden');
      return;
    }

    // Sertifika tarihine göre en yeniden en eskiye sırala
    allCertData = [...certData].sort((a, b) => parseCertDate(getCertDateStr(b)) - parseCertDate(getCertDateStr(a)));
    certCurrentPage = 1;
    if (count) count.textContent = String(allCertData.length);
    renderCertPage();

  }

  function renderCertPage() {
    const wrapper  = document.getElementById('cert-list-wrapper');
    const tbody    = document.getElementById('cert-tbody');
    const pageCont = document.getElementById('cert-pagination-container');
    const pageInd  = document.getElementById('cert-page-indicator');

    const totalPages = Math.ceil(allCertData.length / CERT_PAGE_SIZE) || 1;
    if (certCurrentPage > totalPages) certCurrentPage = totalPages;
    const start = (certCurrentPage - 1) * CERT_PAGE_SIZE;
    const pageData = allCertData.slice(start, start + CERT_PAGE_SIZE);

    const isRaw = Array.isArray(allCertData[0]);

    const nextRows: Array<{ id: string; status: string }> = [];

    const rows = pageData.map((c, rowIdx) => {
      let id, standart, otherStandart, sertNo, belgeTarihi, gozT, akredite, danisman, durum, akreditasyon, note, denetim, kapsam, scope, certLink, qr, eventId, gozetimConf;
      if (isRaw) {
        id           = String(c[0] || '').trim();
        standart     = String(c[3] || '').trim();
        denetim      = String(c[4] || '').trim();
        sertNo       = String(c[5] || '').trim();
        belgeTarihi  = String(c[6] || '').trim();
        gozT         = String(c[7] || '').trim();
        kapsam       = String(c[10] || '').trim();
        scope        = String(c[11] || '').trim();
        akreditasyon = String(c[14] || '').trim();
        akredite     = String(c[15] || '').trim();
        danisman     = String(c[16] || '').trim();
        durum        = String(c[17] || '').trim();
        note         = String(c[18] || '').trim();
        gozetimConf  = String(c[19] || '').toUpperCase() === 'TRUE';
        otherStandart= String(c[20] || '').trim();
        eventId      = String(c[21] || '').trim();
        qr           = String(c[22] || '').trim();
        certLink     = String(c[23] || '').trim();
      } else {
        id           = g(c, 'ID', 'id');
        standart     = g(c, 'Standart', 'standart');
        otherStandart= g(c, 'Other Standard', 'Other', 'other', 'Diğer', 'diger', 'Diger', 'diğer', 'Diğer Standart', 'digerStandart');
        sertNo       = g(c, 'Sertifika No', 'sertNo', 'SertifikaNo');
        belgeTarihi  = g(c, 'Sertifika Tarihi', 'Belge Tarihi', 'gst', 'GST', 'sTarihi');
        gozT         = g(c, 'Gözetim Tarihi', 'Sertifika Gözetim Tarihi', 'goz', 'GOZ', 'sGozetimT', 'GözetimTarihi');
        akreditasyon = g(c, 'Akreditasyon', 'akrn', 'akreditasyon');
        akredite     = g(c, 'Akredite', 'akredite');
        danisman     = g(c, 'Danışman', 'Danisman', 'dan', 'danisman');
        durum        = g(c, 'Durum', 'durum');
        note         = g(c, 'Not', 'not');
        denetim      = g(c, 'Denetim Tipi', 'denetim');
        kapsam       = g(c, 'Kapsam', 'kapsam');
        scope        = g(c, 'Scope', 'scope');
        eventId      = g(c, 'Calendar ID', 'eventId');
        qr           = g(c, 'QR Code', 'qr');
        certLink     = g(c, 'Cert Link', 'certLink');
        gozetimConf  = String(g(c, 'Gözetim Conf.', 'gozetimConfirmed', 'gozetimConf')).toUpperCase() === 'TRUE';
      }

      const sLow = standart.toLowerCase();
      const isOther = sLow === 'diğer' || sLow === 'diger' || sLow === 'other';

      if (isOther && !otherStandart && !isRaw && id === (allCertData[0] as any)?.ID) {
        console.log('[DEBUG cert keys]', Object.keys(c));
      }

      // Eğer bilinen key'lerle bulunamadıysa obje içinde normalize eşleşme ara
      if (isOther && !otherStandart && !isRaw) {
        const normKey = (s: string) => s.trim().toLowerCase()
          .replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s')
          .replace(/ö/g,'o').replace(/ç/g,'c').replace(/ı/g,'i')
          .replace(/[^a-z0-9]/g,'');
        for (const k of Object.keys(c)) {
          const n = normKey(k);
          if (n === 'other' || n === 'diger') { otherStandart = String(c[k] || ''); break; }
        }
      }

      const standartDisplay = isOther && otherStandart ? otherStandart : standart;

      const parsedDate = gozT ? new Date(gozT.split('.').reverse().join('-')) : null;
      const now = new Date();
      const diffDays = parsedDate ? Math.floor((parsedDate.getTime() - now.getTime()) / 86400000) : null;
      const statusKey = gozetimConf
        ? 'uyku'
        : parsedDate && parsedDate < now
          ? 'pasif'
          : diffDays !== null && diffDays < 46
            ? 'warning'
            : 'active';

      nextRows.push({ id, status: statusKey });

      const statusHtml = gozetimConf
        ? `<span class="px-2 py-0.5 rounded-md bg-slate-500/10 text-slate-300 border border-slate-500/20 text-[9px] font-bold">GOZETIMDE</span>`
        : statusKey === 'pasif'
          ? `<span class="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 border border-rose-500/20 text-[9px] font-bold">PASIF</span>`
          : statusKey === 'warning'
            ? `<span class="px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-300 border border-amber-500/20 text-[9px] font-bold">YAKLASAN</span>`
            : `<span class="px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[9px] font-bold">AKTIF</span>`;

      const copyPayload = [
        belgeTarihi && `Tarih: ${belgeTarihi}`,
        standartDisplay && `Standart: ${standartDisplay}`,
        sertNo && `No: ${sertNo}`,
        akredite && `Akredite: ${akredite}`,
        gozT && `Gozetim: ${gozT}`,
        danisman && `Danisman: ${danisman}`,
        (durum || statusKey) && `Durum: ${durum || statusKey}`,
      ].filter(Boolean).join(' | ');

      const detailCards = [
        { label: 'Denetim Tipi', value: denetim },
        { label: 'Akreditasyon', value: akreditasyon },
        { label: 'Kapsam', value: kapsam },
        { label: 'Scope', value: scope },
        { label: 'Not', value: note },
        { label: 'QR', value: qr },
        { label: 'Calendar ID', value: eventId },
      ].filter((item) => item.value).map((item) => `
        <div class="rounded-xl border border-border-main bg-surface-hover p-3 space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-muted">${escHtml(item.label)}</p>
          <p class="text-xs text-main leading-relaxed break-words">${escHtml(item.value)}</p>
        </div>
      `).join('');

      const detailLink = certLink
        ? `<a href="${escHtml(certLink)}" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-2 text-[10px] font-bold uppercase tracking-wide text-emerald-300 hover:bg-emerald-500/15 transition-colors">Belgeyi Ac</a>`
        : '';

      const zebraClass = rowIdx % 2 !== 0 ? 'bg-black/[0.03]' : '';
      return `<tr class="border-b border-border-main hover:bg-primary/5 transition-colors ${zebraClass}">
        <td class="px-3 py-3 text-center align-middle">
          <input type="checkbox" class="cert-select-row h-4 w-4 rounded border-border-main bg-surface-hover text-emerald-500 focus:ring-emerald-500/40" value="${id}">
        </td>
        <td class="px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${belgeTarihi || '—'}</td>
        <td class="px-4 py-3 font-bold text-main text-xs align-middle">${escHtml(standartDisplay || '—')}</td>
        <td class="px-4 py-3 text-muted font-mono text-xs align-middle whitespace-nowrap">${escHtml(sertNo || '—')}</td>
        <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(akredite || '—')}</td>
        <td class="px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${escHtml(gozT || '—')}</td>
        <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(danisman || '—')}</td>
        <td class="px-4 py-3 text-center align-middle">${statusHtml}</td>
        <td class="px-4 py-3 text-center align-middle">
          <div class="inline-flex items-center gap-1.5">
            <button type="button" class="cert-copy-row inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" data-copy-value="${escHtml(copyPayload || id)}" title="Satiri Kopyala" aria-label="Satiri kopyala">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
              </svg>
            </button>
            <button type="button" class="cert-toggle-detail inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" data-target="cert-detail-${id}" aria-expanded="false" title="Detay Goster" aria-label="Detay goster">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </td>
      </tr>
      <tr id="cert-detail-${id}" class="hidden border-b border-border-main bg-surface-hover/40">
        <td colspan="9" class="px-4 sm:px-7 py-4">
          <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div class="grid flex-1 grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
              ${detailCards || `<div class="rounded-xl border border-dashed border-border-main p-3 text-xs text-muted">Ek detay bulunamadi.</div>`}
            </div>
            <div class="flex flex-wrap items-center gap-2 xl:justify-end">
              ${detailLink}
              <a href="/certificates" class="inline-flex items-center justify-center rounded-lg border border-border-main bg-surface px-3 py-2 text-[10px] font-bold uppercase tracking-wide text-main hover:bg-surface-hover transition-colors">Sertifika Merkezi</a>
            </div>
          </div>
        </td>
      </tr>`;
    }).join('');

    currentCertRows = nextRows;
    const validIds = new Set(nextRows.map((row) => row.id));
    Array.from(selectedCertIds).forEach((id) => {
      if (!validIds.has(id)) selectedCertIds.delete(id);
    });

    if (tbody) tbody.innerHTML = rows;
    wrapper?.classList.remove('hidden');

    // Pagination
    if (pageInd) pageInd.textContent = `${certCurrentPage} / ${totalPages}`;
    if (pageCont) pageCont.classList.toggle('hidden', totalPages <= 1);
    renderCertPaginationUI(totalPages);

    // Update add cert link
    const btnAddCert = document.getElementById('btn-add-cert') as HTMLAnchorElement | null;
    if (btnAddCert) btnAddCert.href = `/certificates?add=1&firmaId=${firmaId}`;

    const folderLink = document.getElementById('cert-folder-link') as HTMLAnchorElement | null;
    if (folderLink) folderLink.href = '/documents/view';

    document.querySelectorAll<HTMLInputElement>('.cert-select-row').forEach((input) => {
      input.addEventListener('change', () => {
        if (input.checked) selectedCertIds.add(input.value);
        else selectedCertIds.delete(input.value);
        refreshCertSelectionSummary();
        refreshCertActionButtons();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.cert-copy-row').forEach((button) => {
      button.addEventListener('click', async () => {
        const payload = button.dataset.copyValue || '';
        if (!payload) return;
        await copyText(payload);
        flashCopyState(button);
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.cert-toggle-detail').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.dataset.target || '';
        const detailRow = targetId ? document.getElementById(targetId) : null;
        if (!detailRow) return;

        const isHidden = detailRow.classList.contains('hidden');
        detailRow.classList.toggle('hidden', !isHidden);
        button.setAttribute('aria-expanded', String(isHidden));
        button.classList.toggle('text-emerald-400', isHidden);
      });
    });

    setupCertificateActionBar();
    syncCertCheckboxes();
  }

  function renderCertPaginationUI(totalPages: number) {
    const controls = document.getElementById('cert-pagination-controls');
    if (!controls) return;
    controls.innerHTML = '';

    const prevBtn = document.createElement('button');
    prevBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>`;
    prevBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${certCurrentPage > 1 ? 'text-primary hover:bg-primary/10' : 'text-muted opacity-30 cursor-not-allowed'}`;
    prevBtn.onclick = () => { if (certCurrentPage > 1) { certCurrentPage--; renderCertPage(); } };
    controls.appendChild(prevBtn);

    const delta = 1;
    const range: number[] = [];
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= certCurrentPage - delta && i <= certCurrentPage + delta)) {
        range.push(i);
      }
    }

    let last: number | null = null;
    range.forEach(i => {
      if (last && i - last > 1) {
        const dots = document.createElement('span');
        dots.textContent = '...';
        dots.className = 'px-2 text-muted text-xs';
        controls.appendChild(dots);
      }
      const btn = document.createElement('button');
      btn.textContent = i.toString();
      btn.className = `w-9 h-9 rounded-lg border text-xs font-black transition-all ${
        i === certCurrentPage
          ? 'bg-primary text-white border-primary shadow-lg shadow-primary/20'
          : 'border-border-main text-muted hover:text-primary hover:bg-primary/10'
      }`;
      btn.onclick = () => { certCurrentPage = i; renderCertPage(); };
      controls.appendChild(btn);
      last = i;
    });

    const nextBtn = document.createElement('button');
    nextBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
    nextBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${certCurrentPage < totalPages ? 'text-primary hover:bg-primary/10' : 'text-muted opacity-30 cursor-not-allowed'}`;
    nextBtn.onclick = () => { if (certCurrentPage < totalPages) { certCurrentPage++; renderCertPage(); } };
    controls.appendChild(nextBtn);
  }

  // ─── Load Tests ───────────────────────────────────────────────────────────────

  function updateTestSelectAll() {
    const all = Array.from(document.querySelectorAll<HTMLInputElement>('.test-select-row'));
    const selectAll = document.getElementById('test-select-all') as HTMLInputElement | null;
    if (selectAll) selectAll.checked = all.length > 0 && all.every(cb => cb.checked);
  }

  async function loadTests() {
    const res = await api.call('getTestsByFirmaId', { firmaId });
    const skeleton = document.getElementById('test-skeleton');
    const wrapper  = document.getElementById('test-list-wrapper');
    const empty    = document.getElementById('test-empty');
    const tbody    = document.getElementById('test-tbody');
    const count    = document.getElementById('test-count');

    skeleton?.classList.add('hidden');

    const tests: any[] = res?.data || [];

    if (!tests.length) {
      empty?.classList.remove('hidden');
      return;
    }

    if (count) count.textContent = String(tests.length);

    const isRaw = Array.isArray(tests[0]);

    const rows = tests.map((t, rowIdx) => {
      let testAdi, urun, marka, raporTarihi;
      if (isRaw) {
        testAdi     = t[3]  || '';
        marka       = t[4]  || '';
        urun        = t[5]  || '';
        raporTarihi = t[13] || '';
      } else {
        testAdi     = g(t, 'Test Adı', 'testAdi');
        marka       = g(t, 'Marka', 'marka');
        urun        = g(t, 'Ürün', 'urun');
        raporTarihi = g(t, 'Rapor Tarihi', 'raporTarihi');
      }

      const testId = String(isRaw ? (t[0] || rowIdx) : (g(t, 'ID', 'id') || rowIdx));
      const zebraClass = rowIdx % 2 !== 0 ? 'bg-black/[0.03]' : '';

      return `<tr class="border-b border-border-main hover:bg-primary/5 transition-colors ${zebraClass}">
        <td class="px-3 py-3 text-center align-middle">
          <input type="checkbox" class="test-select-row h-4 w-4 rounded border-border-main bg-surface-hover text-violet-500 focus:ring-violet-500/40" value="${testId}">
        </td>
        <td class="px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${raporTarihi || '—'}</td>
        <td class="px-4 py-3 font-bold text-main text-xs align-middle">${escHtml(testAdi || '—')}</td>
        <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(marka || '—')}</td>
        <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(urun || '—')}</td>
        <td class="px-4 py-3 text-center align-middle">
          <div class="inline-flex items-center gap-1.5">
            <button type="button" class="test-print-row inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" data-id="${testId}" title="Test Raporunu Yazdır">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect width="12" height="8" x="6" y="14"></rect></svg>
            </button>
            <button type="button" class="test-delete-row inline-flex h-9 w-9 items-center justify-center rounded-lg border border-rose-500/20 bg-rose-500/5 text-rose-400 hover:bg-rose-500/15 transition-colors" data-id="${testId}" title="Testi Sil">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path></svg>
            </button>
          </div>
        </td>
      </tr>`;
    }).join('');

    if (tbody) tbody.innerHTML = rows;
    wrapper?.classList.remove('hidden');

    document.querySelectorAll<HTMLInputElement>('.test-select-row').forEach(input => {
      input.addEventListener('change', () => updateTestSelectAll());
    });

    document.getElementById('test-select-all')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      document.querySelectorAll<HTMLInputElement>('.test-select-row').forEach(cb => { cb.checked = checked; });
    });

    document.querySelectorAll<HTMLButtonElement>('.test-print-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id || '';
        if (id) window.location.href = `/documents/add?firmaId=${firmaId}&testId=${id}`;
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.test-delete-row').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id || '';
        if (!id || !confirm('Bu test kaydını silmek istediğinizden emin misiniz?')) return;
        btn.disabled = true;
        const res = await api.call('deleteTest', { id });
        if (res?.success) {
          await loadTests();
        } else {
          alert('Silme işlemi başarısız.');
          btn.disabled = false;
        }
      });
    });
  }

  // ─── Certificates from Store ──────────────────────────────────────────────────

  function loadCertsFromStore(certs: readonly any[]) {
    const filtered = (certs as any[]).filter(c => {
      const no = g(c, 'Firma No', 'FirmaNo', 'firmaNo');
      return String(no) === String(firmaId);
    });
    renderCerts(filtered);
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────────

  if (firmaId) {
    setupCopyButtons();
    let resizeTimer = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => refreshExpandableTexts(), 120);
    });

    SyncManager.init().then(() => {
      // Once store is ready, filter certs
      const certs = $certificates.get();
      if (certs.length > 0) {
        loadCertsFromStore(certs);
      } else {
        // Fallback: fetch from API
        api.call('getCertificatesByFirmaId', { firmaId }).then(res => {
          renderCerts(res?.data || []);
        });
      }
    });

    $certificates.subscribe(certs => {
      if (certs.length > 0) loadCertsFromStore(certs);
    });

    Promise.all([loadCompany(), loadTests()]);
  }
</script>
