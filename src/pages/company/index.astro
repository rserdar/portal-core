  async function updateSelectedSurveillance(status: 'TRUE' | 'FALSE') {
    if (selectedCertIds.size === 0) return;

    const buttonId = status === 'TRUE' ? 'cert-mark-passive' : 'cert-mark-active';
    const button = document.getElementById(buttonId) as HTMLButtonElement | null;
    if (button) button.disabled = true;

    try {
      const res = await api.updateSurveillance(Array.from(selectedCertIds), status, firmaId);
      if (!res?.success) {
        toast.error(res?.error || res?.message || 'Gözetim durumu güncellenemedi.');
        return;
      }
      const count = res.data?.updatedCount ?? selectedCertIds.size;
      const label = status === 'TRUE' ? 'Gözetimde' : 'Aktif';
      toast.success(`${count} sertifika "${label}" olarak işaretlendi.`);
      await refreshCertificates();
    } catch (err: any) {
      toast.error(err?.message || 'Beklenmedik bir hata oluştu.');
    } finally {
      refreshCertActionButtons();
    }
  }

