---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import {
  MapPin, Phone, Mail, Globe,
  FileText, Award, ClipboardList, Pencil, ArrowLeft,
  Users, Briefcase, BadgeCheck, AlertCircle, Layers,
  ChevronDown, CheckSquare, RefreshCw, FolderOpen, Printer, ShieldCheck, ShieldOff
} from 'lucide-astro';

/**
 * 🏢 Firma Profil Sayfası
 * URL: /company?id=42
 */
---

<DashboardLayout title="Firma Profili">

  <!-- Back + skeleton header -->
  <div class="max-w-6xl mx-auto pb-20 space-y-6">

    <!-- Navigation -->
    <div class="flex items-center gap-3">
      <a href="/search" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
        Firma Listesi
      </a>
      <span class="text-border-main">/</span>
      <span class="text-xs font-bold text-muted" id="breadcrumb-nick">Yükleniyor...</span>
    </div>

    <!-- Hero Card -->
    <div class="bg-surface border border-border-main shadow-2xl rounded-2xl sm:rounded-[2.5rem] p-5 sm:p-8 relative overflow-hidden" id="hero-card">
      <div class="absolute -right-10 -top-10 w-60 h-60 bg-indigo-600/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Loading skeleton -->
      <div id="hero-skeleton" class="animate-pulse space-y-4">
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-3 flex-1">
            <div class="h-3 bg-surface-hover rounded w-24"></div>
            <div class="h-8 bg-surface-hover rounded w-64"></div>
          </div>
          <div class="flex gap-2 shrink-0">
            <div class="h-9 w-24 bg-surface-hover rounded-xl"></div>
            <div class="h-9 w-24 bg-surface-hover rounded-xl"></div>
          </div>
        </div>
        <div class="space-y-3 pt-2">
          {[1,2,3,4,5].map(() => (
            <div class="flex items-center gap-3 py-1">
              <div class="h-3 bg-surface-hover rounded w-20 shrink-0"></div>
              <div class="h-3 bg-surface-hover rounded flex-1"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- Real content -->
      <div id="hero-content" class="hidden">
        <!-- Nick + Badges + Aksiyon -->
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 relative z-10">
          <div class="space-y-2">
            <div class="flex flex-wrap items-center gap-2" id="hero-badges"></div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-main tracking-tight leading-tight" id="hero-nick"></h1>
          </div>
          <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-2 sm:gap-3 relative z-10 flex-shrink-0" id="hero-actions">
            <a id="btn-edit" href="#" class="col-span-2 sm:col-span-1 flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-xl sm:rounded-2xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all">
              <Pencil size={14} />Düzenle
            </a>
            <a href="/documents/view" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-xs font-bold rounded-xl sm:rounded-2xl transition-all">
              <FileText size={14} />Doküman Üret
            </a>
            <a id="btn-add-audit" href="#" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-xs font-bold rounded-xl sm:rounded-2xl transition-all">
              <ClipboardList size={14} />Denetim Planla
            </a>
          </div>
        </div>

        <!-- Divider -->
        <div class="my-4 sm:my-5 border-t border-border-main relative z-10"></div>

        <!-- Kopyalanabilir Alan Satırları -->
        <div class="relative z-10 space-y-0">

          <!-- Unvan -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-unvan" title="Kopyala">
              <Briefcase size={13} />
              <span class="text-[9px] font-black uppercase tracking-widest w-14 text-left">Unvan</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-unvan">—</p>
          </div>

          <!-- Adres -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-adres" title="Kopyala">
              <MapPin size={13} />
              <span class="text-[9px] font-black uppercase tracking-widest w-14 text-left">Adres</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-adres">—</p>
          </div>

          <!-- Şube (varsa) -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40 hidden" id="hero-sube-row">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-sube" title="Kopyala">
              <MapPin size={13} />
              <span class="text-[9px] font-black uppercase tracking-widest w-14 text-left">Şube</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-sube">—</p>
          </div>

          <!-- Kapsam (TR) -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-kapsam" title="Kopyala">
              <Layers size={13} />
              <span class="text-[9px] font-black uppercase tracking-widest w-14 text-left">Kapsam</span>
            </button>
            <p class="text-sm text-main leading-relaxed italic flex-1" id="hero-kapsam"><span class="not-italic opacity-30">—</span></p>
          </div>

          <!-- Scope (EN) -->
          <div class="flex items-start gap-3 py-2.5">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-scope" title="Kopyala">
              <Globe size={13} />
              <span class="text-[9px] font-black uppercase tracking-widest w-14 text-left">Scope</span>
            </button>
            <p class="text-sm text-main leading-relaxed italic flex-1" id="hero-scope"><span class="not-italic opacity-30">—</span></p>
          </div>

        </div>
      </div>
    </div>

    <!-- Info Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6" id="info-grid">

      <!-- Operasyonel Profil Card (span 2) -->
      <div class="lg:col-span-2 bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="profile-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-sky-500/10 flex items-center justify-center text-sky-400 flex-shrink-0">
            <Briefcase size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Operasyonel Profil</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3" id="profile-grid">
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-location-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-location" title="Kopyala">
              <MapPin size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">Şehir / Ülke</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-location"><span class="text-muted opacity-40">—</span></p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-tcs-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-tcs" title="Kopyala">
              <Users size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">Toplam Çalışan</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-tcs"><span class="text-muted opacity-40">—</span></p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-sector-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-sector" title="Kopyala">
              <Briefcase size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">NACE / EA</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-sector"><span class="text-muted opacity-40">—</span></p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-facility-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-facility" title="Kopyala">
              <Layers size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">Alan / Departman</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-facility"><span class="text-muted opacity-40">—</span></p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-vardiya-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-vardiya" title="Kopyala">
              <ClipboardList size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">Vardiya Düzeni</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-vardiya"><span class="text-muted opacity-40">—</span></p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-workforce-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-workforce" title="Kopyala">
              <BadgeCheck size={13} />
              <span class="text-[10px] font-bold uppercase tracking-[0.22em] text-left">Çalışan Dağılımı</span>
            </button>
            <p class="text-sm font-semibold text-main leading-snug" id="info-workforce"><span class="text-muted opacity-40">—</span></p>
          </div>
        </div>
        <div class="mt-5 pt-4 border-t border-border-main space-y-2" id="info-sube-row">
          <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-sube" title="Kopyala">
            <MapPin size={13} />
            <span class="text-[10px] font-bold uppercase tracking-widest text-left">Şube / Yazışma Adresi</span>
          </button>
          <p class="text-sm text-main leading-relaxed" id="info-sube"><span class="text-muted opacity-40">—</span></p>
        </div>
      </div>

      <!-- İletişim Card -->
      <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="contact-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <Phone size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">İletişim</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3" id="info-telefon-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-telefon" title="Kopyala">
              <Phone size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider text-left">Telefon</span>
            </button>
            <div>
              <p class="text-sm font-semibold text-main mt-0.5" id="info-telefon">—</p>
            </div>
          </div>
          <div class="flex items-start gap-3" id="info-faks-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-faks" title="Kopyala">
              <Phone size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider text-left">Faks</span>
            </button>
            <div>
              <p class="text-sm font-semibold text-main mt-0.5" id="info-faks">—</p>
            </div>
          </div>
          <div class="flex items-start gap-3" id="info-mail-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-mail" title="Kopyala">
              <Mail size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider text-left">E-Posta</span>
            </button>
            <div>
              <p class="text-sm font-semibold text-main mt-0.5 break-all" id="info-mail">—</p>
            </div>
          </div>
          <div class="flex items-start gap-3" id="info-web-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-web" title="Kopyala">
              <Globe size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider text-left">Web</span>
            </button>
            <div>
              <p class="text-sm font-semibold text-main mt-0.5" id="info-web">—</p>
            </div>
          </div>
          <div class="pt-2 border-t border-border-main space-y-1" id="info-vergi-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors" data-copy="info-vergi" title="Kopyala">
              <FileText size={12} />
              <span class="text-[10px] font-bold uppercase tracking-wider text-left">Vergi Dairesi / No</span>
            </button>
            <p class="text-sm font-semibold text-main" id="info-vergi">—</p>
          </div>
        </div>
      </div>

      <!-- Yetkililer & İrtibat -->
      <div class="lg:col-span-2 bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="people-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 flex-shrink-0">
            <Users size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Yetkililer & İrtibat</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-kyt-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-kyt" title="Kopyala">
              <BadgeCheck size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">KYT</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-kyt">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-yetkili-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-yetkili" title="Kopyala">
              <Users size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">Yetkili Adı</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-yetkili">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-yetkili-unvan-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-yetkili-unvan" title="Kopyala">
              <Briefcase size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">Yetkili Ünvanı</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-yetkili-unvan">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-irtibat-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-irtibat" title="Kopyala">
              <Users size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">İrtibat Kişisi</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-irtibat">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-irtibat-unvan-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-irtibat-unvan" title="Kopyala">
              <Briefcase size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">İrtibat Ünvanı</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-irtibat-unvan">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5" id="info-irtibat-tel-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-irtibat-tel" title="Kopyala">
              <Phone size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">İrtibat Telefonu</span>
            </button>
            <p class="text-sm font-bold text-main" id="info-irtibat-tel">—</p>
          </div>
          <div class="p-4 rounded-2xl bg-surface-hover border border-border-main space-y-1.5 md:col-span-2 xl:col-span-1" id="info-irtibat-mail-block">
            <button class="copy-btn flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors" data-copy="info-irtibat-mail" title="Kopyala">
              <Mail size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">İrtibat E-Posta</span>
            </button>
            <p class="text-sm font-bold text-main break-all" id="info-irtibat-mail">—</p>
          </div>
        </div>
      </div>

      <!-- Kayıtlar & Varlıklar -->
      <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="records-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 flex-shrink-0">
            <FileText size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Kayıtlar & Varlıklar</h3>
        </div>
        <div class="space-y-3">
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-dan-block">
            <button class="copy-btn flex items-center gap-2 text-indigo-400 hover:text-indigo-300 transition-colors" data-copy="info-dan" title="Kopyala">
              <Users size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">Danışman</span>
            </button>
            <p class="text-sm font-semibold text-main" id="info-dan">—</p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-not-block">
            <button class="copy-btn flex items-center gap-2 text-indigo-400 hover:text-indigo-300 transition-colors" data-copy="info-not" title="Kopyala">
              <FileText size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">Firma Notları</span>
            </button>
            <p class="text-sm text-main leading-relaxed" id="info-not">—</p>
          </div>
          <div class="rounded-2xl border border-border-main bg-surface-hover p-4 space-y-1.5" id="info-logo-block">
            <button class="copy-btn flex items-center gap-2 text-indigo-400 hover:text-indigo-300 transition-colors" data-copy="info-logo" title="Kopyala">
              <Pencil size={13} />
              <span class="text-[10px] font-bold uppercase tracking-widest text-left">Logo / Kaşe-İmza</span>
            </button>
            <p class="text-sm text-main leading-relaxed break-all" id="info-logo">—</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Firma Detayları (NACE, EA, Çalışan) -->
    <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="details-card">
      <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
        <div class="w-9 h-9 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 flex-shrink-0">
          <Briefcase size={16} />
        </div>
        <h3 class="text-sm font-black uppercase tracking-widest text-main">Firma Detayları</h3>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4" id="details-grid">
        <!-- Injected by JS -->
      </div>
      <div class="mt-5 pt-4 border-t border-border-main space-y-2" id="yapis-row">
        <p class="text-[10px] font-bold text-muted uppercase tracking-widest">Yapılan İşler</p>
        <p class="text-sm text-main leading-relaxed" id="info-yapis"><span class="text-muted opacity-40">—</span></p>
      </div>
    </div>

    <!-- Sertifikalar -->
    <div class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <div class="flex items-center justify-between p-4 sm:p-7 border-b border-border-main">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <Award size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Sertifikalar</h3>
          <span id="cert-count" class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"></span>
        </div>
        <a id="btn-add-cert" href="#" class="flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-black rounded-xl transition-all">
          + Sertifika Ekle
        </a>
      </div>

      <div id="cert-skeleton" class="p-7 animate-pulse space-y-3">
        {[1,2,3].map(() => (
          <div class="flex gap-4">
            <div class="h-3 bg-surface-hover rounded flex-1"></div>
