                  <ShieldCheck size={13} />
                  Gozetimde
                </button>
                <button type="button" id="cert-mark-active" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                  <ShieldOff size={13} />
