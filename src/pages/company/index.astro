                <th class="px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest whitespace-nowrap">Rapor Tarihi</th>
                <th class="px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Test Adı</th>
                <th class="px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Marka</th>
                <th class="px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Ürün</th>
