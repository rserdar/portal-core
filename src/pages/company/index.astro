---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import {
  MapPin, Phone, Mail, Globe,
  FileText, Award, ClipboardList, Pencil, ArrowLeft,
  Users, Briefcase, BadgeCheck, Layers, FlaskConical,
  ChevronDown, CheckSquare, RefreshCw, FolderOpen, Printer, ShieldCheck, ShieldOff
} from 'lucide-astro';

/**
 * 🏢 Firma Profil Sayfası
 * URL: /company?id=42
 */
---

<DashboardLayout title="Firma Profili">

  <!-- Back + skeleton header -->
  <div class="max-w-6xl mx-auto pb-20 space-y-6">

    <!-- Navigation -->
    <div class="flex items-center gap-3">
      <a href="/search" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
        Firma Listesi
      </a>
      <span class="text-border-main">/</span>
      <span class="text-xs font-bold text-muted" id="breadcrumb-nick">Yükleniyor...</span>
    </div>

    <!-- Hero Card -->
    <div class="bg-surface border border-border-main shadow-2xl rounded-2xl sm:rounded-[2.5rem] p-5 sm:p-8 relative overflow-hidden" id="hero-card">
      <div class="absolute -right-10 -top-10 w-60 h-60 bg-indigo-600/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Loading skeleton -->
      <div id="hero-skeleton" class="animate-pulse space-y-4">
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-3 flex-1">
            <div class="h-3 bg-surface-hover rounded w-24"></div>
            <div class="h-8 bg-surface-hover rounded w-64"></div>
          </div>
          <div class="flex gap-2 shrink-0">
            <div class="h-9 w-24 bg-surface-hover rounded-xl"></div>
            <div class="h-9 w-24 bg-surface-hover rounded-xl"></div>
          </div>
        </div>
        <div class="space-y-3 pt-2">
          {[1,2,3,4,5].map(() => (
            <div class="flex items-center gap-3 py-1">
              <div class="h-3 bg-surface-hover rounded w-20 shrink-0"></div>
              <div class="h-3 bg-surface-hover rounded flex-1"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- Real content -->
      <div id="hero-content" class="hidden">
        <!-- Nick + Badges + Aksiyon -->
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 relative z-10">
          <div class="space-y-2">
            <div class="flex flex-wrap items-center gap-2" id="hero-badges"></div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-main tracking-tight leading-tight" id="hero-nick"></h1>
          </div>
          <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-2 sm:gap-3 relative z-10 flex-shrink-0" id="hero-actions">
            <a id="btn-edit" href="#" class="col-span-2 sm:col-span-1 flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-xl sm:rounded-2xl shadow-[0_4px_15px_rgba(79,70,229,0.3)] transition-all">
              <Pencil size={14} />Düzenle
            </a>
            <a href="/documents/view" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-surface-hover border border-border-main hover:border-indigo-500/30 text-main text-xs font-bold rounded-xl sm:rounded-2xl transition-all">
              <FileText size={14} />Doküman Üret
            </a>
          </div>
        </div>

        <!-- Divider -->
        <div class="my-4 sm:my-5 border-t border-border-main relative z-10"></div>

        <!-- Kopyalanabilir Alan Satırları -->
        <div class="relative z-10 space-y-0">

          <!-- Unvan -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-unvan" title="Kopyala">
              <Briefcase size={13} />
              <span class="text-[10px] font-black uppercase tracking-widest w-16 text-left">Unvan</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-unvan">—</p>
          </div>

          <!-- Adres -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-adres" title="Kopyala">
              <MapPin size={13} />
              <span class="text-[10px] font-black uppercase tracking-widest w-16 text-left">Adres</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-adres">—</p>
          </div>

          <!-- Şube (varsa) -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40 hidden" id="hero-sube-row">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-sube" title="Kopyala">
              <MapPin size={13} />
              <span class="text-[10px] font-black uppercase tracking-widest w-16 text-left">Şube</span>
            </button>
            <p class="text-sm text-main leading-snug flex-1" id="hero-sube">—</p>
          </div>

          <!-- Kapsam (TR) -->
          <div class="flex items-start gap-3 py-2.5 border-b border-border-main/40">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-kapsam" title="Kopyala">
              <Layers size={13} />
              <span class="text-[10px] font-black uppercase tracking-widest w-16 text-left">Kapsam</span>
            </button>
            <p class="text-sm text-main leading-relaxed italic flex-1" id="hero-kapsam"><span class="not-italic opacity-30">—</span></p>
          </div>

          <!-- Scope (EN) -->
          <div class="flex items-start gap-3 py-2.5">
            <button class="copy-btn flex items-center gap-1.5 text-muted hover:text-primary transition-colors shrink-0 pt-0.5" data-copy="hero-scope" title="Kopyala">
              <Globe size={13} />
              <span class="text-[10px] font-black uppercase tracking-widest w-16 text-left">Scope</span>
            </button>
            <p class="text-sm text-main leading-relaxed italic flex-1" id="hero-scope"><span class="not-italic opacity-30">—</span></p>
          </div>

        </div>
      </div>
    </div>

    <!-- Info Grid: 3 eşit kolon -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6" id="info-grid">

      <!-- İletişim -->
      <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="contact-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <Phone size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">İletişim</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3" id="info-telefon-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-telefon" title="Kopyala">
              <Phone size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Telefon</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-telefon">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-faks-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-faks" title="Kopyala">
              <Phone size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Faks</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-faks">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-mail-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-mail" title="Kopyala">
              <Mail size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">E-Posta</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1 break-all" id="info-mail">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-web-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-web" title="Kopyala">
              <Globe size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Web</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-web">—</p>
          </div>
          <div class="flex items-start gap-3 pt-2 border-t border-border-main" id="info-vergi-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-vergi" title="Kopyala">
              <FileText size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Vergi</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-vergi">—</p>
          </div>
        </div>
      </div>

      <!-- Yetkililer & İrtibat -->
      <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="people-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 flex-shrink-0">
            <Users size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Yetkililer & İrtibat</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3" id="info-kyt-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-kyt" title="Kopyala">
              <BadgeCheck size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">KYT</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-kyt">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-yetkili-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-yetkili" title="Kopyala">
              <Users size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Yetkili</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-yetkili">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-yetkili-unvan-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-yetkili-unvan" title="Kopyala">
              <Briefcase size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Ünvan</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-yetkili-unvan">—</p>
          </div>
          <div class="flex items-start gap-3 pt-2 border-t border-border-main" id="info-irtibat-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-irtibat" title="Kopyala">
              <Users size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">İrtibat</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-irtibat">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-irtibat-unvan-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-irtibat-unvan" title="Kopyala">
              <Briefcase size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Ünvan</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-irtibat-unvan">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-irtibat-tel-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-irtibat-tel" title="Kopyala">
              <Phone size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Telefon</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-irtibat-tel">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-irtibat-mail-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-irtibat-mail" title="Kopyala">
              <Mail size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">E-Posta</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1 break-all" id="info-irtibat-mail">—</p>
          </div>
        </div>
      </div>

      <!-- Operasyon & Profil -->
      <div class="bg-surface border border-border-main shadow-xl p-4 sm:p-7 rounded-2xl sm:rounded-[2rem]" id="ops-card">
        <div class="flex items-center gap-3 mb-5 pb-4 border-b border-border-main">
          <div class="w-9 h-9 rounded-xl bg-sky-500/10 flex items-center justify-center text-sky-400 flex-shrink-0">
            <Briefcase size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main">Operasyon & Profil</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3" id="info-location-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-location" title="Kopyala">
              <MapPin size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Şehir</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-location">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-sector-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-sector" title="Kopyala">
              <Briefcase size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">NACE / EA</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-sector">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-tcs-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-tcs" title="Kopyala">
              <Users size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Çalışan</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-tcs">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-workforce-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-workforce" title="Kopyala">
              <BadgeCheck size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Dağılım</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-workforce">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-facility-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-facility" title="Kopyala">
              <Layers size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Alan</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-facility">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-vardiya-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-vardiya" title="Kopyala">
              <ClipboardList size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Vardiya</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-vardiya">—</p>
          </div>
          <div class="flex items-start gap-3 pt-2 border-t border-border-main" id="info-dan-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-dan" title="Kopyala">
              <Users size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Danışman</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-dan">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-logo-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-logo" title="Kopyala">
              <Pencil size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Logo</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1 break-all" id="info-logo">—</p>
          </div>
          <div class="flex items-start gap-3 hidden" id="info-sube-row">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-sube" title="Kopyala">
              <MapPin size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Şube</span>
            </button>
            <p class="text-sm font-semibold text-main mt-0.5 flex-1" id="info-sube">—</p>
          </div>
          <div class="flex items-start gap-3" id="info-not-block">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-not" title="Kopyala">
              <FileText size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">Not</span>
            </button>
            <p class="text-sm text-main mt-0.5 flex-1 leading-relaxed" id="info-not">—</p>
          </div>
          <div class="flex items-start gap-3 hidden" id="yapis-row">
            <button class="copy-btn flex items-center gap-2 text-muted hover:text-primary transition-colors shrink-0 mt-0.5" data-copy="info-yapis" title="Kopyala">
              <Layers size={12} class="flex-shrink-0" />
              <span class="text-[10px] font-bold uppercase tracking-wider w-16 text-left">İşler</span>
            </button>
            <p class="text-sm text-main mt-0.5 flex-1 leading-relaxed" id="info-yapis">—</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Sertifikalar -->
    <div class="bg-surface border border-border-main shadow-xl rounded-[2rem] overflow-hidden">
      <div class="flex items-center justify-between gap-3 p-4 sm:p-7 border-b border-border-main">
        <div class="flex items-center gap-3 min-w-0">
          <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 flex-shrink-0">
            <Award size={16} />
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest text-main truncate">Sertifikalar</h3>
          <span id="cert-count" class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 flex-shrink-0"></span>
        </div>
        <a id="btn-add-cert" href="#" class="flex-shrink-0 flex items-center gap-1.5 px-3 py-2 sm:px-4 bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-black rounded-xl transition-all">
          <span class="hidden sm:inline">+ Sertifika Ekle</span>
          <span class="sm:hidden">+ Ekle</span>
        </a>
      </div>

      <div id="cert-skeleton" class="p-7 animate-pulse space-y-3">
        {[1,2,3].map(() => (
          <div class="flex gap-4">
            <div class="h-3 bg-surface-hover rounded flex-1"></div>
            <div class="h-3 bg-surface-hover rounded w-20"></div>
            <div class="h-3 bg-surface-hover rounded w-24"></div>
            <div class="h-3 bg-surface-hover rounded w-16"></div>
          </div>
        ))}
      </div>

      <div id="cert-list-wrapper" class="hidden">
        <div class="px-4 sm:px-7 py-4 border-b border-border-main bg-surface-hover/40">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <div class="flex items-center gap-2 flex-wrap">
              <button
                type="button"
                id="cert-actions-toggle"
                class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface hover:bg-surface-hover text-main text-[11px] font-black uppercase tracking-widest transition-colors"
              >
                <ChevronDown size={13} class="transition-transform" id="cert-actions-chevron" />
                <span class="hidden sm:inline">Toplu </span>İşlemler
              </button>
              <p class="text-[11px] text-muted" id="cert-selection-summary">Secili sertifika yok.</p>
            </div>
            <div class="flex items-center gap-1.5 flex-wrap">
              <button type="button" id="cert-refresh" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl border border-border-main bg-surface hover:bg-surface-hover text-main text-[11px] font-bold transition-colors">
                <RefreshCw size={13} />
                <span class="hidden sm:inline">Yenile</span>
              </button>
