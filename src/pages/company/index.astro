  // ─── Load Certificates ────────────────────────────────────────────────────────



  function renderCerts(certData: any[]) {
    const skeleton = document.getElementById('cert-skeleton');
    const wrapper  = document.getElementById('cert-list-wrapper');
    const empty    = document.getElementById('cert-empty');
    const count    = document.getElementById('cert-count');

    skeleton?.classList.add('hidden');
    wrapper?.classList.add('hidden');
    empty?.classList.add('hidden');

    if (!certData.length) {
      allCertData = [];
      currentCertRows = [];
      selectedCertIds.clear();
      refreshCertSelectionSummary();
      refreshCertActionButtons();
      empty?.classList.remove('hidden');
      return;
    }

    // Sertifika tarihine göre en yeniden en eskiye sırala
    allCertData = [...certData].sort((a, b) => (parseDateValue(pickValue(b, ['sertifika_tarihi', 'Sertifika Tarihi', 'Belge Tarihi', 'gst', 'GST', 'sTarihi'], ''))?.getTime() || 0) - (parseDateValue(pickValue(a, ['sertifika_tarihi', 'Sertifika Tarihi', 'Belge Tarihi', 'gst', 'GST', 'sTarihi'], ''))?.getTime() || 0));
    certCurrentPage = 1;
    if (count) count.textContent = String(allCertData.length);
    renderCertPage();
    updateHeroKapsamFromCerts();
    updateDanismanFromCerts();
  }


  function updateDanismanFromCerts() {
    if (!allCertData.length) return;
    const last25 = allCertData.slice(0, 25);
    const freq: Record<string, number> = {};
    for (const c of last25) {
      const val = g(c, 'consultant', 'danisman', 'Danışman', 'Danisman', 'dan').trim();
      if (val) freq[val] = (freq[val] || 0) + 1;
    }

    const top = Object.entries(freq).sort((a, b) => b[1] - a[1])[0]?.[0];
    if (!top) return;

    const danEl = document.getElementById('info-dan');
    const danBlock = document.getElementById('info-dan-block');
    if (danEl) danEl.textContent = top;
    if (danBlock) danBlock.classList.remove('hidden');

    const badgeEl = document.getElementById('hero-badge-dan');
    if (badgeEl) {
      badgeEl.textContent = top;
    } else {
      const badgesEl = document.getElementById('hero-badges');
      if (badgesEl) {
        const span = document.createElement('span');
        span.id = 'hero-badge-dan';
        span.className = 'text-[10px] font-bold px-2.5 py-1 rounded-full border bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
        span.textContent = top;
        badgesEl.appendChild(span);
      }
    }
  }

  function getCertDateStr(c: Record<string, unknown>): string {
    return pickValue(c, ['sertifika_tarihi', 'Sertifika Tarihi', 'Belge Tarihi', 'gst', 'GST', 'sTarihi'], '');
  }

  function parseCertDate(str: string): number {
    return parseDateValue(str)?.getTime() ?? 0;
  }

  function updateHeroKapsamFromCerts() {
    if (!allCertData.length) return;
    const mapped = allCertData.map(c => ({
      standart: g(c, 'standart', 'Standart', 'standard'),
      kapsam:   g(c, 'kapsam', 'Kapsam'),
      scope:    g(c, 'scope', 'Scope'),
      date:     parseCertDate(getCertDateStr(c)),
    }));

    const isCE    = (s: string) => { const u = s.trim().toUpperCase(); return u === 'CE' || u.startsWith('CE '); };
    const isOther = (s: string) => { const u = s.trim().toUpperCase(); return u === 'DİĞER' || u === 'DIGER' || u === 'OTHER'; };

    const byPriority = (arr: typeof mapped) => {
      const sorted = [...arr].sort((a, b) => {
        const diff = getStandartPriority(a.standart) - getStandartPriority(b.standart);
        return diff !== 0 ? diff : b.date - a.date;
      });
      return sorted.find(c => c.kapsam || c.scope) ?? null;
    };

    const best =
      byPriority(mapped.filter(c => !isCE(c.standart) && !isOther(c.standart))) ??
      byPriority(mapped.filter(c => isOther(c.standart))) ??
      byPriority(mapped.filter(c => isCE(c.standart)));

    if (best) {
      renderExpandableText('hero-kapsam', best.kapsam);
      renderExpandableText('hero-scope', best.scope);
      setupExpandableTextButtons();
    }
  }

  function renderCertPage() {
    const wrapper  = document.getElementById('cert-list-wrapper');
    const tbody    = document.getElementById('cert-tbody');
    const pageCont = document.getElementById('cert-pagination-container');
    const pageInd  = document.getElementById('cert-page-indicator');

    const totalPages = Math.ceil(allCertData.length / CERT_PAGE_SIZE) || 1;
    if (certCurrentPage > totalPages) certCurrentPage = totalPages;
    const start = (certCurrentPage - 1) * CERT_PAGE_SIZE;
    const pageData = allCertData.slice(start, start + CERT_PAGE_SIZE);

    const nextRows: Array<{ id: string; status: string }> = [];

    const rows = pageData.map((c, rowIdx) => {
      const id           = getCertificateRecordId(c);
      const standart     = g(c, 'standart', 'Standart');
      let otherStandart = g(c, 'other_standart', 'Other Standard', 'Other', 'other', 'Diğer', 'diger', 'Diger', 'diğer', 'Diğer Standart', 'digerStandart');
      const sertNo       = g(c, 'sertifika_no', 'sertifikaNo', 'Sertifika No', 'sertNo');
      const belgeTarihi  = g(c, 'sertifika_tarihi', 'sertifikaTarihi', 'Sertifika Tarihi', 'Belge Tarihi', 'gst');
      const gozT         = g(c, 'gozetim_tarihi', 'gozetimTarihi', 'Gözetim Tarihi', 'goz');
      const akreditasyon = g(c, 'akreditasyon', 'Akreditasyon', 'akrn');
      const akredite     = g(c, 'akredite', 'Akredite');
      const danisman     = g(c, 'consultant', 'danisman', 'Danışman', 'Danisman', 'dan');
      const durum        = g(c, 'durum', 'Durum');
      const note         = g(c, 'sertifika_not', 'not', 'Not');
      const denetim      = g(c, 'denetim_tipi', 'denetimTipi', 'Denetim Tipi', 'denetim');
      const kapsam       = g(c, 'kapsam', 'Kapsam');
      const scope        = g(c, 'scope', 'Scope');
      const eventId      = g(c, 'calendar_id', 'eventId', 'Calendar ID');
      const qr           = g(c, 'qr', 'QR Code');
      const certLink     = g(c, 'cert_link', 'certLink', 'Cert Link');
      const gozetimConf  = isTruthyFlag(g(c, 'gozetim_confirmed', 'gozetimConfirmed', 'Gözetim Conf.', 'gozetimConf'));

      const sLow = standart.toLowerCase();
      const isOther = sLow === 'diğer' || sLow === 'diger' || sLow === 'other';

      // Eğer bilinen key'lerle bulunamadıysa obje içinde normalize eşleşme ara
      if (isOther && !otherStandart) {
        const normKey = (s: string) => s.trim().toLowerCase()
          .replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s')
          .replace(/ö/g,'o').replace(/ç/g,'c').replace(/ı/g,'i')
          .replace(/[^a-z0-9]/g,'');
        for (const k of Object.keys(c)) {
          const n = normKey(k);
          if (n === 'other' || n === 'diger') { otherStandart = String(c[k] || ''); break; }
        }
      }

      const standartDisplay = isOther && otherStandart ? otherStandart : standart;

      const parsedGoz = gozT ? new Date(toInputDateValue(gozT)) : null;
      const parsedBelge = belgeTarihi ? new Date(toInputDateValue(belgeTarihi)) : null;
      const now = new Date();
      now.setHours(0, 0, 0, 0);

      if (parsedGoz && !Number.isNaN(parsedGoz.getTime())) parsedGoz.setHours(0, 0, 0, 0);
      if (parsedBelge && !Number.isNaN(parsedBelge.getTime())) parsedBelge.setHours(0, 0, 0, 0);

      const diffDays = parsedGoz ? Math.floor((parsedGoz.getTime() - now.getTime()) / 86400000) : null;
      const isBetweenBelgeAndGoz = Boolean(
        parsedBelge &&
        parsedGoz &&
        !Number.isNaN(parsedBelge.getTime()) &&
        !Number.isNaN(parsedGoz.getTime()) &&
        now >= parsedBelge &&
        now <= parsedGoz
      );

      let statusKey = 'pasif';
      if (gozetimConf) {
        statusKey = 'pasif';
      } else if (parsedGoz && !Number.isNaN(parsedGoz.getTime()) && parsedGoz < now) {
        statusKey = 'aski';
      } else if (diffDays !== null && diffDays >= 0 && diffDays < 46) {
        statusKey = 'warning';
      } else if (isBetweenBelgeAndGoz) {
        statusKey = 'active';
      }

      nextRows.push({ id, status: statusKey });

      const statusHtml = statusKey === 'pasif'
        ? `<span class="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 border border-rose-500/20 text-[9px] font-bold">PASİF</span>`
        : statusKey === 'aski'
          ? `<span class="px-2 py-0.5 rounded-md bg-orange-500/10 text-orange-400 border border-orange-500/20 text-[9px] font-bold">ASKI</span>`
          : statusKey === 'warning'
            ? `<span class="px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-300 border border-amber-500/20 text-[9px] font-bold">YAKLAŞAN</span>`
            : `<span class="px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[9px] font-bold">AKTİF</span>`;

      const makeCard = (label: string, value: string, extraClass = '') =>
        `<div class="${extraClass} rounded-xl border border-border-main bg-surface-hover p-3 space-y-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-muted">${escHtml(label)}</p>
          <p class="text-xs text-main leading-relaxed break-words">${escHtml(value)}</p>
        </div>`;

      // Sadece mobilde görünür — masa üstünde zaten satırda gösteriliyor
      const mobileCards = [
        { label: 'Sertifika Tarihi', value: belgeTarihi },
        { label: 'Gözetim Tarihi', value: gozT },
        { label: 'Sertifika No', value: sertNo },
        { label: 'Danışman', value: danisman },
      ].filter(i => i.value).map(i => makeCard(i.label, i.value, 'sm:hidden')).join('');

      // Her iki boyutta da görünür
      const sharedCards = [
        { label: 'Kapsam', value: kapsam },
        { label: 'Scope', value: scope },
      ].filter(i => i.value).map(i => makeCard(i.label, i.value)).join('');

      // Sadece masaüstünde görünür
      const desktopCards = [
        { label: 'Denetim Tipi', value: denetim },
        { label: 'Akreditasyon', value: akreditasyon },
        { label: 'Not', value: note },
        { label: 'QR', value: qr },
        { label: 'Calendar ID', value: eventId },
      ].filter(i => i.value).map(i => makeCard(i.label, i.value, 'hidden sm:block')).join('');

      const detailCards = mobileCards + sharedCards + desktopCards;

      const detailLink = certLink
        ? `<a href="${escHtml(certLink)}" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-2 text-[10px] font-bold uppercase tracking-wide text-emerald-300 hover:bg-emerald-500/15 transition-colors">Belgeyi Aç</a>`
        : '';

      const zebraClass = rowIdx % 2 !== 0 ? 'bg-emerald-500/[0.03]' : 'bg-surface';
      return `<tr class="border-b border-border-main hover:bg-emerald-500/10 transition-colors ${zebraClass}">
        <td class="px-3 py-3 text-center align-middle">
          <input type="checkbox" class="cert-select-row h-4 w-4 rounded border-border-main bg-surface-hover text-emerald-500 focus:ring-emerald-500/40" value="${id}">
        </td>
        <td class="hidden sm:table-cell px-3 sm:px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${formatDate(belgeTarihi)}</td>
        <td class="px-3 sm:px-4 py-3 font-bold text-main text-xs align-middle">${escHtml(standartDisplay || '—')}</td>
        <td class="hidden sm:table-cell px-3 sm:px-4 py-3 text-muted font-mono text-xs align-middle whitespace-nowrap">${escHtml(sertNo || '—')}</td>
        <td class="hidden md:table-cell px-3 sm:px-4 py-3 text-muted text-xs align-middle">${escHtml(akredite || '—')}</td>
        <td class="hidden md:table-cell px-3 sm:px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${formatDate(gozT)}</td>
        <td class="hidden md:table-cell px-3 sm:px-4 py-3 text-muted text-xs align-middle">${escHtml(danisman || '—')}</td>
        <td class="px-3 sm:px-4 py-3 text-center align-middle">${statusHtml}</td>
        <td class="px-3 sm:px-4 py-3 text-center align-middle">
          <div class="inline-flex items-center gap-1.5">
            <a href="/certificates/add?id=${encodeURIComponent(firmaId)}&edit=${encodeURIComponent(id)}" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-indigo-500/20 bg-indigo-500/10 text-indigo-300 hover:bg-indigo-500/15 transition-colors" title="Sertifikayı Düzenle" aria-label="Sertifikayı düzenle">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z"></path>
              </svg>
            </a>
            <a href="/certificates/add?id=${encodeURIComponent(firmaId)}&clone=${encodeURIComponent(id)}" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" title="Sertifikayı Kopyala" aria-label="Sertifikayı kopyala">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
              </svg>
            </a>
            <button type="button" class="cert-toggle-detail inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" data-target="cert-detail-${id}" aria-expanded="false" title="Detay Göster" aria-label="Detay göster">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </td>
      </tr>
      <tr id="cert-detail-${id}" class="hidden border-b border-border-main bg-surface-hover">
        <td colspan="9" class="px-4 sm:px-7 py-4">
          <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div class="grid flex-1 grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
              ${detailCards || `<div class="rounded-xl border border-dashed border-border-main p-3 text-xs text-muted">Ek detay bulunamadı.</div>`}
            </div>
            <div class="flex flex-wrap items-center gap-2 xl:justify-end">
              ${detailLink}
              <a href="/certificates" class="inline-flex items-center justify-center rounded-lg border border-border-main bg-surface px-3 py-2 text-[10px] font-bold uppercase tracking-wide text-main hover:bg-surface-hover transition-colors">Sertifika Merkezi</a>
            </div>
          </div>
        </td>
      </tr>`;
    }).join('');

    currentCertRows = nextRows;
    const validIds = new Set(nextRows.map((row) => row.id));
    Array.from(selectedCertIds).forEach((id) => {
      if (!validIds.has(id)) selectedCertIds.delete(id);
    });

    if (tbody) tbody.innerHTML = rows;
    wrapper?.classList.remove('hidden');

    // Pagination
    if (pageInd) pageInd.textContent = `${certCurrentPage} / ${totalPages}`;
    if (pageCont) pageCont.classList.toggle('hidden', totalPages <= 1);
    renderCertPaginationUI(totalPages);

    // Update add cert link
    const btnAddCert = document.getElementById('btn-add-cert') as HTMLAnchorElement | null;
    if (btnAddCert) btnAddCert.href = getCompanyCertificateHref();


    document.querySelectorAll<HTMLInputElement>('.cert-select-row').forEach((input) => {
      input.addEventListener('change', () => {
        if (input.checked) selectedCertIds.add(input.value);
        else selectedCertIds.delete(input.value);
        refreshCertSelectionSummary();
        refreshCertActionButtons();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.cert-toggle-detail').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.dataset.target || '';
        const detailRow = targetId ? document.getElementById(targetId) : null;
        if (!detailRow) return;

        const isHidden = detailRow.classList.contains('hidden');
        detailRow.classList.toggle('hidden', !isHidden);
        button.setAttribute('aria-expanded', String(isHidden));
        button.classList.toggle('text-emerald-400', isHidden);
      });
    });

    syncCertCheckboxes();
  }

  function renderCertPaginationUI(totalPages: number) {
    const controls = document.getElementById('cert-pagination-controls');
    if (!controls) return;
    controls.innerHTML = '';

    const prevBtn = document.createElement('button');
    prevBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>`;
    prevBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${certCurrentPage > 1 ? 'text-primary hover:bg-primary/10' : 'text-muted opacity-30 cursor-not-allowed'}`;
    prevBtn.onclick = () => { if (certCurrentPage > 1) { certCurrentPage--; renderCertPage(); } };
    controls.appendChild(prevBtn);

    const delta = 1;
    const range: number[] = [];
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= certCurrentPage - delta && i <= certCurrentPage + delta)) {
        range.push(i);
      }
    }

    let last: number | null = null;
    range.forEach(i => {
      if (last && i - last > 1) {
        const dots = document.createElement('span');
        dots.textContent = '...';
        dots.className = 'px-2 text-muted text-xs';
        controls.appendChild(dots);
      }
      const btn = document.createElement('button');
      btn.textContent = i.toString();
      btn.className = `w-9 h-9 rounded-lg border text-xs font-black transition-all ${
        i === certCurrentPage
          ? 'bg-primary text-white border-primary shadow-lg shadow-primary/20'
          : 'border-border-main text-muted hover:text-primary hover:bg-primary/10'
      }`;
      btn.onclick = () => { certCurrentPage = i; renderCertPage(); };
      controls.appendChild(btn);
      last = i;
    });

    const nextBtn = document.createElement('button');
    nextBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
    nextBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${certCurrentPage < totalPages ? 'text-primary hover:bg-primary/10' : 'text-muted opacity-30 cursor-not-allowed'}`;
    nextBtn.onclick = () => { if (certCurrentPage < totalPages) { certCurrentPage++; renderCertPage(); } };
    controls.appendChild(nextBtn);
  }

  // ─── Load Tests ───────────────────────────────────────────────────────────────

  function updateTestSelectAll() {
    const all = Array.from(document.querySelectorAll<HTMLInputElement>('.test-select-row'));
    const selectAll = document.getElementById('test-select-all') as HTMLInputElement | null;
    if (selectAll) {
      const total = all.length;
      const selectedCount = all.filter(cb => cb.checked).length;
      selectAll.checked = total > 0 && selectedCount === total;
      selectAll.indeterminate = selectedCount > 0 && selectedCount < total;
    }
    
    // Update Set
    all.forEach(cb => {
      if (cb.checked) selectedTestIds.add(cb.value);
      else selectedTestIds.delete(cb.value);
    });

    refreshTestSelectionSummary();
    refreshTestActionButtons();
  }

  function refreshTestSelectionSummary() {
    const el = document.getElementById('test-selection-summary');
    if (!el) return;

    const selected = selectedTestIds.size;
    el.textContent = selected > 0 ? `${selected} test seçili` : "Seçili test yok.";
  }

  function refreshTestActionButtons() {
    const hasSelection = selectedTestIds.size > 0;
    const printBtn = document.getElementById('test-print-selected') as HTMLButtonElement | null;
    const deleteBtn = document.getElementById('test-delete-selected') as HTMLButtonElement | null;
    
    if (printBtn) printBtn.disabled = !hasSelection;
    if (deleteBtn) deleteBtn.disabled = !hasSelection;
  }

  async function printSelectedTests() {
    if (selectedTestIds.size === 0) return;
    const ids = Array.from(selectedTestIds).join(',');
    window.location.href = `/tests/print?firmaId=${firmaId}&testId=${ids}`;
  }

  async function deleteSelectedTests() {
    if (selectedTestIds.size === 0) return;
    if (!confirm(`${selectedTestIds.size} adet test kaydını silmek istediğinizden emin misiniz?`)) return;

    const ids = Array.from(selectedTestIds);
    toast.info(`${ids.length} test siliniyor...`);
    
    let success = 0;
    for (const id of ids) {
      const res = await api.deleteTest(id);
      if (res.success) success++;
    }

    toast.success(`${success} test başarıyla silindi.`);
    selectedTestIds.clear();
    await loadTests();
  }

  async function loadTests() {
    const skeleton = document.getElementById('test-skeleton');
    const wrapper  = document.getElementById('test-list-wrapper');
    const tbody    = document.getElementById('test-tbody');

    // Only show skeleton if table is empty
    if (!tbody || !tbody.innerHTML.trim()) {
      skeleton?.classList.remove('hidden');
      wrapper?.classList.add('hidden');
    }

    try {
      const res = await api.getTestsByFirmaId(firmaId);
      const empty    = document.getElementById('test-empty');
      const count    = document.getElementById('test-count');

      skeleton?.classList.add('hidden');

      const tests: any[] = res?.data || [];

      if (!tests.length) {
        empty?.classList.remove('hidden');
        return;
      }

      if (count) count.textContent = String(tests.length);

      const rows = tests.map((t, rowIdx) => {
        const testAdi     = g(t, 'test_adi', 'Test Adı', 'testAdi');
        const marka       = g(t, 'marka', 'Marka');
        const urun        = g(t, 'urun', 'Ürün');
        const raporTarihi = g(t, 'rapor_tarihi', 'Rapor Tarihi', 'raporTarihi');

        const testId = String(g(t, 'ID', 'id') || rowIdx);
        const zebraClass = rowIdx % 2 !== 0 ? 'bg-surface-hover' : '';

        const isChecked = selectedTestIds.has(testId) ? 'checked' : '';

        return `<tr class="border-b border-border-main hover:bg-primary/5 transition-colors ${zebraClass}">
          <td class="px-3 py-3 text-center align-middle">
            <input type="checkbox" class="test-select-row h-4 w-4 rounded border-border-main bg-surface-hover text-violet-500 focus:ring-violet-500/40" value="${testId}" ${isChecked}>
          </td>
          <td class="px-4 py-3 text-muted text-xs align-middle whitespace-nowrap">${formatDate(raporTarihi)}</td>
          <td class="px-4 py-3 font-bold text-main text-xs align-middle">${escHtml(testAdi || '—')}</td>
          <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(marka || '—')}</td>
          <td class="px-4 py-3 text-muted text-xs align-middle">${escHtml(urun || '—')}</td>
          <td class="px-4 py-3 text-center align-middle">
            <div class="inline-flex items-center gap-1.5">
              <button type="button" class="test-print-row inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border-main bg-surface-hover text-main hover:bg-surface transition-colors" data-id="${testId}" title="Test Raporunu Yazdır">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect width="12" height="8" x="6" y="14"></rect></svg>
              </button>
              <button type="button" class="test-delete-row inline-flex h-9 w-9 items-center justify-center rounded-lg border border-rose-500/20 bg-rose-500/5 text-rose-400 hover:bg-rose-500/15 transition-colors" data-id="${testId}" title="Testi Sil">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path></svg>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');

      if (tbody) tbody.innerHTML = rows;
      skeleton?.classList.add('hidden');
      wrapper?.classList.remove('hidden');
      revealSection('test');

      document.querySelectorAll<HTMLInputElement>('.test-select-row').forEach(input => {
        input.addEventListener('change', () => {
          if (input.checked) selectedTestIds.add(input.value);
          else selectedTestIds.delete(input.value);
          updateTestSelectAll();
        });
      });

      document.getElementById('test-select-all')?.addEventListener('change', (e) => {
        const checked = (e.target as HTMLInputElement).checked;
        document.querySelectorAll<HTMLInputElement>('.test-select-row').forEach(cb => { 
          cb.checked = checked;
          if (checked) selectedTestIds.add(cb.value);
          else selectedTestIds.delete(cb.value);
        });
        refreshTestSelectionSummary();
        refreshTestActionButtons();
      });

      // Bind Action Buttons once
      const printSelectedBtn = document.getElementById('test-print-selected');
      if (printSelectedBtn && !printSelectedBtn.dataset.bound) {
        printSelectedBtn.dataset.bound = 'true';
        printSelectedBtn.addEventListener('click', () => void printSelectedTests());
      }

      const deleteSelectedBtn = document.getElementById('test-delete-selected');
      if (deleteSelectedBtn && !deleteSelectedBtn.dataset.bound) {
        deleteSelectedBtn.dataset.bound = 'true';
        deleteSelectedBtn.addEventListener('click', () => void deleteSelectedTests());
      }

      document.querySelectorAll<HTMLButtonElement>('.test-print-row').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id || '';
          if (id) window.location.href = `/tests/print?firmaId=${firmaId}&testId=${id}`;
        });
      });

      document.querySelectorAll<HTMLButtonElement>('.test-delete-row').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id || '';
          if (!id || !confirm('Bu test kaydını silmek istediğinizden emin misiniz?')) return;
          btn.disabled = true;
          const res = await api.deleteTest(id);
          if (res?.success) {
            await loadTests();
          } else {
            toast.error('Silme işlemi başarısız.');
            btn.disabled = false;
          }
        });
      });
    } catch (e) {
      console.error('[Tests] loadTests failed:', e);
      toast.error('Test verileri yüklenemedi.');
      document.getElementById('test-skeleton')?.classList.add('hidden');
      document.getElementById('test-list-wrapper')?.classList.remove('hidden');
      document.getElementById('test-empty')?.classList.remove('hidden');
    }
  }

  // ─── Certificates from Store ──────────────────────────────────────────────────
  
  async function loadCertificates() {
    const skeleton = document.getElementById('cert-skeleton');
    const wrapper  = document.getElementById('cert-list-wrapper');
    const tbody    = document.getElementById('cert-tbody');

    // Only show skeleton if list is empty
    if (!tbody || !tbody.innerHTML.trim()) {
      skeleton?.classList.remove('hidden');
      wrapper?.classList.add('hidden');
    }

    try {
      const res = await api.getCertificatesByFirmaId(firmaId);
      renderCerts(res?.data || []);
      revealSection('cert');
    } catch (e) {
      console.error('[Certificates] Load failed:', e);
      toast.error('Sertifika verileri yüklenemedi.');
      revealSection('cert');
      renderCerts([]);
    }
  }

  function loadCertsFromStore(certs: readonly any[]) {
    const filtered = (certs as any[]).filter(c => {
      const no = g(c, 'Firma No', 'FirmaNo', 'firmaNo');
      return String(no) === String(firmaId);
    });
    renderCerts(filtered);
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────────

  const initHandler = () => initPage();

  function initPage() {
    const nextFirmaId = readFirmaIdFromUrl();

    // 1. Run previous cleanups if any
    runCleanups();
    resetPageState(nextFirmaId);

    if (!firmaId) {
      console.warn('[Profile] firmaId URL parametresi bulunamadı.');
      toast.error('Firma ID bulunamadı.');
      return;
    }

    setupOperationLinks();
    setupCopyButtons();
    setupCertificateActionBar();
    
    const onResize = () => refreshExpandableTexts();
    const resizeHandler = () => {
      let resizeTimer = 0;
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(onResize, 120);
    };
    window.addEventListener('resize', resizeHandler);
    registerCleanup(() => window.removeEventListener('resize', resizeHandler));

    // Auto-update when companies store changes
    const unsubCompanies = $companies.subscribe(() => loadCompanyFromStore());
    registerCleanup(unsubCompanies);

    // Timeout Guard: Reveal page no matter what after 3.5s
    const guardTimer = setTimeout(() => {
      if (!hydratedSections.has('hero')) {
        console.warn('[Profile] Timeout guard triggered. Force unhiding page.');
        toast.error('Sayfa yüklenemedi, lütfen yenileyin.');
        hideAllSkeletons();
      }
    }, 3500);
    registerCleanup(() => clearTimeout(guardTimer));

    SyncManager.init().then(() => {
      loadCompanyFromStore();
    }).catch(e => {
      console.warn('[Profile] Sync failed but continuing:', e);
    });

    loadCompany();
    loadTests();
    loadCertificates();

    // Toggle for Test Bulk Actions
    document.getElementById('test-actions-toggle')?.addEventListener('click', () => {
      const wrapper = document.getElementById('test-actions-wrapper');
      if (wrapper) wrapper.classList.toggle('hidden');
    });
  }

  initPageCleanup(initHandler, runCleanups);
</script>
