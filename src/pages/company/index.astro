                <button type="button" data-cert-select="warning" class="cert-batch-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors">Yaklasan</button>
                <button type="button" data-cert-select="uyku" class="cert-batch-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors">Gozetimde</button>
                <button type="button" data-cert-select="pasif" class="cert-batch-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors">Pasif</button>
                <button type="button" data-cert-select="none" class="cert-batch-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover hover:bg-surface text-main text-[11px] font-bold transition-colors">Temizle</button>
              </div>
            </div>

            <div class="rounded-2xl border border-border-main bg-surface p-4 space-y-3">
              <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em] text-muted">
                <Printer size={12} />
