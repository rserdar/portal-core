      <div id="audit-skeleton" class="p-7 animate-pulse space-y-3">
        {[1,2].map(() => (
          <div class="flex gap-4">
            <div class="h-3 bg-surface-hover rounded w-20"></div>
            <div class="h-3 bg-surface-hover rounded flex-1"></div>
            <div class="h-3 bg-surface-hover rounded w-28"></div>
          </div>
        ))}
      </div>

      <div id="audit-list-wrapper" class="hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-border-main">
                <th class="px-4 sm:px-7 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Standart</th>
                <th class="hidden sm:table-cell px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Tür</th>
                <th class="hidden sm:table-cell px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">A1 Tarihi</th>
                <th class="hidden md:table-cell px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">A2 Tarihi</th>
                <th class="hidden md:table-cell px-4 py-3 text-left text-[10px] font-bold text-muted uppercase tracking-widest">Baş Denetçi</th>
              </tr>
            </thead>
            <tbody id="audit-tbody"></tbody>
          </table>
        </div>
      </div>

      <div id="audit-empty" class="hidden p-10 text-center">
        <AlertCircle size={32} class="mx-auto text-muted opacity-20 mb-3" />
        <p class="text-sm font-bold text-muted">Bu firmaya ait denetim kaydı bulunamadı.</p>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import { $certificates } from '../../lib/store';
  import { SyncManager } from '../../lib/sync';

  // ─── Helpers ─────────────────────────────────────────────────────────────────

  /** Bir objeden birden fazla olası key ile değer okur */
  function g(obj: Record<string, any>, ...keys: string[]): string {
    for (const k of keys) {
      const v = obj?.[k];
      if (v !== undefined && v !== null && String(v).trim() !== '') return String(v).trim();
    }
    return '';
  }

  function setEl(id: string, value: string) {
    const el = document.getElementById(id);
    if (!el) return;
    if (value) {
      el.textContent = value;
    } else {
      el.innerHTML = '<span class="text-muted opacity-30">—</span>';
    }
  }

  function setMany(ids: string[], value: string) {
    ids.forEach(id => setEl(id, value));
  }

  function setField(id: string, value: string, blockId?: string) {
    setEl(id, value);
    if (!blockId) return;

    const block = document.getElementById(blockId);
    if (!block) return;

    if (value) {
      block.classList.remove('hidden');
    } else {
      block.classList.add('hidden');
    }
  }

  function toggleCardVisibility(cardId: string, blockIds: string[]) {
    const card = document.getElementById(cardId);
    if (!card) return;

    const hasVisibleBlock = blockIds.some((blockId) => {
      const block = document.getElementById(blockId);
      return block && !block.classList.contains('hidden');
    });

    if (hasVisibleBlock) {
      card.classList.remove('hidden');
    } else {
      card.classList.add('hidden');
    }
  }

  function badge(text: string, cls: string) {
    return `<span class="text-[10px] font-bold px-2.5 py-1 rounded-full border ${cls}">${text}</span>`;
  }

  const copyResetTimers = new WeakMap<HTMLButtonElement, number>();
  let currentCompanyNick = '';
  let currentCertRows: Array<{ id: string; status: string }> = [];
  const selectedCertIds = new Set<string>();
  let certLang: 'TR' | 'EN' = 'EN';
  let certSign: 'S' | 'NS' = 'NS';
  const copySuccessMarkup = `
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 6 9 17l-5-5"/>
    </svg>
    <span class="text-[9px] font-black uppercase tracking-widest text-left">Kopyalandı</span>
  `;

  async function copyText(value: string) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(value);
      return;
    }

    const area = document.createElement('textarea');
    area.value = value;
    area.setAttribute('readonly', 'true');
    area.className = 'fixed -left-[9999px] -top-[9999px]';
    document.body.appendChild(area);
    area.select();
    document.execCommand('copy');
    area.remove();
  }

  function flashCopyState(button: HTMLButtonElement) {
    if (!button.dataset.originalHtml) {
      button.dataset.originalHtml = button.innerHTML;
      button.dataset.originalClass = button.className;
    }

    const activeTimer = copyResetTimers.get(button);
    if (activeTimer) window.clearTimeout(activeTimer);

    button.className = `${button.dataset.originalClass} text-emerald-400`;
    button.innerHTML = copySuccessMarkup;

    const timer = window.setTimeout(() => {
      if (button.dataset.originalHtml && button.dataset.originalClass) {
        button.innerHTML = button.dataset.originalHtml;
        button.className = button.dataset.originalClass;
      }
    }, 2000);

    copyResetTimers.set(button, timer);
  }

  function setupCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(button => {
      if (button.dataset.copyReady === 'true') return;
      button.dataset.copyReady = 'true';
      button.dataset.originalHtml = button.innerHTML;
      button.dataset.originalClass = button.className;

      button.addEventListener('click', async () => {
        const targetId = button.dataset.copy;
        if (!targetId) return;

        const target = document.getElementById(targetId);
        const text = target?.textContent?.trim() || '';
        if (!text || text === '—') return;

        try {
          await copyText(text);
          flashCopyState(button);
        } catch (error) {
          console.error('Copy failed:', error);
        }
      });
    });
  }

  function refreshCertSelectionSummary() {
    const el = document.getElementById('cert-selection-summary');
    if (!el) return;

    const total = currentCertRows.length;
    const selected = selectedCertIds.size;
    el.textContent = selected > 0
      ? `${selected} / ${total} sertifika secili.`
      : total > 0
        ? `Secili sertifika yok. Toplam ${total} kayit.`
        : 'Secili sertifika yok.';
  }

  function refreshCertActionButtons() {
    const hasSelection = selectedCertIds.size > 0;
    [
      'cert-generate-selected',
      'cert-mark-passive',
      'cert-mark-active',
    ].forEach((id) => {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (btn) btn.disabled = !hasSelection;
    });
  }

  function syncCertCheckboxes() {
    document.querySelectorAll<HTMLInputElement>('.cert-select-row').forEach((input) => {
      input.checked = selectedCertIds.has(input.value);
    });
    refreshCertSelectionSummary();
    refreshCertActionButtons();
  }

  function applyCertPreset(preset: string) {
    selectedCertIds.clear();

    if (preset !== 'none') {
      currentCertRows.forEach((row) => {
        if (preset === 'all' || row.status === preset) {
          selectedCertIds.add(row.id);
        }
      });
    }

    syncCertCheckboxes();
  }

  async function refreshCertificates() {
    const res = await api.call('getCertificatesByFirmaId', { firmaId });
    renderCerts(res?.data || []);
  }

  async function updateSelectedSurveillance(status: 'TRUE' | 'FALSE') {
    if (selectedCertIds.size === 0) return;

    const buttonId = status === 'TRUE' ? 'cert-mark-passive' : 'cert-mark-active';
    const button = document.getElementById(buttonId) as HTMLButtonElement | null;
    if (button) button.disabled = true;

    try {
      await api.call('updateSurveillance', { ids: Array.from(selectedCertIds), status });
      await refreshCertificates();
    } finally {
      refreshCertActionButtons();
    }
  }

  async function generateSelectedCertificates() {
    if (selectedCertIds.size === 0 || !currentCompanyNick) return;

    const button = document.getElementById('cert-generate-selected') as HTMLButtonElement | null;
    const original = button?.innerHTML || '';
    if (button) {
      button.disabled = true;
      button.innerHTML = `<span class="inline-flex items-center gap-2">Hazirlaniyor</span>`;
    }

    try {
      const folderRes = await api.call('getFolderId', { nickname: currentCompanyNick });
      const folderId = folderRes?.data;
      if (!folderId) throw new Error('Firma klasoru bulunamadi.');

      for (const certId of selectedCertIds) {
        const payloadRes = await api.buildCertPayload(certId, certLang, certSign);
        if (!payloadRes.success || !payloadRes.data) {
          throw new Error(payloadRes.error || `Payload olusturulamadi: ${certId}`);
        }

        const genRes = await api.call('generateIso', { cert: payloadRes.data, folderId });
        if (!genRes.success) {
          throw new Error(genRes.error || `Belge uretilemedi: ${certId}`);
        }
      }
    } catch (error) {
      console.error('Certificate generation failed:', error);
    } finally {
      if (button) {
        button.innerHTML = original;
      }
      refreshCertActionButtons();
    }
  }

  function setupCertificateActionBar() {
    const toggle = document.getElementById('cert-actions-toggle') as HTMLButtonElement | null;
    const panel = document.getElementById('cert-actions-panel');
    const chevron = document.getElementById('cert-actions-chevron');

    if (toggle && panel && chevron && toggle.dataset.bound !== 'true') {
      toggle.dataset.bound = 'true';
      toggle.addEventListener('click', () => {
        panel.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180');
      });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-cert-select]').forEach((button) => {
      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => applyCertPreset(button.dataset.certSelect || 'none'));
    });

    document.querySelectorAll<HTMLButtonElement>('[data-cert-lang]').forEach((button) => {
      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        certLang = (button.dataset.certLang as 'TR' | 'EN') || 'EN';
        document.querySelectorAll<HTMLButtonElement>('[data-cert-lang]').forEach((btn) => {
          const active = btn.dataset.certLang === certLang;
          btn.className = active
            ? 'cert-lang-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 text-[11px] font-bold transition-colors'
            : 'cert-lang-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover text-main text-[11px] font-bold transition-colors';
        });
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-cert-sign]').forEach((button) => {
      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        certSign = (button.dataset.certSign as 'S' | 'NS') || 'NS';
        document.querySelectorAll<HTMLButtonElement>('[data-cert-sign]').forEach((btn) => {
          const active = btn.dataset.certSign === certSign;
          btn.className = active
            ? 'cert-sign-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 text-[11px] font-bold transition-colors'
            : 'cert-sign-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-border-main bg-surface-hover text-main text-[11px] font-bold transition-colors';
        });
      });
    });

    const refreshBtn = document.getElementById('cert-refresh') as HTMLButtonElement | null;
    if (refreshBtn && refreshBtn.dataset.bound !== 'true') {
      refreshBtn.dataset.bound = 'true';
      refreshBtn.addEventListener('click', () => void refreshCertificates());
    }

    const genBtn = document.getElementById('cert-generate-selected') as HTMLButtonElement | null;
    if (genBtn && genBtn.dataset.bound !== 'true') {
      genBtn.dataset.bound = 'true';
      genBtn.addEventListener('click', () => void generateSelectedCertificates());
    }

    const passiveBtn = document.getElementById('cert-mark-passive') as HTMLButtonElement | null;
    if (passiveBtn && passiveBtn.dataset.bound !== 'true') {
      passiveBtn.dataset.bound = 'true';
      passiveBtn.addEventListener('click', () => void updateSelectedSurveillance('TRUE'));
    }

    const activeBtn = document.getElementById('cert-mark-active') as HTMLButtonElement | null;
    if (activeBtn && activeBtn.dataset.bound !== 'true') {
      activeBtn.dataset.bound = 'true';
      activeBtn.addEventListener('click', () => void updateSelectedSurveillance('FALSE'));
    }
  }

  // ─── URL Param ────────────────────────────────────────────────────────────────

  const params = new URLSearchParams(location.search);
  const firmaId = params.get('id') || '';

  if (!firmaId) {
    document.getElementById('hero-skeleton')!.innerHTML = '<p class="text-sm text-rose-400 font-bold">Geçersiz firma ID.</p>';
  }

  // ─── Load Company ─────────────────────────────────────────────────────────────

  async function loadCompany() {
    const res = await api.call('getCompanyById', { id: firmaId });
    const c = res?.data;
    if (!c) {
      document.getElementById('hero-skeleton')!.innerHTML = '<p class="text-sm text-rose-400 font-bold">Firma bulunamadı (ID: ' + firmaId + ')</p>';
      return;
    }

    // Normalize key lookup
    const nick    = g(c, 'Firma Adı', 'Nick', 'nick', 'FirmaAdi');
    const unvan   = g(c, 'Unvan', 'unvan');
    const il      = g(c, 'İl', 'Il', 'Şehir', 'Sehir', 'il', 'sehir');
    const ulke    = g(c, 'Ülke', 'Ulke', 'ulke');
    const adres   = g(c, 'Adres', 'adres');
    const yazisma = g(c, 'Yazışma Adresi', 'YazismaAdresi', 'yazisma', 'Şube Adresi');
    const kapsam  = g(c, 'Türkçe Kapsam', 'Sertifika Kapsamı (TR)', 'Kapsam', 'kapsam');
    const scope   = g(c, 'İngilizce Kapsam', 'Sertifika Kapsamı (EN)', 'Scope', 'scope');
    const tel     = g(c, 'Telefon', 'Tel', 'tel');
    const faks    = g(c, 'Faks', 'faks');
    const mail    = g(c, 'Mail', 'mail', 'E-Posta');
    const web     = g(c, 'İnternet', 'Web', 'www', 'web');
    const vergiD  = g(c, 'Vergi Dairesi', 'VergiDairesi', 'vergiD');
    const vergiN  = g(c, 'Vergi Numarası', 'VergiNumarasi', 'vergiN');
    const kyt     = g(c, 'KYT', 'Kalite Yönetim Temsilcisi', 'kyt');
    const yetA    = g(c, 'Yetkili Adı', 'YetkiliAdi', 'yetA');
    const yetU    = g(c, 'Yetkili Ünvanı', 'YetkiliUnvani', 'yetU');
    const irtA    = g(c, 'İrtibat Kişisi', 'IrtibatKisi', 'irtA');
    const irtU    = g(c, 'İrtibat Ünvanı', 'IrtibatUnvani', 'irtU');
    const irtN    = g(c, 'İrtibat Tel', 'IrtibatKisiNumarasi', 'irtN');
    const irtM    = g(c, 'İrtibat Mail', 'IrtibatKisisMail', 'irtM');
    const dan     = g(c, 'Danışman', 'Danisman', 'dan', 'danisman');
    const nace    = g(c, 'NACE', 'nace');
    const ea      = g(c, 'EA', 'ea');
    const tcs     = g(c, 'Toplam Çalışan Sayısı', 'Toplam Calisan', 'TCS', 'tcs');
    const yapis   = g(c, 'Yapılan İş', 'YapilanIs', 'yapis');
    const not_    = g(c, 'Firma Not', 'Not', 'not');
    const logoK   = g(c, 'Logo/Kase', 'Logo Kase', 'Logo/Kase-Imza', 'logoK');
    const ycs     = g(c, 'YCS', 'ycs');
    const ucs     = g(c, 'UCS', 'ucs');
    const yzcs    = g(c, 'YZCS', 'yzcs');
    const tascs   = g(c, 'TASCS', 'tascs');
    const alan    = g(c, 'Alan', 'alan');
    const dept    = g(c, 'Departman', 'dept');
    const vardiya = g(c, 'Vardiya', 'vardiya');

    // Update breadcrumb
    const breadcrumb = document.getElementById('breadcrumb-nick');
    if (breadcrumb) breadcrumb.textContent = nick || `Firma #${firmaId}`;

    // Update page title
    document.title = `${nick || 'Firma'} | Astro Portal`;

    // Hero badges
    const badgesEl = document.getElementById('hero-badges');
    if (badgesEl) {
      let html = badge(`M${firmaId}`, 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20');
      if (il) html += badge(il, 'bg-surface-hover text-muted border-border-main');
      if (dan) html += badge(dan, 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20');
      badgesEl.innerHTML = html;
    }

    setEl('hero-nick', nick);
    setEl('hero-unvan', unvan);
    setEl('hero-adres', [adres, [il, ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - '));
    currentCompanyNick = nick;

    // Edit link
    const btnEdit = document.getElementById('btn-edit') as HTMLAnchorElement | null;
    if (btnEdit) btnEdit.href = `/company/edit?id=${firmaId}`;

    const btnAddAudit = document.getElementById('btn-add-audit') as HTMLAnchorElement | null;
    if (btnAddAudit) btnAddAudit.href = `/audits/add?firmaId=${firmaId}`;
    const btnAuditLink = document.getElementById('btn-audit-link') as HTMLAnchorElement | null;
    if (btnAuditLink) btnAuditLink.href = `/audits/add?firmaId=${firmaId}`;

    // Kapsam
    setEl('hero-kapsam', kapsam);
    setEl('hero-scope', scope);

    const heroSubeRow = document.getElementById('hero-sube-row');
    const infoSubeRow = document.getElementById('info-sube-row');
    if (yazisma) {
      setEl('hero-sube', yazisma);
      setEl('info-sube', yazisma);
      heroSubeRow?.classList.remove('hidden');
      infoSubeRow?.classList.remove('hidden');
    } else {
      heroSubeRow?.classList.add('hidden');
      infoSubeRow?.classList.add('hidden');
    }

    // İletişim
    setField('info-telefon', tel, 'info-telefon-block');
    setField('info-faks', faks, 'info-faks-block');
    setField('info-mail', mail, 'info-mail-block');
    setField('info-web', web, 'info-web-block');
    const vergi = [vergiD, vergiN].filter(Boolean).join(' — ');
    setField('info-vergi', vergi, 'info-vergi-block');
    setField('info-location', [il, ulke].filter(Boolean).join(' / '), 'info-location-block');
    setField('info-tcs', tcs, 'info-tcs-block');
    setField('info-sector', [nace, ea].filter(Boolean).join(' / '), 'info-sector-block');
    setField('info-facility', [alan && `${alan} m2`, dept && `${dept} departman`].filter(Boolean).join(' / '), 'info-facility-block');
    setField('info-vardiya', vardiya, 'info-vardiya-block');

    const workforce = [
      ycs && `Yonetim: ${ycs}`,
      ucs && `Uretim: ${ucs}`,
      yzcs && `Yari Zamanli: ${yzcs}`,
      tascs && `Taseron: ${tascs}`,
    ].filter(Boolean).join(' / ');
    setField('info-workforce', workforce, 'info-workforce-block');

    // Yetkililer
    setField('info-kyt', kyt, 'info-kyt-block');
    setField('info-yetkili', yetA, 'info-yetkili-block');
    setField('info-yetkili-unvan', yetU, 'info-yetkili-unvan-block');
    setField('info-irtibat', irtA, 'info-irtibat-block');
    setField('info-irtibat-unvan', irtU, 'info-irtibat-unvan-block');
    setField('info-irtibat-tel', irtN, 'info-irtibat-tel-block');
    setField('info-irtibat-mail', irtM, 'info-irtibat-mail-block');

    // Kayıtlar
    setField('info-dan', dan, 'info-dan-block');
    setField('info-not', not_, 'info-not-block');
    setField('info-logo', logoK, 'info-logo-block');

    // Kart görünürlüğü
    toggleCardVisibility('profile-card', [
      'info-location-block',
      'info-tcs-block',
      'info-sector-block',
      'info-facility-block',
      'info-vardiya-block',
      'info-workforce-block',
      'info-sube-row',
    ]);

    toggleCardVisibility('contact-card', [
      'info-telefon-block',
      'info-faks-block',
      'info-mail-block',
      'info-web-block',
      'info-vergi-block',
    ]);

    toggleCardVisibility('people-card', [
      'info-kyt-block',
      'info-yetkili-block',
      'info-yetkili-unvan-block',
      'info-irtibat-block',
      'info-irtibat-unvan-block',
      'info-irtibat-tel-block',
      'info-irtibat-mail-block',
    ]);

    toggleCardVisibility('records-card', [
      'info-dan-block',
      'info-not-block',
      'info-logo-block',
    ]);

    // Firma Detayları
    const detailsGrid = document.getElementById('details-grid');
    if (detailsGrid) {
      const details = [
        { label: 'NACE', value: nace },
        { label: 'EA', value: ea },
        { label: 'Toplam Çalışan', value: tcs },
      ].filter(d => d.value);

      detailsGrid.innerHTML = details.map(d => `
        <div class="${d.span ? 'md:col-span-2' : ''} p-4 rounded-2xl bg-surface-hover border border-border-main">
          <p class="text-[10px] font-bold text-muted uppercase tracking-widest mb-1">${d.label}</p>
          <p class="text-sm font-semibold text-main">${d.value}</p>
        </div>`).join('');
    }

    setEl('info-yapis', yapis);
    if (!yapis) { document.getElementById('yapis-row')?.classList.add('hidden'); }

    // Show hero
    document.getElementById('hero-skeleton')?.classList.add('hidden');
    document.getElementById('hero-content')?.classList.remove('hidden');
  }

  // ─── Load Certificates ────────────────────────────────────────────────────────

  function renderCerts(certData: any[]) {
    const skeleton = document.getElementById('cert-skeleton');
    const wrapper  = document.getElementById('cert-list-wrapper');
    const empty    = document.getElementById('cert-empty');
    const tbody    = document.getElementById('cert-tbody');
    const count    = document.getElementById('cert-count');

    skeleton?.classList.add('hidden');
    wrapper?.classList.add('hidden');
    empty?.classList.add('hidden');

    if (!certData.length) {
      currentCertRows = [];
      selectedCertIds.clear();
      refreshCertSelectionSummary();
      refreshCertActionButtons();
      empty?.classList.remove('hidden');
      return;
    }

    if (count) count.textContent = String(certData.length);

    // Certs from store are objects; certs from API are raw rows
    const isRaw = Array.isArray(certData[0]);

    const nextRows: Array<{ id: string; status: string }> = [];

    const rows = certData.map(c => {
      let id, standart, sertNo, belgeTarihi, gozT, akreditasyon, gozetimConf;
      if (isRaw) {
        // Raw row: [id, nick, firmaNo, standart, sertNo, belgeTarihi?, ...]
        id          = String(c[0] || '');
        standart    = c[3]  || '';
        sertNo      = c[4]  || '';
        belgeTarihi = c[5]  || '';
        gozT        = c[6]  || '';
        akreditasyon= c[14] || '';
        gozetimConf = String(c[19] || '').toUpperCase() === 'TRUE';
      } else {
        id          = g(c, 'ID', 'id');
        standart    = g(c, 'Standart', 'standart');
        sertNo      = g(c, 'Sertifika No', 'sertNo', 'SertifikaNo');
        belgeTarihi = g(c, 'Sertifika Tarihi', 'Belge Tarihi', 'sTarihi');
        gozT        = g(c, 'Gözetim Tarihi', 'sGozetimT', 'GözetimTarihi');
        akreditasyon= g(c, 'Akreditasyon', 'akrn', 'akreditasyon');
        gozetimConf = String(g(c, 'Gözetim Conf.', 'gozetimConf')).toUpperCase() === 'TRUE';
      }

      const parsedDate = gozT ? new Date(gozT.split('.').reverse().join('-')) : null;
      const now = new Date();
      const diffDays = parsedDate ? Math.floor((parsedDate.getTime() - now.getTime()) / 86400000) : null;
      const statusKey = gozetimConf
        ? 'uyku'
        : parsedDate && parsedDate < now
          ? 'pasif'
          : diffDays !== null && diffDays < 46
            ? 'warning'
            : 'active';

      nextRows.push({ id, status: statusKey });

      const statusHtml = gozetimConf
        ? `<span class="px-2 py-0.5 rounded-md bg-slate-500/10 text-slate-300 border border-slate-500/20 text-[9px] font-bold">GOZETIMDE</span>`
        : statusKey === 'pasif'
          ? `<span class="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 border border-rose-500/20 text-[9px] font-bold">PASIF</span>`
          : statusKey === 'warning'
            ? `<span class="px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-300 border border-amber-500/20 text-[9px] font-bold">YAKLASAN</span>`
            : `<span class="px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[9px] font-bold">AKTIF</span>`;

      return `<tr class="border-b border-border-main hover:bg-surface-hover transition-colors">
        <td class="px-4 sm:px-7 py-3 text-center">
          <input type="checkbox" class="cert-select-row h-4 w-4 rounded border-border-main bg-surface-hover text-emerald-500 focus:ring-emerald-500/40" value="${id}">
        </td>
        <td class="px-4 sm:px-7 py-3 font-bold text-main text-xs">
          <div>${standart || '—'}</div>
          <div class="sm:hidden text-[10px] text-muted font-mono mt-0.5">${sertNo || ''}</div>
        </td>
        <td class="hidden sm:table-cell px-4 py-3 text-muted font-mono text-xs">${sertNo || '—'}</td>
        <td class="hidden md:table-cell px-4 py-3 text-muted text-xs">${belgeTarihi || '—'}</td>
        <td class="hidden md:table-cell px-4 py-3 text-muted text-xs">${gozT || '—'}</td>
        <td class="hidden lg:table-cell px-4 py-3 text-muted text-xs">${akreditasyon || '—'}</td>
        <td class="px-4 py-3 text-center">${statusHtml}</td>
        <td class="px-4 py-3 text-center">
          <div class="inline-flex items-center justify-center gap-1">
            <a href="/certificates" class="inline-flex min-w-0 items-center justify-center rounded-lg border border-border-main bg-surface-hover px-2.5 py-2 text-main hover:bg-surface transition-colors text-[10px] font-bold uppercase tracking-wide" title="Sertifika Merkezi">
              Merkez
            </a>
            <button type="button" class="cert-copy-id inline-flex min-w-0 items-center justify-center rounded-lg border border-border-main bg-surface-hover px-2.5 py-2 text-main hover:bg-surface transition-colors text-[10px] font-bold uppercase tracking-wide" data-cert-id="${id}" title="ID Kopyala">
              ID
            </button>
          </div>
        </td>
      </tr>`;
    }).join('');

    currentCertRows = nextRows;
    const validIds = new Set(nextRows.map((row) => row.id));
    Array.from(selectedCertIds).forEach((id) => {
      if (!validIds.has(id)) selectedCertIds.delete(id);
    });

    if (tbody) tbody.innerHTML = rows;
    wrapper?.classList.remove('hidden');

    // Update add cert link
    const btnAddCert = document.getElementById('btn-add-cert') as HTMLAnchorElement | null;
    if (btnAddCert) btnAddCert.href = `/certificates?add=1&firmaId=${firmaId}`;

    const folderLink = document.getElementById('cert-folder-link') as HTMLAnchorElement | null;
    if (folderLink) folderLink.href = '/documents/view';

    document.querySelectorAll<HTMLInputElement>('.cert-select-row').forEach((input) => {
      input.addEventListener('change', () => {
        if (input.checked) selectedCertIds.add(input.value);
        else selectedCertIds.delete(input.value);
        refreshCertSelectionSummary();
        refreshCertActionButtons();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.cert-copy-id').forEach((button) => {
      button.addEventListener('click', async () => {
        const certId = button.dataset.certId || '';
        if (!certId) return;
        await copyText(certId);
        flashCopyState(button);
      });
    });

    setupCertificateActionBar();
    syncCertCheckboxes();
  }

  // ─── Load Audits ──────────────────────────────────────────────────────────────

  async function loadAudits() {
    const res = await api.call('getAuditsByFirmaId', { firmaId });
    const skeleton = document.getElementById('audit-skeleton');
    const wrapper  = document.getElementById('audit-list-wrapper');
    const empty    = document.getElementById('audit-empty');
    const tbody    = document.getElementById('audit-tbody');
    const count    = document.getElementById('audit-count');

    skeleton?.classList.add('hidden');

    const audits: any[] = res?.data || [];

    if (!audits.length) {
      empty?.classList.remove('hidden');
      return;
    }

    if (count) count.textContent = String(audits.length);

    const isRaw = Array.isArray(audits[0]);

    const rows = audits.map(a => {
      let standart, tur, a1Basla, a1Bitis, a2Basla, a2Bitis, a1Lead;
      if (isRaw) {
        standart = a[3] || '';
        tur      = a[4] || '';
        a1Basla  = a[9] || '';
        a1Bitis  = a[10] || '';
        a2Basla  = a[15] || '';
        a2Bitis  = a[16] || '';
        a1Lead   = a[6] || '';
      } else {
        standart = g(a, 'standart', 'Standart');
        tur      = g(a, 'denetimTipi', 'Denetim Tipi');
        a1Basla  = g(a, 'a1Basla');
        a1Bitis  = g(a, 'a1Bitis');
        a2Basla  = g(a, 'a2Basla');
        a2Bitis  = g(a, 'a2Bitis');
        a1Lead   = g(a, 'a1Lead', 'A1 Lead');
      }

      const a1Range = a1Basla ? `${a1Basla}${a1Bitis && a1Bitis !== a1Basla ? ' → ' + a1Bitis : ''}` : '—';
      const a2Range = a2Basla ? `${a2Basla}${a2Bitis && a2Bitis !== a2Basla ? ' → ' + a2Bitis : ''}` : '—';

      return `<tr class="border-b border-border-main hover:bg-surface-hover transition-colors">
        <td class="px-4 sm:px-7 py-3 font-bold text-main text-xs">
          <div>${standart || '—'}</div>
          <div class="sm:hidden text-[10px] text-muted mt-0.5">${tur || ''}</div>
        </td>
        <td class="hidden sm:table-cell px-4 py-3 text-muted text-xs">${tur || '—'}</td>
        <td class="hidden sm:table-cell px-4 py-3 text-muted font-mono text-[11px]">${a1Range}</td>
        <td class="hidden md:table-cell px-4 py-3 text-muted font-mono text-[11px]">${a2Range}</td>
        <td class="hidden md:table-cell px-4 py-3 text-muted text-xs">${a1Lead || '—'}</td>
      </tr>`;
    }).join('');

    if (tbody) tbody.innerHTML = rows;
    wrapper?.classList.remove('hidden');
  }

  // ─── Certificates from Store ──────────────────────────────────────────────────

  function loadCertsFromStore(certs: readonly any[]) {
    const filtered = (certs as any[]).filter(c => {
      const no = g(c, 'Firma No', 'FirmaNo', 'firmaNo');
      return String(no) === String(firmaId);
    });
    renderCerts(filtered);
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────────

  if (firmaId) {
    setupCopyButtons();

    SyncManager.init().then(() => {
      // Once store is ready, filter certs
      const certs = $certificates.get();
      if (certs.length > 0) {
        loadCertsFromStore(certs);
      } else {
        // Fallback: fetch from API
        api.call('getCertificatesByFirmaId', { firmaId }).then(res => {
          renderCerts(res?.data || []);
        });
      }
    });

    $certificates.subscribe(certs => {
      if (certs.length > 0) loadCertsFromStore(certs);
    });

    Promise.all([loadCompany(), loadAudits()]);
  }
</script>
