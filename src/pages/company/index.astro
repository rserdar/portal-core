  function buildCompanyOperationLink(baseHref: string) {
    if (!baseHref || !firmaId) return baseHref;
    const [pathname, rawQuery = ''] = baseHref.split('?');
    const searchParams = new URLSearchParams(rawQuery);
    searchParams.set('id', firmaId);
    if (pathname === '/audits/add') searchParams.set('firmaId', firmaId);
    const query = searchParams.toString();
    return query ? `${pathname}?${query}` : pathname;
  }

  function setupOperationLinks() {
