      } else {
        const msg = res.error || 'Firma klasörü bulunamadı.';
        toast.error(msg);
        console.error(`[Profile] getFolderId failed:`, msg);
      }
    } catch (err: any) {
      toast.error('Klasör açılırken bir hata oluştu.');
