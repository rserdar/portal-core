---
import OperationPageShell from '../../components/operations/OperationPageShell.astro';
---

<OperationPageShell
  pageKey="contract"
  title="Sozlesme"
  description="Sozlesme ucreti, tarihi ve konusu gibi alanlari firma context'i ile birlestiren ayri operasyon sayfasidir."
>
  <div class="space-y-6">
    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-5">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-2xl bg-indigo-500/10 text-indigo-400 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <div>
            <h2 class="text-sm font-black uppercase tracking-widest text-main">Sozlesme Bilgileri</h2>
            <p class="text-xs text-muted">Sozlesme ucreti, tarihi ve konusu</p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Sozlesme Tarihi</label>
            <input id="contract-date" type="date" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main focus:border-indigo-500/50 outline-none transition-colors" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Sozlesme Ucreti</label>
            <input id="contract-price" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main focus:border-indigo-500/50 outline-none transition-colors" placeholder="Ucret girin (Or: 5.000 TL)" />
          </div>
        </div>
        
        <div class="space-y-2">
          <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Sozlesme Konusu</label>
          <input id="contract-subject" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm font-semibold text-main focus:border-indigo-500/50 outline-none transition-colors" placeholder="Sozlesme konusu" />
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-5">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-2xl bg-sky-500/10 text-sky-400 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"></path><path d="M14 17H5"></path><circle cx="17" cy="17" r="3"></circle><circle cx="7" cy="7" r="3"></circle></svg>
          </div>
          <div>
            <h2 class="text-sm font-black uppercase tracking-widest text-main">Firma Referansi</h2>
            <p class="text-xs text-muted">Sertifika ve irtibat detaylari</p>
          </div>
        </div>

        <div class="rounded-2xl border border-border-main bg-surface-hover p-4 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
          <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1">Vergi Bilgileri</p>
            <p id="contract-preview-tax" class="font-bold text-main">—</p>
          </div>
          <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1">Yetkili Kisi ve Unv.</p>
            <p id="contract-preview-auth" class="font-bold text-main">—</p>
          </div>
          <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1">Telefon / Faks</p>
            <div class="flex flex-col gap-0.5">
              <p id="contract-preview-tel" class="font-bold text-sky-300 truncate text-[12px] leading-tight">—</p>
              <p id="contract-preview-faks" class="font-bold text-sky-300 truncate text-[12px] leading-tight">—</p>
            </div>
          </div>
        </div>
        
        <div class="rounded-2xl border border-dashed border-sky-500/20 bg-sky-500/5 p-4 text-[11px] leading-relaxed text-muted/80 italic">
          Bu bilgiler Google Docs uzerinde olusturulacak sozlesme dokumanina otomatik olarak aktarilacaktir.
        </div>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <button id="contract-clear" type="button" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-5 py-3 text-sm font-bold text-main hover:bg-surface-hover transition-colors">Formu Temizle</button>
      <button id="contract-generate" type="button" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-6 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-500/20 disabled:opacity-50 disabled:cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
        <span id="generate-label">Sozlesme Uret</span>
      </button>
    </div>
  </div>
</OperationPageShell>

<script>
  import { toast } from '../../lib/toast';
  import { api } from '../../lib/api';
  import { loadCompanyOperationContext } from '../../features/operations/context';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/operations/definitions';

  const params = new URLSearchParams(location.search);
  const firmaId = params.get('id') || '';
  let activeContext: Awaited<ReturnType<typeof loadCompanyOperationContext>> = null;

  async function generateContract() {
    if (!activeContext) return;
    const btn = document.getElementById('contract-generate') as HTMLButtonElement | null;
    const label = document.getElementById('generate-label');
    const dateInput = document.getElementById('contract-date') as HTMLInputElement | null;
    const priceInput = document.getElementById('contract-price') as HTMLInputElement | null;
    const subjectInput = document.getElementById('contract-subject') as HTMLInputElement | null;

    if (!dateInput?.value || !priceInput?.value || !subjectInput?.value) {
      toast.warning('Lutfen sozlesme tarihi, ucreti ve konusunu doldurun.');
      return;
    }

    if (btn) {
      btn.disabled = true;
      if (label) label.textContent = 'Hazirlaniyor...';
    }

    toast.info('Sozlesme dokumani hazirlaniyor, lutfen bekleyin...');

    try {
      const payload = {
        id: firmaId,
        ...activeContext,
        contractDate: dateInput.value.split('-').reverse().join('.'),
        contractPrice: priceInput.value,
        contractSubject: subjectInput.value
      };

      const res = await api.generateContract(payload);
      if (res.success) {
        toast.success('Sozlesme dokumani basariyla olusturuldu.');
        const url = (res.data as any)?.url;
        if (url) window.open(url, '_blank');
      } else {
        toast.error(res.error || 'Sozlesme olusturulurken bir hata olustu.');
      }
    } catch (err: any) {
      toast.error('Kritik hata: ' + err.message);
    } finally {
      if (btn) {
        btn.disabled = false;
        if (label) label.textContent = 'Sozlesme Uret';
      }
    }
  }

  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text || '—';
  }

  async function boot() {
    if (!firmaId) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.remove('hidden');
      return;
    }

    const context = await loadCompanyOperationContext(firmaId);
    activeContext = context;
    if (!context) {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.remove('hidden');
      return;
    }

    (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${firmaId}`);
    document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
      const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
      const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
      if (definition) link.href = buildOperationHref(definition.href, firmaId);
    });

    setText('op-company-id', `M${context.firmaId}`);
    setText('op-company-nick', context.nick || 'Firma');
    setText('op-company-dan', context.danisman || 'Danisman atanamamis');
    setText('op-company-unvan', context.unvan || context.nick || `Firma #${context.firmaId}`);
    setText('op-company-address', [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—');
    setText('op-company-kapsam', context.kapsam || context.scope || 'Kapsam bulunamadi.');
    setText('op-company-stats', `${context.certificates.length} sertifika, ${context.tests.length} test verisi sozlesme referansi icin hazir.`);

    const subjectInput = document.getElementById('contract-subject') as HTMLInputElement | null;
    if (subjectInput) {
      subjectInput.value = `${context.unvan || context.nick} belgelendirme hizmetleri`;
    }

    setText('contract-preview-tax', [context.vergiD, context.vergiN].filter(Boolean).join(' / '));
    setText('contract-preview-auth', [context.yetkiliAdi, context.yetkiliUnvani].filter(Boolean).join(' / '));
    setText('contract-preview-tel', context.tel || '');
    setText('contract-preview-faks', context.faks || '');

    document.getElementById('contract-generate')?.addEventListener('click', generateContract);
    document.getElementById('contract-clear')?.addEventListener('click', () => {
      ['contract-date', 'contract-price', 'contract-subject'].forEach(id => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) el.value = '';
      });
    });

    document.getElementById('op-skeleton')?.classList.add('hidden');
    document.getElementById('op-shell')?.classList.remove('hidden');
  }

  void boot();
</script>
