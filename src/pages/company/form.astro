---
import PageShell from '../../components/PageShell.astro';
import CompanyPicker from '../../components/CompanyPicker.astro';
---

<PageShell
  pageKey="form"
  title="Başvuru Formu"
  description="Standart seçimi, akreditasyon tercihleri ve firma kapsam kontrolünü tek akışta toplayan mobil uyumlu başvuru hazırlama ekranıdır."
>
  <CompanyPicker
    slot="select"
    prefix="form"
    eyebrow="Başvuru Formu"
    description="Bu ekran header'dan doğrudan açıldığında önce ilgili firmayı seçersin. Firma profilinden geliyorsan bu adım otomatik atlanır."
  />

  <div class="space-y-6">
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Standartlar</h2>
          <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 1</span>
        </div>
        <div class="grid grid-cols-2 gap-3 text-sm">
          {[
            { label: 'ISO 9001', key: 'qms' },
            { label: 'ISO 13485', key: 'mdd' },
            { label: 'ISO 14001', key: 'ems' },
            { label: 'ISO 22000', key: 'fsms' },
            { label: 'ISO 27001', key: 'isms' },
            { label: 'ISO 45001', key: 'ohs' },
            { label: 'ISO 50001', key: 'eng' },
            { label: 'ISO 22716', key: 'gmp' },
            { label: 'ISO 10002', key: 'obi' },
            { label: '2017/745/EU', key: 'ce' },
            { label: 'Diğer', key: 'oth' }
          ].map((item) => (
            <label class="flex items-center gap-3 rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-main cursor-pointer hover:bg-surface-active transition-colors">
              <input type="checkbox" id={`form-std-${item.key}`} class="h-4 w-4 rounded border-border-main bg-surface text-primary" />
              <span class="font-semibold">{item.label}</span>
            </label>
          ))}
        </div>
        <div class="space-y-2">
          <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Diğer Standart</label>
          <input type="text" id="form-std-diger" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Gerekirse manuel standart girin" />
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Akreditasyon</h2>
          <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 2</span>
        </div>
        <div class="space-y-2">
          <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Belgelendirme Firması</label>
          <select id="form-nbody" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50">
            <option value="Medicert">Medicert</option>
            <option value="Inspect">Inspect</option>
          </select>
        </div>
        <div class="space-y-2">
          <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Akreditasyon Kuruluşu</label>
          <select id="form-acc" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main focus:outline-none focus:ring-2 focus:ring-indigo-500/50">
            <option value="TURKAK">TURKAK</option>
            <option value="IAS">IAS</option>
            <option value="NON-ACC">Akreditasyonsuz</option>
          </select>
        </div>
        <div class="rounded-2xl border border-dashed border-border-main p-4 text-sm leading-relaxed text-muted">
          Kaydetme ve belge üretme aksiyonları ikinci adımda API'ye bağlanacak. Bu sayfa şu an mobil akışı ve alan mimarisini sabitliyor.
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Firma Kontrolü</h2>
          <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 3</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Yetkili Adı</label>
            <input id="form-yetkili" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Yetkili ad soyad" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Yetkili Unvanı</label>
            <input id="form-yetkili-unvan" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Örn: Genel Müdür" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">İrtibat Kişisi</label>
            <input id="form-irtibat" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="İrtibat ad soyad" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">İrtibat Unvanı</label>
            <input id="form-irtibat-unvan" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" placeholder="Örn: Kalite Yöneticisi" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">Telefon</label>
            <input id="form-tel" type="text" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" />
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-bold uppercase tracking-widest text-muted">E-Posta</label>
            <input id="form-mail" type="email" class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main" />
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-border-main bg-surface p-5 sm:p-6 space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-sm font-black uppercase tracking-widest text-main">Kapsam İncelemesi</h2>
          <span class="text-[10px] font-bold px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted">Adım 4</span>
        </div>
        <textarea id="form-kapsam" rows={6} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[180px]"></textarea>
        <textarea id="form-scope" rows={6} class="w-full rounded-2xl border border-border-main bg-surface-hover px-4 py-3 text-sm text-main min-h-[180px]" placeholder="Scope (EN)"></textarea>
      </div>
    </section>

    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
      <a href="/company/edit" id="form-edit-link" class="inline-flex items-center justify-center rounded-2xl border border-border-main bg-surface px-4 py-3 text-sm font-bold text-main hover:bg-surface-hover transition-colors">Firma Bilgilerini Düzenle</a>
      <button id="form-generate" type="button" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 px-6 py-3 text-sm font-black text-white hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-500/20 disabled:opacity-50 disabled:cursor-not-allowed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
        <span>Kaydet ve Form Üret</span>
      </button>
    </div>
  </div>
</PageShell>

<script>
  import { toast } from '../../lib/toast';
  import { api } from '../../lib/api';
  import { setupOperationCompanyPicker } from '../../features/company-picker';
  import { loadCompanyOperationContext } from '../../features/context';
  import { OPERATION_DEFINITIONS, buildOperationHref } from '../../features/definitions';

  let activeContext: Awaited<ReturnType<typeof loadCompanyOperationContext>> = null;
  let firmaId = '';
  let cleanupFns: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }

  function runCleanups() {
    cleanupFns.forEach(fn => fn());
    cleanupFns = [];
  }

  function initPage() {
    runCleanups();

    const params = new URLSearchParams(location.search);
    firmaId = params.get('id') || params.get('firmaId') || '';

    function showCompanyPicker() {
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-error')?.classList.add('hidden');
      document.getElementById('op-shell')?.classList.add('hidden');
      document.getElementById('op-select')?.classList.remove('hidden');
      (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', '/search');
    }

    function setValue(id: string, value: string) {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
      if (el) el.value = value || '';
    }

    function getValue(id: string) {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      return el ? el.value.trim() : '';
    }

    function isChecked(id: string) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      return el ? (el.checked ? 'X' : '') : '';
    }

    async function generateForm() {
      if (!activeContext) {
        toast.error('Firma verisi yüklenemedi.');
        return;
      }

      const btn = document.getElementById('form-generate') as HTMLButtonElement | null;
      const nbody = getValue('form-nbody');
      if (!nbody) {
        toast.warning('Lütfen belgelendirme firmasını seçin.');
        return;
      }

      if (btn) btn.disabled = true;
      toast.info('Başvuru formu hazırlanıyor, lütfen bekleyin...');

      try {
        const payload = {
          ...activeContext,
          id: firmaId,
          nickname: activeContext?.nick || 'Firma',
          unvan: activeContext?.unvan || activeContext?.nick || 'Firma',
          nbody,
          acc: getValue('form-acc'),
          yetA: getValue('form-yetkili'),
          yetU: getValue('form-yetkili-unvan'),
          irtA: getValue('form-irtibat'),
          irtU: getValue('form-irtibat-unvan'),
          tel: getValue('form-tel'),
          mail: getValue('form-mail'),
          kapsam: getValue('form-kapsam'),
          scope: getValue('form-scope'),
          // Standartlar (Checkboxes)
          qms: isChecked('form-std-qms'),
          mdd: isChecked('form-std-mdd'),
          ems: isChecked('form-std-ems'),
          fsms: isChecked('form-std-fsms'),
          isms: isChecked('form-std-isms'),
          ohs: isChecked('form-std-ohs'),
          eng: isChecked('form-std-eng'),
          gmp: isChecked('form-std-gmp'),
          obi: isChecked('form-std-obi'),
          ce: isChecked('form-std-ce'),
          oth: isChecked('form-std-oth'),
          diger: getValue('form-std-diger')
        };

        const folderRes = await api.call('getFolderId', { id: firmaId });
        const folderId = folderRes.success ? folderRes.data : null;

        const res = await api.call('generateAppForm', { info: payload, folderId });
        
        if (res.success) {
          toast.success('Başvuru formu başarıyla oluşturuldu.');
          const url = (res.data as any)?.url;
          if (url) window.open(url, '_blank');
        } else {
          toast.error(res.error || 'Form oluşturulurken bir hata meydana geldi.');
        }
      } catch (err: any) {
        toast.error('Kritik sistem hatası: ' + err.message);
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function loadScreen() {
      if (!firmaId) return;

      const context = await loadCompanyOperationContext(firmaId);
      activeContext = context;
      if (!context) {
        document.getElementById('op-skeleton')?.classList.add('hidden');
        document.getElementById('op-error')?.classList.remove('hidden');
        return;
      }

      (document.getElementById('op-back-link') as HTMLAnchorElement | null)?.setAttribute('href', `/company?id=${firmaId}`);
      document.querySelectorAll<HTMLAnchorElement>('[data-op-link]').forEach((link) => {
        const key = link.dataset.opLink as 'form' | 'proforma' | 'draft' | 'contract';
        const definition = OPERATION_DEFINITIONS.find((item) => item.key === key);
        if (definition) link.href = buildOperationHref(definition.href, firmaId);
      });

      const setText = (id: string, text: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = text || '—';
      };

      setText('op-company-id', `M${context.firmaId}`);
      setText('op-company-nick', context.nick || 'Firma');
      setText('op-company-dan', context.danisman || 'Danışman atanamamış');
      setText('op-company-unvan', context.unvan || context.nick || `Firma #${context.firmaId}`);
      setText('op-company-address', [context.adres, [context.sehir, context.ulke].filter(Boolean).join(' / ')].filter(Boolean).join(' - ') || '—');
      setText('op-company-kapsam', context.kapsam || context.scope || 'Kapsam bulunamadı.');
      setText('op-company-stats', `${context.certificates.length} sertifika, ${context.tests.length} test kaydı bulundu.`);

      setValue('form-yetkili', context.yetkiliAdi);
      setValue('form-yetkili-unvan', context.yetkiliUnvani);
      setValue('form-irtibat', context.irtibatAdi);
      setValue('form-irtibat-unvan', context.irtibatUnvani || '');
      setValue('form-tel', context.tel || context.irtibatTel);
      setValue('form-mail', context.mail || context.irtibatMail);
      setValue('form-kapsam', context.kapsam);
      setValue('form-scope', context.scope);
      
      const digerInput = document.getElementById('form-std-diger') as HTMLInputElement | null;
      const digerCheck = document.getElementById('form-std-oth') as HTMLInputElement | null;
      if (digerInput && digerCheck) {
        digerInput.addEventListener('input', () => {
          if (digerInput.value.trim().length > 0) {
            digerCheck.checked = true;
          }
        });
      }

      const editLink = document.getElementById('form-edit-link') as HTMLAnchorElement | null;
      if (editLink) editLink.href = `/company/edit?id=${firmaId}`;

      document.getElementById('form-generate')?.addEventListener('click', generateForm);

      document.getElementById('op-select')?.classList.add('hidden');
      document.getElementById('op-skeleton')?.classList.add('hidden');
      document.getElementById('op-shell')?.classList.remove('hidden');
    }

    async function prepareCompanyPicker() {
      await setupOperationCompanyPicker({
        prefix: 'form',
        registerCleanup,
        onShowPicker: showCompanyPicker,
        onSelected: async ({ id }) => {
          firmaId = id;
          await loadScreen();
        },
      });
    }

    async function boot() {
      if (!firmaId) {
        await prepareCompanyPicker();
        return;
      }
      await loadScreen();
    }

    void boot();
  }

  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
