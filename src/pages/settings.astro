---
import DashboardLayout from "../layouts/DashboardLayout.astro";

const SYNC_SCOPE_OPTIONS = [
  { value: "companies", label: "Firmalar" },
  { value: "certificates", label: "Sertifikalar" },
  { value: "audits", label: "Denetimler" },
  { value: "tests", label: "Testler" },
  { value: "proformas", label: "Proformalar" },
];

const MASTER_SYNC_OPTIONS = [
  { value: "standards", label: "Standartlar" },
  { value: "auditors", label: "Denetçiler" },
  { value: "consultants", label: "Danışmanlar" },
  { value: "testdocs", label: "TestDoc" },
  { value: "sysdocs", label: "SysDoc" },
];
---

<DashboardLayout title="Ayarlar">
  <section class="space-y-6">
    <div class="bg-surface border border-border-main rounded-2xl p-6 shadow-xl">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Master Data</p>
          <h1 class="text-2xl font-extrabold mt-1">Ana Veri Yönetimi</h1>
          <p class="text-sm text-muted mt-2">
            Standartlar, Denetçiler, Danışmanlar, TestDoc ve SysDoc verilerini buradan yönetebilirsin.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="refresh-btn" class="px-4 py-2 rounded-xl bg-surface-hover border border-border-main text-sm font-bold">
            Yenile
          </button>
        </div>
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-center gap-3">
        <label for="dataset-select" class="text-sm font-bold text-muted">Veri Seti</label>
        <select id="dataset-select" class="bg-surface-hover border border-border-main rounded-xl px-3 py-2 text-sm">
          <option value="standards">Standartlar</option>
          <option value="auditors">Denetçiler</option>
          <option value="consultants">Danışmanlar</option>
          <option value="testdocs">TestDoc</option>
          <option value="sysdocs">SysDoc</option>
        </select>
        <div class="ml-auto text-xs text-muted">
          <span id="meta-version">v-</span>
          <span class="mx-2">|</span>
          <span id="meta-updated">-</span>
        </div>
      </div>

      <div id="status-box" class="hidden rounded-xl px-3 py-2 text-sm"></div>

      <div class="overflow-auto border border-border-main rounded-xl">
        <table class="min-w-full text-sm">
          <thead id="master-thead" class="bg-surface-hover"></thead>
          <tbody id="master-tbody"></tbody>
        </table>
      </div>

      <div class="flex flex-wrap gap-2">
        <button id="add-row-btn" class="px-4 py-2 rounded-xl bg-surface-hover border border-border-main text-sm font-bold">
          Satır Ekle
        </button>
        <button id="save-btn" class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold">
          Kaydet
        </button>
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Aksiyon Kapsamı</p>
          <h2 class="text-xl font-extrabold mt-1">İşlem Kapsamı Seçimi</h2>
          <p class="text-sm text-muted mt-2">
            Aşağıdaki işlemlerden hangilerinin yapılacağını buradan seçebilirsin.
          </p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
        {SYNC_SCOPE_OPTIONS.map((scope) => (
          <label class="flex items-center gap-2 p-3 rounded-xl bg-surface-hover border border-border-main cursor-pointer hover:border-indigo-500 transition-colors">
            <input type="checkbox" name="sync-scope" value={scope.value} checked class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
            <span class="text-sm font-medium">{scope.label}</span>
          </label>
        ))}
      </div>
      <div class="rounded-2xl border border-border-main bg-surface-hover/70 p-4 space-y-4">
        <label class="flex items-center gap-2 font-semibold text-sm">
          <input id="master-sync-all" type="checkbox" name="sync-scope" value="master" checked class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
          <span>Ana Veri</span>
        </label>
        <p class="text-xs text-muted">
          Ana Veri kutusu tüm alt başlıkları birlikte seçer. İstersen sadece belirli ana veri tablolarını güncelleyip gereksiz D1 yazımını azaltabilirsin.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3">
          {MASTER_SYNC_OPTIONS.map((scope) => (
            <label class="flex items-center gap-2 p-3 rounded-xl bg-surface border border-border-main cursor-pointer hover:border-indigo-500 transition-colors">
              <input type="checkbox" name="master-sync-scope" value={scope.value} checked class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
              <span class="text-sm font-medium">{scope.label}</span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-border-main pb-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Google Sheets → D1</p>
          <h2 class="text-xl font-extrabold mt-1">Sheets Senkronizasyonu</h2>
          <p class="text-sm text-muted mt-2">
            Verileri Google Sheets'ten Cloudflare D1'e çeker. Seçili kapsamları günceller.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="smart-sync-btn" class="px-4 py-2 rounded-xl bg-teal-600 hover:bg-teal-500 text-white text-sm font-bold shadow-lg shadow-teal-600/20 active:scale-95 transition-all">
            ⚡ Hızlı Sync
          </button>
          <button id="ops-sync-btn" class="px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold shadow-lg shadow-indigo-600/20 active:scale-95 transition-all">
            Seçili Verileri Sheets'ten Çek
          </button>
        </div>
      </div>

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 pt-2">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">D1 &lt;-&gt; JSON</p>
          <h2 class="text-xl font-extrabold mt-1">JSON Yedekleme / Geri Yükleme</h2>
          <p class="text-sm text-muted mt-2">
            Canlı D1 verilerini .json olarak yedekle veya bir yedeği sisteme (Replace) geri yükle.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="export-backup-btn" class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold shadow-lg shadow-emerald-600/20 active:scale-95 transition-all">
            Seçili Verileri .json Olarak Yedekle
          </button>
        </div>
      </div>

      <div id="backup-status-box" class="hidden rounded-xl px-4 py-3 text-sm font-medium animate-in fade-in slide-in-from-top-2 duration-300"></div>

      <div class="rounded-xl border border-border-main bg-surface-hover p-4 space-y-3">
        <div class="flex flex-col md:flex-row md:items-center gap-3">
          <input id="import-file-input" type="file" accept=".json,application/json" class="block w-full text-sm text-muted file:mr-4 file:rounded-lg file:border-0 file:bg-surface file:px-3 file:py-2 file:text-sm file:font-bold file:text-main cursor-pointer" />
          <button id="import-backup-btn" class="px-4 py-2 rounded-xl bg-rose-600 hover:bg-rose-500 text-white text-sm font-bold disabled:opacity-50 disabled:cursor-not-allowed shadow-lg shadow-rose-600/20 active:scale-95 transition-all whitespace-nowrap" disabled>
            Yedeği İçeri Aktar (Replace)
          </button>
        </div>
        <div class="flex items-start gap-2 text-xs text-amber-400/80 bg-amber-500/5 p-2 rounded-lg border border-amber-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          <p>
            <b>DİKKAT:</b> İçeri aktarma işlemi <u>tüm tabloları</u> (firmalar, sertifikalar, testler, denetimler, proformalar) yedekteki veriyle değiştirir. Kısmi geri yükleme desteklenmez.
          </p>
        </div>
      </div>
    </div>

    <!-- 🛠️ BAKIM & KURTARMA -->
    <div class="bg-surface border border-amber-500/20 rounded-2xl p-5 shadow-xl space-y-4 bg-amber-500/5">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-amber-500 font-bold">Bakım & Kurtarma</p>
          <h2 class="text-xl font-extrabold mt-1 text-main">Sistem İndeks Onarımı</h2>
          <p class="text-sm text-muted mt-2">
            Ana sayfa istatistikleri veya listeler eksik/hatalı görünüyorsa, D1'deki verileri tarayarak dashboard istatistiklerini yeniden inşa eder.
            <span class="text-amber-500 font-medium">Bu işlem Google Sheets'ten veri çekmez, mevcut D1 verisini düzenler.</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="deep-repair-btn" class="px-6 py-2 rounded-xl bg-amber-600 hover:bg-amber-500 text-white text-sm font-bold shadow-lg shadow-amber-600/20 active:scale-95 transition-all">
            İstatistikleri D1'den Yeniden Hesapla
          </button>
        </div>
      </div>
    </div>
  </section>
</DashboardLayout>

<script>
  import { api } from "../lib/api";
  import { toast } from "../lib/toast";
  import { SyncManager } from "../lib/sync";
  import { $dashboardStats } from "../lib/store";
  import { DB } from "../lib/db";

  const selectEl = document.getElementById("dataset-select") as HTMLSelectElement | null;
  const refreshBtn = document.getElementById("refresh-btn") as HTMLButtonElement | null;
  const addRowBtn = document.getElementById("add-row-btn") as HTMLButtonElement | null;
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement | null;
  const metaVersion = document.getElementById("meta-version") as HTMLElement | null;
  const metaUpdated = document.getElementById("meta-updated") as HTMLElement | null;
  const thead = document.getElementById("master-thead") as HTMLElement | null;
  const tbody = document.getElementById("master-tbody") as HTMLElement | null;
  const statusBox = document.getElementById("status-box") as HTMLElement | null;
  const importFileInput = document.getElementById("import-file-input") as HTMLInputElement | null;
  const backupStatusBox = document.getElementById("backup-status-box") as HTMLElement | null;

  // ─── Lifecycle & Cleanup ─────────────────────────────────────────────────────

  let cleanupTasks: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupTasks.push(fn);
  }

  function runCleanups() {
    cleanupTasks.forEach(fn => { try { fn(); } catch(e) {} });
    cleanupTasks = [];
  }

  let currentType: string = "standards";
  let currentVersion: string | null = null;
  let currentHeaders: string[] = [];
  let currentRows: any[][] = [];
  let selectedBackupPayload: any = null;
  const MASTER_SCOPE_OPTIONS = ["standards", "auditors", "consultants", "testdocs", "sysdocs"] as const;
  type MasterScopeType = typeof MASTER_SCOPE_OPTIONS[number];

  function getSelectedScopes(): string[] {
    const checkboxes = document.querySelectorAll('input[name="sync-scope"]:checked');
    return Array.from(checkboxes).map(el => (el as HTMLInputElement).value);
  }

  function getSelectedMasterTypes(): MasterScopeType[] {
    const checkboxes = document.querySelectorAll('input[name="master-sync-scope"]:checked');
    return Array.from(checkboxes)
      .map(el => (el as HTMLInputElement).value)
      .filter((value): value is MasterScopeType => MASTER_SCOPE_OPTIONS.includes(value as MasterScopeType));
  }

  function getSyncSelection() {
    const scopes = getSelectedScopes().filter((scope) => scope !== "master");
    const masterTypes = getSelectedMasterTypes();
    if (masterTypes.length) scopes.push("master");
    return { scopes, masterTypes };
  }

  function setStatus(message: string, type: "info" | "error" | "success" = "info") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.classList.remove("hidden", "bg-red-500/15", "text-red-200", "bg-emerald-500/15", "text-emerald-200", "bg-cyan-500/15", "text-cyan-100");
    if (type === "error") statusBox.classList.add("bg-red-500/15", "text-red-200");
    else if (type === "success") statusBox.classList.add("bg-emerald-500/15", "text-emerald-200");
    else statusBox.classList.add("bg-cyan-500/15", "text-cyan-100");
  }

  function setBackupStatus(message: string, type: "info" | "error" | "success" = "info") {
    if (!backupStatusBox) return;
    backupStatusBox.textContent = message;
    backupStatusBox.classList.remove("hidden", "bg-red-500/15", "text-red-400", "border-red-500/30", "bg-emerald-500/10", "text-emerald-400", "border-emerald-500/30", "bg-indigo-500/10", "text-indigo-400", "border-indigo-500/30");
    backupStatusBox.classList.add("border");
    if (type === "error") backupStatusBox.classList.add("bg-red-500/15", "text-red-400", "border-red-500/30");
    else if (type === "success") backupStatusBox.classList.add("bg-emerald-500/10", "text-emerald-400", "border-emerald-500/30");
    else backupStatusBox.classList.add("bg-indigo-500/10", "text-indigo-400", "border-indigo-500/30");
  }

  function getScopeLabel(scope: string) {
    return scope === "companies" ? "Firmalar" :
           scope === "certificates" ? "Sertifikalar" :
           scope === "audits" ? "Denetimler" :
           scope === "tests" ? "Testler" :
           scope === "proformas" ? "Proformalar" :
           "Ana Veri";
  }

  function getMasterScopeLabel(scope: MasterScopeType) {
    return scope === "standards" ? "Standartlar" :
           scope === "auditors" ? "Denetçiler" :
           scope === "consultants" ? "Danışmanlar" :
           scope === "testdocs" ? "TestDoc" :
           "SysDoc";
  }

  function syncMasterParentState() {
    const parent = document.getElementById("master-sync-all") as HTMLInputElement | null;
    if (!parent) return;
    const children = Array.from(document.querySelectorAll('input[name="master-sync-scope"]')) as HTMLInputElement[];
    const checkedCount = children.filter((child) => child.checked).length;
    parent.checked = checkedCount > 0;
    parent.indeterminate = checkedCount > 0 && checkedCount < children.length;
  }

  function setMasterChildrenChecked(checked: boolean) {
    const children = Array.from(document.querySelectorAll('input[name="master-sync-scope"]')) as HTMLInputElement[];
    children.forEach((child) => {
      child.checked = checked;
    });
    syncMasterParentState();
  }

  function setButtonBusy(
    btn: HTMLButtonElement | null,
    busy: boolean,
    idleText: string,
    busyText: string,
  ) {
    if (!btn) return;
    btn.disabled = busy;
    btn.textContent = busy ? busyText : idleText;
    btn.classList.toggle("animate-pulse", busy);
    btn.classList.toggle("opacity-80", busy);
  }

  function downloadJson(filename: string, payload: any) {
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function escapeHtml(value: any): string {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function renderTable() {
    if (!thead || !tbody) return;
    thead.innerHTML = `<tr>${currentHeaders.map((h) => `<th class="text-left px-3 py-2 border-b border-border-main whitespace-nowrap">${escapeHtml(h)}</th>`).join("")}<th class="px-3 py-2 border-b border-border-main">Sil</th></tr>`;
    tbody.innerHTML = "";

    currentRows.forEach((row, rowIndex) => {
      const tr = document.createElement("tr");
      tr.className = "border-b border-border-main/60";

      currentHeaders.forEach((_, colIndex) => {
        const td = document.createElement("td");
        td.className = "px-2 py-2";
        const input = document.createElement("input");
        input.type = "text";
        input.value = row[colIndex] ?? "";
        input.className = "w-full bg-surface-hover border border-border-main rounded-lg px-2 py-1 text-xs";
        input.addEventListener("input", (e: Event) => {
          currentRows[rowIndex][colIndex] = (e.target as HTMLInputElement).value;
        });
        td.appendChild(input);
        tr.appendChild(td);
      });

      const tdDel = document.createElement("td");
      tdDel.className = "px-2 py-2 text-center";
      const delBtn = document.createElement("button");
      delBtn.className = "px-2 py-1 rounded-lg text-xs bg-red-600/80 hover:bg-red-500 text-white";
      delBtn.textContent = "Sil";
      delBtn.addEventListener("click", () => {
        currentRows.splice(rowIndex, 1);
        renderTable();
      });
      tdDel.appendChild(delBtn);
      tr.appendChild(tdDel);
      tbody.appendChild(tr);
    });
  }

  function normalizeMasterPayload(raw: any, type: string) {
    if (!raw) return null;
    
    // Case 1: Already relational structure { dataset: { headers, rows, sheetName }, version, updatedAt }
    if (raw.dataset && typeof raw.dataset === "object" && Array.isArray(raw.dataset.rows)) {
      return raw;
    }

    // Case 2: Wrapped in a data property (standard api.ts wrapper)
    if (raw.data && typeof raw.data === "object" && raw.data.dataset) {
      return raw.data;
    }

    // Case 3: Raw array of objects (legacy or direct D1 results)
    if (Array.isArray(raw)) {
      if (raw.length === 0) {
        return {
          dataset: { headers: [], rows: [], sheetName: type },
          version: null,
          updatedAt: null
        };
      }
      
      const first = raw[0];
      const headers = first && typeof first === "object" ? Object.keys(first) : [];
      return {
        dataset: {
          headers,
          rows: raw.map(r => headers.map(h => r[h] ?? "")),
          sheetName: type
        },
        version: null,
        updatedAt: null
      };
    }

    // Case 4: Legacy structure { [type]: rowArray }
    const combinedRows = raw[type];
    if (Array.isArray(combinedRows)) {
      return {
        dataset: { 
          headers: combinedRows.length > 0 && typeof combinedRows[0] === 'object' && !Array.isArray(combinedRows[0]) ? Object.keys(combinedRows[0]) : [],
          rows: combinedRows.map(r => Array.isArray(r) ? r : (typeof r === 'object' ? Object.values(r) : [r])), 
          sheetName: type 
        },
        version: raw.version ?? null,
        updatedAt: raw.updatedAt ?? null
      };
    }

    return null;
  }

  function describeMasterResponse(res: any, type: string) {
    const data = res?.data;
    const topLevelKeys = data && typeof data === "object" ? Object.keys(data).slice(0, 10) : [];
    const normalized = normalizeMasterPayload(data, type);
    const rowCount = Array.isArray(normalized?.dataset?.rows) ? normalized.dataset.rows.length : 0;
    const sheetName = normalized?.dataset?.sheetName ?? null;
    return {
      success: Boolean(res?.success),
      status: res?.status ?? null,
      error: res?.error ?? null,
      hasData: Boolean(data),
      rowCount,
      sheetName,
      topLevelKeys,
      normalized,
    };
  }

  async function loadDataset(type: string) {
    currentType = type;
    setStatus("Veri yükleniyor...");

    let res = await api.getMasterData(type);
    let payload = normalizeMasterPayload(res.data, type);
    console.log("[Settings][MasterData] initial response", type, describeMasterResponse(res, type));

    if (!res.success || !payload?.dataset) {
      setStatus("D1 boş. Master data aktarımı başlatılıyor...");
      const syncRes = await api.syncMasterData([type as MasterScopeType]);
      console.log("[Settings][MasterData] sync attempt", type, {
        success: syncRes?.success,
        status: syncRes?.status ?? null,
        error: syncRes?.error ?? null,
        data: syncRes?.data ?? null
      });
      if (!syncRes.success) {
        setStatus("Master sync başarısız: " + (syncRes.error || "Bilinmeyen hata"), "error");
        return;
      }
      res = await api.getMasterData(type);
      payload = normalizeMasterPayload(res.data, type);
      console.log("[Settings][MasterData] post-sync response", type, describeMasterResponse(res, type));
    }

    if (!res.success || !payload?.dataset) {
      const debug = describeMasterResponse(res, type);
      const detailParts = [
        `success=${res.success}`,
        res.status ? `status=${res.status}` : null,
        res.error ? `error=${res.error}` : null,
        `hasPayload=${!!payload}`,
        `hasDataset=${!!payload?.dataset}`,
        debug.topLevelKeys.length ? `keys=${debug.topLevelKeys.join(",")}` : "keys=none"
      ].filter(Boolean);
      console.error("[Settings][MasterData] invalid response", type, debug);
      setStatus("Veri alınamadı veya yapı geçersiz: " + detailParts.join(" | "), "error");
      return;
    }

    const ds = payload.dataset;
    currentVersion = payload.version ?? null;
    currentHeaders = Array.isArray(ds.headers) ? ds.headers : [];
    currentRows = Array.isArray(ds.rows) ? ds.rows.map((r: any) => Array.isArray(r) ? [...r] : []) : [];

    if (metaVersion) metaVersion.textContent = `v${currentVersion || "-"}`;
    if (metaUpdated) metaUpdated.textContent = payload.updatedAt ? "Güncelleme: " + new Date(payload.updatedAt).toLocaleString("tr-TR") : "Güncelleme: -";

    renderTable();
    setStatus((ds.sheetName || type) + " yüklendi (" + currentRows.length + " satır).", "success");
  }

  async function saveDataset() {
    if (!currentType) return;
    setStatus("Kaydediliyor...");
    const res = await api.updateMasterData(currentType, { rows: currentRows }, currentVersion || undefined);
    if (!res.success) {
      if (res.error === "MASTER_VERSION_CONFLICT") {
        setStatus("Versiyon çakışması: Veri başka bir oturumda değişmiş. Yenileyip tekrar dene.", "error");
      } else if (res.error === "MASTER_EMPTY_REPLACE_BLOCKED") {
        setStatus("Boş veri setiyle tüm tabloyu silme işlemi güvenlik nedeniyle engellendi.", "error");
      } else {
        setStatus("Kayıt hatası: " + (res.error || "Bilinmeyen hata"), "error");
      }
      return;
    }

    const data = res.data || {};
    currentVersion = data.version || currentVersion;
    if (metaVersion) metaVersion.textContent = `v${currentVersion || "-"}`;
    if (metaUpdated) metaUpdated.textContent = data.updatedAt ? "Güncelleme: " + new Date(data.updatedAt).toLocaleString("tr-TR") : "Güncelleme: -";
    setStatus("Kaydedildi.", "success");
  }

  function initPage() {
    runCleanups();

    const addEv = (id: string, ev: string, fn: any) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener(ev, fn);
      registerCleanup(() => el.removeEventListener(ev, fn));
    };

    const selectEl = document.getElementById("dataset-select") as HTMLSelectElement | null;
    if (selectEl) {
      addEv("dataset-select", "change", (e: Event) => {
        loadDataset((e.target as HTMLSelectElement).value);
      });
    }

    addEv("master-sync-all", "change", (e: Event) => {
      setMasterChildrenChecked((e.target as HTMLInputElement).checked);
    });

    const masterCheckboxes = Array.from(document.querySelectorAll('input[name="master-sync-scope"]')) as HTMLInputElement[];
    masterCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", syncMasterParentState);
      registerCleanup(() => checkbox.removeEventListener("change", syncMasterParentState));
    });
    syncMasterParentState();

    addEv("refresh-btn", "click", () => loadDataset(currentType));

    addEv("smart-sync-btn", "click", async () => {
      const btn = document.getElementById("smart-sync-btn") as HTMLButtonElement | null;
      const idleText = "⚡ Hızlı Sync";
      setButtonBusy(btn, true, idleText, "Kontrol ediliyor...");
      setBackupStatus("Hızlı sync başlatıldı — sadece değişen veriler çekiliyor...", "info");

      try {
        const res = await api.smartSync();
        if (!res.success) throw new Error(res.error || "Hızlı sync başarısız");

        if (res.isDelta) {
          const { companies = 0, certificates = 0, audits = 0, tests = 0, proformas = 0 } = res.written || {};
          const total = companies + certificates + audits + tests + proformas;
          if (total === 0) {
            setBackupStatus("Değişiklik bulunamadı — D1 zaten güncel.", "success");
            toast.success("Sistem zaten güncel, yazılacak değişiklik yok.");
          } else {
            setBackupStatus(`Hızlı sync tamamlandı: ${total} satır güncellendi (firma: ${companies}, sertifika: ${certificates}, denetim: ${audits}, test: ${tests}, proforma: ${proformas}).`, "success");
            toast.success(`${total} satır güncellendi.`);
          }
        } else {
          setBackupStatus("Tam senkronizasyon tamamlandı (fallback).", "success");
          toast.success("Tam senkronizasyon tamamlandı.");
        }

        await SyncManager.forceSync();
      } catch (e: any) {
        setBackupStatus("Hızlı sync hatası: " + e.message, "error");
        toast.error("Hızlı sync başarısız: " + e.message);
      } finally {
        setButtonBusy(btn, false, idleText);
      }
    });

    addEv("ops-sync-btn", "click", async () => {
      const { scopes, masterTypes } = getSyncSelection();
      if (!scopes.length) {
        setBackupStatus("Lütfen en az bir kapsam seçin.", "error");
        toast.warning("Lütfen senkronize edilecek en az bir kapsam seçin.");
        return;
      }

      const btn = document.getElementById("ops-sync-btn") as HTMLButtonElement | null;
      const idleText = "Seçili Verileri Sheets'ten Çek";
      setButtonBusy(btn, true, idleText, "Senkronize Ediliyor...");
      const selectionLabels = scopes.flatMap((scope) => {
        if (scope !== "master") return [getScopeLabel(scope)];
        return masterTypes.map((type) => `Ana Veri / ${getMasterScopeLabel(type)}`);
      });
      toast.info(`${selectionLabels.join(", ")} için senkronizasyon başlatıldı...`);

      try {
        for (const scope of scopes) {
          const label = getScopeLabel(scope);

          if (scope === "master") {
            const masterLabel = masterTypes.map(getMasterScopeLabel).join(", ");
            setBackupStatus(`Ana veri alt başlıkları çekiliyor: ${masterLabel}`, "info");
            const res = await api.syncMasterData(masterTypes);
            if (!res.success) throw new Error("Master veri senkronizasyonu başarısız: " + (res.error || "Bilinmeyen hata"));
            const checkbox = document.querySelector(`input[name="sync-scope"][value="master"]`) as HTMLInputElement | null;
            if (checkbox) checkbox.checked = false;
            setMasterChildrenChecked(false);
            continue;
          }

          setBackupStatus(`${label} çekiliyor...`, "info");
          const res = await api.bulkSync({ scope: [scope] });
          if (!res.success) throw new Error(`${label} senkronizasyonu başarısız: ${res.error || "Bilinmeyen hata"}`);

          const checkbox = document.querySelector(`input[name="sync-scope"][value="${scope}"]`) as HTMLInputElement | null;
          if (checkbox) checkbox.checked = false;
        }

        await loadDataset(currentType);
        setBackupStatus("Tüm işlemler başarıyla tamamlandı.", "success");
        toast.success("Tüm seçili senkronizasyon işlemleri başarıyla tamamlandı!");
      } catch (err: any) {
        setBackupStatus("Hata: " + err.message, "error");
        toast.error("İşlem sırasında bir hata oluştu: " + err.message);
      } finally {
        setButtonBusy(btn, false, idleText, "Senkronize Ediliyor...");
      }
    });


    addEv("export-backup-btn", "click", async () => {
      const topLevelScopes = getSelectedScopes().filter((scope) => scope !== "master");
      const masterTypes = getSelectedMasterTypes();
      const scope = masterTypes.length ? [...topLevelScopes, "master"] : topLevelScopes;
      if (!scope.length) {
        setBackupStatus("Lütfen yedeklemek istediğiniz kapsamları seçin.", "error");
        return;
      }
      setBackupStatus("[" + scope.join(", ") + "] kapsamı için D1 yedek paketi hazırlanıyor...");
      const res = await api.exportData(scope, masterTypes);
      if (!res.success || !res.exportData) {
        setBackupStatus("Dışa aktarma başarısız: " + (res.error || "Bilinmeyen hata"), "error");
        return;
      }
      const stamp = new Date().toISOString().replace(/[:.]/g, "-");
      downloadJson("mc-d1-backup-" + stamp + ".json", res.exportData);
      setBackupStatus("D1 yedeği indirildi (" + scope.length + " kategori).", "success");
    });

    const fileInput = document.getElementById("import-file-input") as HTMLInputElement | null;
    const iBtn = document.getElementById("import-backup-btn") as HTMLButtonElement | null;

    if (fileInput) {
      addEv("import-file-input", "change", async (event: Event) => {
        const file = (event.target as HTMLInputElement).files?.[0];
        selectedBackupPayload = null;
        if (iBtn) iBtn.disabled = true;
        if (!file) {
          setBackupStatus("İçeri aktarma için bir JSON dosyası seçin.");
          return;
        }
        try {
          const text = await file.text();
          selectedBackupPayload = JSON.parse(text);
          if (iBtn) iBtn.disabled = false;
          setBackupStatus("Yedek dosyası hazır: " + file.name + ". 'Geri Yükle' butonuna basarak işlemi başlatabilirsin.", "success");
        } catch (error) {
          setBackupStatus("Seçilen dosya geçerli bir JSON yedeği değil.", "error");
        }
      });
    }

    addEv("import-backup-btn", "click", async () => {
      if (!selectedBackupPayload) {
        setBackupStatus("Önce geçerli bir yedek JSON dosyası seçin.", "error");
        return;
      }
      if (!confirm("DİKKAT! Bu işlem TÜM tabloları (firmalar, sertifikalar, testler, denetimler, proformalar) yedekteki veriyle değiştirecektir. Devam etmek istiyor musun?")) {
        return;
      }

      console.log("[Backup] Geri yükleme başlatıldı (tam kapsam).");
      const originalText = iBtn ? iBtn.textContent : "Geri Yükle";
      if (iBtn) {
        iBtn.disabled = true;
        iBtn.textContent = "Yükleniyor... Lütfen Bekleyin";
        iBtn.classList.add("animate-pulse");
      }

      setBackupStatus("Tüm tablolar geri yükleniyor... Bu işlem verinin boyutuna göre biraz zaman alabilir.", "info");
      toast.info("Yedekten geri yükleme başlatıldı (tam kapsam)...");

      try {
        const res = await api.importBackup(selectedBackupPayload);
        console.log("[Backup] Sunucu yanıtı:", res);

        if (!res.success) {
          toast.error("Geri yükleme başarısız: " + (res.error || "Bilinmeyen hata"));
          setBackupStatus("Geri yükleme başarısız: " + (res.error || "Bilinmeyen hata"), "error");
          return;
        }

        console.log("[Backup] Başarılı. Veri setleri tazeleniyor...");
        setBackupStatus("Veriler yüklendi. Yerel veritabanı senkronize ediliyor...", "info");
        toast.info("Sunucu verileri yenilendi. Yerel senkronizasyon başlatılıyor...");

        await SyncManager.forceSync();

        await loadDataset(currentType);
        toast.success("Seçili kapsamlar başarıyla geri yüklendi ve senkronize edildi!");
        setBackupStatus("Geri yükleme ve senkronizasyon başarılı. Tüm verileriniz artık güncel.", "success");
      } catch (err: any) {
        console.error("[Backup] Kritik Hata:", err);
        toast.error("Geri yükleme sırasında hata: " + err.message);
        setBackupStatus("Geri yükleme sırasında ağ hatası oluştu: " + err.message, "error");
      } finally {
        if (iBtn) {
          iBtn.disabled = false;
          iBtn.textContent = originalText;
          iBtn.classList.remove("animate-pulse");
        }
      }
    });

    addEv("add-row-btn", "click", () => {
      currentRows.push(Array(currentHeaders.length).fill(""));
      renderTable();
    });

    addEv("save-btn", "click", saveDataset);

    addEv("deep-repair-btn", "click", async () => {
      if (!confirm("İndeks onarımı başlatılacak. Bu işlem ana sayfa istatistiklerini ve sertifika listelerini D1 verisine göre yeniden düzenler. Devam etmek istiyor musun?")) return;

      const btn = document.getElementById("deep-repair-btn") as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Onarım Başlatılıyor...";
      }

      toast.info("İndeks onarımı Cloudflare üzerinde başlatıldı...");
      const res = await api.deepRepairIndex();

      if (res.success) {
        toast.success("Onarım emri gönderildi! Arka planda tamamlandığında verileriniz düzelecektir.");
        setTimeout(async () => {
          await SyncManager.forceSync();
          if (btn) {
            btn.disabled = false;
            btn.textContent = "İndeksleri D1'den Onar";
          }
        }, 3000);
      } else {
        toast.error("Hata: " + (res.error || "Bilinmeyen hata"));
        if (btn) {
          btn.disabled = false;
          btn.textContent = "İndeksleri D1'den Onar";
        }
      }
    });

    loadDataset(currentType);
  }

  // Initial load
  initPage();
  // ViewTransitions support
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups);
</script>
