---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Ayarlar">
  <section class="space-y-6">
    <div class="bg-surface border border-border-main rounded-2xl p-6 shadow-xl">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Master Data</p>
          <h1 class="text-2xl font-extrabold mt-1">Kemik Veri Yonetimi</h1>
          <p class="text-sm text-muted mt-2">
            Standarts, Auditors, Consultants, TestDoc ve SysDoc verilerini buradan yonetebilirsin.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="full-sync-btn" class="px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold">
            Sheets'ten Tumunu Cek
          </button>
          <button id="sync-master-btn" class="px-4 py-2 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-bold">
            Sheets'ten Senkronla
          </button>
          <button id="refresh-btn" class="px-4 py-2 rounded-xl bg-surface-hover border border-border-main text-sm font-bold">
            Yenile
          </button>
        </div>
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-center gap-3">
        <label for="dataset-select" class="text-sm font-bold text-muted">Dataset</label>
        <select id="dataset-select" class="bg-surface-hover border border-border-main rounded-xl px-3 py-2 text-sm">
          <option value="standards">Standards (Standarts)</option>
          <option value="auditors">Auditors</option>
          <option value="consultants">Consultants</option>
          <option value="testdocs">TestDoc</option>
          <option value="sysdocs">SysDoc</option>
        </select>
        <div class="ml-auto text-xs text-muted">
          <span id="meta-version">v-</span>
          <span class="mx-2">|</span>
          <span id="meta-updated">-</span>
        </div>
      </div>

      <div id="status-box" class="hidden rounded-xl px-3 py-2 text-sm"></div>

      <div class="overflow-auto border border-border-main rounded-xl">
        <table class="min-w-full text-sm">
          <thead id="master-thead" class="bg-surface-hover"></thead>
          <tbody id="master-tbody"></tbody>
        </table>
      </div>

      <div class="flex flex-wrap gap-2">
        <button id="add-row-btn" class="px-4 py-2 rounded-xl bg-surface-hover border border-border-main text-sm font-bold">
          Satir Ekle
        </button>
        <button id="save-btn" class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold">
          Kaydet
        </button>
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Aksiyon Kapsami</p>
          <h2 class="text-xl font-extrabold mt-1">Islem Kapsami Secimi</h2>
          <p class="text-sm text-muted mt-2">
            Asagidaki islemlerden hangilerinin yapilacagini buradan secebilirsin.
          </p>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {["companies", "certificates", "audits", "tests", "proformas", "master"].map((scope) => (
          <label class="flex items-center gap-2 p-3 rounded-xl bg-surface-hover border border-border-main cursor-pointer hover:border-indigo-500 transition-colors">
            <input type="checkbox" name="sync-scope" value={scope} checked class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
            <span class="text-sm font-medium capitalize">
              {scope === "companies" ? "Firmalar" : 
               scope === "certificates" ? "Sertifikalar" : 
               scope === "audits" ? "Denetimler" : 
               scope === "tests" ? "Testler" : 
               scope === "proformas" ? "Proformalar" : 
               "Master Veri"}
            </span>
          </label>
        ))}
      </div>
    </div>

    <div class="bg-surface border border-border-main rounded-2xl p-5 shadow-xl space-y-4">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 border-b border-border-main pb-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Google Sheets &lt;-&gt; KV</p>
          <h2 class="text-xl font-extrabold mt-1">Sheets Senkronizasyonu</h2>
          <p class="text-sm text-muted mt-2">
            Verileri Google Sheets'ten Cloudflare KV'ye ceker. Secili kapsamlari gunceller.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="ops-sync-btn" class="px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold shadow-lg shadow-indigo-600/20 active:scale-95 transition-all">
            Secili Verileri Sheets'ten Cek
          </button>
          <button id="rebuild-stats-btn" class="px-4 py-2 rounded-xl bg-emerald-700 hover:bg-emerald-600 text-white text-sm font-bold shadow-lg shadow-emerald-700/20 active:scale-95 transition-all">
            Dashboard Istatistiklerini Yeniden Hesapla
          </button>
        </div>
      </div>

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 pt-2">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Cloudflare KV &lt;-&gt; JSON</p>
          <h2 class="text-xl font-extrabold mt-1">JSON Yedekleme / Geri Yukleme</h2>
          <p class="text-sm text-muted mt-2">
            Canli KV verilerini .json olarak yedekle veya bir yedegi sisteme (Replace) geri yukle.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="export-kv-btn" class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold shadow-lg shadow-emerald-600/20 active:scale-95 transition-all">
            Secili Verileri .json Olarak Yedekle
          </button>
        </div>
      </div>

      <div id="backup-status-box" class="hidden rounded-xl px-4 py-3 text-sm font-medium animate-in fade-in slide-in-from-top-2 duration-300"></div>

      <div class="rounded-xl border border-border-main bg-surface-hover p-4 space-y-3">
        <div class="flex flex-col md:flex-row md:items-center gap-3">
          <input id="import-file-input" type="file" accept=".json,application/json" class="block w-full text-sm text-muted file:mr-4 file:rounded-lg file:border-0 file:bg-surface file:px-3 file:py-2 file:text-sm file:font-bold file:text-main cursor-pointer" />
          <button id="import-kv-btn" class="px-4 py-2 rounded-xl bg-rose-600 hover:bg-rose-500 text-white text-sm font-bold disabled:opacity-50 disabled:cursor-not-allowed shadow-lg shadow-rose-600/20 active:scale-95 transition-all whitespace-nowrap" disabled>
            Yedeği İçeri Aktar (Replace)
          </button>
        </div>
        <div class="flex items-start gap-2 text-xs text-amber-400/80 bg-amber-500/5 p-2 rounded-lg border border-amber-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          <p>
            <b>DIKKAT:</b> Iceri aktarma islemi, sectiginiz kapsamdaki mevcut KV verilerini tamamen <u>siler</u> ve yedektekilerle degistirir. Diger kapsamlar korunur.
          </p>
        </div>
      </div>
    </div>

    <!-- 🛠️ BAKIM & KURTARMA -->
    <div class="bg-surface border border-amber-500/20 rounded-2xl p-5 shadow-xl space-y-4 bg-amber-500/5">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-amber-500 font-bold">Bakim & Kurtarma</p>
          <h2 class="text-xl font-extrabold mt-1 text-main">Sistem Indeks Onarimi</h2>
          <p class="text-sm text-muted mt-2">
            Anasayfa istatistikleri veya listeler eksik/hatali gorunuyorsa, KV'deki ham sertifika dosyalarini tarayarak indeksleri yeniden insa eder. 
            <span class="text-amber-500 font-medium">Bu islem Google Sheets'ten veri cekmez, mevcut KV verisini duzenler.</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button id="deep-repair-btn" class="px-6 py-2 rounded-xl bg-amber-600 hover:bg-amber-500 text-white text-sm font-bold shadow-lg shadow-amber-600/20 active:scale-95 transition-all">
            Indeksleri KV'den Onar
          </button>
        </div>
      </div>
    </div>
  </section>
</DashboardLayout>

<script>
  import { api } from "../lib/api";
  import { toast } from "../lib/toast";
  import { SyncManager } from "../lib/sync";
  import { $dashboardStats } from "../lib/store";
  import { DB } from "../lib/db";

  const selectEl = document.getElementById("dataset-select") as HTMLSelectElement | null;
  const syncBtn = document.getElementById("sync-master-btn") as HTMLButtonElement | null;
  const fullSyncBtn = document.getElementById("full-sync-btn") as HTMLButtonElement | null;
  const refreshBtn = document.getElementById("refresh-btn") as HTMLButtonElement | null;
  const addRowBtn = document.getElementById("add-row-btn") as HTMLButtonElement | null;
  const saveBtn = document.getElementById("save-btn") as HTMLButtonElement | null;
  const metaVersion = document.getElementById("meta-version") as HTMLElement | null;
  const metaUpdated = document.getElementById("meta-updated") as HTMLElement | null;
  const thead = document.getElementById("master-thead") as HTMLElement | null;
  const tbody = document.getElementById("master-tbody") as HTMLElement | null;
  const statusBox = document.getElementById("status-box") as HTMLElement | null;
  const opsSyncBtn = document.getElementById("ops-sync-btn") as HTMLButtonElement | null;
  const exportKvBtn = document.getElementById("export-kv-btn") as HTMLButtonElement | null;
  const importFileInput = document.getElementById("import-file-input") as HTMLInputElement | null;
  const importKvBtn = document.getElementById("import-kv-btn") as HTMLButtonElement | null;
  const backupStatusBox = document.getElementById("backup-status-box") as HTMLElement | null;

  // ─── Lifecycle & Cleanup ─────────────────────────────────────────────────────

  let cleanupTasks: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupTasks.push(fn);
  }

  function runCleanups() {
    cleanupTasks.forEach(fn => { try { fn(); } catch(e) {} });
    cleanupTasks = [];
  }

  let currentType: string = "standards";
  let currentVersion: string | null = null;
  let currentHeaders: string[] = [];
  let currentRows: any[][] = [];
  let selectedBackupPayload: any = null;

  function getSelectedScopes(): string[] {
    const checkboxes = document.querySelectorAll('input[name="sync-scope"]:checked');
    return Array.from(checkboxes).map(el => (el as HTMLInputElement).value);
  }

  function setStatus(message: string, type: "info" | "error" | "success" = "info") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.classList.remove("hidden", "bg-red-500/15", "text-red-200", "bg-emerald-500/15", "text-emerald-200", "bg-cyan-500/15", "text-cyan-100");
    if (type === "error") statusBox.classList.add("bg-red-500/15", "text-red-200");
    else if (type === "success") statusBox.classList.add("bg-emerald-500/15", "text-emerald-200");
    else statusBox.classList.add("bg-cyan-500/15", "text-cyan-100");
  }

  function setBackupStatus(message: string, type: "info" | "error" | "success" = "info") {
    if (!backupStatusBox) return;
    backupStatusBox.textContent = message;
    backupStatusBox.classList.remove("hidden", "bg-red-500/15", "text-red-400", "border-red-500/30", "bg-emerald-500/10", "text-emerald-400", "border-emerald-500/30", "bg-indigo-500/10", "text-indigo-400", "border-indigo-500/30");
    backupStatusBox.classList.add("border");
    if (type === "error") backupStatusBox.classList.add("bg-red-500/15", "text-red-400", "border-red-500/30");
    else if (type === "success") backupStatusBox.classList.add("bg-emerald-500/10", "text-emerald-400", "border-emerald-500/30");
    else backupStatusBox.classList.add("bg-indigo-500/10", "text-indigo-400", "border-indigo-500/30");
  }

  function downloadJson(filename: string, payload: any) {
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  function escapeHtml(value: any): string {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function renderTable() {
    if (!thead || !tbody) return;
    thead.innerHTML = `<tr>${currentHeaders.map((h) => `<th class="text-left px-3 py-2 border-b border-border-main whitespace-nowrap">${escapeHtml(h)}</th>`).join("")}<th class="px-3 py-2 border-b border-border-main">Sil</th></tr>`;
    tbody.innerHTML = "";

    currentRows.forEach((row, rowIndex) => {
      const tr = document.createElement("tr");
      tr.className = "border-b border-border-main/60";

      currentHeaders.forEach((_, colIndex) => {
        const td = document.createElement("td");
        td.className = "px-2 py-2";
        const input = document.createElement("input");
        input.type = "text";
        input.value = row[colIndex] ?? "";
        input.className = "w-full bg-surface-hover border border-border-main rounded-lg px-2 py-1 text-xs";
        input.addEventListener("input", (e: Event) => {
          currentRows[rowIndex][colIndex] = (e.target as HTMLInputElement).value;
        });
        td.appendChild(input);
        tr.appendChild(td);
      });

      const tdDel = document.createElement("td");
      tdDel.className = "px-2 py-2 text-center";
      const delBtn = document.createElement("button");
      delBtn.className = "px-2 py-1 rounded-lg text-xs bg-red-600/80 hover:bg-red-500 text-white";
      delBtn.textContent = "Sil";
      delBtn.addEventListener("click", () => {
        currentRows.splice(rowIndex, 1);
        renderTable();
      });
      tdDel.appendChild(delBtn);
      tr.appendChild(tdDel);
      tbody.appendChild(tr);
    });
  }

  async function loadDataset(type: string) {
    currentType = type;
    setStatus("Veri yukleniyor...");

    let res = await api.getMasterData(type);
    if (!res.success && (res.needsHydration || res.error === "KV_PRIMARY_MISS")) {
      setStatus("KV bos. Master data hydration baslatiliyor...");
      const syncRes = await api.bulkSyncMaster();
      if (!syncRes.success) {
        setStatus("Master sync basarisiz: " + (syncRes.error || "Bilinmeyen hata"), "error");
        return;
      }
      res = await api.getMasterData(type);
    }

    if (!res.success || !res.data || !res.data.dataset) {
      setStatus("Veri alinamadi: " + (res.error || "Gecersiz yanit"), "error");
      return;
    }

    const payload = res.data;
    const ds = payload.dataset;
    currentVersion = payload.version ?? null;
    currentHeaders = Array.isArray(ds.headers) ? ds.headers : [];
    currentRows = Array.isArray(ds.rows) ? ds.rows.map((r: any) => Array.isArray(r) ? [...r] : []) : [];

    if (metaVersion) metaVersion.textContent = `v${currentVersion || "-"}`;
    if (metaUpdated) metaUpdated.textContent = payload.updatedAt ? "Guncelleme: " + new Date(payload.updatedAt).toLocaleString("tr-TR") : "Guncelleme: -";

    renderTable();
    setStatus((ds.sheetName || type) + " yuklendi (" + currentRows.length + " satir).", "success");
  }

  async function saveDataset() {
    if (!currentType) return;
    setStatus("Kaydediliyor...");
    const res = await api.updateMasterData(currentType, { rows: currentRows }, currentVersion || undefined);
    if (!res.success) {
      if (res.error === "MASTER_VERSION_CONFLICT") {
        setStatus("Version conflict: Veri baska bir oturumda degismis. Yenileyip tekrar dene.", "error");
      } else if (res.error === "MASTER_EMPTY_REPLACE_BLOCKED") {
        setStatus("Bos dataset ile tum tabloyu silme islemi guvenlik nedeniyle engellendi.", "error");
      } else {
        setStatus("Kayit hatasi: " + (res.error || "Bilinmeyen hata"), "error");
      }
      return;
    }

    const data = res.data || {};
    currentVersion = data.version || currentVersion;
    if (metaVersion) metaVersion.textContent = `v${currentVersion || "-"}`;
    if (metaUpdated) metaUpdated.textContent = data.updatedAt ? "Guncelleme: " + new Date(data.updatedAt).toLocaleString("tr-TR") : "Guncelleme: -";
    setStatus("Kaydedildi.", "success");
  }

  function initPage() {
    runCleanups();

    const addEv = (id: string, ev: string, fn: any) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener(ev, fn);
      registerCleanup(() => el.removeEventListener(ev, fn));
    };

    const selectEl = document.getElementById("dataset-select") as HTMLSelectElement | null;
    if (selectEl) {
      addEv("dataset-select", "change", (e: Event) => {
        loadDataset((e.target as HTMLSelectElement).value);
      });
    }

    addEv("refresh-btn", "click", () => loadDataset(currentType));
    
    addEv("sync-master-btn", "click", async () => {
      setStatus("Sheets -> KV master sync baslatildi...");
      toast.info("Master Veri senkronizasyonu baslatildi (Standards, Auditors, Consultants...)");
      const res = await api.bulkSyncMaster();
      if (!res.success) {
        setStatus("Master sync basarisiz: " + (res.error || "Bilinmeyen hata"), "error");
        toast.error("Master sync basarisiz: " + (res.error || "Bilinmeyen hata"));
        return;
      }
      await loadDataset(currentType);
      setStatus("Master sync tamamlandi.", "success");
      toast.success("Master Veri basariyla senkronize edildi!");
    });

    addEv("full-sync-btn", "click", async () => {
      setStatus("Sheets -> KV tam senkron baslatildi...");
      toast.info("Tüm sistem senkronizasyonu başlatıldı (Sertifikalar, Firmalar, Master...). Lütfen bekleyin...");
      const coreRes = await api.bulkSync();
      if (!coreRes.success) {
        setStatus("Core sync basarisiz: " + (coreRes.error || "Bilinmeyen hata"), "error");
        toast.error("Sistem senkronizasyonu başarısız: " + (coreRes.error || "Bilinmeyen hata"));
        return;
      }
      const masterRes = await api.bulkSyncMaster();
      if (!masterRes.success) {
        setStatus("Master sync basarisiz: " + (masterRes.error || "Bilinmeyen hata"), "error");
        toast.error("Master veri senkronizasyonu başarısız oldu.");
        return;
      }
      await loadDataset(currentType);
      setStatus("Sheets -> KV tam senkron tamamlandi.", "success");
      toast.success("Tüm sistem verileri başarıyla senkronize edildi!");
    });

    addEv("ops-sync-btn", "click", async () => {
      const scopes = getSelectedScopes();
      if (!scopes.length) {
        setBackupStatus("Lutfen en az bir kapsam secin.", "error");
        toast.warning("Lütfen senkronize edilecek en az bir kapsam seçin.");
        return;
      }

      const btn = document.getElementById("ops-sync-btn") as HTMLButtonElement | null;
      if (btn) btn.disabled = true;

      try {
        const CHUNK_SIZE = 40; // [CRITICAL] Cloudflare 50 sub-request limitine takılmamak için 40'a düşürüldü

        for (const scope of scopes) {
          const label = scope === "companies" ? "Firmalar" : 
                        scope === "certificates" ? "Sertifikalar" : 
                        scope === "audits" ? "Denetim" : 
                        scope === "tests" ? "Testler" : 
                        scope === "proformas" ? "Proformalar" : "Master Veri";

          if (scope === "master") {
            setBackupStatus("Master veriler çekiliyor...", "info");
            toast.info("Master veri senkronizasyonu başlatıldı...");
            const res = await api.bulkSyncMaster();
            if (!res.success) throw new Error("Master veri senkronizasyonu başarısız.");
            const checkbox = document.querySelector(`input[name="sync-scope"][value="master"]`) as HTMLInputElement | null;
            if (checkbox) checkbox.checked = false;
            toast.success("Master veriler başarıyla güncellendi.");
            continue;
          }

          // 1. İlk parçayı çek ve toplam sayıyı öğren
          setBackupStatus(`${label} çekiliyor...`, "info");
          const firstRes = await api.bulkSync({ scope: [scope], offset: 0, limit: CHUNK_SIZE });
          if (!firstRes.success) throw new Error(`${label} ilk parça çekilirken hata oluştu.`);

          const totalCount = firstRes.data?.totalCount || 0;
          const totalPages = Math.ceil(totalCount / CHUNK_SIZE);

          if (totalPages > 1) {
            toast.info(`${label} senkronizasyonu başlatıldı (1/${totalPages})...`);
            
            for (let page = 1; page < totalPages; page++) {
              setBackupStatus(`${label} çekiliyor (${page + 1}/${totalPages})...`, "info");
              toast.info(`${label} çekiliyor (${page + 1}/${totalPages})...`);
              
              const res = await api.bulkSync({ scope: [scope], offset: page * CHUNK_SIZE, limit: CHUNK_SIZE });
              if (!res.success) throw new Error(`${label} ${page + 1}. parça çekilirken hata oluştu.`);
              
              await new Promise(r => setTimeout(r, 300)); // Kısa back-off
            }
          }

          // Başarılıysa checkbox'ı kaldır
          const checkbox = document.querySelector(`input[name="sync-scope"][value="${scope}"]`) as HTMLInputElement | null;
          if (checkbox) checkbox.checked = false;
          toast.success(`${label} başarıyla senkronize edildi.`);
          
          await new Promise(r => setTimeout(r, 500));
        }

        await loadDataset(currentType);
        setBackupStatus("Tüm işlemler başarıyla tamamlandı.", "success");
        toast.success("Tüm seçili senkronizasyon işlemleri başarıyla tamamlandı!");
      } catch (err: any) {
        setBackupStatus("Hata: " + err.message, "error");
        toast.error("İşlem sırasında bir hata oluştu: " + err.message);
      } finally {
        if (btn) btn.disabled = false;
      }
    });

    addEv("rebuild-stats-btn", "click", async () => {
      setBackupStatus("Dashboard istatistikleri yeniden hesaplaniyor...");
      const btn = document.getElementById("rebuild-stats-btn") as HTMLButtonElement | null;
      if (btn) btn.disabled = true;
      try {
        const res = await api.call("rebuildStats");
        if (!res.success) {
          setBackupStatus("Rebuild basarisiz: " + (res.error || "Bilinmeyen hata"), "error");
          return;
        }
        // KV güncellendi — store + IndexedDB'yi direkt güncelle (checkAndSync'in guard'ına takılmadan)
        if (res.data) {
          $dashboardStats.set(res.data);
          await DB.save(DB.DASHBOARD_STATS, res.data);
        }
        const stats = res.data?.stats;
        setBackupStatus(
          `Istatistikler guncellendi — Aktif sertifika: ${stats?.activeCertificates ?? "?"}, Toplam firma: ${stats?.totalCompanies ?? "?"}`,
          "success"
        );
      } finally {
        if (btn) btn.disabled = false;
      }
    });

    addEv("export-kv-btn", "click", async () => {
      const scope = getSelectedScopes();
      if (!scope.length) {
        setBackupStatus("Lutfen yedeklemek istediginiz kapsamlari secin.", "error");
        return;
      }
      setBackupStatus("[" + scope.join(", ") + "] kapsami icin KV yedek paketi hazirlaniyor...");
      const res = await api.exportKvData(scope);
      if (!res.success || !res.exportData) {
        setBackupStatus("Disa aktarma basarisiz: " + (res.error || "Bilinmeyen hata"), "error");
        return;
      }
      const stamp = new Date().toISOString().replace(/[:.]/g, "-");
      downloadJson("mc-kv-backup-" + stamp + ".json", res.exportData);
      setBackupStatus("KV yedegi indirildi (" + scope.length + " kategori).", "success");
    });

    const fileInput = document.getElementById("import-file-input") as HTMLInputElement | null;
    const iBtn = document.getElementById("import-kv-btn") as HTMLButtonElement | null;
    
    if (fileInput) {
      addEv("import-file-input", "change", async (event: Event) => {
        const file = (event.target as HTMLInputElement).files?.[0];
        selectedBackupPayload = null;
        if (iBtn) iBtn.disabled = true;
        if (!file) {
          setBackupStatus("Iceri aktarma icin bir JSON dosyasi secin.");
          return;
        }
        try {
          const text = await file.text();
          selectedBackupPayload = JSON.parse(text);
          if (iBtn) iBtn.disabled = false;
          setBackupStatus("Yedek dosyasi hazir: " + file.name + ". 'Geri Yukle' butonuna basarak islemi baslatabilirsin.", "success");
        } catch (error) {
          setBackupStatus("Secilen dosya gecerli bir JSON yedegi degil.", "error");
        }
      });
    }

    addEv("import-kv-btn", "click", async () => {
      const scope = getSelectedScopes();
      if (!selectedBackupPayload) {
        setBackupStatus("Once gecerli bir backup JSON dosyasi secin.", "error");
        return;
      }
      if (!scope.length) {
        setBackupStatus("Lutfen geri yuklemek istediginiz kapsamlari (Secim Paneli) belirleyin.", "error");
        return;
      }
      if (!confirm("DIKKAT! Secilen kapsamlardaki (" + scope.join(", ") + ") MEVCUT KV verileri tamamen SILINECEK ve yedektekilerle degistirilecektir. Devam etmek istiyor musun?")) {
        return;
      }

      console.log("[Backup] Geri yukleme baslatildi. Kapsam:", scope);
      const originalText = iBtn ? iBtn.textContent : "Geri Yukle";
      if (iBtn) {
        iBtn.disabled = true;
        iBtn.textContent = "Yukleniyor... Lutfen Bekleyin";
        iBtn.classList.add("animate-pulse");
      }

      setBackupStatus("[" + scope.join(", ") + "] kapsami geri yukleniyor (Replace)... Bu islem verinin boyutuna gore biraz zaman alabilir.", "info");
      toast.info(`[${scope.join(", ")}] kapsami geri yukleniyor...`);
      
      try {
        const res = await api.importKvData(selectedBackupPayload, scope);
        console.log("[Backup] Sunucu yaniti:", res);

        if (!res.success) {
          toast.error("Geri yukleme basarisiz: " + (res.error || "Bilinmeyen hata"));
          setBackupStatus("Geri yukleme basarisiz: " + (res.error || "Bilinmeyen hata"), "error");
          return;
        }

        console.log("[Backup] Basarili. Veri setleri tazeleniyor...");
        setBackupStatus("Veriler yuklendi. Yerel veritabanı senkronize ediliyor...", "info");
        toast.info("Sunucu verileri yenilendi. Yerel senkronizasyon baslatiliyor...");
        
        await SyncManager.forceSync();
        
        await loadDataset(currentType);
        toast.success("Secili kapsamlar basariyla geri yuklendi ve senkronize edildi!");
        setBackupStatus("Geri yukleme ve senkronizasyon basarili. Tum verileriniz artik guncel.", "success");
      } catch (err: any) {
        console.error("[Backup] Kritik Hata:", err);
        toast.error("Geri yukleme sirasinda hata: " + err.message);
        setBackupStatus("Geri yukleme sirasinda ag hatasi olustu: " + err.message, "error");
      } finally {
        if (iBtn) {
          iBtn.disabled = false;
          iBtn.textContent = originalText;
          iBtn.classList.remove("animate-pulse");
        }
      }
    });

    addEv("add-row-btn", "click", () => {
      currentRows.push(Array(currentHeaders.length).fill(""));
      renderTable();
    });

    addEv("save-btn", "click", saveDataset);

    addEv("deep-repair-btn", "click", async () => {
      if (!confirm("Indeks onarimi baslatilacak. Bu islem anasayfa istatistiklerini ve sertifika listelerini KV verisine gore yeniden duzenler. Devam etmek istiyor musun?")) return;
      
      const btn = document.getElementById("deep-repair-btn") as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Onarim Baslatiliyor...";
      }

      toast.info("Indeks onarimi Cloudflare uzerinde baslatildi...");
      const res = await api.deepRepairIndex();
      
      if (res.success) {
        toast.success("Onarim emri gonderildi! Arka planda tamamlandiginda verileriniz duzelecektir.");
        // Bir kac saniye sonra force sync yapip durumu gorelim
        setTimeout(async () => {
          await SyncManager.forceSync();
          if (btn) {
            btn.disabled = false;
            btn.textContent = "Indeksleri KV'den Onar";
          }
        }, 3000);
      } else {
        toast.error("Hata: " + (res.error || "Bilinmeyen hata"));
        if (btn) {
          btn.disabled = false;
          btn.textContent = "Indeksleri KV'den Onar";
        }
      }
    });

    loadDataset(currentType);
  }

  // Initial load
  initPage();
  // ViewTransitions support
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
