---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import DataTable from "../../components/DataTable.astro";
import FilterBar from "../../components/FilterBar.astro";
---

<DashboardLayout title="Test Yönetimi">
  <div class="space-y-4">
    <FilterBar placeholder="Firma, Test Adı veya Rapor No ile ara...">
      <a slot="actions" href="/tests/add" class="btn btn-primary">
        + <span class="hidden xs:inline">YENİ TEST</span>
      </a>
    </FilterBar>

    <DataTable emptyMessage="Eşleşen test kaydı bulunamadı">
      <Fragment slot="header">
        <th class="w-24 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center italic">Rapor Tarihi</th>
        <th class="w-44 px-5 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Firma Adı</th>
        <th class="w-48 pl-6 pr-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Test Adı</th>
        <th class="w-24 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Marka</th>
        <th class="w-36 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Ürün</th>
        <th class="w-44 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-left">Rapor No</th>
        <th class="w-16 px-4 py-3.5 text-[10px] font-black uppercase tracking-widest text-muted text-center">Detay</th>
      </Fragment>
    </DataTable>
  </div>
</DashboardLayout>

<script>
  import { api } from "../../lib/api";
  import { $tests, $companies, $syncStatus } from "../../lib/store";
  import { SyncManager } from "../../lib/sync";
  import { todayIso } from "../../features/date-format";
  import { escAttr, escHtml, getInitials, getCertificateRecordId, parseDateValue } from "../../lib/utils";
  import { useCleanup, initPageCleanup } from "../../lib/composables/useCleanup";
  import { useTableFilter } from "../../lib/composables/useTableFilter";

  const { registerCleanup, runCleanups } = useCleanup();

  function initPage() {
    runCleanups();

    const tableBody = document.getElementById("table-body");
    const tableLoader = document.getElementById("table-loader");
    const emptyState = document.getElementById("empty-state");
    const globalSearch = document.getElementById("global-search") as HTMLInputElement | null;
    const syncIndicator = document.getElementById("sync-indicator");
    const pageSizeSelect = document.getElementById("page-size-select") as HTMLSelectElement | null;
    const prevPageBtn = document.getElementById("prev-page-btn") as HTMLButtonElement | null;
    const nextPageBtn = document.getElementById("next-page-btn") as HTMLButtonElement | null;

    if (!tableBody || !globalSearch || !pageSizeSelect || !prevPageBtn || !nextPageBtn) return;

    const findCompany = (firmaNo: string) =>
      ($companies.get() || []).find((company: any) => String(company.id) === String(firmaNo));

    const resolveCompanyName = (item: any) => {
      const company = findCompany(String(item.firma_no || ""));
      return company?.nick || company?.nickname || company?.unvan || item.firma_adi || "-";
    };

    const setTableState = (state: "loading" | "empty" | "ready") => {
      if (state === "loading") {
        tableLoader.classList.remove("hidden");
        emptyState?.classList.add("hidden");
        return;
      }

      tableLoader.classList.add("hidden");
      emptyState?.classList.toggle("hidden", state !== "empty");
    };

    const renderRows = (items: any[]) => {
      tableBody.innerHTML = items
        .map((item) => {
          const id = getCertificateRecordId(item, "-");
          const raporTarihi = item.rapor_tarihi || "-";
          const firma = resolveCompanyName(item);
          const firmaNo = item.firma_no || "-";
          const testAdi = item.test_adi || "-";
          const raporNo = item.rapor_no || "-";
          const marka = item.marka || "-";
          const urun = item.urun || "-";
          const initials = getInitials(firma);
          const detailRowId = `test-detail-${escAttr(id)}`;

          return `
            <tr class="hover:bg-surface-hover transition-colors group/row text-[11px]">
              <td class="px-4 py-4 text-center font-mono font-bold text-muted italic">${escHtml(raporTarihi)}</td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0">
                    <span class="text-[10px] font-black text-indigo-400 uppercase">${escHtml(initials)}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="font-bold text-main truncate uppercase tracking-tight leading-tight">${escHtml(firma)}</div>
                    <div class="text-[9px] text-muted font-bold mt-0.5 leading-tight truncate uppercase tracking-tight italic">ID: ${escHtml(firmaNo)}</div>
                  </div>
                </div>
              </td>
              <td class="pl-6 pr-4 py-4 text-left font-bold text-primary/70">${escHtml(testAdi.length > 30 ? `${testAdi.slice(0, 30)}...` : testAdi)}</td>
              <td class="px-4 py-4 text-center font-bold text-muted">${escHtml(marka)}</td>
              <td class="px-4 py-4 text-center text-muted font-medium">${escHtml(urun.length > 25 ? `${urun.slice(0, 25)}...` : urun)}</td>
              <td class="px-4 py-4 text-left font-mono font-bold text-main">${escHtml(raporNo)}</td>
              <td class="px-4 py-4">
                <div class="flex items-center justify-center gap-1.5">
                  <button
                    class="detail-toggle-btn w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main bg-surface text-muted hover:text-primary hover:bg-surface-hover transition-all duration-300"
                    data-target="${detailRowId}"
                    title="Detayları Gör"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
              </td>
            </tr>
            <tr id="${detailRowId}" class="hidden border-b border-border-main bg-surface-hover">
              <td colspan="7" class="px-3 sm:px-6 pb-4 pt-1 align-middle">
                <div class="rounded-xl border border-border-main bg-surface p-4 shadow-inner grid grid-cols-2 md:grid-cols-4 gap-3">
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Test No / ID</p>
                    <p class="text-xs font-mono text-main">${escHtml(id)}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Rapor No</p>
                    <p class="text-xs text-main font-semibold">${escHtml(item.rapor_no || "-")}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Ürün Kodu</p>
                    <p class="text-xs text-main">${escHtml(item.urun_kodu || "-")}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Lot / Seri No</p>
                    <p class="text-xs text-main">${escHtml(item.lot || "-")}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Ürün Kabul</p>
                    <p class="text-xs text-main">${escHtml(item.urun_kabul || "-")} ${escHtml(item.kabul_saat || "")}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Test Dönemi</p>
                    <p class="text-xs text-main">${escHtml(item.test_baslangic || "-")} — ${escHtml(item.test_bitis || "-")}</p>
                  </div>
                  <div class="space-y-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted">Numune Sayısı</p>
                    <p class="text-xs text-main">${escHtml(item.numune_sayisi || "-")}</p>
                  </div>
                  <div class="col-span-2 md:col-span-4 pt-2 border-t border-border-main mt-1">
                    <p class="text-[9px] font-bold uppercase tracking-wider text-muted mb-1">Ürün Bilgisi / Detay</p>
                    <p class="text-xs text-muted leading-relaxed">${escHtml(item.urun_bilgi || "-")} ${escHtml(item.detay || "")}</p>
                  </div>
                  <div class="col-span-2 md:col-span-4 flex justify-end pt-2 mt-1">
                    <a href="/tests/add?firmaId=${escAttr(String(item.firma_no || ""))}&testId=${escAttr(id)}"
                      class="inline-flex items-center gap-2 rounded-xl border border-indigo-500/20 bg-indigo-500/10 px-4 py-2 text-[11px] font-black uppercase tracking-wide text-indigo-300 hover:bg-indigo-500/20 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      Düzenle
                    </a>
                  </div>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");

      document.querySelectorAll(".detail-toggle-btn").forEach((btn) => {
        const handler = (event: Event) => {
          const button = event.currentTarget as HTMLElement;
          const targetId = button.dataset.target;
          if (!targetId) return;
          const detailRow = document.getElementById(targetId);
          if (!detailRow) return;
          const isHidden = detailRow.classList.contains("hidden");
          detailRow.classList.toggle("hidden");

          const icon = button.querySelector("svg");
          if (icon) icon.style.transform = isHidden ? "rotate(180deg)" : "rotate(0deg)";
          button.classList.toggle("bg-primary/20", isHidden);
          button.classList.toggle("text-primary", isHidden);
          button.classList.toggle("border-primary/30", isHidden);
        };

        btn.addEventListener("click", handler);
        registerCleanup(() => btn.removeEventListener("click", handler));
      });
    };

    const table = useTableFilter<any>({
      data: $tests.get(),
      pageSize: Number(pageSizeSelect.value) || 20,
      filterFn: (item, filters) => {
        const firma = resolveCompanyName(item).toLocaleLowerCase("tr-TR");
        const testAdi = String(item.test_adi || "").toLocaleLowerCase("tr-TR");
        const raporNo = String(item.rapor_no || "").toLocaleLowerCase("tr-TR");
        const search = String(filters.search || "").toLocaleLowerCase("tr-TR");

        return !search || firma.includes(search) || testAdi.includes(search) || raporNo.includes(search);
      },
      sortFn: (a, b) => {
        const dateA = parseDateValue(a.rapor_tarihi || a.test_bitis || a.test_baslangic || "")?.getTime() || 0;
        const dateB = parseDateValue(b.rapor_tarihi || b.test_bitis || b.test_baslangic || "")?.getTime() || 0;
        return dateB - dateA;
      },
      onStateChange: setTableState,
      onRender: renderRows,
    });

    const unsubTests = $tests.subscribe((data) => {
      table.updateData(data || []);
    });
    registerCleanup(unsubTests);

    const unsubSync = $syncStatus.subscribe((status) => {
      if (!syncIndicator) return;
      const dot = syncIndicator.querySelector("span");
      const textEl = syncIndicator.querySelector(".sync-status-text");
      if (!dot) return;

      if (status === "syncing") {
        dot.className = "w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse";
        if (textEl) textEl.textContent = "GÜNCELLENİYOR";
      } else if (status === "error") {
        dot.className = "w-1.5 h-1.5 rounded-full bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]";
        if (textEl) textEl.textContent = "HATA";
      } else {
        dot.className = "w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]";
        if (textEl) textEl.textContent = "HAZIR";
      }
    });
    registerCleanup(unsubSync);

    const searchHandler = (event: Event) => {
      table.setFilters({ search: (event.target as HTMLInputElement).value });
    };
    globalSearch.addEventListener("input", searchHandler);
    registerCleanup(() => globalSearch.removeEventListener("input", searchHandler));

    const pageSizeHandler = (event: Event) => {
      table.setPageSize(Number((event.target as HTMLSelectElement).value) || 20);
    };
    pageSizeSelect.addEventListener("change", pageSizeHandler);
    registerCleanup(() => pageSizeSelect.removeEventListener("change", pageSizeHandler));

    const prevHandler = () => table.prevPage();
    prevPageBtn.addEventListener("click", prevHandler);
    registerCleanup(() => prevPageBtn.removeEventListener("click", prevHandler));

    const nextHandler = () => table.nextPage();
    nextPageBtn.addEventListener("click", nextHandler);
    registerCleanup(() => nextPageBtn.removeEventListener("click", nextHandler));

    const exportCsvBtn = document.createElement("button");
    exportCsvBtn.type = "button";
    exportCsvBtn.title = "CSV Dışa Aktar";
    exportCsvBtn.className = "btn-icon hidden sm:inline-flex";
    exportCsvBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>`;
    syncIndicator?.parentElement?.appendChild(exportCsvBtn);

    const exportHandler = () => {
      const rows = table.getFilteredData().map((item) => {
        const company = findCompany(String(item.firma_no || ""));
        return {
          id: item.id,
          raporTarihi: item.rapor_tarihi,
          firma: company?.nick || company?.unvan || item.firma_adi,
          test: item.test_adi,
          marka: item.marka,
          urun: item.urun,
          raporNo: item.rapor_no,
          lot: item.lot,
        };
      });

      const csv = [
        ["ID", "Tarih", "Firma", "Test", "Marka", "Ürün", "Rapor No", "Lot"].join(","),
        ...rows.map((row) =>
          Object.values(row)
            .map((value) => `"${String(value ?? "").replace(/"/g, '""')}"`)
            .join(","),
        ),
      ].join("\n");

      const blob = new Blob(["\uFEFF" + csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `Testler_${todayIso()}.csv`;
      link.click();
      URL.revokeObjectURL(url);
    };
    exportCsvBtn.addEventListener("click", exportHandler);
    registerCleanup(() => exportCsvBtn.removeEventListener("click", exportHandler));
    registerCleanup(() => exportCsvBtn.remove());

    setTableState("loading");

    void SyncManager.init().then(async () => {
      if (($companies.get() || []).length === 0) {
        const companiesRes = await api.getCompanies();
        if (companiesRes.success && Array.isArray(companiesRes.data)) {
          $companies.set(companiesRes.data);
        }
      }

      if (($tests.get() || []).length === 0) {
        const testsRes = await api.getTests();
        if (testsRes.success && Array.isArray(testsRes.data)) {
          $tests.set(testsRes.data);
        }
      }

      table.renderTable();
    });
  }

  initPageCleanup(initPage, runCleanups);
</script>
