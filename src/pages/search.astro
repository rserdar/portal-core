---
import DashboardLayout from '../layouts/DashboardLayout.astro';

/**
 * 🔍 Firma Arama (Sıfır Gecikmeli)
 * 
 * Bu sayfa Nano Stores ve IndexedDB üzerinden verileri yerel olarak okur.
 * Senkronizasyon arka planda SyncManager tarafından yönetilir.
 */
---

<DashboardLayout title="Firma Ara">
  <div class="space-y-6">
    <!-- Header/Search Control -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between glass p-6 rounded-2xl border-white/5 shadow-xl">
      <div class="flex items-center gap-4 flex-1 w-full">
        <div class="w-12 h-12 rounded-xl bg-indigo-600/10 flex items-center justify-center text-indigo-400 group-focus-within:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <div class="flex-1">
          <input 
            type="text" 
            id="search-input" 
            placeholder="Aramak için yazınız..." 
            class="bg-transparent border-none focus:outline-none focus:ring-0 text-lg text-white w-full placeholder:text-gray-600"
          />
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <div id="sync-indicator" class="flex items-center gap-2 px-4 py-2 glass rounded-xl border-white/5 text-xs text-gray-500">
          <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10b981]"></span>
          Senkronize
        </div>
        <div class="text-sm font-bold text-gray-400 px-4 py-2 glass rounded-xl border-white/5">
          Sonuç: <span id="result-count" class="text-indigo-400">0</span>
        </div>
      </div>
    </div>

    <!-- Table Container -->
    <div class="glass rounded-3xl overflow-hidden border-white/10 shadow-2xl backdrop-blur-3xl">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-white/5 bg-white/5 text-gray-400">
              <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-indigo-400/70">#</th>
              <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest">Firma Ünvanı</th>
              <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest">Klasör / Kısa Ad</th>
              <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest">Şehir</th>
              <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-right">İşlemler</th>
            </tr>
          </thead>
          <tbody id="company-table-body" class="divide-y divide-white/5">
            <!-- Data rows injected by Store -->
          </tbody>
        </table>
      </div>
      
      <!-- Empty/Initial State Loader -->
      <div id="table-loader" class="px-8 py-32 text-center flex flex-col items-center justify-center gap-4">
        <div class="w-12 h-12 border-2 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin"></div>
        <p class="text-sm text-gray-500 animate-pulse font-medium">Veritabanı senkronize ediliyor...</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { api } from '../lib/api';
  import { DB } from '../lib/db';
  import { $companies, $syncStatus } from '../lib/store';
  import { SyncManager } from '../lib/sync';

  const tableBody = document.getElementById('company-table-body');
  const tableLoader = document.getElementById('table-loader');
  const searchInput = document.getElementById('search-input');
  const resultCount = document.getElementById('result-count');
  const syncIndicator = document.getElementById('sync-indicator');

  let currentSearchTerm = '';

  // 📡 Store'u Dinle (Reaktif Tablo)
  $companies.subscribe((companies) => {
    if (companies && companies.length > 0) {
      if (tableLoader) tableLoader.classList.add('hidden');
      filterAndRender(companies, currentSearchTerm);
    }
  });

  // 🔄 Sync Durumunu Dinle
  $syncStatus.subscribe((status) => {
    if (syncIndicator) {
      const dot = syncIndicator.querySelector('span');
      const text = syncIndicator.lastChild;
      
      if (status === 'syncing') {
        dot.className = 'w-2 h-2 rounded-full bg-amber-500 animate-pulse';
        text.textContent = ' Güncelleniyor...';
      } else if (status === 'idle') {
        dot.className = 'w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10b981]';
        text.textContent = ' Senkronize';
      } else {
        dot.className = 'w-2 h-2 rounded-full bg-red-500';
        text.textContent = ' Hata';
      }
    }
  });

  // 🖼️ Tablo Render Mantığı
  function filterAndRender(data, term) {
    if (!tableBody) return;
    
    const filtered = data.filter(row => {
      const text = `${row.nickname} ${row.unvan} ${row.city} ${row.id}`.toLocaleLowerCase('tr-TR');
      return text.includes(term.toLocaleLowerCase('tr-TR'));
    });

    tableBody.innerHTML = '';
    resultCount.textContent = filtered.length;

    filtered.forEach((row, index) => {
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-white/5 transition-all group border-l-2 border-l-transparent hover:border-l-indigo-600';
      
      tr.innerHTML = `
        <td class="px-8 py-5 text-sm font-mono text-gray-600">${index + 1}</td>
        <td class="px-8 py-5">
          <div class="text-[15px] font-bold text-white group-hover:text-indigo-400 transition-colors">${row.unvan || '-'}</div>
          <div class="text-[10px] text-gray-600 mt-1 uppercase font-mono tracking-wider">${row.id}</div>
        </td>
        <td class="px-8 py-5">
          <button class="folder-btn inline-flex items-center gap-2.5 px-4 py-2 rounded-xl bg-white/5 border border-white/5 text-xs font-bold text-gray-300 hover:bg-indigo-600 hover:text-white hover:border-indigo-600 transition-all shadow-lg" data-nickname="${row.nickname}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            ${row.nickname || 'KLASÖR'}
          </button>
        </td>
        <td class="px-8 py-5 text-sm text-gray-400 font-medium">${row.city || '-'}</td>
        <td class="px-8 py-5 text-right">
          <div class="flex items-center justify-end gap-3 translate-x-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
            <a href="/company/edit?id=${encodeURIComponent(row.id)}" class="p-2.5 glass rounded-xl text-gray-400 hover:text-indigo-400 hover:border-indigo-400/50 transition shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 5-3-3H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
            </a>
          </div>
        </td>
      `;
      
      tableBody.appendChild(tr);
    });

    attachActions();
  }

  function attachActions() {
    document.querySelectorAll('.folder-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const nickname = e.currentTarget.dataset.nickname;
        btn.classList.add('opacity-50', 'pointer-events-none');
        const response = await api.call('getFolderId', { nickname });
        btn.classList.remove('opacity-50', 'pointer-events-none');
        
        if (response.success && response.data) {
          window.open(`https://drive.google.com/drive/folders/${response.data}`, '_blank');
        } else {
          alert('Klasör bulunamadı.');
        }
      });
    });
  }

  // 🔍 Arama Olayı
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentSearchTerm = e.target.value;
      filterAndRender($companies.get(), currentSearchTerm);
    });
  }

  // 🚀 Başlat
  SyncManager.init();
</script>
