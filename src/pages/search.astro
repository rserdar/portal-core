---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Firma Ara">
  <div class="space-y-4">

    <!-- Arama Çubuğu -->
    <div class="bg-surface border border-border-main shadow-lg p-3 sm:p-4 rounded-2xl flex items-center gap-3">
      <div class="relative flex-1">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted w-4 h-4 pointer-events-none shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="search"
          id="searchInput"
          placeholder="Ünvan, şehir veya ID… (İpucu: Firma @ Şehir)"
          autocomplete="off"
          class="w-full bg-surface-hover border border-border-main rounded-xl pl-10 pr-4 py-2.5 text-main placeholder:text-muted focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-sm"
        />
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span id="searchCounter" class="text-xs font-black text-primary bg-primary/10 border border-primary/20 px-3 py-1.5 rounded-lg min-w-[2.75rem] text-center tabular-nums">0</span>
        <div id="sync-indicator" class="flex items-center gap-1.5 px-2.5 py-1.5 bg-surface-hover border border-border-main rounded-lg text-[10px] uppercase font-bold tracking-tight text-muted shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]"></span>
          <span class="hidden sm:inline sync-status-text">HAZIR</span>
        </div>
      </div>
    </div>

    <!-- Tablo Kartı -->
    <div class="bg-surface border border-border-main shadow-xl rounded-2xl overflow-hidden">

      <!-- Desktop Tablo (sm ve üzeri) -->
      <div class="hidden sm:block">
        <table class="w-full table-fixed border-collapse">
          <colgroup>
            <col class="w-12" />   <!-- # -->
            <col />                <!-- Firma — kalan tüm alanı alır -->
            <col class="w-28" />   <!-- Şehir -->
            <col class="w-36" />   <!-- İşlemler (3 ikon buton) -->
          </colgroup>
          <thead class="bg-surface-hover border-b border-border-main">
            <tr class="text-[10px] font-black uppercase tracking-widest text-muted text-center">
              <th class="px-4 py-3.5">#</th>
              <th class="px-5 py-3.5 text-left">Firma</th>
              <th class="px-4 py-3.5">Şehir</th>
              <th class="px-4 py-3.5">İşlemler</th>
            </tr>
          </thead>
          <tbody id="searchResults" class="divide-y divide-border-main"></tbody>
        </table>
      </div>

      <!-- Mobil Liste (sm altı) -->
      <div class="sm:hidden divide-y divide-border-main" id="searchResultsMobile"></div>

      <!-- Boş durum mesajı -->
      <div id="empty-state" class="hidden py-16 flex flex-col items-center justify-center gap-3 text-center px-6">
        <div class="w-14 h-14 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <p class="text-sm font-bold text-muted uppercase tracking-widest">Eşleşen kayıt bulunamadı</p>
      </div>

      <!-- Yükleniyor -->
      <div id="table-loader" class="py-20 flex flex-col items-center justify-center gap-3">
        <div class="w-10 h-10 border-2 border-primary/20 border-t-primary rounded-full animate-spin"></div>
        <p class="text-xs font-bold text-muted tracking-widest uppercase animate-pulse">Veri Yükleniyor</p>
      </div>

      <!-- Sayfalama -->
      <div id="pagination-container" class="bg-surface-hover border-t border-border-main px-4 sm:px-6 py-3 flex flex-wrap items-center justify-between gap-3 hidden">
        <div class="flex items-center gap-3">
          <span id="page-indicator" class="text-xs font-black text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20 tabular-nums">1 / 1</span>
          <div class="flex items-center gap-2 border-l border-border-main pl-3">
            <span class="text-[10px] font-bold text-muted uppercase tracking-widest hidden sm:inline">Göster:</span>
            <select id="pageSizeSelect" class="bg-surface border border-border-main rounded-lg px-2 py-1 text-[11px] font-bold text-main outline-none focus:ring-1 focus:ring-primary/40 transition-all cursor-pointer">
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
          </div>
        </div>
        <div id="pagination-controls" class="flex items-center gap-1.5"></div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { api } from '../lib/api';
  import { $companies, $syncStatus, $certificates } from '../lib/store';
  import { SyncManager } from '../lib/sync';
  import { toast } from '../lib/toast';

  let currentTerm = '';
  let currentPage = 1;
  let pageSize = 20;
  let cleanupFns: Array<() => void> = [];

  function registerCleanup(fn: () => void) {
    cleanupFns.push(fn);
  }

  function runCleanups() {
    cleanupFns.forEach(fn => fn());
    cleanupFns = [];
  }

  // Desktop ikonları (16px)
  const folderSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>`;
  const eyeSvg   = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`;
  const trashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;
  // Mobil ikonları — dokunma hedefi için biraz daha büyük (18px)
  const folderSvgLg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>`;
  const eyeSvgLg   = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`;
  const trashSvgLg = `<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;

  function initPage() {
    runCleanups();

    const loader = document.getElementById('table-loader') as HTMLElement;
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const syncIndicator = document.getElementById('sync-indicator');
    const pageSizeSelect = document.getElementById('pageSizeSelect') as HTMLSelectElement;

    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q') || '';


    function refreshSearchView() {
      const data = $companies.get() || [];
      const syncStatus = $syncStatus.get();
      const hasData = Array.isArray(data) && data.length > 0;
      const emptyState = document.getElementById('empty-state');
      const loaderEl = document.getElementById('table-loader');

      console.log(`[View] Refreshing: data=${data.length}, status=${syncStatus}`);

      if (hasData) {
        loaderEl?.classList.add('hidden');
        renderResults(data, currentTerm);
        return;
      }

      if (syncStatus === 'syncing') {
        loaderEl?.classList.remove('hidden');
        emptyState?.classList.add('hidden');
        return;
      }

      // idle veya error durumu
      loaderEl?.classList.add('hidden');
      renderResults([], currentTerm);
    }

    const unsubCompanies = $companies.subscribe(() => {
      refreshSearchView();
    });
    registerCleanup(unsubCompanies);

    const unsubSync = $syncStatus.subscribe(status => {
      if (!syncIndicator) return;
      const dot = syncIndicator.querySelector('span');
      const textEl = syncIndicator.querySelector('.sync-status-text');
      if (!dot) return;
      
      if (status === 'syncing') {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse';
        if (textEl) textEl.textContent = 'GÜNCELLENİYOR';
      } else if (status === 'error') {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]';
        if (textEl) textEl.textContent = 'HATA';
      } else {
        dot.className = 'w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]';
        if (textEl) textEl.textContent = 'HAZIR';
      }
      refreshSearchView();
    });
    registerCleanup(unsubSync);

    searchInput?.addEventListener('input', (e) => {
      currentTerm = (e.target as HTMLInputElement).value;
      currentPage = 1;
      renderResults($companies.get(), currentTerm);
    });

    pageSizeSelect?.addEventListener('change', () => {
      pageSize = parseInt(pageSizeSelect.value);
      currentPage = 1;
      refreshUI();
    });

    if (searchInput && initialQuery && !currentTerm) {
      searchInput.value = initialQuery;
      currentTerm = initialQuery;
    }

    refreshSearchView();
    SyncManager.init().then(() => {
      refreshSearchView();
    });
  }

  // Helper functions used by renderResults (kept outside initPage for clarity)

  function normalize(str: any): string {
    if (!str) return '';
    return str.toString()
      .toLocaleLowerCase('tr-TR')
      .replace(/ı/g, 'i').replace(/ğ/g, 'g').replace(/ü/g, 'u')
      .replace(/ş/g, 's').replace(/ö/g, 'o').replace(/ç/g, 'c').trim();
  }

  function pickField(company: any, keys: string[], fallback = ''): string {
    if (!company) return fallback;
    for (const key of keys) {
      const value = company[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') return String(value).trim();
    }
    return fallback;
  }

  function mapCompany(company: any) {
    // Worker search index uses: id, nickname, unvan, city, kapsam, scope
    const id = pickField(company, ['id', 'ID', 'Firma No', 'firmaNo']);
    const nickname = pickField(company, ['nickname', 'nick', 'Markası', 'Marka Adı', 'Firma Adı', 'Nickname'], '-');
    const unvan = pickField(company, ['unvan', 'Unvan', 'UNVAN'], '-');
    const city = pickField(company, ['city', 'sehir', 'şehir', 'il', 'İl'], '-');
    const searchStr = normalize(`${unvan} ${nickname} ${id}`);
    return { id, unvan, nickname, city, searchStr };
  }


  function getInitials(nick: string): string {
    return String(nick || '').trim().split(/\s+/).filter(Boolean).map(w => w[0]).join('').toUpperCase().slice(0, 2) || '??';
  }

  function renderResults(companies: readonly any[], term: string) {
    const resultsBody = document.getElementById('searchResults') as HTMLTableSectionElement;
    const resultsMobile = document.getElementById('searchResultsMobile') as HTMLElement;
    const paginationContainer = document.getElementById('pagination-container');
    const emptyState = document.getElementById('empty-state');
    const counter = document.getElementById('searchCounter');
    if (!resultsBody || !resultsMobile || !counter || !paginationContainer || !emptyState) return;

    const normalizedTerm = normalize(term);
    const mapped = companies.map(mapCompany);

    let filtered: ReturnType<typeof mapCompany>[];
    if (normalizedTerm.includes('@')) {
      const [namePart, cityPart] = normalizedTerm.split('@').map(s => s.trim());
      filtered = mapped.filter(c => c.searchStr.includes(namePart) && normalize(c.city).includes(cityPart));
    } else {
      filtered = mapped.filter(c => `${c.searchStr} ${normalize(c.city)}`.includes(normalizedTerm));
    }

    counter.textContent = filtered.length.toString();

    const totalPages = Math.ceil(filtered.length / pageSize) || 1;
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * pageSize;
    const paginatedItems = filtered.slice(start, start + pageSize);

    // Temizle
    resultsBody.innerHTML = '';
    resultsMobile.innerHTML = '';

    if (paginatedItems.length === 0) {
      paginationContainer.classList.add('hidden');
      emptyState.classList.remove('hidden');
      emptyState.classList.add('flex');
      return;
    }

    emptyState.classList.add('hidden');
    emptyState.classList.remove('flex');
    paginationContainer.classList.remove('hidden');
    renderPaginationUI(filtered.length);

    const pageIndicator = document.getElementById('page-indicator');
    if (pageIndicator) pageIndicator.textContent = `${currentPage} / ${totalPages}`;

    let desktopHtml = '';
    let mobileHtml = '';

    paginatedItems.forEach((c) => {
      const safeId = c.id || '';
      const encodedId = encodeURIComponent(safeId);
      const initials = getInitials(c.nickname);

      // Desktop
      desktopHtml += `
        <tr class="hover:bg-surface-hover transition-colors group/row">
          <td class="px-4 py-3 text-center">
            <span class="text-[11px] font-mono font-bold text-muted">${safeId || '-'}</span>
          </td>
          <td class="px-5 py-3 overflow-hidden">
            <a href="/company?id=${encodedId}" class="flex items-center gap-3 min-w-0 group/link">
              <div class="w-8 h-8 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0 group-hover/link:bg-indigo-500/20 transition-colors">
                <span class="text-[10px] font-black text-indigo-400 uppercase">${initials}</span>
              </div>
              <div class="min-w-0 flex-1">
                <div class="font-bold text-sm text-main group-hover/link:text-primary transition-colors truncate uppercase tracking-tight leading-tight">${escHtml(c.nickname || '-')}</div>
                <div class="text-[11px] text-muted truncate mt-0.5 leading-tight">${escHtml(c.unvan || '-')}</div>
              </div>
            </a>
          </td>
          <td class="px-4 py-3 text-center">
            <span class="inline-block text-[11px] font-bold text-muted bg-surface-hover border border-border-main px-2 py-0.5 rounded-md uppercase tracking-wide truncate max-w-full">${escHtml(c.city || '-')}</span>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center justify-center gap-1.5">
              <button class="folder-btn w-9 h-9 inline-flex items-center justify-center rounded-lg border border-border-main text-muted hover:text-primary hover:bg-primary/10 hover:border-primary/30 transition-all" data-nickname="${escHtml(c.nickname)}" title="Drive Klasörü">
                ${folderSvg}
              </button>
              <button class="eye-btn w-9 h-9 inline-flex items-center justify-center rounded-lg border border-primary/30 bg-primary/5 text-primary hover:bg-primary hover:text-white hover:border-primary transition-all" data-id="${safeId}" data-preview-target="search-preview-${safeId}" aria-expanded="false" title="Hızlı Önizleme">
                ${eyeSvg}
              </button>
              <button class="delete-btn w-9 h-9 inline-flex items-center justify-center rounded-lg border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white hover:border-rose-500 transition-all" data-id="${safeId}" title="Sil">
                ${trashSvg}
              </button>
            </div>
          </td>
        </tr>
        <tr id="search-preview-${safeId}" class="hidden border-b border-border-main">
          <td colspan="4"></td>
        </tr>
      `;

      // Mobile
      mobileHtml += `
        <div class="flex items-center gap-3 px-4 py-3 hover:bg-surface-hover transition-colors">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0">
            <span class="text-xs font-black text-indigo-400 uppercase">${initials}</span>
          </div>
          <a href="/company?id=${encodedId}" class="flex-1 min-w-0 block">
            <div class="font-bold text-sm text-main uppercase tracking-tight truncate">${escHtml(c.nickname || '-')}</div>
            <div class="text-[11px] text-muted truncate mt-0.5">${escHtml(c.unvan || '-')}</div>
            <div class="flex items-center gap-1.5 mt-1">
              ${c.city && c.city !== '-' ? `<span class="text-[10px] font-bold text-muted uppercase">${escHtml(c.city)}</span><span class="text-muted text-[10px]">·</span>` : ''}
              <span class="text-[10px] font-mono text-muted/70">M${safeId}</span>
            </div>
          </a>
          <div class="flex items-center gap-2 shrink-0">
            <button class="folder-btn w-11 h-11 flex items-center justify-center rounded-xl border border-border-main bg-surface-hover text-muted hover:text-primary hover:bg-primary/10 hover:border-primary/30 active:scale-95 transition-all touch-manipulation" data-nickname="${escHtml(c.nickname)}" title="Drive Klasörü">
              ${folderSvgLg}
            </button>
            <button class="eye-btn w-11 h-11 flex items-center justify-center rounded-xl border border-primary/30 bg-primary/8 text-primary hover:bg-primary hover:text-white active:scale-95 transition-all touch-manipulation" data-id="${safeId}" data-preview-target="search-preview-mob-${safeId}" aria-expanded="false" title="Hızlı Önizleme">
              ${eyeSvgLg}
            </button>
            <button class="delete-btn w-11 h-11 flex items-center justify-center rounded-xl border border-rose-500/20 text-rose-400 hover:bg-rose-500 hover:text-white active:scale-95 transition-all touch-manipulation" data-id="${safeId}" title="Sil">
              ${trashSvgLg}
            </button>
          </div>
        </div>
        <div id="search-preview-mob-${safeId}" class="hidden border-b border-border-main"></div>
      `;
    });

    resultsBody.innerHTML = desktopHtml;
    resultsMobile.innerHTML = mobileHtml;

    attachEvents();
  }

  function renderPaginationUI(totalCount: number) {
    const controls = document.getElementById('pagination-controls');
    if (!controls) return;
    const totalPages = Math.ceil(totalCount / pageSize) || 1;
    controls.innerHTML = '';

    const prevBtn = document.createElement('button');
    prevBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>`;
    prevBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${currentPage > 1 ? 'text-primary hover:bg-primary/10 hover:border-primary/30' : 'text-muted opacity-30 cursor-not-allowed'}`;
    prevBtn.disabled = currentPage <= 1;
    prevBtn.onclick = () => { if (currentPage > 1) { currentPage--; refreshUI(); } };
    controls.appendChild(prevBtn);

    let range: number[] = [];
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) range.push(i);
    }

    let last: number | null = null;
    range.forEach(i => {
      if (last && i - last > 1) {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.className = 'px-1.5 text-muted text-xs';
        controls.appendChild(dots);
      }
      const pageBtn = document.createElement('button');
      pageBtn.textContent = i.toString();
      pageBtn.className = `w-8 h-8 rounded-lg border text-xs font-black transition-all ${
        i === currentPage
          ? 'bg-primary text-white border-primary shadow-md shadow-primary/20'
          : 'border-border-main text-muted hover:text-primary hover:bg-primary/10 hover:border-primary/30'
      }`;
      pageBtn.onclick = () => { currentPage = i; refreshUI(); };
      controls.appendChild(pageBtn);
      last = i;
    });

    const nextBtn = document.createElement('button');
    nextBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
    nextBtn.className = `p-1.5 rounded-lg border border-border-main transition-all ${currentPage < totalPages ? 'text-primary hover:bg-primary/10 hover:border-primary/30' : 'text-muted opacity-30 cursor-not-allowed'}`;
    nextBtn.disabled = currentPage >= totalPages;
    nextBtn.onclick = () => { if (currentPage < totalPages) { currentPage++; refreshUI(); } };
    controls.appendChild(nextBtn);
  }

  function refreshUI() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    renderResults($companies.get(), currentTerm);
  }

  // ── Inline Önizleme ──────────────────────────────────────────────────────────

  /** Bir objeden birden fazla olası key ile değer okur (basit versiyon) */
  function gField(obj: any, ...keys: string[]): string {
    for (const k of keys) {
      const v = obj?.[k];
      if (v !== undefined && v !== null && String(v).trim() !== '') return String(v).trim();
    }
    return '';
  }

  function escHtml(value: any): string {
    return String(value ?? '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function certBadge(standard: string): string {
    const s = standard.trim();
    if (!s) return '';
    let cls = 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20';
    const sl = s.toLowerCase();
    if (sl.includes('14001')) cls = 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
    else if (sl.includes('45001')) cls = 'bg-amber-500/10 text-amber-400 border-amber-500/20';
    else if (sl.includes('13485')) cls = 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20';
    else if (sl.includes('27001')) cls = 'bg-purple-500/10 text-purple-400 border-purple-500/20';
    else if (sl.includes('50001')) cls = 'bg-rose-500/10 text-rose-400 border-rose-500/20';
    return `<span class="text-[10px] font-bold px-2.5 py-1 rounded-full border ${cls}">${escHtml(s)}</span>`;
  }

  function buildPreviewContent(companyId: string): string {
    const allCompanies = $companies.get();
    const raw = allCompanies.find((c: any) => {
      const id = gField(c, 'id', 'ID', 'Firma No', 'firmaNo', 'firma_no', 'no');
      return String(id) === String(companyId);
    });
    if (!raw) return '<p class="text-xs text-muted italic p-4">Firma bulunamadı.</p>';

    const kapsam = gField(raw, 'Türkçe Kapsam', 'Sertifika Kapsamı (TR)', 'Kapsam', 'kapsam');
    const scope  = gField(raw, 'İngilizce Kapsam', 'Sertifika Kapsamı (EN)', 'Scope', 'scope');

    const allCerts = $certificates.get();
    const firmaCerts = allCerts.filter((cert: any) => {
      const fn = gField(cert, 'Firma No', 'FirmaNo', 'firmaNo', 'firma_no');
      return String(fn) === String(companyId);
    });
    const standards = Array.from(new Set(
      firmaCerts.map((cert: any) => {
        const s = gField(cert, 'Standart', 'standart');
        const other = gField(cert, 'Other Standard', 'Other', 'other', 'Diğer', 'diger', 'Diğer Standart', 'digerStandart');
        const sl = s.toLowerCase();
        const isOther = sl === 'diğer' || sl === 'diger' || sl === 'other';
        return isOther && other ? other : s;
      }).filter(Boolean)
    )) as string[];

    const kapsamHtml = kapsam ? `
      <div>
        <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1">Kapsam</p>
        <p class="text-xs text-main italic leading-relaxed">${escHtml(kapsam)}</p>
      </div>` : '';

    const scopeHtml = scope ? `
      <div>
        <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1">Scope</p>
        <p class="text-xs text-main italic leading-relaxed">${escHtml(scope)}</p>
      </div>` : '';

    const certsHtml = standards.length > 0 ? `
      <div>
        <p class="text-[10px] font-black uppercase tracking-widest text-muted mb-1.5">Sertifikalar</p>
        <div class="flex flex-wrap gap-1.5">${standards.map(certBadge).join('')}</div>
      </div>` : '';

    const emptyHtml = !kapsamHtml && !scopeHtml && !certsHtml
      ? '<p class="text-xs text-muted italic">Ek bilgi bulunamadı.</p>'
      : '';

    return `
      <div class="flex flex-wrap items-start gap-x-8 gap-y-3 px-5 sm:px-7 py-4 bg-surface-hover">
        ${kapsamHtml}
        ${scopeHtml}
        ${certsHtml}
        ${emptyHtml}
      </div>
    `;
  }

  function toggleInlinePreview(btn: HTMLButtonElement) {
    const targetId = btn.dataset.previewTarget || '';
    const previewEl = targetId ? document.getElementById(targetId) : null;
    if (!previewEl) return;

    const isHidden = previewEl.classList.contains('hidden');

    if (isHidden) {
      if (!previewEl.dataset.built) {
        const companyId = btn.dataset.id || '';
        // Desktop: <tr> içinde <td colspan="4"> var, içine yaz
        const td = previewEl.querySelector('td');
        if (td) {
          td.innerHTML = buildPreviewContent(companyId);
        } else {
          // Mobil: doğrudan div
          previewEl.innerHTML = buildPreviewContent(companyId);
        }
        previewEl.dataset.built = 'true';
      }
      previewEl.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.classList.add('bg-primary', 'text-white', 'border-primary');
      btn.classList.remove('bg-primary/5', 'text-primary', 'border-primary/30');
    } else {
      previewEl.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      btn.classList.remove('bg-primary', 'text-white', 'border-primary');
      btn.classList.add('bg-primary/5', 'text-primary', 'border-primary/30');
    }
  }

  // ────────────────────────────────────────────────────────────────────────────

  function attachEvents() {
    document.querySelectorAll('.eye-btn').forEach(el => {
      const btn = el as HTMLButtonElement;
      btn.onclick = () => toggleInlinePreview(btn);
    });

    document.querySelectorAll('.folder-btn').forEach(el => {
      const btn = el as HTMLButtonElement;
      btn.onclick = async () => {
        const nick = btn.dataset.nickname;
        const prev = btn.innerHTML;
        btn.innerHTML = '<div class="w-3.5 h-3.5 border-2 border-current border-t-transparent rounded-full animate-spin"></div>';
        btn.disabled = true;
        const res = await api.call('getFolderId', { nickname: nick });
        btn.innerHTML = prev;
        btn.disabled = false;
        if (res.success && res.data) window.open(`https://drive.google.com/drive/folders/${res.data}`, '_blank');
      };
    });

    document.querySelectorAll('.delete-btn').forEach(el => {
      const btn = el as HTMLButtonElement;
      let timer: ReturnType<typeof setTimeout>;
      btn.onclick = () => {
        if (btn.dataset.confirm !== 'true') {
          btn.dataset.confirm = 'true';
          const prev = btn.innerHTML;
          btn.innerHTML = 'Onayla?';
          btn.classList.add('bg-rose-500', 'text-white', 'border-rose-500');
          timer = setTimeout(() => {
            btn.dataset.confirm = '';
            btn.innerHTML = prev;
            btn.classList.remove('bg-rose-500', 'text-white', 'border-rose-500');
          }, 3000);
        } else {
          clearTimeout(timer);
          // api.call('deleteCompany', { id: btn.dataset.id });
          console.log('Delete target:', btn.dataset.id);
        }
      };
    });
  }

  // Initial load
  initPage();
  // ViewTransitions support
  document.addEventListener('astro:page-load', initPage);
  // Cleanup away
  document.addEventListener('astro:before-preparation', runCleanups, { once: true });
</script>
