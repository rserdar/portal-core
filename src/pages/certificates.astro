---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Sertifika Yönetimi">
  <div class="space-y-6">

    <!-- 🎛️ Filtreleme Paneli -->
    <div class="bg-surface border border-border-main shadow-xl p-5 rounded-3xl space-y-4">

      <!-- Üst satır: Sync + Bulk Actions -->
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div id="sync-indicator" class="flex items-center gap-2 px-3 py-1.5 bg-surface border border-border-main rounded-lg text-[10px] uppercase tracking-wider text-gray-500 font-bold">
          <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_6px_#10b981]"></span>
          Güncel
        </div>
        <div class="flex items-center gap-2">
          <button id="export-csv-btn" class="px-3 py-2 rounded-lg border border-border-main bg-surface text-[10px] font-black uppercase tracking-wider text-muted hover:text-primary transition-all">
            CSV Dışa Aktar
          </button>
          <button id="export-excel-btn" class="px-3 py-2 rounded-lg border border-border-main bg-surface text-[10px] font-black uppercase tracking-wider text-muted hover:text-emerald-400 transition-all">
            Excel Dışa Aktar
          </button>
        </div>

        <!-- Bulk Actions (JS ile gösterilir) -->
        <div id="bulk-actions" class="hidden items-center gap-3 bg-surface border border-primary/30 px-4 py-2 rounded-xl animate-fade-in">
          <span id="selected-count" class="text-[10px] font-black text-indigo-400">0 SEÇİLİ</span>
          <div class="h-4 w-px bg-white/10"></div>
          <button id="bulk-done-btn" class="text-[10px] font-bold text-emerald-400 hover:text-emerald-300 transition-colors uppercase tracking-wider px-2 py-1 rounded-lg hover:bg-emerald-500/10">
            ✓ Gözetim Yapıldı
          </button>
          <div class="h-4 w-px bg-white/10"></div>
          <button id="bulk-pending-btn" class="text-[10px] font-bold text-amber-400 hover:text-amber-300 transition-colors uppercase tracking-wider px-2 py-1 rounded-lg hover:bg-amber-500/10">
            ⏸ Beklemeye Al
          </button>
        </div>
      </div>

      <!-- Alt satır: Arama + Filtreler (AYNI GLASS KART İÇİNDE) -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <div class="md:col-span-2 relative group">
          <input
            type="text"
            id="global-search"
            placeholder="Firma, Standart veya Belge No ile ara..."
            class="w-full bg-white/5 border border-white/10 rounded-xl px-11 py-3 text-sm focus:ring-2 focus:ring-indigo-500/50 outline-none transition-all text-white placeholder:text-gray-600"
          />
          <svg class="absolute left-3.5 top-3.5 text-gray-500 group-focus-within:text-indigo-400 transition-colors pointer-events-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>

        <select id="standard-filter" class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/50 text-gray-300 appearance-none cursor-pointer transition-all">
          <option value="">Tüm Standartlar</option>
          <option value="9001">ISO 9001</option>
          <option value="14001">ISO 14001</option>
          <option value="45001">ISO 45001</option>
          <option value="22000">ISO 22000</option>
          <option value="27001">ISO 27001</option>
          <option value="13485">ISO 13485</option>
          <option value="10002">ISO 10002</option>
        </select>

        <select id="status-filter" class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/50 text-gray-300 appearance-none cursor-pointer transition-all">
          <option value="">Tüm Durumlar</option>
          <option value="TRUE">Aktif (Gözetim Tamam)</option>
          <option value="FALSE">Bekliyor (Gözetim Gerekli)</option>
        </select>
      </div>

    </div><!-- /.glass filter panel — KAPATILDI -->

    <!-- 📊 Veri Tablosu -->
    <div class="bg-surface border border-border-main shadow-2xl rounded-3xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-white/5 bg-white/5 text-gray-500">
              <th class="px-6 py-4 w-10">
                <input type="checkbox" id="select-all" class="w-4 h-4 rounded border-gray-700 text-indigo-600 bg-transparent cursor-pointer">
              </th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-indigo-400/80">Durum</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest">Firma</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest">Standart</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest">Belge No</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-center">Gözetim Tarihi</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest">Not</th>
              <th class="px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-right">İşlemler</th>
            </tr>
          </thead>
          <tbody id="cert-table-body" class="divide-y divide-white/5">
          </tbody>
        </table>
      </div>

      <!-- Yükleniyor -->
      <div id="table-loader" class="px-8 py-32 flex flex-col items-center justify-center gap-4">
        <div class="w-12 h-12 border-2 border-indigo-500/20 border-t-indigo-500 rounded-full animate-spin"></div>
        <p class="text-sm text-gray-500 animate-pulse font-medium">Sertifikalar yükleniyor...</p>
      </div>

      <!-- Boş Durum -->
      <div id="empty-state" class="hidden px-8 py-32 flex flex-col items-center justify-center gap-4">
        <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        </div>
        <p class="text-lg font-bold text-gray-500">Sertifika bulunamadı</p>
        <p class="text-xs text-gray-600">Filtre kriterlerinizi değiştirmeyi deneyin.</p>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { api } from '../lib/api';
  import { $certificates, $syncStatus } from '../lib/store';
  import { SyncManager } from '../lib/sync';

  const tableBody = document.getElementById('cert-table-body');
  const tableLoader = document.getElementById('table-loader');
  const emptyState = document.getElementById('empty-state');
  const globalSearch = document.getElementById('global-search') as HTMLInputElement;
  const standardFilter = document.getElementById('standard-filter') as HTMLSelectElement;
  const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
  const syncIndicator = document.getElementById('sync-indicator');
  const exportCsvBtn = document.getElementById('export-csv-btn') as HTMLButtonElement;
  const exportExcelBtn = document.getElementById('export-excel-btn') as HTMLButtonElement;

  let filters = { search: '', standard: '', status: '' };

  function pickValue(item: any, aliases: string[], fallback = '') {
    for (const key of aliases) {
      if (item && item[key] !== undefined && item[key] !== null && String(item[key]).trim() !== '') {
        return String(item[key]);
      }
    }
    return fallback;
  }

  function pickExistingField(item: any, aliases: string[], fallback: string) {
    for (const key of aliases) {
      if (item && Object.prototype.hasOwnProperty.call(item, key)) return key;
    }
    return fallback;
  }

  function escHtml(v: any) {
    return String(v ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function escAttr(v: any) {
    return escHtml(v).replace(/"/g, "&quot;");
  }

  $certificates.subscribe(certs => {
    if (certs && certs.length > 0) {
      tableLoader?.classList.add('hidden');
      renderTable(certs);
    }
  });

  $syncStatus.subscribe(status => {
    if (!syncIndicator) return;
    const dot = syncIndicator.querySelector('span');
    const text = syncIndicator.lastChild;
    if (status === 'syncing') {
      if (dot) { dot.className = 'w-2 h-2 rounded-full bg-amber-500 animate-pulse'; }
      if (text) text.textContent = ' GÜNCELLENİYOR';
    } else {
      if (dot) { dot.className = 'w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_6px_#10b981]'; }
      if (text) text.textContent = ' GÜNCEL';
    }
  });

  function getFilteredData(data: readonly any[]) {
    return data.filter((item: any) => {
      const firma = pickValue(item, ["Firma Adı", "Nickname", "nick"]);
      const id = pickValue(item, ["ID", "id"]);
      const certNo = pickValue(item, ["Sertifika No", "sNo", "SNo", "sno"]);
      const standart = pickValue(item, ["Standart", "standard"]);
      const gozetim = pickValue(item, ["Gözetim", "Gözetim Conf.", "gozetimConfirmed"], "FALSE").toUpperCase();

      const matchSearch = `${firma}${id}${certNo}`.toLowerCase().includes(filters.search.toLowerCase());
      const matchStd = !filters.standard || standart.includes(filters.standard);
      const matchStatus = !filters.status || gozetim === filters.status;
      return matchSearch && matchStd && matchStatus;
    });
  }

  function renderTable(data: readonly any[]) {
    if (!tableBody) return;

    const filtered = getFilteredData(data);

    tableBody.innerHTML = '';

    if (filtered.length === 0) {
      emptyState?.classList.remove('hidden');
      return;
    }
    emptyState?.classList.add('hidden');

    filtered.forEach((item: any) => {
      const id = pickValue(item, ["ID", "id"]);
      const firma = pickValue(item, ["Firma Adı", "Nickname", "nick"], "-");
      const danisman = pickValue(item, ["Danışman", "dan"], "");
      const standart = pickValue(item, ["Standart", "standard"], "-");
      const certNo = pickValue(item, ["Sertifika No", "sNo", "SNo", "sno"], "-");
      const gozetimTarihi = pickValue(item, ["Sertifika Gözetim Tarihi", "goz", "GOZ"], "");
      const sertifikaTarihi = pickValue(item, ["Sertifika Tarihi", "gst", "GST"], "");
      const note = pickValue(item, ["Not", "not"], "");
      const gozetim = pickValue(item, ["Gözetim", "Gözetim Conf.", "gozetimConfirmed"], "FALSE").toUpperCase();
      const isOk = gozetim === "TRUE";

      const gozetimField = pickExistingField(item, ["Sertifika Gözetim Tarihi", "goz", "GOZ"], "goz");
      const noteField = pickExistingField(item, ["Not", "not"], "Not");
      const idAttr = escAttr(id);
      const firmaHtml = escHtml(firma);
      const danismanHtml = escHtml(danisman);
      const standartHtml = escHtml(standart);
      const certNoHtml = escHtml(certNo);
      const gozetimTarihiAttr = escAttr(gozetimTarihi);
      const sertifikaTarihiHtml = escHtml(sertifikaTarihi);
      const noteAttr = escAttr(note);
      const gozetimFieldAttr = escAttr(gozetimField);
      const noteFieldAttr = escAttr(noteField);

      const tr = document.createElement('tr');
      tr.className = 'hover:bg-white/[0.03] transition-colors group border-l-2 border-l-transparent hover:border-l-indigo-600/50';

      tr.innerHTML = `
        <td class="px-6 py-4">
          <input type="checkbox" class="cert-checkbox w-4 h-4 rounded border-gray-700 text-indigo-600 bg-transparent cursor-pointer" data-id="${idAttr}">
        </td>
        <td class="px-6 py-4">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full flex-shrink-0 ${isOk ? 'bg-emerald-500 shadow-[0_0_6px_#10b981]' : 'bg-amber-500 shadow-[0_0_6px_#f59e0b]'}"></span>
            <span class="text-[10px] font-bold ${isOk ? 'text-emerald-400' : 'text-amber-400'}">${isOk ? 'AKTİF' : 'BEKLİYOR'}</span>
          </div>
        </td>
        <td class="px-6 py-4">
          <div class="text-sm font-semibold text-white group-hover:text-indigo-300 transition-colors leading-tight">${firmaHtml}</div>
          <div class="text-[10px] text-gray-600 font-mono mt-0.5">${danismanHtml}</div>
        </td>
        <td class="px-6 py-4">
          <span class="text-xs font-bold text-indigo-300/80 bg-indigo-500/10 px-2.5 py-1 rounded-lg">${standartHtml}</span>
        </td>
        <td class="px-6 py-4 text-xs text-gray-500 font-mono">${certNoHtml}</td>
        <td class="px-6 py-4 text-center">
          <input
            type="text"
            class="inline-surv w-32 bg-surface border border-border-main rounded-md px-2 py-1 text-xs text-main text-center"
            data-id="${idAttr}"
            data-field="${gozetimFieldAttr}"
            data-original="${gozetimTarihiAttr}"
            value="${gozetimTarihiAttr}"
            placeholder="dd.MM.yyyy"
          />
          <div class="text-[10px] text-gray-600 mt-1">${sertifikaTarihiHtml}</div>
        </td>
        <td class="px-6 py-4">
          <input
            type="text"
            class="inline-note w-full min-w-[180px] bg-surface border border-border-main rounded-md px-2 py-1 text-xs text-main"
            data-id="${idAttr}"
            data-field="${noteFieldAttr}"
            data-original="${noteAttr}"
            value="${noteAttr}"
            placeholder="Kısa not..."
          />
        </td>
        <td class="px-6 py-4 text-right">
          <div class="flex items-center justify-end gap-2 translate-x-2 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
            <button class="save-inline-btn p-2 bg-surface border border-border-main shadow-sm rounded-lg text-muted hover:text-emerald-400 transition-all" title="Satırı Kaydet" data-id="${idAttr}">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            </button>
            <button class="folder-btn p-2 bg-surface border border-border-main shadow-sm rounded-lg text-muted hover:text-primary transition-all" title="Drive Klasörü" data-nick="${escAttr(firma)}">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93l-1-1A2 2 0 0 0 9.6 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z"/></svg>
            </button>
            <button class="pdf-btn p-2 bg-surface border border-border-main shadow-sm rounded-lg text-muted hover:text-rose-400 transition-all" title="PDF Dönüştür" data-id="${idAttr}">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            </button>
          </div>
        </td>
      `;
      tableBody.appendChild(tr);
    });

    attachTableActions();
  }

  // --- TOPLU İŞLEMLER ---
  const selectAll = document.getElementById('select-all') as HTMLInputElement;
  const bulkActionsBar = document.getElementById('bulk-actions');
  const selectedCountDisplay = document.getElementById('selected-count');
  const bulkDoneBtn = document.getElementById('bulk-done-btn');
  const bulkPendingBtn = document.getElementById('bulk-pending-btn');

  function updateBulkUI() {
    const checked = document.querySelectorAll('.cert-checkbox:checked');
    if (selectedCountDisplay) selectedCountDisplay.textContent = `${checked.length} SEÇİLİ`;
    if (checked.length > 0) {
      bulkActionsBar?.classList.remove('hidden');
      bulkActionsBar?.classList.add('flex');
    } else {
      bulkActionsBar?.classList.add('hidden');
      bulkActionsBar?.classList.remove('flex');
      if (selectAll) selectAll.checked = false;
    }
  }

  selectAll?.addEventListener('change', (e) => {
    const isChecked = (e.target as HTMLInputElement).checked;
    document.querySelectorAll('.cert-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = isChecked;
    });
    updateBulkUI();
  });

  tableBody?.addEventListener('change', (e) => {
    if ((e.target as HTMLElement).classList.contains('cert-checkbox')) {
      updateBulkUI();
    }
  });

  async function callBulkUpdate(status: boolean) {
    const checked = Array.from(document.querySelectorAll('.cert-checkbox:checked'))
      .map(cb => (cb as HTMLElement).dataset.id);
    if (checked.length === 0) return;
    if (!confirm(`${checked.length} adet belgenin gözetim durumunu güncellemek istediğinizden emin misiniz?`)) return;
    const res = await api.call('updateSurveillance', { ids: checked, status });
    if (res.success) {
      alert('İşlem Başarılı!');
      window.location.reload();
    } else {
      alert('Hata: ' + res.error);
    }
  }

  bulkDoneBtn?.addEventListener('click', () => callBulkUpdate(true));
  bulkPendingBtn?.addEventListener('click', () => callBulkUpdate(false));

  function attachTableActions() {
    document.querySelectorAll('.save-inline-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        if (!id) return;
        const survInput = document.querySelector(`.inline-surv[data-id="${id}"]`) as HTMLInputElement | null;
        const noteInput = document.querySelector(`.inline-note[data-id="${id}"]`) as HTMLInputElement | null;
        if (!survInput && !noteInput) return;

        const btnEl = e.currentTarget as HTMLElement;
        btnEl.classList.add('text-emerald-400');
        try {
          if (survInput) {
            const curr = survInput.value.trim();
            const orig = (survInput.dataset.original || '').trim();
            if (curr !== orig) {
              const field = survInput.dataset.field || 'goz';
              const res = await api.updateCertificateField(id, field, curr);
              if (!res.success) throw new Error(res.error || 'Gözetim tarihi güncellenemedi');
              survInput.dataset.original = curr;
            }
          }
          if (noteInput) {
            const curr = noteInput.value.trim();
            const orig = (noteInput.dataset.original || '').trim();
            if (curr !== orig) {
              const field = noteInput.dataset.field || 'Not';
              const res = await api.updateCertificateField(id, field, curr);
              if (!res.success) throw new Error(res.error || 'Not güncellenemedi');
              noteInput.dataset.original = curr;
            }
          }
        } catch (err: any) {
          alert('Kaydetme hatası: ' + (err?.message || String(err)));
        } finally {
          btnEl.classList.remove('text-emerald-400');
        }
      });
    });

    document.querySelectorAll('.folder-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const nick = (e.currentTarget as HTMLElement).dataset.nick;
        const res = await api.call('getFolderId', { nickname: nick });
        if (res.success) window.open(`https://drive.google.com/drive/folders/${res.data}`, '_blank');
      });
    });
    document.querySelectorAll('.pdf-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        const btnEl = e.currentTarget as HTMLElement;
        btnEl.classList.add('animate-spin', 'text-rose-500');
        alert('PDF Dönüştürme başlatıldı. Lütfen Drive klasörünü kontrol edin.');
        btnEl.classList.remove('animate-spin', 'text-rose-500');
      });
    });
  }

  globalSearch?.addEventListener('input', (e) => {
    filters.search = (e.target as HTMLInputElement).value;
    renderTable($certificates.get());
  });
  standardFilter?.addEventListener('change', (e) => {
    filters.standard = (e.target as HTMLSelectElement).value;
    renderTable($certificates.get());
  });
  statusFilter?.addEventListener('change', (e) => {
    filters.status = (e.target as HTMLSelectElement).value;
    renderTable($certificates.get());
  });

  function toCsvValue(v: any) {
    const s = String(v ?? '');
    if (s.includes('"') || s.includes(',') || s.includes('\n')) {
      return `"${s.replace(/"/g, '""')}"`;
    }
    return s;
  }

  function getExportRows() {
    const filtered = getFilteredData($certificates.get());
    return filtered.map((item: any) => ({
      id: pickValue(item, ["ID", "id"]),
      firma: pickValue(item, ["Firma Adı", "Nickname", "nick"]),
      standart: pickValue(item, ["Standart", "standard"]),
      belgeNo: pickValue(item, ["Sertifika No", "sNo", "SNo", "sno"]),
      gozetim: pickValue(item, ["Gözetim", "Gözetim Conf.", "gozetimConfirmed"], "FALSE").toUpperCase(),
      gozetimTarihi: pickValue(item, ["Sertifika Gözetim Tarihi", "goz", "GOZ"]),
      sertifikaTarihi: pickValue(item, ["Sertifika Tarihi", "gst", "GST"]),
      not: pickValue(item, ["Not", "not"]),
      danisman: pickValue(item, ["Danışman", "dan"])
    }));
  }

  function downloadFile(filename: string, content: string, mime: string) {
    const blob = new Blob([content], { type: mime });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  exportCsvBtn?.addEventListener('click', () => {
    const rows = getExportRows();
    const headers = ['ID', 'Firma', 'Standart', 'Belge No', 'Gözetim', 'Gözetim Tarihi', 'Sertifika Tarihi', 'Not', 'Danışman'];
    const lines = [headers.join(',')];
    rows.forEach(r => {
      lines.push([
        toCsvValue(r.id),
        toCsvValue(r.firma),
        toCsvValue(r.standart),
        toCsvValue(r.belgeNo),
        toCsvValue(r.gozetim),
        toCsvValue(r.gozetimTarihi),
        toCsvValue(r.sertifikaTarihi),
        toCsvValue(r.not),
        toCsvValue(r.danisman)
      ].join(','));
    });
    downloadFile(`Sertifikalar_${new Date().toISOString().slice(0,10)}.csv`, '\uFEFF' + lines.join('\n'), 'text/csv;charset=utf-8;');
  });

  exportExcelBtn?.addEventListener('click', () => {
    const rows = getExportRows();
    const tableHtml = `
      <table>
        <thead>
          <tr>
            <th>ID</th><th>Firma</th><th>Standart</th><th>Belge No</th><th>Gözetim</th><th>Gözetim Tarihi</th><th>Sertifika Tarihi</th><th>Not</th><th>Danışman</th>
          </tr>
        </thead>
        <tbody>
          ${rows.map(r => `<tr><td>${r.id}</td><td>${r.firma}</td><td>${r.standart}</td><td>${r.belgeNo}</td><td>${r.gozetim}</td><td>${r.gozetimTarihi}</td><td>${r.sertifikaTarihi}</td><td>${r.not}</td><td>${r.danisman}</td></tr>`).join('')}
        </tbody>
      </table>
    `;
    const html = `<html><head><meta charset="utf-8" /></head><body>${tableHtml}</body></html>`;
    downloadFile(`Sertifikalar_${new Date().toISOString().slice(0,10)}.xls`, html, 'application/vnd.ms-excel;charset=utf-8;');
  });

  SyncManager.init();
</script>
