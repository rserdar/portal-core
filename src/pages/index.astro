---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { 
  Building2, 
  Award, 
  CalendarClock, 
  RefreshCw,
  Plus,
  Search,
  FileSpreadsheet,
  ChevronRight,
  TrendingUp,
  ShieldCheck,
  Cpu,
  Activity,
  Zap
} from 'lucide-astro';

/**
 * 🏠 Dashboard Overview (WOW Phase v5.0)
 * 
 * Portalın ana sayfası. Özet bilgiler, dinamik istatistikler ve 
 * yüksek performanslı aksiyon kartları içerir.
 */

const stats = [
	{ label: "Toplam Firma", id: "stat-companies", icon: Building2, color: "indigo" },
	{ label: "Aktif Sertifika", id: "stat-certificates", icon: Award, color: "emerald" },
	{ label: "Kritik Gözetim", id: "stat-pending-count", icon: CalendarClock, color: "amber" },
];

const quickActions = [
	{ title: "Yeni Firma Ekle", desc: "Müşteri portföyüne yeni kayıt ekleyin.", href: "/company/add", icon: Plus },
	{ title: "Sertifika Sorgula", desc: "Arşivdeki tüm belgeleri listeleyin.", href: "/search", icon: Search },
	{ title: "Doküman Üret", desc: "ISO doküman seti hazırlayın.", href: "/docs", icon: FileSpreadsheet },
];
---

<DashboardLayout title="Genel Bakış">
	<!-- Top Stats Section -->
	<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
		{stats.map((item) => {
      const Icon = item.icon;
      return (
        <div class="bg-surface border border-border-main shadow-xl p-6 rounded-[2rem] relative overflow-hidden group hover:scale-[1.02] transition-all duration-300">
          <!-- Background Glow -->
          <div class={`absolute -right-4 -bottom-4 w-24 h-24 bg-${item.color}-500/10 rounded-full blur-2xl group-hover:bg-${item.color}-500/20 transition-colors`}></div>
          
          <div class="flex items-center justify-between mb-6 relative z-10">
            <div class={`w-12 h-12 rounded-2xl bg-${item.color}-500/10 flex items-center justify-center text-${item.color}-400 ring-1 ring-${item.color}-500/20 group-hover:rotate-6 transition-transform`}>
              <Icon size={24} />
            </div>
            <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-hover border border-border-main text-[10px] font-bold text-muted uppercase tracking-tighter shadow-sm">
              <TrendingUp size={12} class="text-emerald-400" />
              Canlı Veri
            </div>
          </div>
          
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest relative z-10">{item.label}</h3>
           <div class="flex items-end gap-2 relative z-10">
            <p class="text-4xl font-extrabold mt-1 text-main tracking-tighter" id={item.id}>0</p>
            {item.id === 'stat-pending-count' && (
              <span id="stat-pending-badge" class="mb-1 text-[10px] font-bold px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">TEMİZ</span>
            )}
          </div>
        </div>
      )
    })}
	</div>

	<!-- System Connectivity Hub & Actions -->
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
		<!-- Left: Quick Actions -->
		<div class="lg:col-span-2 space-y-6">
			<div class="flex items-center justify-between px-2">
			  <h2 class="text-xl font-bold text-main flex items-center gap-2">
          Hızlı Aksiyonlar
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shadow-[0_0_8px_rgba(99,102,241,0.5)]"></span>
        </h2>
        <a href="/search" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1 group">
          Tümünü Gör <ChevronRight size={14} class="group-hover:translate-x-1 transition-transform" />
        </a>
			</div>
      
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				{quickActions.map((action) => {
          const Icon = action.icon;
          return (
            <a href={action.href} class="bg-surface border border-border-main shadow-xl p-5 rounded-[1.5rem] flex items-center justify-between hover:bg-surface-hover hover:border-primary/20 transition-all group overflow-hidden relative">
              <div class="flex items-center gap-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-surface-hover border border-border-main flex items-center justify-center text-muted group-hover:text-primary group-hover:bg-primary/10 transition-all">
                  <Icon size={20} />
                </div>
                <div>
                  <h3 class="font-bold text-main group-hover:text-indigo-400 transition-colors uppercase tracking-tight">{action.title}</h3>
                  <p class="text-[10px] text-muted mt-0.5 uppercase tracking-wide">{action.desc}</p>
                </div>
              </div>
              <ChevronRight size={18} class="text-gray-700 group-hover:text-indigo-500 group-hover:translate-x-1 transition-all relative z-10" />
            </a>
          )
        })}
			</div>

			<!-- Recent Activity Dashboard -->
			<div class="bg-surface border border-border-main shadow-2xl p-8 rounded-[2.5rem] relative overflow-hidden">
        <div class="flex items-center justify-between mb-8">
				  <h2 class="text-lg font-bold text-main uppercase tracking-tight">Son Operasyonlar</h2>
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-hover border border-border-main shadow-sm text-[10px] font-bold text-muted">
            <Activity size={12} class="text-indigo-500" />
            GERÇEK ZAMANLI AKIŞ
          </div>
        </div>

				<div class="space-y-4">
					{[1, 2, 3].map((_, i) => (
						<div class="flex items-center justify-between py-4 border-b border-border-main last:border-0 hover:bg-surface-hover rounded-2xl px-4 transition-all cursor-pointer group">
							<div class="flex items-center gap-5">
								<div class="w-12 h-12 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center group-hover:border-indigo-500/20 transition-colors shadow-sm">
									<Cpu size={20} class="text-indigo-400/60 group-hover:text-indigo-400 transition-colors" />
								</div>
								<div>
									<p class="text-sm font-bold text-main group-hover:text-indigo-300 transition-colors">Sertifika Veritabanı Güncellendi</p>
									<p class="text-[10px] text-muted uppercase tracking-widest mt-1">Sistem Otomasyonu • KV-Cache</p>
								</div>
							</div>
							<span class="text-[10px] font-bold text-muted bg-surface-hover border border-border-main px-2 py-1 rounded-md shadow-sm">{i + 1} saat önce</span>
						</div>
					))}
				</div>
			</div>
		</div>

		<!-- Right Panel: Connectivity & Information -->
		<div class="space-y-6">
      <!-- Sync Pulse Widget -->
			<div class="bg-surface border border-border-main shadow-xl p-8 rounded-[2.5rem] relative overflow-hidden group">
				<div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-600/10 rounded-full blur-3xl group-hover:bg-indigo-600/20 transition-colors animate-pulse"></div>
				<h3 class="text-sm font-bold text-indigo-400 mb-3 flex items-center gap-2 uppercase tracking-widest italic">
          <Zap size={14} fill="currentColor" />
          Pro Tip
        </h3>
				<p class="text-xs text-muted relative z-10 leading-relaxed font-medium">
					Senkronizasyon hızı için KV Cache altyapısı devrede. "SİSTEMİ SENKRONİZE ET" butonuyla tüm Google Sheets verisini CF Edge noktalarına saniyeler içinde taşıyabilirsiniz.
				</p>
			</div>

			<div class="bg-surface border border-border-main shadow-xl p-6 rounded-[2.5rem] flex flex-col gap-6">
        <div>
				  <h3 class="text-sm font-bold text-main uppercase tracking-widest mb-4 flex items-center gap-2">
            <RefreshCw size={14} class="text-indigo-400" />
            Core Status
          </h3>
				  <div class="space-y-4">
					  <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest">
						  <span class="text-muted">KV Backend</span>
						  <span class="text-emerald-400 flex items-center gap-2">
							  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse"></span> Çevrimiçi
						  </span>
					  </div>
					  <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest">
						  <span class="text-muted">GAS Gateway</span>
						  <span class="text-emerald-400 flex items-center gap-2">
							  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse"></span> Çevrimiçi
						  </span>
					  </div>
            
            <div class="mt-4 p-3 rounded-xl bg-surface-hover border border-border-main shadow-sm">
              <span class="text-[10px] text-muted block mb-1 font-bold">SON SENKRONİZASYON</span>
              <p class="text-xs font-bold text-indigo-400" id="last-sync-label">Tespit Ediliyor...</p>
            </div>
				  </div>
        </div>

				<button id="btn-bulk-sync" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-2xl shadow-[0_4px_20px_rgba(79,70,229,0.3)] hover:shadow-[0_8px_25px_rgba(79,70,229,0.5)] transition-all flex items-center justify-center gap-3 group relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
					<RefreshCw size={16} id="sync-icon" class="group-hover:rotate-180 transition-transform duration-700" />
					SİSTEMİ SENKRONİZE ET (KV)
				</button>

        <div class="flex items-center justify-center gap-2 pt-2 grayscale opacity-50">
          <ShieldCheck size={14} class="text-muted" />
          <span class="text-[9px] font-bold text-muted uppercase tracking-[0.2em]">Secured by CF Worker v5.0</span>
        </div>
			</div>
		</div>
	</div>
</DashboardLayout>

<script>
  import { $companies, $certificates, $lastSyncTime, $syncStatus } from '../lib/store';
  import { SyncManager } from '../lib/sync';
  import { api } from '../lib/api';

  // UI Handlers (DOM Elements)
  const statCompanies = document.getElementById('stat-companies');
  const statCertificates = document.getElementById('stat-certificates');
  const statPendingCount = document.getElementById('stat-pending-count');
  const statPendingBadge = document.getElementById('stat-pending-badge');
  const lastSyncLabel = document.getElementById('last-sync-label');

  // 🔥 Reactive Store Subscriptions
  $companies.subscribe(val => {
    if (statCompanies) {
      // Counter animation helper
      statCompanies.textContent = val.length.toString();
    }
  });

  $certificates.subscribe(val => {
    if (statCertificates) {
        const activeCount = val.filter(c => String(c["Gözetim"]) === "TRUE").length;
        statCertificates.textContent = activeCount.toString();
    }
    if (statPendingCount) {
        const pendingCount = val.filter(c => String(c["Gözetim"]) === "FALSE").length;
        statPendingCount.textContent = pendingCount.toString();
        
        if (statPendingBadge) {
            statPendingBadge.textContent = pendingCount > 0 ? 'KRİTİK' : 'TEMİZ';
            statPendingBadge.className = `mb-1 text-[10px] font-bold px-2 py-0.5 rounded-md border transition-colors ${
              pendingCount > 0 
                ? 'bg-rose-500/10 text-rose-400 border-rose-500/20 shadow-[0_0_8px_rgba(244,63,94,0.2)]' 
                : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
            }`;
        }
    }
  });

  $lastSyncTime.subscribe(val => {
      if (lastSyncLabel && val) {
          lastSyncLabel.textContent = new Date(val).toLocaleString('tr-TR', { 
            hour: '2-digit', 
            minute: '2-digit', 
            day: '2-digit', 
            month: 'short' 
          }).toUpperCase();
      }
  });

  // 🔄 Global Sync Logic (Interactive)
  const btnSync = document.getElementById('btn-bulk-sync') as HTMLButtonElement | null;
  
  if (btnSync) {
    const originalContent = btnSync.innerHTML;
    btnSync.addEventListener('click', async () => {
      try {
        btnSync.disabled = true;
        btnSync.innerHTML = `
          <svg class="animate-spin -ml-1 mr-3 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          AKTARILIYOR...
        `;

        const res = await api.bulkSync();
        
        if (res.success && res.stats) {
          // Success Feedback
          const msg = `🚀 BAŞARILI!\n${res.stats.companies} Firma ve ${res.stats.certRows} Sertifika kaydı CF Edge noktalarına senkronize edildi.`;
          alert(msg);
          await SyncManager.checkAndSync(); // Refresh local store from fresh KV immediately
        } else {
          alert('❌ HATA: ' + (res.error || 'Bağlantı kesildi.'));
        }
      } catch (err) {
        console.error(err);
      } finally {
        if (btnSync) {
          btnSync.disabled = false;
          btnSync.innerHTML = originalContent;
        }
      }
    });
  }

  // 🚀 Start Lifecycle
  SyncManager.init();
</script>
