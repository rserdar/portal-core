---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import {
  Building2, Award, CalendarClock, RefreshCw,
  Plus, Search, FileSpreadsheet, ChevronRight,
  TrendingUp, ShieldCheck, Activity, Zap, ClipboardList, Users
} from 'lucide-astro';
import TurkeyMap from '../components/TurkeyMap.astro';

/**
 * 🏠 Dashboard Overview (v5.2.0)
 */

const stats = [
  {
    label: "Toplam Firma", id: "stat-companies", icon: Building2,
    iconClass: "bg-indigo-500/10 text-indigo-400 ring-indigo-500/20 group-hover:rotate-6",
    glowClass: "bg-indigo-500/10 group-hover:bg-indigo-500/20"
  },
  {
    label: "Aktif Sertifika", id: "stat-certificates", icon: Award,
    iconClass: "bg-emerald-500/10 text-emerald-400 ring-emerald-500/20 group-hover:rotate-6",
    glowClass: "bg-emerald-500/10 group-hover:bg-emerald-500/20"
  },
  {
    label: "Bu Ayki Gözetimler", id: "stat-pending-count", icon: CalendarClock,
    iconClass: "bg-amber-500/10 text-amber-400 ring-amber-500/20 group-hover:rotate-6",
    glowClass: "bg-amber-500/10 group-hover:bg-amber-500/20"
  },
];

const quickActions = [
  { title: "Yeni Firma Ekle",    desc: "Müşteri portföyüne yeni kayıt ekleyin.",  href: "/company/add",  icon: Plus },
  { title: "Sertifika Sorgula",  desc: "Arşivdeki tüm belgeleri listeleyin.",      href: "/search",       icon: Search },
  { title: "Doküman Üret",       desc: "ISO doküman seti hazırlayın.",             href: "/documents/view", icon: FileSpreadsheet },
  { title: "Denetim Planla",     desc: "Yeni denetim takvimi oluşturun.",          href: "/audits/add",   icon: ClipboardList },
];
---

<DashboardLayout title="Genel Bakış">

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <!-- Top Stats Section -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    {stats.map((item) => {
      const Icon = item.icon;
      return (
        <div class="bg-surface border border-border-main shadow-xl p-6 rounded-[2rem] relative overflow-hidden group hover:scale-[1.02] transition-all duration-300">
          <div class={`absolute -right-4 -bottom-4 w-24 h-24 ${item.glowClass} rounded-full blur-2xl transition-colors`}></div>

          <div class="flex items-center justify-between mb-6 relative z-10">
            <div class={`w-12 h-12 rounded-2xl flex items-center justify-center ring-1 transition-transform ${item.iconClass}`}>
              <Icon size={24} />
            </div>
            <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface-hover border border-border-main text-[10px] font-bold text-muted uppercase tracking-tighter shadow-sm">
              <TrendingUp size={12} class="text-emerald-400" />
              Canlı Veri
            </div>
          </div>

          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest relative z-10">{item.label}</h3>
          <div class="flex items-end gap-2 relative z-10">
            <p class="text-4xl font-extrabold mt-1 text-main tracking-tighter" id={item.id} data-target="0">—</p>
            {item.id === 'stat-pending-count' && (
              <span id="stat-pending-badge" class="mb-1 text-[10px] font-bold px-2 py-0.5 rounded-md bg-surface-hover text-muted border border-border-main">...</span>
            )}
          </div>
        </div>
      )
    })}
  </div>

  <!-- System Connectivity Hub & Actions -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left: Quick Actions + Activity -->
    <div class="lg:col-span-2 space-y-6">
      <div class="flex items-center justify-between px-2">
        <h2 class="text-xl font-bold text-main flex items-center gap-2">
          Hızlı Aksiyonlar
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shadow-[0_0_8px_rgba(99,102,241,0.5)]"></span>
        </h2>
        <a href="/search" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1 group">
          Tümünü Gör <ChevronRight size={14} class="group-hover:translate-x-1 transition-transform" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {quickActions.map((action) => {
          const Icon = action.icon;
          return (
            <a href={action.href} class="bg-surface border border-border-main shadow-xl p-5 rounded-[1.5rem] flex items-center justify-between hover:bg-surface-hover hover:border-primary/20 transition-all group overflow-hidden relative">
              <div class="flex items-center gap-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-surface-hover border border-border-main flex items-center justify-center text-muted group-hover:text-primary group-hover:bg-primary/10 transition-all">
                  <Icon size={20} />
                </div>
                <div>
                  <h3 class="font-bold text-main group-hover:text-indigo-400 transition-colors uppercase tracking-tight">{action.title}</h3>
                  <p class="text-[10px] text-muted mt-0.5 uppercase tracking-wide">{action.desc}</p>
                </div>
              </div>
              <ChevronRight size={18} class="text-gray-700 group-hover:text-indigo-500 group-hover:translate-x-1 transition-all relative z-10" />
            </a>
          )
        })}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-surface border border-border-main shadow-xl p-5 rounded-[1.5rem] relative overflow-hidden group">
          <div class="absolute right-0 bottom-0 w-20 h-20 bg-cyan-500/10 blur-2xl rounded-full group-hover:bg-cyan-500/20 transition-colors"></div>
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 rounded-full bg-surface-hover border border-border-main px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-cyan-400">
              <Users size={12} />
              Danışman Havuzu
            </div>
            <div class="mt-4 flex items-center gap-4">
              <div class="relative h-24 w-24 shrink-0">
                <div
                  id="consultant-chart"
                  class="h-24 w-24 rounded-full border border-border-main shadow-inner"
                  style="background: conic-gradient(rgba(148,163,184,0.25) 0deg 360deg);"
                ></div>
              </div>
              <div class="min-w-0 flex-1">
                <div id="consultant-chart-legend" class="space-y-2"></div>
              </div>
            </div>
            <p class="mt-3 text-[11px] text-muted">Sertifika dağılımında öne çıkan danışmanların toplam payı.</p>
          </div>
        </div>

        <div class="bg-surface border border-border-main shadow-xl p-5 rounded-[1.5rem] relative overflow-hidden group">
          <div class="absolute right-0 bottom-0 w-20 h-20 bg-rose-500/10 blur-2xl rounded-full group-hover:bg-rose-500/20 transition-colors"></div>
          <div class="relative z-10">
            <div>
              <div class="inline-flex items-center gap-2 rounded-full bg-surface-hover border border-border-main px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-rose-400">
                <TrendingUp size={12} />
                Yıllara Göre Sertifika
              </div>
              <div class="mt-2 flex items-center justify-between gap-3">
                <p class="text-[11px] text-muted">Sertifika tarihine göre dağılım.</p>
                <p id="cert-year-chart-latest" class="text-[11px] font-bold tracking-tight text-main">—</p>
              </div>
            </div>
            <div class="mt-4">
              <svg id="cert-year-chart" viewBox="0 0 320 132" class="h-32 w-full overflow-visible">
                <defs>
                  <linearGradient id="cert-year-area" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(244,63,94,0.34)" />
                    <stop offset="100%" stop-color="rgba(244,63,94,0)" />
                  </linearGradient>
                </defs>
                <g id="cert-year-grid" class="text-border-main"></g>
                <path id="cert-year-area-path" fill="url(#cert-year-area)" stroke="none"></path>
                <path id="cert-year-line" fill="none" stroke="#fb7185" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
                <g id="cert-year-points"></g>
                <g id="cert-year-labels"></g>
              </svg>
            </div>
            <div class="mt-4 rounded-2xl border border-border-main bg-surface-hover/40 px-4 py-3">
              <p class="text-[10px] font-black uppercase tracking-[0.18em] text-main">Önceki Yıllar</p>
              <div id="cert-year-chart-summary" class="mt-2">
                <div class="grid grid-cols-6 gap-2 border-b border-border-main/70 pb-2 text-[10px] font-black uppercase tracking-[0.14em] text-muted">
                  <span>Yıl</span>
                  <span>Adet</span>
                  <span>Yıl</span>
                  <span>Adet</span>
                  <span>Yıl</span>
                  <span>Adet</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="space-y-6">
      <!-- Pro Tip -->
      <div class="bg-surface border border-border-main shadow-xl p-8 rounded-[2.5rem] relative overflow-hidden group">
        <div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-600/10 rounded-full blur-3xl group-hover:bg-indigo-600/20 transition-colors animate-pulse"></div>
        <h3 class="text-sm font-bold text-indigo-400 mb-3 flex items-center gap-2 uppercase tracking-widest italic">
          <Zap size={14} fill="currentColor" />
          Pro Tip
        </h3>
        <p class="text-xs text-muted relative z-10 leading-relaxed font-medium">
          KV Cache altyapısı devrede. "SİSTEMİ SENKRONİZE ET" ile tüm Google Sheets verisini CF Edge noktalarına saniyeler içinde taşıyabilirsiniz.
        </p>
      </div>

      <!-- Status + Sync -->
      <div class="bg-surface border border-border-main shadow-xl p-6 rounded-[2.5rem] flex flex-col gap-6">
        <div>
          <h3 class="text-sm font-bold text-main uppercase tracking-widest mb-4 flex items-center gap-2">
            <RefreshCw size={14} class="text-indigo-400" />
            Core Status
          </h3>
          <div class="space-y-4">
            <!-- KV Backend -->
            <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest">
              <span class="text-muted">KV Backend</span>
              <span id="status-kv" class="text-muted flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-muted opacity-40"></span> Kontrol...
              </span>
            </div>
            <!-- GAS Gateway -->
            <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest">
              <span class="text-muted">GAS Gateway</span>
              <span id="status-gas" class="text-muted flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-muted opacity-40"></span> Kontrol...
              </span>
            </div>

            <div class="mt-4 p-3 rounded-xl bg-surface-hover border border-border-main shadow-sm">
              <span class="text-[10px] text-muted block mb-1 font-bold">SON SENKRONİZASYON</span>
              <p class="text-xs font-bold text-indigo-400" id="last-sync-label">Tespit Ediliyor...</p>
            </div>
          </div>
        </div>

        <button id="btn-bulk-sync" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-2xl shadow-[0_4px_20px_rgba(79,70,229,0.3)] hover:shadow-[0_8px_25px_rgba(79,70,229,0.5)] transition-all flex items-center justify-center gap-3 group relative overflow-hidden disabled:opacity-60 disabled:cursor-not-allowed">
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          <RefreshCw size={16} id="sync-icon" class="group-hover:rotate-180 transition-transform duration-700" />
          <span id="sync-label">SİSTEMİ SENKRONİZE ET (KV)</span>
        </button>

        <div class="flex items-center justify-center gap-2 pt-2 grayscale opacity-50">
          <ShieldCheck size={14} class="text-muted" />
          <span class="text-[9px] font-bold text-muted uppercase tracking-[0.2em]">Secured by CF Worker v5.0</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Regional Distribution & Insights -->
  <div class="mt-10">
    <TurkeyMap />
  </div>

  <div class="mt-10 bg-surface border border-border-main shadow-2xl p-8 rounded-[2.5rem] relative overflow-hidden">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-lg font-bold text-main uppercase tracking-tight">Son Eklenen Firmalar</h2>
      <a href="/search" class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-hover border border-border-main shadow-sm text-[10px] font-bold text-muted hover:text-indigo-400 transition-colors">
        <Activity size={12} class="text-indigo-500" />
        TÜMÜNÜ GÖR
      </a>
    </div>

    <div id="activity-skeleton" class="space-y-4">
      {[1,2,3].map(() => (
        <div class="flex items-center gap-5 py-4 px-4 rounded-2xl animate-pulse">
          <div class="w-12 h-12 rounded-2xl bg-surface-hover flex-shrink-0"></div>
          <div class="flex-1 space-y-2">
            <div class="h-3 bg-surface-hover rounded w-2/5"></div>
            <div class="h-2 bg-surface-hover rounded w-1/4"></div>
          </div>
          <div class="h-2 bg-surface-hover rounded w-16"></div>
        </div>
      ))}
    </div>

    <div id="activity-list" class="space-y-1 hidden"></div>

    <div id="activity-empty" class="hidden flex flex-col items-center justify-center py-10 text-center gap-3">
      <div class="w-14 h-14 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center">
        <Activity size={24} class="text-muted opacity-40" />
      </div>
      <p class="text-sm font-bold text-muted">Henüz veri yok</p>
      <p class="text-[11px] text-muted opacity-60">"Sistemi Senkronize Et" butonuna basarak veriyi yükleyin.</p>
    </div>
  </div>
</DashboardLayout>

<script>
  import { $companies, $certificates, $lastSyncTime } from '../lib/store';
  import { SyncManager } from '../lib/sync';
  import { api } from '../lib/api';

  // ─── Toast System ────────────────────────���───────────────────────────────────

  function showToast(message: string, type: 'success' | 'error' | 'info' = 'info') {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const colors = {
      success: 'border-emerald-500/30 bg-emerald-500/10 text-emerald-300',
      error:   'border-rose-500/30 bg-rose-500/10 text-rose-300',
      info:    'border-indigo-500/30 bg-indigo-500/10 text-indigo-300',
    };

    const toast = document.createElement('div');
    toast.className = `pointer-events-auto flex items-center gap-3 px-5 py-4 rounded-2xl border backdrop-blur-md shadow-2xl text-sm font-bold max-w-sm translate-y-4 opacity-0 transition-all duration-300 ${colors[type]}`;
    toast.innerHTML = message;
    container.appendChild(toast);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-4', 'opacity-0');
      });
    });

    setTimeout(() => {
      toast.classList.add('translate-y-4', 'opacity-0');
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  // ─── CountUp Animation ───────────────────────────��──────────────────────────��

  function countUp(el: HTMLElement, target: number) {
    if (target === 0) { el.textContent = '0'; return; }
    const duration = 600;
    const start = performance.now();
    const from = parseInt(el.textContent || '0') || 0;

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3); // ease-out cubic
      el.textContent = Math.round(from + (target - from) * ease).toString();
      if (progress < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  function parseTrDate(value: unknown): Date | null {
    const raw = String(value ?? '').trim();
    const match = raw.match(/^(\d{2})\.(\d{2})\.(\d{4})$/);
    if (!match) return null;

    const [, dayStr, monthStr, yearStr] = match;
    const day = Number(dayStr);
    const monthIndex = Number(monthStr) - 1;
    const year = Number(yearStr);
    const date = new Date(year, monthIndex, day);

    if (
      Number.isNaN(date.getTime()) ||
      date.getFullYear() !== year ||
      date.getMonth() !== monthIndex ||
      date.getDate() !== day
    ) {
      return null;
    }

    date.setHours(0, 0, 0, 0);
    return date;
  }

  function pickValue(item: Record<string, any>, aliases: string[], fallback = ''): string {
    for (const key of aliases) {
      const value = item?.[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') {
        return String(value).trim();
      }
    }
    return fallback;
  }

  function getCurrentMonthLabel(): string {
    const now = new Date();
    const monthName = now.toLocaleDateString('tr-TR', { month: 'long' });
    if (!monthName) return 'Bu Ayki Gözetimler';
    return `${monthName.charAt(0).toUpperCase()}${monthName.slice(1)} Gözetimleri`;
  }

  function renderConsultantChart(certificates: Record<string, any>[]) {
    const chartEl = document.getElementById('consultant-chart') as HTMLElement | null;
    const legendEl = document.getElementById('consultant-chart-legend') as HTMLElement | null;

    if (!chartEl || !legendEl) return;

    const consultantCounts = new Map<string, number>();

    certificates.forEach((certificate) => {
      const consultant = pickValue(certificate, ['Danışman', 'Danisman', 'dan'], 'Atanmamış');
      const normalized = consultant || 'Atanmamış';
      consultantCounts.set(normalized, (consultantCounts.get(normalized) || 0) + 1);
    });

    const sorted = Array.from(consultantCounts.entries()).sort((a, b) => b[1] - a[1]);
    const totalCertificates = sorted.reduce((sum, [, count]) => sum + count, 0);

    if (sorted.length === 0 || totalCertificates === 0) {
      chartEl.style.background = 'conic-gradient(rgba(148,163,184,0.25) 0deg 360deg)';
      legendEl.innerHTML = `<p class="text-[11px] text-muted">Danışman verisi henüz görünmüyor.</p>`;
      return;
    }

    const palette = [
      '#22c55e',
      '#06b6d4',
      '#6366f1',
      '#f59e0b',
      '#f472b6',
    ];

    const topEntries = sorted.slice(0, 4);
    const remainingCount = sorted.slice(4).reduce((sum, [, count]) => sum + count, 0);
    const chartEntries = remainingCount > 0 ? [...topEntries, ['Diğer', remainingCount] as [string, number]] : topEntries;

    let currentAngle = 0;
    const gradientSegments = chartEntries.map(([_, count], index) => {
      const portion = count / totalCertificates;
      const start = currentAngle;
      currentAngle += portion * 360;
      return `${palette[index % palette.length]} ${start}deg ${currentAngle}deg`;
    });

    chartEl.style.background = `conic-gradient(${gradientSegments.join(', ')})`;
    legendEl.innerHTML = chartEntries.map(([name, count], index) => {
      const percentage = Math.round((count / totalCertificates) * 100);
      return `
        <div class="flex items-center justify-between gap-3 border-b border-border-main/60 pb-2 last:border-0 last:pb-0">
          <div class="min-w-0 flex items-center gap-2">
            <span class="h-2.5 w-2.5 rounded-full shrink-0" style="background:${palette[index % palette.length]}"></span>
            <span class="truncate text-[11px] font-bold text-main">${name}</span>
          </div>
          <span class="shrink-0 text-[10px] font-black uppercase tracking-[0.14em] text-muted">%${percentage}</span>
        </div>
      `;
    }).join('');
  }

  function renderYearlyCertificateChart(certificates: Record<string, any>[]) {
    const svg = document.getElementById('cert-year-chart') as SVGSVGElement | null;
    const gridEl = document.getElementById('cert-year-grid') as SVGGElement | null;
    const areaEl = document.getElementById('cert-year-area-path') as SVGPathElement | null;
    const lineEl = document.getElementById('cert-year-line') as SVGPathElement | null;
    const pointsEl = document.getElementById('cert-year-points') as SVGGElement | null;
    const labelsEl = document.getElementById('cert-year-labels') as SVGGElement | null;
    const latestEl = document.getElementById('cert-year-chart-latest') as HTMLElement | null;
    const summaryEl = document.getElementById('cert-year-chart-summary') as HTMLElement | null;

    if (!svg || !gridEl || !areaEl || !lineEl || !pointsEl || !labelsEl || !latestEl || !summaryEl) return;

    const yearlyCounts = new Map<number, number>();

    certificates.forEach((certificate) => {
      const issueDate = parseTrDate(
        pickValue(certificate, ['gst', 'GST', 'Sertifika Tarihi', 'Belge Tarihi', 'sTarihi'])
      );
      if (!issueDate) return;
      const year = issueDate.getFullYear();
      yearlyCounts.set(year, (yearlyCounts.get(year) || 0) + 1);
    });

    const sortedYears = Array.from(yearlyCounts.keys()).sort((a, b) => a - b);

    if (sortedYears.length === 0) {
      latestEl.textContent = 'Son yıl verisi görünmüyor';
      gridEl.innerHTML = '';
      areaEl.setAttribute('d', '');
      lineEl.setAttribute('d', '');
      pointsEl.innerHTML = '';
      summaryEl.innerHTML = `
        <div class="grid grid-cols-6 gap-2 border-b border-border-main/70 pb-2 text-[10px] font-black uppercase tracking-[0.14em] text-muted">
          <span>Yıl</span>
          <span>Adet</span>
          <span>Yıl</span>
          <span>Adet</span>
          <span>Yıl</span>
          <span>Adet</span>
        </div>
        <div class="px-1 py-3 text-[11px] text-muted">
          Yıllık sertifika verisi görünmüyor.
        </div>
      `;
      labelsEl.innerHTML = `<text x="160" y="68" text-anchor="middle" class="fill-muted text-[11px]">Yıllık sertifika verisi görünmüyor</text>`;
      return;
    }

    const yearsToShow = sortedYears.slice(-6);
    const series = yearsToShow.map((year) => ({ year, count: yearlyCounts.get(year) || 0 }));
    const latest = series[series.length - 1];
    latestEl.textContent = `${latest.year}'te ${latest.count} sertifika`;

    const hiddenYears = sortedYears.slice(0, -yearsToShow.length);
    const summaryYears = (hiddenYears.length > 0 ? hiddenYears : sortedYears)
      .slice(-5)
      .map((year) => ({ year, count: yearlyCounts.get(year) || 0 }))
      .reverse();

    const summaryRows = [];
    for (let index = 0; index < summaryYears.length; index += 3) {
      summaryRows.push(summaryYears.slice(index, index + 3));
    }

    summaryEl.innerHTML = `
      <div class="grid grid-cols-6 gap-2 border-b border-border-main/70 pb-2 text-[10px] font-black uppercase tracking-[0.14em] text-muted">
        <span>Yıl</span>
        <span>Adet</span>
        <span>Yıl</span>
        <span>Adet</span>
        <span>Yıl</span>
        <span>Adet</span>
      </div>
      <div class="mt-2 space-y-1.5">
      ${summaryRows.map((row) => `
        <div class="grid grid-cols-6 gap-2 px-1 py-1 text-[11px]">
          <span class="font-bold text-main">${row[0]?.year ?? '—'}</span>
          <span class="font-black tracking-tight text-rose-400">${row[0]?.count ?? '—'}</span>
          <span class="font-bold text-main">${row[1]?.year ?? '—'}</span>
          <span class="font-black tracking-tight text-rose-400">${row[1]?.count ?? '—'}</span>
          <span class="font-bold text-main">${row[2]?.year ?? '—'}</span>
          <span class="font-black tracking-tight text-rose-400">${row[2]?.count ?? '—'}</span>
        </div>
      `).join('')}
      </div>
    `;

    const width = 320;
    const height = 132;
    const left = 18;
    const right = 16;
    const top = 14;
    const bottom = 26;
    const chartWidth = width - left - right;
    const chartHeight = height - top - bottom;
    const maxCount = Math.max(...series.map((item) => item.count), 1);
    const stepX = series.length > 1 ? chartWidth / (series.length - 1) : 0;

    const points = series.map((item, index) => {
      const x = left + stepX * index;
      const y = top + chartHeight - (item.count / maxCount) * chartHeight;
      return { ...item, x, y };
    });

    gridEl.innerHTML = [0.25, 0.5, 0.75].map((ratio) => {
      const y = top + chartHeight - chartHeight * ratio;
      return `<line x1="${left}" y1="${y}" x2="${width - right}" y2="${y}" stroke="currentColor" stroke-opacity="0.16" stroke-dasharray="4 6" />`;
    }).join('');

    const linePath = points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x} ${point.y}`).join(' ');
    const areaPath = `${linePath} L ${points[points.length - 1].x} ${height - bottom} L ${points[0].x} ${height - bottom} Z`;

    lineEl.setAttribute('d', linePath);
    areaEl.setAttribute('d', areaPath);

    pointsEl.innerHTML = points.map((point) => `
      <g>
        <circle cx="${point.x}" cy="${point.y}" r="4" fill="#fb7185" />
        <circle cx="${point.x}" cy="${point.y}" r="8" fill="transparent">
          <title>${point.year}: ${point.count} sertifika</title>
        </circle>
      </g>
    `).join('');

    labelsEl.innerHTML = points.map((point) => `
      <g>
        <text x="${point.x}" y="${height - 8}" text-anchor="middle" class="fill-muted text-[10px] font-bold">${point.year}</text>
        <text x="${point.x}" y="${point.y - 10}" text-anchor="middle" class="fill-main text-[10px] font-black">${point.count}</text>
      </g>
    `).join('');
  }

  // ─── Status Check ────────────────────────────��───────────────────────────────

  async function checkStatus() {
    const kvEl  = document.getElementById('status-kv');
    const gasEl = document.getElementById('status-gas');

    const onlineHTML  = `<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse"></span> <span class="text-emerald-400">Çevrimiçi</span>`;
    const offlineHTML = `<span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span> <span class="text-rose-400">Bağlanamadı</span>`;
    const checkHTML   = `<span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> <span class="text-amber-400">Kontrol...</span>`;

    if (kvEl)  kvEl.innerHTML  = checkHTML;
    if (gasEl) gasEl.innerHTML = checkHTML;

    try {
      const res = await api.call('syncCheck');
      if (res.success) {
        // Worker responded + GAS returned data → both online
        if (kvEl)  kvEl.innerHTML  = onlineHTML;
        if (gasEl) gasEl.innerHTML = onlineHTML;
      } else {
        // Worker reached but GAS returned error
        if (kvEl)  kvEl.innerHTML  = onlineHTML;
        if (gasEl) gasEl.innerHTML = offlineHTML;
      }
    } catch {
      // Network/Worker unreachable
      if (kvEl)  kvEl.innerHTML  = offlineHTML;
      if (gasEl) gasEl.innerHTML = offlineHTML;
    }
  }

  // ─── Activity Feed ─────────────────────────────────��─────────────────────────

  function renderActivity(companies: any[]) {
    const skeleton = document.getElementById('activity-skeleton');
    const list     = document.getElementById('activity-list');
    const empty    = document.getElementById('activity-empty');

    if (!list || !skeleton || !empty) return;

    skeleton.classList.add('hidden');

    const recent = (companies as any[]).slice().reverse().slice(0, 5);

    if (recent.length === 0) {
      list.classList.add('hidden');
      empty.classList.remove('hidden');
      empty.classList.add('flex');
      return;
    }

    empty.classList.add('hidden');
    empty.classList.remove('flex');
    list.classList.remove('hidden');

    list.innerHTML = recent.map(c => {
      const firmaNo  = c['Firma No']  || c['id']   || '—';
      const nick     = c['Nick']      || c['nick']  || '—';
      const unvan    = c['Unvan']     || c['unvan'] || '—';
      const il       = c['İl']        || c['il']    || '';

      return `
        <a href="/company?id=${firmaNo}" class="flex items-center justify-between py-4 border-b border-border-main last:border-0 hover:bg-surface-hover rounded-2xl px-4 transition-all cursor-pointer group">
          <div class="flex items-center gap-5">
            <div class="w-11 h-11 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center group-hover:border-indigo-500/20 transition-colors shadow-sm flex-shrink-0">
              <span class="text-xs font-black text-indigo-400/70 group-hover:text-indigo-400 transition-colors uppercase">${String(nick).slice(0,2)}</span>
            </div>
            <div>
              <p class="text-sm font-bold text-main group-hover:text-indigo-300 transition-colors leading-snug">${unvan}</p>
              <p class="text-[10px] text-muted uppercase tracking-widest mt-0.5">${nick}${il ? ' • ' + il : ''}</p>
            </div>
          </div>
          <span class="text-[10px] font-bold text-muted bg-surface-hover border border-border-main px-2 py-1 rounded-md shadow-sm flex-shrink-0">M${firmaNo}</span>
        </a>`;
    }).join('');
  }

  // ─── Reactive Store Subscriptions ────────────────────────────────��───────────

  const statCompanies    = document.getElementById('stat-companies');
  const statCertificates = document.getElementById('stat-certificates');
  const statPendingCount = document.getElementById('stat-pending-count');
  const statPendingBadge = document.getElementById('stat-pending-badge');
  const lastSyncLabel    = document.getElementById('last-sync-label');

  const pendingStatLabel = document
    .getElementById('stat-pending-count')
    ?.closest('.relative.z-10')
    ?.previousElementSibling as HTMLElement | null;

  if (pendingStatLabel) {
    pendingStatLabel.textContent = getCurrentMonthLabel();
  }

  $companies.subscribe(val => {
    if (statCompanies) countUp(statCompanies, val.length);
    renderActivity(val as any[]);
  });

  $certificates.subscribe(val => {
    renderConsultantChart(val as Record<string, any>[]);
    renderYearlyCertificateChart(val as Record<string, any>[]);

    if (statCertificates) {
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const activeCount = val.filter(c => {
        const gst = parseTrDate(pickValue(c, ['gst', 'GST', 'Sertifika Tarihi', 'Belge Tarihi', 'sTarihi']));
        const goz = parseTrDate(pickValue(c, ['goz', 'GOZ', 'Sertifika Gözetim Tarihi', 'Gözetim Tarihi', 'sGozetimT']));
        const gozetimConf = pickValue(c, ['Gözetim Conf.', 'Gözetim', 'gozetimConfirmed'], 'FALSE').toUpperCase();

        if (!gst || !goz) return false;
        if (gozetimConf !== 'FALSE') return false;

        return today >= gst && today <= goz;
      }).length;

      countUp(statCertificates, activeCount);
    }
    if (statPendingCount) {
      const now = new Date();
      const currentMonth = now.getMonth();
      const currentYear = now.getFullYear();

      const pendingCount = val.filter(c => {
        const goz = parseTrDate(pickValue(c, ['goz', 'GOZ', 'Sertifika Gözetim Tarihi', 'Gözetim Tarihi', 'sGozetimT']));
        const gozetimConf = pickValue(c, ['Gözetim Conf.', 'Gözetim', 'gozetimConfirmed'], 'FALSE').toUpperCase();

        if (!goz) return false;
        if (gozetimConf !== 'FALSE') return false;

        return goz.getMonth() === currentMonth && goz.getFullYear() === currentYear;
      }).length;

      countUp(statPendingCount, pendingCount);

      if (statPendingBadge) {
        statPendingBadge.textContent = pendingCount > 0 ? 'BEKLİYOR' : 'TEMİZ';
        statPendingBadge.className = `mb-1 text-[10px] font-bold px-2 py-0.5 rounded-md border transition-colors ${
          pendingCount > 0
            ? 'bg-rose-500/10 text-rose-400 border-rose-500/20 shadow-[0_0_8px_rgba(244,63,94,0.2)]'
            : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
        }`;
      }
    }
  });

  $lastSyncTime.subscribe(val => {
    if (lastSyncLabel && val) {
      lastSyncLabel.textContent = new Date(Number(val)).toLocaleString('tr-TR', {
        hour: '2-digit', minute: '2-digit',
        day: '2-digit', month: 'short'
      }).toUpperCase();
    }
  });

  // ─── Sync Button ─────────────────────────────────────────────────────────────

  const btnSync   = document.getElementById('btn-bulk-sync') as HTMLButtonElement | null;
  const syncLabel = document.getElementById('sync-label');
  const syncIcon  = document.getElementById('sync-icon');

  if (btnSync) {
    btnSync.addEventListener('click', async () => {
      try {
        btnSync.disabled = true;
        if (syncLabel) syncLabel.textContent = 'AKTARILIYOR...';
        if (syncIcon)  syncIcon.classList.add('animate-spin');

        const res = await api.bulkSync();

        if (res.success && res.stats) {
          showToast(
            `✓ Senkronizasyon tamamlandı — ${res.stats.companies} firma, ${res.stats.certRows ?? res.stats.certs} sertifika CF Edge'e aktarıldı.`,
            'success'
          );
          await SyncManager.checkAndSync();
        } else {
          showToast(`✕ Senkronizasyon başarısız: ${res.error || 'Bağlantı kesildi.'}`, 'error');
        }
      } catch (err: any) {
        showToast(`✕ Beklenmeyen hata: ${err?.message || err}`, 'error');
      } finally {
        btnSync.disabled = false;
        if (syncLabel) syncLabel.textContent = 'SİSTEMİ SENKRONİZE ET (KV)';
        if (syncIcon)  syncIcon.classList.remove('animate-spin');
      }
    });
  }

  // ─── Boot ──────────────────────────────────────────────────────��─────────────

  SyncManager.init();
  checkStatus();
</script>
