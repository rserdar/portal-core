---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import {
  Building2,
  Award,
  CalendarClock,
  RefreshCw,
  Plus,
  Search,
  FileSpreadsheet,
  ChevronRight,
  TrendingUp,
  ShieldCheck,
  Activity,
  Zap,
  ClipboardList,
  Users,
  BarChart2,
} from "lucide-astro";
import TurkeyMap from "../components/TurkeyMap.astro";

/**
 * Dashboard Overview (v5.2.0)
 */

const stats = [
  {
    label: "Toplam Firma",
    id: "stat-companies",
    icon: Building2,
    iconClass:
      "bg-indigo-500/10 text-indigo-400 ring-indigo-500/20 group-hover:rotate-6",
    glowClass: "bg-indigo-500/10 group-hover:bg-indigo-500/20",
  },
  {
    label: "Aktif Sertifika",
    id: "stat-certificates",
    icon: Award,
    iconClass:
      "bg-emerald-500/10 text-emerald-400 ring-emerald-500/20 group-hover:rotate-6",
    glowClass: "bg-emerald-500/10 group-hover:bg-emerald-500/20",
  },
  {
    label: "Toplam Sertifika",
    id: "stat-certificates-total",
    icon: ShieldCheck,
    iconClass:
      "bg-blue-500/10 text-blue-400 ring-blue-500/20 group-hover:rotate-6",
    glowClass: "bg-blue-500/10 group-hover:bg-blue-500/20",
  },
  {
    label: "Daha Fazlası",
    id: "stat-pending-count",
    icon: CalendarClock,
    iconClass:
      "bg-amber-500/10 text-amber-400 ring-amber-500/20 group-hover:rotate-6",
    glowClass: "bg-amber-500/10 group-hover:bg-amber-500/20",
  },
];

const quickActions = [
  {
    title: "Yeni Firma Ekle",
    desc: "Müşteri portföyüne yeni kayıt ekleyin.",
    href: "/company/add",
    icon: Plus,
  },
  {
    title: "Sertifika Sorgula",
    desc: "Arşivdeki tüm belgeleri listeleyin.",
    href: "/search",
    icon: Search,
  },
  {
    title: "Doküman Üret",
    desc: "ISO doküman seti hazırlayın.",
    href: "/documents/view",
    icon: FileSpreadsheet,
  },
  {
    title: "Denetim Planla",
    desc: "Yeni denetim takvimi oluşturun.",
    href: "/audits/add",
    icon: ClipboardList,
  },
];
---

<DashboardLayout title="Genel Bakış">


  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-10">
    {
      stats.map((item) => {
        const Icon = item.icon;
        return (
          <div class="bg-surface border border-border-main shadow-xl p-3 sm:p-6 rounded-2xl relative overflow-hidden group md:hover:scale-[1.02] transition-all duration-300">
            <div
              class={`absolute -right-4 -bottom-4 w-24 h-24 ${item.glowClass} rounded-full blur-2xl transition-colors`}
            />

            <div class="flex items-center justify-between gap-2 mb-3 sm:mb-6 relative z-10">
              <div
                class={`w-8 h-8 sm:w-12 sm:h-12 rounded-xl sm:rounded-2xl flex items-center justify-center ring-1 transition-transform ${item.iconClass}`}
              >
                <Icon size={16} class="sm:hidden" />
                <Icon size={24} class="hidden sm:block" />
              </div>
              <div class="hidden sm:flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface-hover border border-border-main text-[9px] sm:text-[10px] font-bold text-muted uppercase tracking-tighter shadow-sm shrink-0">
                <TrendingUp size={12} class="text-emerald-400" />
                Canlı Veri
              </div>
            </div>

            <h3 class="text-[8px] sm:text-xs font-bold text-gray-500 uppercase tracking-tight sm:tracking-widest relative z-10 leading-tight">
              {item.label}
            </h3>
            <div class="flex items-end gap-1 sm:gap-2 relative z-10 flex-wrap">
              <p
                class="text-xl sm:text-4xl font-extrabold mt-1 text-main tracking-tighter"
                id={item.id}
                data-target="0"
              >
                —
              </p>
              {item.id === "stat-pending-count" && (
                <span
                  id="stat-pending-badge"
                  class="mb-1 text-[9px] sm:text-[10px] font-bold px-1.5 sm:px-2 py-0.5 rounded-md bg-surface-hover text-muted border border-border-main"
                >
                  ...
                </span>
              )}
            </div>
          </div>
        );
      })
    }
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    <div class="lg:col-span-2 space-y-6 order-last lg:order-first">
      <div class="flex items-center justify-between gap-3 px-1 sm:px-2">
        <h2
          class="text-lg sm:text-xl font-bold text-main flex items-center gap-2"
        >
          Hızlı Aksiyonlar
          <span
            class="w-1.5 h-1.5 rounded-full bg-indigo-500 shadow-[0_0_8px_rgba(99,102,241,0.5)]"
          ></span>
        </h2>
        <a
          href="/search"
          class="text-[11px] sm:text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1 group shrink-0"
        >
          Tümünü Gör <ChevronRight
            size={14}
            class="group-hover:translate-x-1 transition-transform"
          />
        </a>
      </div>

      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        {
          quickActions.map((action) => {
            const Icon = action.icon;
            return (
              <a
                href={action.href}
                class="bg-surface border border-border-main shadow-xl p-3 sm:p-5 rounded-2xl flex items-center justify-between gap-2 sm:gap-3 hover:bg-surface-hover hover:border-primary/20 transition-all group overflow-hidden relative"
              >
                <div class="flex items-center gap-2 sm:gap-4 relative z-10 min-w-0">
                  <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-surface-hover border border-border-main flex items-center justify-center text-muted group-hover:text-primary group-hover:bg-primary/10 transition-all shrink-0">
                    <Icon size={18} />
                  </div>
                  <div class="min-w-0">
                    <h3 class="text-[11px] sm:text-base font-bold text-main group-hover:text-indigo-400 transition-colors uppercase tracking-tight leading-tight">
                      {action.title}
                    </h3>
                    <p class="hidden sm:block text-[10px] text-muted mt-0.5 uppercase tracking-wide line-clamp-2">
                      {action.desc}
                    </p>
                  </div>
                </div>
                <ChevronRight
                  size={16}
                  class="hidden sm:block text-gray-700 group-hover:text-indigo-500 group-hover:translate-x-1 transition-all relative z-10 shrink-0"
                />
              </a>
            );
          })
        }
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div
          class="bg-surface border border-border-main shadow-xl p-5 rounded-2xl relative overflow-hidden group h-full"
        >
          <div
            class="absolute right-0 bottom-0 w-20 h-20 bg-cyan-500/10 blur-2xl rounded-full group-hover:bg-cyan-500/20 transition-colors"
          >
          </div>
          <div class="relative z-10 flex h-full flex-col">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-surface-hover border border-border-main px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-cyan-400"
            >
              <Users size={12} />
              Danışman Havuzu
            </div>
            <div
              class="mt-4 flex flex-1 flex-col items-start gap-4 sm:flex-row sm:items-center"
            >
              <div class="relative h-24 w-24 shrink-0">
                <div
                  id="consultant-chart"
                  class="h-24 w-24 rounded-full border border-border-main shadow-inner"
                  style="background: conic-gradient(rgba(148,163,184,0.25) 0deg 360deg);"
                >
                </div>
              </div>
              <div class="min-w-0 flex-1 w-full">
                <div id="consultant-chart-legend" class="space-y-2"></div>
              </div>
            </div>
            <p class="mt-4 text-[11px] text-muted">
              Sertifika dağılımında öne çıkan danışmanların toplam payı.
            </p>
          </div>
        </div>

        <div
          class="bg-surface border border-border-main shadow-xl p-5 rounded-2xl relative overflow-hidden group h-full"
        >
          <div
            class="absolute right-0 bottom-0 w-20 h-20 bg-rose-500/10 blur-2xl rounded-full group-hover:bg-rose-500/20 transition-colors"
          >
          </div>
          <div class="relative z-10 flex h-full flex-col">
            <div>
              <div
                class="inline-flex items-center gap-2 rounded-full bg-surface-hover border border-border-main px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-rose-400"
              >
                <TrendingUp size={12} />
                Yıllara Göre Sertifika
              </div>
              <div
                class="mt-2 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center sm:gap-3"
              >
                <p class="text-[11px] text-muted">
                  Sertifika tarihine göre dağılım.
                </p>
                <p
                  id="cert-year-chart-latest"
                  class="text-[11px] font-bold tracking-tight text-main"
                >
                  —
                </p>
              </div>
            </div>
            <div class="mt-4 flex flex-1 flex-col justify-center">
              <div class="mb-3 flex items-end justify-between gap-3">
                <div>
                  <p
                    class="text-[10px] font-black uppercase tracking-[0.16em] text-muted"
                  >
                    Toplam Sertifika
                  </p>
                  <p
                    id="cert-year-chart-total"
                    class="mt-1 text-2xl font-black tracking-tight text-main"
                  >
                    0
                  </p>
                </div>
              </div>
              <svg
                id="cert-year-chart"
                viewBox="0 0 320 132"
                class="h-28 sm:h-32 w-full overflow-visible"
              >
                <defs>
                  <linearGradient
                    id="cert-year-area"
                    x1="0"
                    y1="0"
                    x2="0"
                    y2="1"
                  >
                    <stop offset="0%" stop-color="rgba(244,63,94,0.34)"></stop>
                    <stop offset="100%" stop-color="rgba(244,63,94,0)"></stop>
                  </linearGradient>
                </defs>
                <g id="cert-year-grid" class="text-border-main"></g>
                <path
                  id="cert-year-area-path"
                  fill="url(#cert-year-area)"
                  stroke="none"></path>
                <path
                  id="cert-year-line"
                  fill="none"
                  stroke="#fb7185"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <g id="cert-year-points"></g>
                <g id="cert-year-labels"></g>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-6 order-first lg:order-last">
      <div
        class="hidden sm:block bg-surface border border-border-main shadow-xl p-6 sm:p-8 rounded-2xl relative overflow-hidden group"
      >
        <div
          class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-600/10 rounded-full blur-3xl group-hover:bg-indigo-600/20 transition-colors animate-pulse"
        >
        </div>
        <h3
          class="text-sm font-bold text-indigo-400 mb-3 flex items-center gap-2 uppercase tracking-widest italic"
        >
          <Zap size={14} fill="currentColor" />
          Pro Tip
        </h3>
        <p class="text-xs text-muted relative z-10 leading-relaxed font-medium">
          KV Cache altyapısı devrede. Bu buton sadece mevcut KV verisini
          tarayıcıyla eşitler. Sheets'ten veri çekme ve yedekleme işlemleri
          Ayarlar ekranından ayrı yönetilir.
        </p>
      </div>

      <div
        class="bg-surface border border-border-main shadow-xl p-4 sm:p-6 rounded-2xl flex flex-col gap-4 sm:gap-6"
      >
        <div>
          <h3
            class="text-sm font-bold text-main uppercase tracking-widest mb-4 flex items-center gap-2"
          >
            <RefreshCw size={14} class="text-indigo-400" />
            Core Status
          </h3>
          <div class="space-y-4">
            <div
              class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest"
            >
              <span class="text-muted">KV Backend</span>
              <span id="status-kv" class="text-muted flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-muted opacity-40"
                ></span> Kontrol...
              </span>
            </div>
            <div
              class="flex items-center justify-between text-[10px] font-bold uppercase tracking-widest"
            >
              <span class="text-muted">GAS Gateway</span>
              <span id="status-gas" class="text-muted flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-muted opacity-40"
                ></span> Kontrol...
              </span>
            </div>

            <div
              class="mt-4 p-3 rounded-xl bg-surface-hover border border-border-main shadow-sm"
            >
              <span class="text-[10px] text-muted block mb-1 font-bold"
                >SON SENKRONİZASYON</span
              >
              <p class="text-xs font-bold text-indigo-400" id="last-sync-label">
                Tespit Ediliyor...
              </p>
            </div>
          </div>
        </div>

        <button
          id="btn-bulk-sync"
          class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black rounded-2xl shadow-[0_4px_20px_rgba(79,70,229,0.3)] hover:shadow-[0_8px_25px_rgba(79,70,229,0.5)] transition-all flex items-center justify-center gap-3 group relative overflow-hidden disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <div
            class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"
          >
          </div>
          <RefreshCw
            size={16}
            id="sync-icon"
            class="group-hover:rotate-180 transition-transform duration-700"
          />
          <span id="sync-label">GÖRÜNÜMÜ YENİLE (KV CACHE)</span>
        </button>

        <button
          id="btn-rebuild-stats"
          class="w-full py-3 border border-amber-500/30 bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 text-xs font-black rounded-2xl transition-all flex items-center justify-center gap-2 group relative overflow-hidden disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-amber-300/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          <BarChart2 size={14} id="rebuild-stats-icon" class="group-hover:scale-125 transition-transform duration-300" />
          <span id="rebuild-stats-label">İSTATİSTİKLERİ YENİDEN HESAPLA</span>
        </button>

        <div
          class="flex items-center justify-center gap-2 pt-2 grayscale opacity-50"
        >
          <ShieldCheck size={14} class="text-muted" />
          <span
            class="text-[9px] font-bold text-muted uppercase tracking-[0.2em]"
            >Secured by CF Worker v5.0</span
          >
        </div>
      </div>
    </div>
  </div>

  <div class="mt-10 dashboard-deferred">
    <TurkeyMap />
  </div>

  <div
    class="mt-10 dashboard-deferred bg-surface border border-border-main shadow-2xl p-5 sm:p-8 rounded-2xl relative overflow-hidden"
  >
    <div class="flex items-center justify-between gap-3 mb-6 sm:mb-8">
      <h2
        class="text-base sm:text-lg font-bold text-main uppercase tracking-tight"
      >
        Son Eklenen Firmalar
      </h2>
      <a
        href="/search"
        class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-hover border border-border-main shadow-sm text-[10px] font-bold text-muted hover:text-indigo-400 transition-colors shrink-0"
      >
        <Activity size={12} class="text-indigo-500" />
        TÜMÜNÜ GÖR
      </a>
    </div>

    <div id="activity-skeleton" class="space-y-4">
      {
        [1, 2, 3].map(() => (
          <div class="flex items-center gap-5 py-4 px-4 rounded-2xl animate-pulse">
            <div class="w-12 h-12 rounded-2xl bg-surface-hover flex-shrink-0" />
            <div class="flex-1 space-y-2">
              <div class="h-3 bg-surface-hover rounded w-2/5" />
              <div class="h-2 bg-surface-hover rounded w-1/4" />
            </div>
            <div class="h-2 bg-surface-hover rounded w-16" />
          </div>
        ))
      }
    </div>

    <div id="activity-list" class="space-y-1 hidden"></div>

    <div
      id="activity-empty"
      class="hidden flex flex-col items-center justify-center py-10 text-center gap-3"
    >
      <div
        class="w-14 h-14 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center"
      >
        <Activity size={24} class="text-muted opacity-40" />
      </div>
      <p class="text-sm font-bold text-muted">Henüz veri yok</p>
      <p class="text-[11px] text-muted opacity-60">
        "Sistemi Senkronize Et" butonuna basarak veriyi yükleyin.
      </p>
    </div>
  </div>
</DashboardLayout>

<script>
    import { $companies, $certificates, $dashboardStats, $lastSyncTime } from "../lib/store";
    import { DB } from "../lib/db";
    import { SyncManager } from "../lib/sync";
    import { api } from "../lib/api";
    import { toast } from "../lib/toast";

    // --- Helpers ---

    function countUp(el, target) {
      if (target === 0) {
        el.textContent = "0";
        return;
      }
      const duration = 600;
      const start = performance.now();
      const from = parseInt(el.textContent || "0") || 0;

      const tick = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(from + (target - from) * ease).toString();
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    function getCurrentMonthLabel(): string {
      return "Bekleyen Gözetimler";
    }

    // --- Render Functions ---

    function renderConsultantChartFromStats(sortedList: { name: string; count: number }[]) {
      const chartEl = document.getElementById("consultant-chart");
      const legendEl = document.getElementById("consultant-chart-legend");
      if (!chartEl || !legendEl) return;

      const totalCertificates = sortedList.reduce((sum, item) => sum + item.count, 0);

      if (sortedList.length === 0 || totalCertificates === 0) {
        chartEl.style.background = "conic-gradient(rgba(148,163,184,0.25) 0deg 360deg)";
        legendEl.innerHTML = '<p class="text-[11px] text-muted">Danışman verisi henüz görünmüyor.</p>';
        return;
      }

      const palette = ["#22c55e", "#06b6d4", "#6366f1", "#f59e0b", "#f472b6"];
      const sorted = [...sortedList].sort((a,b) => b.count - a.count);
      const topEntries = sorted.slice(0, 4);
      const remainingCount = sorted.slice(4).reduce((sum, item) => sum + item.count, 0);
      const chartEntries = remainingCount > 0 ? [...topEntries, { name: "Diğer", count: remainingCount }] : topEntries;

      let currentAngle = 0;
      const gradientSegments = chartEntries.map((item, index) => {
        const portion = item.count / totalCertificates;
        const start = currentAngle;
        currentAngle += portion * 360;
        return `${palette[index % palette.length]} ${start}deg ${currentAngle}deg`;
      });

      chartEl.style.background = "conic-gradient(" + gradientSegments.join(", ") + ")";
      legendEl.innerHTML = chartEntries.map((item, index) => {
          const percentage = Math.round((item.count / totalCertificates) * 100);
          return `
          <div class="flex items-center justify-between gap-3 border-b border-border-main/60 pb-2 last:border-0 last:pb-0">
            <div class="min-w-0 flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full shrink-0" style="background:${palette[index % palette.length]}"></span>
              <span class="truncate text-[11px] font-bold text-main">${item.name}</span>
            </div>
            <span class="shrink-0 text-[10px] font-black uppercase tracking-[0.14em] text-muted">%${percentage}</span>
          </div>`;
      }).join("");
    }

    function renderYearlyChartFromStats(yearlyData: Record<string, number>) {
      const svg = document.getElementById("cert-year-chart");
      const gridEl = document.getElementById("cert-year-grid");
      const areaEl = document.getElementById("cert-year-area-path");
      const lineEl = document.getElementById("cert-year-line");
      const pointsEl = document.getElementById("cert-year-points");
      const labelsEl = document.getElementById("cert-year-labels");
      const latestEl = document.getElementById("cert-year-chart-latest");
      const totalEl = document.getElementById("cert-year-chart-total");

      if (!svg || !gridEl || !areaEl || !lineEl || !pointsEl || !labelsEl || !latestEl || !totalEl) return;

      const sortedYears = Object.keys(yearlyData).sort((a,b) => parseInt(a) - parseInt(b));
      if (sortedYears.length === 0) return;

      const yearsToShow = sortedYears.slice(-6);
      const series = yearsToShow.map(year => ({ year, count: yearlyData[year] }));
      const latest = series[series.length - 1];
      const totalCertificates = Object.values(yearlyData).reduce((sum, c) => sum + c, 0);

      latestEl.textContent = `${latest.year}'te ${latest.count} sertifika`;
      totalEl.textContent = String(totalCertificates);

      const width = 320, height = 132, left = 18, right = 16, top = 14, bottom = 26;
      const chartWidth = width - left - right;
      const chartHeight = height - top - bottom;
      const maxCount = Math.max(...series.map(item => item.count), 1);
      const stepX = series.length > 1 ? chartWidth / (series.length - 1) : 0;
      const compactViewport = window.innerWidth < 480;

      const points = series.map((item, index) => {
        const x = left + stepX * index;
        const y = top + chartHeight - (item.count / maxCount) * chartHeight;
        return { ...item, x, y };
      });

      gridEl.innerHTML = [0.25, 0.5, 0.75].map(ratio => {
          const y = top + chartHeight - chartHeight * ratio;
          return `<line x1="${left}" y1="${y}" x2="${width - right}" y2="${y}" stroke="currentColor" stroke-opacity="0.16" stroke-dasharray="4 6" />`;
      }).join("");

      const linePath = points.map((p, i) => `${i === 0 ? "M" : "L"} ${p.x} ${p.y}`).join(" ");
      lineEl.setAttribute("d", linePath);
      areaEl.setAttribute("d", `${linePath} L ${points[points.length-1].x} ${height-bottom} L ${points[0].x} ${height-bottom} Z`);

      pointsEl.innerHTML = points.map(p => `
        <g>
          <circle cx="${p.x}" cy="${p.y}" r="${compactViewport ? 3.5 : 4}" fill="#fb7185" />
          <title>${p.year}: ${p.count} sertifika</title>
        </g>`).join("");

      labelsEl.innerHTML = points.map(p => `
        <g>
          <text x="${p.x}" y="${height-8}" text-anchor="middle" class="fill-muted font-bold" style="font-size:${compactViewport ? 8 : 10}px">${p.year}</text>
          <text x="${p.x}" y="${p.y - (compactViewport ? 8 : 10)}" text-anchor="middle" class="fill-main font-black" style="font-size:${compactViewport ? 8 : 10}px">${p.count}</text>
        </g>`).join("");
    }

    async function checkStatus() {
      const kvEl = document.getElementById("status-kv");
      const gasEl = document.getElementById("status-gas");

      const onlineHTML =
        '<span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse"></span> <span class="text-emerald-400">Çevrimiçi</span>';
      const offlineHTML =
        '<span class="w-1.5 h-1.5 rounded-full bg-rose-400"></span> <span class="text-rose-400">Bağlanamadı</span>';
      const checkHTML =
        '<span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> <span class="text-amber-400">Kontrol...</span>';

      if (kvEl) kvEl.innerHTML = checkHTML;
      if (gasEl) gasEl.innerHTML = checkHTML;

      try {
        const res = await api.call("syncCheck");
        if (res.success) {
          if (kvEl) kvEl.innerHTML = onlineHTML;
          if (gasEl) gasEl.innerHTML = onlineHTML;
        } else {
          if (kvEl) kvEl.innerHTML = onlineHTML;
          if (gasEl) gasEl.innerHTML = offlineHTML;
        }
      } catch {
        if (kvEl) kvEl.innerHTML = offlineHTML;
        if (gasEl) gasEl.innerHTML = offlineHTML;
      }
    }

    function renderActivity(companies: any[]) {
      const list = document.getElementById("activity-list");
      const skeleton = document.getElementById("activity-skeleton");
      const empty = document.getElementById("activity-empty");

      if (!list || !skeleton || !empty) return;

      skeleton.classList.add("hidden");
      const recent = (companies || []).slice().reverse().slice(0, 5);

      if (recent.length === 0) {
        list.classList.add("hidden");
        empty.classList.remove("hidden");
        empty.classList.add("flex");
        return;
      }

      empty.classList.add("hidden");
      empty.classList.remove("flex");
      list.classList.remove("hidden");

      list.innerHTML = recent
        .map((c) => {
          const firmaNo = c["Firma No"] || c["id"] || "-";
          const nick =
            c["Nickname"] || c["nickname"] || c["Nick"] || c["nick"] || "-";
          const unvan = c["Unvan"] || c["unvan"] || "-";
          const il = c["city"] || c["City"] || c["Il"] || c["il"] || "";

          return `
          <a href="/company?id=${firmaNo}" class="flex items-center justify-between py-4 border-b border-border-main last:border-0 hover:bg-surface-hover rounded-2xl px-4 transition-all cursor-pointer group">
            <div class="flex items-center gap-5">
              <div class="w-11 h-11 rounded-2xl bg-surface-hover border border-border-main flex items-center justify-center group-hover:border-indigo-500/20 transition-colors shadow-sm flex-shrink-0">
                <span class="text-xs font-black text-indigo-400/70 group-hover:text-indigo-400 transition-colors uppercase">${String(nick).slice(0, 2)}</span>
              </div>
              <div>
                <p class="text-sm font-bold text-main group-hover:text-indigo-300 transition-colors leading-snug">${unvan}</p>
                <p class="text-[10px] text-muted uppercase tracking-widest mt-0.5">${nick}${il ? " • " + il : ""}</p>
              </div>
            </div>
            <span class="text-[10px] font-bold text-muted bg-surface-hover border border-border-main px-2 py-1 rounded-md shadow-sm flex-shrink-0">M${firmaNo}</span>
          </a>`;
        })
        .join("");
    }

    // --- Initializer & Memory Leak Prevention ---
    // Uygulamanın Astro View Transitions (SPA) mimarisinde patlamadan
    // her girişte çalışmasını ve çıkışta temizlenmesini sağlar.
    function initDashboard() {
      SyncManager.init();
      checkStatus();

      const statCompanies = document.getElementById("stat-companies");
      const statCertificates = document.getElementById("stat-certificates");
      const statPendingCount = document.getElementById("stat-pending-count");
      const statPendingBadge = document.getElementById("stat-pending-badge");
      const lastSyncLabel = document.getElementById("last-sync-label");
      const btnSync = document.getElementById(
        "btn-bulk-sync",
      );
      const syncLabel = document.getElementById("sync-label");
      const syncIcon = document.getElementById("sync-icon");

      const pendingStatLabel = document
        .getElementById("stat-pending-count")
        ?.closest(".relative.z-10")?.previousElementSibling;

      if (pendingStatLabel) {
        pendingStatLabel.textContent = getCurrentMonthLabel();
      }

    // Nanostore Subscriptions
    const unsubCompanies = $companies.subscribe((val) => {
      if (statCompanies) countUp(statCompanies, val.length);
      renderActivity(val);
    });

      const statCertificatesTotal = document.getElementById("stat-certificates-total");

      const unsubDashboard = $dashboardStats.subscribe((val) => {
        if (!val) return;
        const { stats, charts } = val;

        // Stats
        if (statCertificates) countUp(statCertificates, stats.activeCertificates);
        if (statCertificatesTotal) countUp(statCertificatesTotal, stats.totalCertificates);
        if (statPendingCount) countUp(statPendingCount, stats.pendingSurveillance);
      
      if (statPendingBadge) {
          const pendingCount = stats.pendingSurveillance;
          statPendingBadge.textContent = pendingCount > 0 ? "BEKLİYOR" : "TEMİZ";
          statPendingBadge.className = `mb-1 text-[10px] font-bold px-2 py-0.5 rounded-md border transition-colors ${
              pendingCount > 0
                ? "bg-rose-500/10 text-rose-400 border-rose-500/20 shadow-[0_0_8px_rgba(244,63,94,0.2)]"
                : "bg-emerald-500/10 text-emerald-400 border-emerald-500/20"
          }`;
      }

      // Charts
      if (charts.consultants) {
          const list = Object.entries(charts.consultants).map(([name, count]) => ({ name, count }));
          renderConsultantChartFromStats(list);
      }
      
      if (charts.yearly) {
          renderYearlyChartFromStats(charts.yearly);
      }
    });

    const unsubCertificates = $certificates.subscribe((val) => {
      // Legacy support if needed, but primarily handled by unsubDashboard now
    });

      const unsubLastSync = $lastSyncTime.subscribe((val) => {
        if (lastSyncLabel && val) {
          lastSyncLabel.textContent = new Date(Number(val))
            .toLocaleString("tr-TR", {
              hour: "2-digit",
              minute: "2-digit",
              day: "2-digit",
              month: "short",
            })
            .toUpperCase();
        }
      });

      // Event Listeners
      const handleSync = async () => {
        try {
          if (btnSync) btnSync.disabled = true;
          if (syncLabel) syncLabel.textContent = "AKTARILIYOR...";
          if (syncIcon) syncIcon.classList.add("animate-spin");

          // KV stats'ı tazele, direkt store + IndexedDB'yi güncelle
          const rebuildRes = await api.call("rebuildStats");
          if (rebuildRes.success && rebuildRes.data) {
            $dashboardStats.set(rebuildRes.data);
            await DB.save(DB.DASHBOARD_STATS, rebuildRes.data);
          }
          await SyncManager.checkAndSync();
          toast.success("Mevcut KV verisi tarayıcıyla yeniden eşitlendi.");
        } catch (err: any) {
          toast.error("Beklenmeyen hata: " + (err?.message || err));
        } finally {
          if (btnSync) btnSync.disabled = false;
          if (syncLabel) syncLabel.textContent = "GÖRÜNÜMÜ YENİLE (KV CACHE)";
          if (syncIcon) syncIcon.classList.remove("animate-spin");
        }
      };

      if (btnSync) btnSync.addEventListener("click", handleSync);

      // İstatistik Rebuild — çift onaylı
      const btnRebuildStats = document.getElementById("btn-rebuild-stats") as HTMLButtonElement | null;
      const rebuildStatsLabel = document.getElementById("rebuild-stats-label");
      const rebuildStatsIcon = document.getElementById("rebuild-stats-icon");

      let rebuildConfirmTimeout: ReturnType<typeof setInterval> | null = null;
      let rebuildConfirmState = false;

      const resetRebuildBtn = () => {
        rebuildConfirmState = false;
        if (rebuildConfirmTimeout) clearInterval(rebuildConfirmTimeout);
        if (rebuildStatsLabel) rebuildStatsLabel.textContent = "İSTATİSTİKLERİ YENİDEN HESAPLA";
        if (btnRebuildStats) {
          btnRebuildStats.className = btnRebuildStats.className
            .replace(/border-red-500\/50|bg-red-500\/20|text-red-400/g, "")
            .trim() + " border-amber-500/30 bg-amber-500/10 text-amber-400";
        }
      };

      const handleRebuildStats = async () => {
        if (!rebuildConfirmState) {
          rebuildConfirmState = true;
          if (btnRebuildStats) {
            btnRebuildStats.className = btnRebuildStats.className
              .replace(/border-amber-500\/30|bg-amber-500\/10|text-amber-400/g, "")
              .trim() + " border-red-500/50 bg-red-500/20 text-red-400";
          }
          let remaining = 5;
          if (rebuildStatsLabel) rebuildStatsLabel.textContent = `EMİN MİSİN? TEKRAR BAS (${remaining})`;
          const countInterval = setInterval(() => {
            remaining--;
            if (remaining <= 0) {
              clearInterval(countInterval);
              resetRebuildBtn();
            } else {
              if (rebuildStatsLabel) rebuildStatsLabel.textContent = `EMİN MİSİN? TEKRAR BAS (${remaining})`;
            }
          }, 1000);
          rebuildConfirmTimeout = countInterval;
          return;
        }

        // İkinci tıklama — çalıştır
        resetRebuildBtn();
        try {
          if (btnRebuildStats) btnRebuildStats.disabled = true;
          if (rebuildStatsLabel) rebuildStatsLabel.textContent = "HESAPLANIYOR...";
          if (rebuildStatsIcon) rebuildStatsIcon.classList.add("animate-spin");

          const res = await api.call("rebuildStats");
          if (res.success && res.data) {
            $dashboardStats.set(res.data);
            await DB.save(DB.DASHBOARD_STATS, res.data);
            toast.success("İstatistikler yeniden hesaplandı.");
          } else {
            toast.error("Hesaplama başarısız: " + (res?.error || "Bilinmeyen hata"));
          }
        } catch (err: any) {
          toast.error("Beklenmeyen hata: " + (err?.message || err));
        } finally {
          if (btnRebuildStats) btnRebuildStats.disabled = false;
          if (rebuildStatsLabel) rebuildStatsLabel.textContent = "İSTATİSTİKLERİ YENİDEN HESAPLA";
          if (rebuildStatsIcon) rebuildStatsIcon.classList.remove("animate-spin");
        }
      };

      if (btnRebuildStats) btnRebuildStats.addEventListener("click", handleRebuildStats);

      // Cleanup işlevi geri döndürülüyor
      return () => {
        unsubCompanies();
        unsubDashboard();
        unsubCertificates();
        unsubLastSync();
        if (btnSync) btnSync.removeEventListener("click", handleSync);
        if (btnRebuildStats) btnRebuildStats.removeEventListener("click", handleRebuildStats);
        if (rebuildConfirmTimeout) clearInterval(rebuildConfirmTimeout);
      };
    }

    // Astro Lifecycle bağlantıları
    let cleanupDashboard: (() => void) | undefined;

    // Sayfa yüklendiğinde abonelikleri başlat
    document.addEventListener("astro:page-load", () => {
      cleanupDashboard = initDashboard();
    });

    // Kullanıcı başka sayfaya geçerken önceki abonelikleri yok et (Memory Leak Koruması)
    document.addEventListener("astro:before-swap", () => {
      if (cleanupDashboard) cleanupDashboard();
    });
</script>
