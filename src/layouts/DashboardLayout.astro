---
/**
 * 🧱 Dashboard Layout
 * 
 * Tüm portal sayfaları için ortak yapıyı kurar.
 * Sol tarafta Sidebar, üstte Header ve ortada değişken içerik alanını yönetir.
 */

import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import { CONFIG } from '../lib/config';
import tenant from '@tenant/config';
import '../styles/index.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang={tenant.locale} data-app-name={CONFIG.APP_NAME}>
	<head>
		<meta charset="UTF-8" />
		<ClientRouter />
		<meta name="description" content={CONFIG.APP_DESCRIPTION} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Favicon -->
		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />

		<!-- PWA -->
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#6366f1" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content={CONFIG.APP_SHORT_NAME} />
		<link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" />

		<meta name="generator" content={Astro.generator} />
		<meta
			http-equiv="Permissions-Policy"
			content="identity-credentials-get=(), digital-credentials-get=(), publickey-credentials-get=(), otp-credentials=(), payment=()"
		/>
		<!-- PWA Service Worker Registration -->
		{ import.meta.env.PROD && <script src="/registerSW.js" is:inline></script> }
		<title>{title} | {CONFIG.APP_NAME}</title>
		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const resolvedDark = stored === 'light' ? false : stored === 'system' ? systemDark : true;
				document.documentElement.classList.toggle('dark', resolvedDark);
				document.documentElement.dataset.theme = stored || 'dark';
			})();
		</script>
	</head>
	<body class="antialiased overflow-x-hidden min-h-screen">
		<!-- Mesh Background -->
		<div class="bg-mesh pointer-events-none" aria-hidden="true"></div>

		<!-- Main Page Structure (No Sidebar) -->
		<div class="min-h-screen flex flex-col">
			<Header title={title} />
			
			<!-- Content Area -->
			<main class="content-area overflow-y-auto custom-scrollbar flex-1 relative">
				<div class="max-w-7xl mx-auto w-full px-4 lg:px-8 py-8 animate-fade-in">
					<slot />
				</div>

				<footer class="mt-20 py-8 border-t border-border-main text-center text-sm text-muted">
					<p>&copy; 2026 {CONFIG.APP_NAME}. {tenant.brand.footerText}</p>
				</footer>
			</main>
		</div>

		<!-- 🍞 Global Toast Container -->
		<div id="toast-container" class="fixed top-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

		<style is:global>
			#toast-container > div {
				box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}
			
			.animate-in {
				animation: animate-in 0.3s ease-out forwards;
			}
			.animate-out {
				animation: animate-out 0.3s ease-in forwards;
			}
			
			@keyframes animate-in {
				from { opacity: 0; transform: translateX(100%) scale(0.9); }
				to { opacity: 1; transform: translateX(0) scale(1); }
			}
			
			@keyframes animate-out {
				from { opacity: 1; transform: translateX(0) scale(1); }
				to { opacity: 0; transform: translateX(100%) scale(0.9); }
			}

			.slide-in-from-right-10 { transform: translateX(10%); }
			.slide-out-to-right-10 { transform: translateX(10%); }
		</style>
	</body>
</html>


