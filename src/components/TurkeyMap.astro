---
import { Building2, Award, CalendarClock, Map as MapIcon, UserRound } from 'lucide-astro';
import turkeySvg from '../assets/images/turkey.svg?raw';
---

<section id="turkey-map-dashboard" class="map-dashboard-shell bg-surface border border-border-main rounded-2xl overflow-hidden relative isolate">
  <div class="absolute inset-x-0 top-0 h-36 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.16),transparent_52%),radial-gradient(circle_at_top_right,rgba(16,185,129,0.1),transparent_36%)] pointer-events-none"></div>
  <div class="relative z-10 p-6 md:p-8 border-b border-border-main">
    <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
      <div class="space-y-2">
        <div class="inline-flex items-center gap-2 rounded-full bg-surface-hover border border-border-main px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-indigo-400">
          <MapIcon size={12} />
          Bölgesel Görünüm
        </div>
        <h2 class="text-2xl md:text-3xl font-black tracking-tight text-main">Türkiye Genelinde Firma Yoğunluğu</h2>
        <p class="max-w-3xl text-xs md:text-sm text-muted leading-relaxed">Harita firma dağılımını il bazında gösterir. Sağ panelde seçili ilin aktif sertifikaları ve bu ay yenileme bekleyen kayıtları yer alır.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 w-full xl:w-auto xl:min-w-[28rem]">
        <div class="rounded-xl border border-border-main bg-surface-hover px-4 py-4 relative overflow-hidden group/summary">
          <div class="absolute right-3 bottom-2 text-indigo-400/10 group-hover/summary:text-indigo-400/20 transition-colors"><MapIcon size={26} /></div>
          <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Aktif İl Sayısı</p>
          <p id="map-summary-cities" class="mt-2 text-2xl font-black tracking-tight text-main">0</p>
        </div>
        <button id="map-summary-top-city-btn" type="button" class="rounded-xl border border-border-main bg-surface-hover px-4 py-4 relative overflow-hidden text-left transition-all hover:border-indigo-500/40 hover:bg-surface group/summary">
          <div class="absolute right-3 bottom-2 text-indigo-400/10 group-hover/summary:text-indigo-400/20 transition-colors"><Building2 size={26} /></div>
          <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">En Yoğun İl</p>
          <p id="map-summary-top-city" class="mt-2 text-lg font-black tracking-tight text-indigo-400">—</p>
        </button>
        <div class="rounded-xl border border-border-main bg-surface-hover px-4 py-4 relative overflow-hidden group/summary">
          <div class="absolute right-3 bottom-2 text-indigo-400/10 group-hover/summary:text-indigo-400/20 transition-colors"><Award size={26} /></div>
          <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Türkiye'deki Firma Sayısı</p>
          <p id="map-summary-companies" class="mt-2 text-2xl font-black tracking-tight text-main">0</p>
        </div>
      </div>
    </div>
  </div>

  <div class="md:hidden p-5 border-b border-border-main">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div class="rounded-xl border border-border-main bg-surface-hover px-4 py-4">
        <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Aktif İl Sayısı</p>
        <p id="map-summary-cities-mobile" class="mt-2 text-2xl font-black tracking-tight text-main">0</p>
      </div>
      <button id="map-summary-top-city-btn-mobile" type="button" class="rounded-xl border border-border-main bg-surface-hover px-4 py-4 text-left transition-all hover:border-indigo-500/40 hover:bg-surface">
        <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">En Yoğun İl</p>
        <p id="map-summary-top-city-mobile" class="mt-2 text-lg font-black tracking-tight text-indigo-400">—</p>
      </button>
      <div class="rounded-xl border border-border-main bg-surface-hover px-4 py-4">
        <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Türkiye'deki Firma Sayısı</p>
        <p id="map-summary-companies-mobile" class="mt-2 text-2xl font-black tracking-tight text-main">0</p>
      </div>
    </div>

    <div class="mt-4 rounded-xl border border-border-main bg-surface-hover px-4 py-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Öne Çıkan İller</p>
          <p class="text-xs text-muted mt-1">Firma sayısına göre ilk 5 il</p>
        </div>
      </div>
      <div id="map-top-cities-mobile" class="mt-4 grid grid-cols-1 gap-2"></div>
    </div>
  </div>

  <div class="hidden md:grid grid-cols-1 xl:grid-cols-[minmax(0,1.45fr)_22rem]">
    <div class="p-5 md:p-8 border-b xl:border-b-0 xl:border-r border-border-main">
      <div class="p-0 md:p-2">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-4">
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-muted">Isı Haritası</p>
            <p class="text-sm text-main font-bold">Yoğunluğa göre tonlanan iller</p>
          </div>
          <div class="flex flex-wrap gap-2 text-[10px] font-bold uppercase tracking-[0.16em] text-muted">
            <span class="inline-flex items-center gap-2 rounded-full border border-border-main bg-surface px-3 py-1"><span class="h-2.5 w-2.5 rounded-full" style="background:rgba(165,180,252,0.75)"></span>Düşük</span>
            <span class="inline-flex items-center gap-2 rounded-full border border-border-main bg-surface px-3 py-1"><span class="h-2.5 w-2.5 rounded-full" style="background:rgba(99,102,241,0.85)"></span>Orta</span>
            <span class="inline-flex items-center gap-2 rounded-full border border-border-main bg-surface px-3 py-1"><span class="h-2.5 w-2.5 rounded-full" style="background:rgba(6,182,212,0.93)"></span>Yüksek</span>
          </div>
        </div>
        <div class="relative">
          <div id="map-tooltip" class="absolute hidden pointer-events-none z-[100] -translate-x-1/2 -translate-y-1/2 rounded-xl border border-border-main bg-surface/95 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-main shadow-2xl ring-1 ring-white/10 backdrop-blur-sm transition-opacity duration-150">İl Adı</div>
          <div id="turkey-map-wrapper" class="relative mx-auto max-w-5xl overflow-hidden aspect-[1005/490]">
            <Fragment set:html={turkeySvg} />
          </div>
        </div>

        <div class="mt-5 rounded-xl border border-border-main bg-surface-hover px-4 py-4">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Öne Çıkan İller</p>
              <p class="text-xs text-muted mt-1">Firma sayısına göre ilk 5 il</p>
            </div>
          </div>
          <div id="map-top-cities" class="mt-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-2"></div>
        </div>
      </div>
    </div>

    <aside class="p-5 md:p-8 dark:bg-[linear-gradient(180deg,rgba(15,23,42,0.55),transparent_40%)]">
      <div id="city-panel-empty" class="flex h-full min-h-[16rem] md:min-h-[22rem] flex-col items-center justify-center rounded-xl md:rounded-2xl border border-dashed border-border-main bg-surface-hover px-5 md:px-6 py-8 md:py-10 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-400 mb-5"><MapIcon size={28} /></div>
        <p class="text-lg font-black tracking-tight text-main">Bir İl Seçin</p>
        <p class="mt-2 max-w-[18rem] text-xs leading-relaxed text-muted">Haritadan herhangi bir ile tıklayarak o bölgedeki firma yoğunluğunu ve sertifika hareketlerini açabilirsin.</p>
      </div>

      <div id="city-panel-content" class="hidden space-y-5">
        <div class="rounded-xl md:rounded-2xl border border-border-main bg-surface px-4 md:px-5 py-4 md:py-5 shadow-xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.2em] text-muted">Seçili İl</p>
              <h3 id="city-details-name" class="mt-2 text-3xl font-black tracking-tight text-main">ANKARA</h3>
            </div>
            <span id="city-details-plate" class="inline-flex items-center rounded-xl bg-indigo-500 px-3 py-1 text-[11px] font-black text-white shadow-lg shadow-indigo-500/20">06</span>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3">
          <button type="button" id="city-card-companies" class="rounded-xl border border-border-main bg-surface px-4 py-4 text-left relative overflow-hidden transition-all hover:border-indigo-500/40 hover:bg-surface-hover group/card">
            <div class="absolute right-3 bottom-2 text-indigo-400/10 group-hover/card:text-indigo-400/25 transition-colors"><Building2 size={24} /></div>
            <div class="flex items-center justify-between"><p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Toplam Firma</p><Building2 size={15} class="text-indigo-400" /></div>
            <p id="city-stat-companies" class="mt-2 text-3xl font-black tracking-tight text-main">0</p>
          </button>
          <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-4 relative overflow-hidden group/card">
            <div class="absolute right-3 bottom-2 text-emerald-300/10 group-hover/card:text-emerald-300/20 transition-colors"><Award size={24} /></div>
            <div class="flex items-center justify-between"><p class="text-[10px] font-black uppercase tracking-[0.18em] text-emerald-300">Aktif Sertifika</p><Award size={15} class="text-emerald-400" /></div>
            <p id="city-stat-active-certs" class="mt-2 text-3xl font-black tracking-tight text-emerald-400">0</p>
          </div>
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-4 relative overflow-hidden group/card">
            <div class="absolute right-3 bottom-2 text-amber-300/10 group-hover/card:text-amber-300/20 transition-colors"><CalendarClock size={24} /></div>
            <div class="flex items-center justify-between"><p id="city-month-label" class="text-[10px] font-black uppercase tracking-[0.18em] text-amber-300">Bu Ay Bekleyen</p><CalendarClock size={15} class="text-amber-400" /></div>
            <p id="city-stat-pending-certs" class="mt-2 text-3xl font-black tracking-tight text-amber-400">0</p>
          </div>
          <div class="rounded-xl border border-border-main bg-surface px-4 py-4 relative overflow-hidden group/card">
            <div class="absolute right-3 bottom-2 text-cyan-400/10 group-hover/card:text-cyan-400/20 transition-colors"><UserRound size={24} /></div>
            <div class="flex items-center justify-between"><p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">Danışman Yoğunluğu</p><UserRound size={15} class="text-cyan-400" /></div>
            <p id="city-stat-consultants" class="mt-2 text-sm font-black tracking-tight text-main">—</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<style is:global>
  #turkey-map-dashboard.map-dashboard-shell {
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 10px 30px rgba(15, 23, 42, 0.08);
  }

  .dark #turkey-map-dashboard.map-dashboard-shell {
    box-shadow:
      0 1px 2px rgba(2, 6, 23, 0.35),
      0 18px 40px rgba(2, 6, 23, 0.38);
  }

  /* SVG kapsayıcı — light modda gölge olmasın, dark modda hafif */
  #turkey-map-dashboard #svg-turkey {
    width: 100%;
    height: auto;
    filter: none;
  }

  .dark #turkey-map-dashboard #svg-turkey {
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.25));
  }

  /* Boş iller — Light mod */
  #turkey-map-dashboard .turkey path {
    fill: rgba(203, 213, 225, 0.75);
    stroke: rgba(148, 163, 184, 0.55);
    stroke-width: 0.85;
    transition: fill 0.22s ease, stroke 0.22s ease, filter 0.22s ease;
    cursor: pointer;
    vector-effect: non-scaling-stroke;
  }

  /* Boş iller — Dark mod */
  .dark #turkey-map-dashboard .turkey path {
    fill: rgba(30, 41, 59, 0.82);
    stroke: rgba(71, 85, 105, 0.5);
  }

  /* Hover — transform yok, sadece glow */
  #turkey-map-dashboard .turkey path:hover,
  #turkey-map-dashboard .turkey g:focus-visible path {
    stroke: rgba(125, 211, 252, 0.9);
    stroke-width: 1.2;
    filter: drop-shadow(0 0 7px rgba(56, 189, 248, 0.45));
  }

  /* Seçili il — Light mod */
  #turkey-map-dashboard .turkey path.map-active {
    fill: rgba(16, 185, 129, 0.72);
    stroke: rgba(167, 243, 208, 0.9);
    stroke-width: 1.4;
    filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.35));
  }

  /* Seçili il — Dark mod */
  .dark #turkey-map-dashboard .turkey path.map-active {
    fill: rgba(16, 185, 129, 0.85);
    stroke: rgba(167, 243, 208, 0.95);
    filter: drop-shadow(0 0 14px rgba(16, 185, 129, 0.4));
  }

  /* Focus temizle */
  #turkey-map-dashboard .turkey g:focus,
  #turkey-map-dashboard .turkey g:focus-visible,
  #turkey-map-dashboard .turkey path:focus,
  #turkey-map-dashboard .turkey path:focus-visible { outline: none !important; }
</style>

<script>
  import { $dashboardStats } from '../lib/store';

  let cityStats = new Map();
  let selectedCityKey = '';

  const DISPLAY_NAMES = {
    'ADIYAMAN': 'Adıyaman', 'AFYONKARAHISAR': 'Afyonkarahisar', 'AGRI': 'Ağrı', 'AKSARAY': 'Aksaray', 'AMASYA': 'Amasya',
    'ANKARA': 'Ankara', 'ANTALYA': 'Antalya', 'ARDAHAN': 'Ardahan', 'ARTVIN': 'Artvin', 'AYDIN': 'Aydın',
    'BALIKESIR': 'Balıkesir', 'BARTIN': 'Bartın', 'BATMAN': 'Batman', 'BAYBURT': 'Bayburt', 'BILECIK': 'Bilecik',
    'BINGOL': 'Bingöl', 'BITLIS': 'Bitlis', 'BOLU': 'Bolu', 'BURDUR': 'Burdur', 'BURSA': 'Bursa',
    'CANAKKALE': 'Çanakkale', 'CANKIRI': 'Çankırı', 'CORUM': 'Çorum', 'DENIZLI': 'Denizli', 'DIYARBAKIR': 'Diyarbakır',
    'DUZCE': 'Düzce', 'EDIRNE': 'Edirne', 'ELAZIG': 'Elazığ', 'ERZINCAN': 'Erzincan', 'ERZURUM': 'Erzurum',
    'ESKISEHIR': 'Eskişehir', 'GAZIANTEP': 'Gaziantep', 'GIRESUN': 'Giresun', 'GUMUSHANE': 'Gümüşhane', 'HAKKARI': 'Hakkari',
    'HATAY': 'Hatay', 'IGDIR': 'Iğdır', 'ISPARTA': 'Isparta', 'ISTANBUL': 'İstanbul', 'IZMIR': 'İzmir',
    'KAHRAMANMARAS': 'Kahramanmaraş', 'KARABUK': 'Karabük', 'KARAMAN': 'Karaman', 'KARS': 'Kars', 'KASTAMONU': 'Kastamonu',
    'KAYSERI': 'Kayseri', 'KILIS': 'Kilis', 'KIRIKKALE': 'Kırıkkale', 'KIRKLARELI': 'Kırklareli', 'KIRSEHIR': 'Kırşehir',
    'KOCAELI': 'Kocaeli', 'KONYA': 'Konya', 'KUTAHYA': 'Kütahya', 'MALATYA': 'Malatya', 'MANISA': 'Manisa',
    'MARDIN': 'Mardin', 'MERSIN': 'Mersin', 'MUGLA': 'Muğla', 'MUS': 'Muş', 'NEVSEHIR': 'Nevşehir',
    'NIGDE': 'Niğde', 'ORDU': 'Ordu', 'OSMANIYE': 'Osmaniye', 'RIZE': 'Rize', 'SAKARYA': 'Sakarya',
    'SAMSUN': 'Samsun', 'SANLIURFA': 'Şanlıurfa', 'SIIRT': 'Siirt', 'SINOP': 'Sinop', 'SIRNAK': 'Şırnak',
    'SIVAS': 'Sivas', 'TEKIRDAG': 'Tekirdağ', 'TOKAT': 'Tokat', 'TRABZON': 'Trabzon', 'TUNCELI': 'Tunceli',
    'USAK': 'Uşak', 'VAN': 'Van', 'YALOVA': 'Yalova', 'YOZGAT': 'Yozgat', 'ZONGULDAK': 'Zonguldak'
  };

  function displayCityName(cityKey) {
    return DISPLAY_NAMES[cityKey] || cityKey;
  }

  function canonicalCityName(name) {
    const normalized = String(name || '').trim().toLocaleUpperCase('tr-TR')
      .replace(/İ/g, 'I').replace(/Ğ/g, 'G').replace(/Ü/g, 'U').replace(/Ş/g, 'S').replace(/Ö/g, 'O').replace(/Ç/g, 'C')
      .replace(/[^A-Z0-9 ]+/g, ' ').replace(/\s+/g, ' ').trim();
    return DISPLAY_NAMES[normalized] ? normalized : '';
  }

  function openCitySearch(cityName) {
    if (!cityName) return;
    window.location.href = `/search?q=${encodeURIComponent('@ ' + cityName)}`;
  }

  function getSortedCities() {
    return Array.from(cityStats.values()).sort((a, b) => b.companyCount - a.companyCount);
  }

  function updateSummary() {
    const sorted = getSortedCities();
    const activeCities = sorted.filter(c => c.companyCount > 0);
    const totalCompanies = sorted.reduce((sum, c) => sum + c.companyCount, 0);
    
    document.querySelectorAll('[id^="map-summary-cities"]').forEach(el => el.textContent = String(activeCities.length));
    document.querySelectorAll('p[id^="map-summary-top-city"]').forEach(el => el.textContent = sorted[0]?.name || '—');
    document.querySelectorAll('[id^="map-summary-companies"]').forEach(el => el.textContent = String(totalCompanies));
    
    document.querySelectorAll('#city-month-label').forEach(el => el.textContent = 'Bekleyen Gözetimler');
  }

  function updateTopCities() {
    const markup = getSortedCities().slice(0, 5).map((city, idx) => `
      <button type="button" class="map-top-city-btn flex items-center justify-between rounded-2xl border border-border-main bg-surface px-3 py-3 text-left transition-all hover:border-indigo-500/40 hover:bg-surface-hover" data-city-key="${city.key}">
        <div class="min-w-0">
          <p class="text-[10px] font-black uppercase tracking-[0.18em] text-muted">#${idx + 1}</p>
          <p class="mt-1 truncate text-sm font-black text-main">${city.name}</p>
        </div>
        <div class="pl-3 text-right">
          <p class="text-lg font-black tracking-tight text-indigo-400">${city.companyCount}</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Firma</p>
        </div>
      </button>
    `).join('') || '<p class="text-xs text-muted">Henüz harita verisi yok.</p>';

    ['map-top-cities', 'map-top-cities-mobile'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.innerHTML = markup;
        el.querySelectorAll('.map-top-city-btn').forEach(btn => {
          btn.onclick = () => {
            const stat = cityStats.get(btn.dataset.cityKey);
            if (stat) showCity(stat.name, stat.code);
          };
        });
      }
    });
  }

  const HEAT_COLORS = [
    'rgba(165, 180, 252, 0.60)', 'rgba(129, 140, 248, 0.72)', 'rgba(99, 102, 241, 0.82)',
    'rgba(34, 211, 238, 0.82)', 'rgba(6, 182, 212, 0.93)'
  ];

  function updateHeatmap() {
    const counts = Array.from(cityStats.values()).map(s => s.companyCount).filter(c => c > 0);
    const maxCount = counts.length > 0 ? Math.max(...counts) : 1;

    document.querySelectorAll('#turkey-map-dashboard .turkey g').forEach(group => {
      const cityKey = canonicalCityName(group.dataset.cityName);
      const stat = cityStats.get(cityKey);
      const path = group.querySelector('path');
      if (!path) return;
      if (stat) stat.code = group.dataset.cityCode || stat.code;

      if (!stat || stat.companyCount === 0) {
        path.style.fill = '';
        return;
      }

      const ratio = stat.companyCount / maxCount;
      const level = ratio > 0.8 ? 4 : ratio > 0.6 ? 3 : ratio > 0.35 ? 2 : ratio > 0.15 ? 1 : 0;
      path.style.fill = HEAT_COLORS[level];
    });
  }

  function showCity(cityName, cityCode) {
    const cityKey = canonicalCityName(cityName);
    const stat = cityStats.get(cityKey);
    if (!stat) return;
    selectedCityKey = cityKey;
    if (cityCode) stat.code = cityCode;

    document.getElementById('city-panel-empty')?.classList.add('hidden');
    document.getElementById('city-panel-content')?.classList.remove('hidden');

    document.getElementById('city-details-name').textContent = displayCityName(stat.key);
    document.getElementById('city-details-plate').textContent = stat.code || '--';
    document.getElementById('city-stat-companies').textContent = String(stat.companyCount);
    document.getElementById('city-stat-active-certs').textContent = String(stat.activeCerts);
    document.getElementById('city-stat-pending-certs').textContent = String(stat.pendingThisMonth);
    document.getElementById('city-stat-consultants').textContent = stat.consultants.length > 0 ? stat.consultants.join(', ') : 'Atanmamış';

    document.querySelectorAll('#turkey-map-dashboard .turkey path').forEach(p => p.classList.remove('map-active'));
    const activePath = document.querySelector(`#turkey-map-dashboard .turkey g[data-city-name="${cityName}"] path`);
    if (activePath) activePath.classList.add('map-active');
  }

  // Action listeners
  document.getElementById('city-card-companies')?.addEventListener('click', () => {
    const current = cityStats.get(selectedCityKey);
    if (current) openCitySearch(current.name);
  });

  ['map-summary-top-city-btn', 'map-summary-top-city-btn-mobile'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', () => {
      const top = getSortedCities()[0];
      if (top) {
        showCity(top.name, top.code);
        openCitySearch(top.name);
      }
    });
  });

  const tooltip = document.getElementById('map-tooltip');
  const mapWrapper = document.getElementById('turkey-map-wrapper');

  document.querySelectorAll('#turkey-map-dashboard .turkey g').forEach(group => {
    group.addEventListener('mouseenter', (e) => {
      if (!tooltip || !group.dataset.cityName) return;
      tooltip.textContent = group.dataset.cityName;
      tooltip.classList.remove('hidden');
      tooltip.style.opacity = '1';
    });
    group.addEventListener('mousemove', (e) => {
      if (!tooltip || !mapWrapper) return;
      const rect = mapWrapper.getBoundingClientRect();
      tooltip.style.left = `${e.clientX - rect.left}px`;
      tooltip.style.top = `${e.clientY - rect.top - 18}px`;
    });
    group.addEventListener('mouseleave', () => {
      if (tooltip) {
        tooltip.classList.add('hidden');
        tooltip.style.opacity = '0';
      }
    });
    group.addEventListener('click', () => showCity(group.dataset.cityName, group.dataset.cityCode));
  });

  const unsubDashboard = $dashboardStats.subscribe(val => {
    if (!val?.charts?.cities) return;
    const freshStats = new Map();
    Object.keys(val.charts.cities).forEach(key => {
      // Sadece bilinen il key'lerini dahil et; "BILINMIYOR" vb. geçersiz key'leri atla
      if (!DISPLAY_NAMES[key]) return;
      const data = val.charts.cities[key];
      freshStats.set(key, {
        key, name: displayCityName(key), code: '',
        companyCount: data.companyCount,
        activeCerts: data.activeCerts,
        pendingThisMonth: data.pendingSurveillance,
        consultants: data.consultants || []
      });
    });
    cityStats = freshStats;
    updateSummary();
    updateTopCities();
    updateHeatmap();
    if (!selectedCityKey) {
      const first = getSortedCities()[0];
      if (first) showCity(first.name, first.code);
    } else {
      const current = cityStats.get(selectedCityKey);
      if (current) showCity(current.name, current.code);
    }
  });

  document.addEventListener('astro:before-swap', () => unsubDashboard(), { once: true });
</script>
