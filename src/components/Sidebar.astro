---
/**
 * 🧭 Sidebar Component
 * 
 * Dashboad navigasyonunu yönetir.
 * Modern, premium bir cam efekti (glassmorphism) ve ikonlarla tasarlanmıştır.
 */

const { activePath = "/" } = Astro.props;

const navItems = [
  { label: "Dashboard", path: "/", icon: "home" },
  { label: "Firma Arama", path: "/search", icon: "search" },
  { label: "Yeni Firma Ekle", path: "/company/add", icon: "plus-circle" },
  { label: "Sertifikalar", path: "/certificates", icon: "award" },
  { label: "Denetim Takvimi", path: "/audits", icon: "calendar" },
  { label: "Doküman Yönetimi", path: "/documents/view", icon: "file-text" },
];

const icons: Record<string, any> = {
  home: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  search: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
  "plus-circle": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>`,
  award: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/><path d="M12 14c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8Z"/></svg>`,
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>`,
  "file-text": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
};
---

<aside class="w-[var(--sidebar-width)] glass-sidebar h-screen sticky top-0 left-0 p-6 flex flex-col hidden lg:flex">
  <div class="mb-10 flex items-center gap-3 px-2">
    <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold">A</div>
    <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
      Astro Portal
    </span>
  </div>

  <nav class="flex-1 space-y-2">
    {navItems.map((item) => (
      <a 
        href={item.path} 
        class:list={[
          "nav-link", 
          { "active": activePath === item.path || (item.path !== "/" && activePath.startsWith(item.path)) }
        ]}
      >
        <Fragment set:html={icons[item.icon]} />
        <span>{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="mt-auto pt-6 border-t border-white/10">
    <div class="glass p-4 rounded-xl flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-500"></div>
      <div class="flex-1 overflow-hidden">
        <p class="text-sm font-medium truncate">Serdar Yavuz</p>
        <p class="text-xs text-gray-400 truncate">Administrator</p>
      </div>
    </div>
  </div>
</aside>
