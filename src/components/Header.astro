---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import logoImage from "../assets/images/Medicert-Logo-sm.webp";
import SearchOverlay from "./SearchOverlay.astro";
import ThemeToggle from "./ThemeToggle.astro";

const user = {
  email: "info@medicert.com.tr",
  name: "Kullanıcı",
  role: "Personel",
  initials: "MC",
  picture: null
};

/**
 * 👑 Management Command Center Header (v6.8.1 - Identity Ready)
 */

const pathname = Astro.url.pathname;

const menuItems = [
  { name: "Anasayfa", href: "/", icon: "mdi:home" },
  {
    name: "Firmalar",
    href: "/search",
    icon: "mdi:office-building",
    dropdown: [
      { name: "Yeni Firma Ekle", href: "/company/add", icon: "mdi:office-building-plus" },
      { name: "Başvuru Formu", href: "/company/form", icon: "mdi:file-document-edit-outline" },
      { name: "Proforma", href: "/company/proforma", icon: "mdi:cash-multiple" },
      { name: "Sözleşme", href: "/company/contract", icon: "mdi:file-sign" },
    ]
  },
  {
    name: "Denetimler",
    href: "/audits",
    icon: "mdi:clipboard-check-outline",
    dropdown: [
      { name: "Denetim Planla", href: "/audits/add", icon: "mdi:calendar-plus" },
    ]
  },
  {
    name: "Sertifikalar",
    href: "/certificates",
    icon: "mdi:certificate-outline",
    dropdown: [
      { name: "Sertifika Ekle", href: "/certificates/add", icon: "mdi:plus-circle-outline" },
      { name: "Taslak Oluştur", href: "/certificates/draft", icon: "mdi:file-document-outline" },
    ]
  },
  {
    name: "Testler",
    href: "/tests",
    icon: "mdi:flask-outline",
    dropdown: [
      { name: "Test Ekle", href: "/tests/add", icon: "mdi:plus-circle-outline" },
    ]
  },
  {
    name: "Dokümanlar",
    href: "/documents/view",
    icon: "mdi:file-document-box-multiple-outline",
    dropdown: [
      { name: "Doküman Oluştur", href: "/documents/add", icon: "mdi:file-plus-outline" },
      { name: "PDF Çevir", href: "/documents/pdf", icon: "mdi:file-pdf-box" },
    ]
  },
];

function isPathActive(target: string) {
  if (target === "/") return pathname === "/";
  return pathname === target || pathname.startsWith(`${target}/`);
}
---

<header id="medicert-header" class="bg-header-bg/95 backdrop-blur-md border-b border-border-main fixed w-full top-0 z-50 font-sans transition-all duration-400 ease-in-out">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 xl:px-8">
    <div id="header-inner" class="grid grid-cols-[auto_1fr_auto] lg:grid-cols-[auto_1fr_auto] items-center h-[90px] transition-all duration-400 ease-in-out gap-x-6 xl:gap-x-10">

      <!-- Logo -->
      <div class="flex items-center">
        <a href="/"><Image id="header-logo" src={logoImage} alt="Medicert Portal" class="h-12 md:h-14 w-auto transition-all duration-400 ease-in-out drop-shadow-sm" loading="eager" /></a>
      </div>

      <!-- Nav — ortada, kendi doğal genişliğinde -->
      <nav class="hidden lg:flex items-stretch h-full relative z-10 justify-center">
        {menuItems.map((item) => {
          const isActive = isPathActive(item.href) || (item.dropdown && item.dropdown.some((drop) => isPathActive(drop.href)));
          return item.dropdown ? (
            <div class="relative group flex items-center h-full">
              <a href={item.href} class={`text-[12px] xl:text-[13px] font-bold uppercase tracking-tight px-4 xl:px-5 flex items-center gap-1.5 transition-all relative h-full hover:text-primary border-t-[3px] whitespace-nowrap ${isActive ? "text-primary border-primary" : "text-main border-transparent hover:border-primary"}`}>
                {item.name}
                <Icon name="mdi:chevron-down" class="h-3.5 w-3.5 opacity-50 group-hover:rotate-180 transition-transform shrink-0" />
              </a>
              <div class="absolute top-full left-1/2 -translate-x-1/2 hidden group-hover:block w-64 z-50 pt-1">
                <div class="bg-surface shadow-[0_20px_50px_rgba(0,0,0,0.4)] border border-border-main rounded-2xl p-2 overflow-hidden ring-1 ring-white/5">
                  {item.dropdown.map((drop) => (
                    <a href={drop.href} class={`flex items-center w-full px-3 py-2.5 transition-all rounded-xl group/item border-l-2 ${isPathActive(drop.href) ? "bg-primary/10 text-primary border-primary" : "text-main hover:text-primary hover:bg-primary/10 border-transparent"}`}>
                      <div class={`w-7 h-7 rounded-lg flex items-center justify-center mr-2.5 transition-colors shrink-0 ${isPathActive(drop.href) ? "bg-primary/20" : "bg-surface-hover group-hover/item:bg-primary/20"}`}>
                        <Icon name={drop.icon} class={`w-4 h-4 transition-colors ${isPathActive(drop.href) ? "text-primary" : "text-muted group-hover/item:text-primary"}`} />
                      </div>
                      <span class="text-[13px] font-bold tracking-tight truncate">{drop.name}</span>
                      {isPathActive(drop.href) && <Icon name="mdi:check" class="w-4 h-4 ml-auto shrink-0 text-primary" />}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class={`text-[12px] xl:text-[13px] font-bold uppercase tracking-tight px-4 xl:px-5 flex items-center transition-all relative h-full hover:text-primary border-t-[3px] whitespace-nowrap ${isActive ? "text-primary border-primary" : "text-main border-transparent hover:border-primary"}`}>
              {item.name}
            </a>
          );
        })}
      </nav>

      <!-- Sağ panel — flex-1 + justify-end ile nav'ı dengeler -->
      <div class="flex-1 flex items-center justify-end gap-1">
        <!-- Desktop aksiyonları -->
        <div class="hidden lg:flex items-center gap-1 h-full text-main">
          <button id="search-open-btn" class="p-2.5 rounded-xl text-muted hover:text-primary hover:bg-surface transition-all" title="Arama (Ctrl+K)">
            <Icon name="mdi:magnify" class="w-5 h-5" />
          </button>
          <button class="p-2.5 rounded-xl text-muted hover:text-primary hover:bg-surface transition-all relative">
            <Icon name="mdi:bell-outline" class="w-5 h-5" />
            <span class="absolute top-2 right-2 flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
            </span>
          </button>
          <div class="flex items-center"><ThemeToggle /></div>
          <a href="/settings" class="p-2.5 rounded-xl text-muted hover:text-primary hover:bg-surface transition-all" title="Ayarlar">
            <Icon name="mdi:cog-outline" class="w-5 h-5" />
          </a>
          <div class="w-px h-7 bg-border-main mx-1.5"></div>
          <div
            id="header-user"
            class="flex items-center gap-2.5 pl-1 group cursor-pointer"
            title={user.email}
            data-user-name={user.name}
            data-user-email={user.email}
            data-user-role={user.role}
            data-user-initials={user.initials}
            data-user-picture={user.picture || ""}
          >
            <div class="flex flex-col items-end">
              <span id="header-user-name" class="text-[12px] font-black group-hover:text-primary transition-colors uppercase line-clamp-1 max-w-[100px] text-right">{user.name}</span>
              <span id="header-user-role" class="text-[10px] font-bold text-muted tracking-widest uppercase">{user.role}</span>
            </div>
            <div class="relative shrink-0">
              <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-primary to-primary-hover p-[2px]">
                <div id="header-user-avatar" class="w-full h-full rounded-full bg-surface flex items-center justify-center overflow-hidden border-2 border-transparent shadow-inner">
                  {user.picture && (
                    <img
                      id="header-user-picture"
                      src={user.picture}
                      alt={user.name}
                      class="w-full h-full object-cover"
                      referrerpolicy="no-referrer"
                    />
                  )}
                  {!user.picture && (
                    <img
                      id="header-user-picture"
                      class="w-full h-full object-cover hidden"
                      referrerpolicy="no-referrer"
                      alt=""
                    />
                  )}
                  <span id="header-user-initials" class:list={["text-xs font-black text-primary", user.picture && "hidden"]}>{user.initials}</span>
                </div>
              </div>
              <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-header-bg rounded-full"></div>
            </div>
          </div>
        </div>

        <!-- Mobil butonlar -->
        <div class="lg:hidden flex items-center gap-2">
          <button data-search-open class="p-2.5 bg-surface border border-border-main shadow-sm rounded-xl text-muted hover:text-primary">
            <Icon name="mdi:magnify" class="h-5 w-5" />
          </button>
          <button id="mobile-menu-button" class="p-2.5 bg-surface border border-border-main shadow-sm rounded-xl text-muted">
            <Icon name="mdi:menu" class="h-6 w-6" id="menu-icon-open" />
            <Icon name="mdi:close" class="hidden h-6 w-6" id="menu-icon-close" />
          </button>
        </div>
      </div>

    </div>
  </div>
</header>
<!-- Mobil Menü -->
<div id="mobile-menu" class="hidden lg:hidden fixed inset-0 z-[80] bg-[var(--bg-color)] flex flex-col overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-[90px] border-b border-border-main bg-header-bg/95 backdrop-blur-md"></div>
  <button
    id="mobile-menu-close"
    type="button"
    class="lg:hidden absolute top-[23px] right-4 z-[81] p-2.5 bg-surface border border-border-main shadow-sm rounded-xl text-muted hover:text-primary"
    aria-label="Menüyü kapat"
  >
    <Icon name="mdi:close" class="h-6 w-6" />
  </button>
  <div class="relative flex-1 overflow-y-auto px-4 pt-[90px] pb-6 space-y-1">
    {menuItems.map((item) => (
      <div class="flex flex-col">
        <a href={item.href} class={`flex items-center px-4 py-3 text-sm font-bold rounded-xl uppercase tracking-tight transition-colors ${isPathActive(item.href) ? "bg-primary/10 text-primary" : "text-main hover:bg-surface"}`}>
          <Icon name={item.icon} class="w-5 h-5 mr-3 opacity-70" />
          {item.name}
        </a>
        {item.dropdown && (
          <div class="pl-12 space-y-1 pb-2">
            {item.dropdown.map((drop) => (
              <a href={drop.href} class={`flex items-center px-4 py-2 text-xs font-semibold uppercase transition-colors ${isPathActive(drop.href) ? "text-primary" : "text-muted hover:text-primary"}`}>
                {drop.name}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
  <div class="border-t border-border-main bg-[var(--surface-color)] px-4 py-3 shadow-[0_-10px_30px_rgba(0,0,0,0.18)]">
    <div class="flex items-center justify-between gap-3">
      <div
        id="header-user-mobile"
        class="flex min-w-0 items-center gap-3"
        title={user.email}
        data-user-name={user.name}
        data-user-email={user.email}
        data-user-role={user.role}
        data-user-initials={user.initials}
        data-user-picture={user.picture || ""}
      >
        <div class="relative shrink-0">
          <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-primary to-primary-hover p-[2px]">
            <div class="w-full h-full rounded-full bg-surface flex items-center justify-center overflow-hidden border-2 border-transparent shadow-inner">
              {user.picture && (
                <img
                  id="header-user-picture-mobile"
                  src={user.picture}
                  alt={user.name}
                  class="w-full h-full object-cover"
                  referrerpolicy="no-referrer"
                />
              )}
              {!user.picture && (
                <img
                  id="header-user-picture-mobile"
                  class="w-full h-full object-cover hidden"
                  referrerpolicy="no-referrer"
                  alt=""
                />
              )}
              <span id="header-user-initials-mobile" class:list={["text-xs font-black text-primary", user.picture && "hidden"]}>{user.initials}</span>
            </div>
          </div>
        </div>
        <div class="min-w-0">
          <p id="header-user-name-mobile" class="truncate text-xs font-black uppercase tracking-tight text-main">{user.name}</p>
          <p id="header-user-role-mobile" class="truncate text-[10px] font-bold uppercase tracking-[0.16em] text-muted">{user.role}</p>
        </div>
      </div>
      <div class="shrink-0 rounded-xl border border-border-main bg-surface-hover px-2 py-1">
        <ThemeToggle direction="up" />
      </div>
    </div>
  </div>
</div>

<SearchOverlay />

<script>
  const HEADER_IDENTITY_CACHE_KEY = 'medicert.header.identity.v1';

  interface HeaderIdentity {
    name?: string;
    email?: string;
    picture?: string;
    initials?: string;
    role?: string;
  }

  function computeInitials(name: string): string {
    return String(name || '')
      .trim()
      .split(/\s+/)
      .filter(Boolean)
      .map((part) => part[0])
      .join('')
      .toUpperCase()
      .slice(0, 2) || 'MC';
  }

  function roleFromEmail(email: string): string {
    return email === 'r.serdar@gmail.com' ? 'Admin' : 'Personel';
  }

  function updateHeaderIdentity(identity: HeaderIdentity) {
    const desktopWrapper = document.getElementById('header-user');
    const email = identity.email || desktopWrapper?.dataset.userEmail || 'info@medicert.com.tr';
    const name = identity.name || desktopWrapper?.dataset.userName || 'Kullanıcı';
    const role = identity.role || roleFromEmail(email);
    const picture = identity.picture || '';
    const initials = identity.initials || computeInitials(name);
    const targets = [
      {
        wrapper: document.getElementById('header-user'),
        nameEl: document.getElementById('header-user-name'),
        roleEl: document.getElementById('header-user-role'),
        pictureEl: document.getElementById('header-user-picture'),
        initialsEl: document.getElementById('header-user-initials'),
      },
      {
        wrapper: document.getElementById('header-user-mobile'),
        nameEl: document.getElementById('header-user-name-mobile'),
        roleEl: document.getElementById('header-user-role-mobile'),
        pictureEl: document.getElementById('header-user-picture-mobile'),
        initialsEl: document.getElementById('header-user-initials-mobile'),
      }
    ];

    targets.forEach((target) => {
      const { wrapper, nameEl, roleEl, pictureEl, initialsEl } = target;
      if (!wrapper || !nameEl || !roleEl || !pictureEl || !initialsEl) return;

      wrapper.title = email;
      wrapper.dataset.userEmail = email;
      wrapper.dataset.userName = name;
      wrapper.dataset.userRole = role;
      wrapper.dataset.userInitials = initials;
      wrapper.dataset.userPicture = picture;

      nameEl.textContent = name;
      roleEl.textContent = role;
      initialsEl.textContent = initials;

      const imgEl = pictureEl as HTMLImageElement;
      if (picture) {
        imgEl.src = picture;
        imgEl.alt = name;
        imgEl.classList.remove('hidden');
        initialsEl.classList.add('hidden');
      } else {
        imgEl.removeAttribute('src');
        imgEl.classList.add('hidden');
        initialsEl.classList.remove('hidden');
      }
    });
  }

  async function hydrateAccessIdentity() {
    try {
      const cached = sessionStorage.getItem(HEADER_IDENTITY_CACHE_KEY);
      if (cached) {
        const parsed = JSON.parse(cached);
        if (parsed && typeof parsed === 'object') {
          updateHeaderIdentity(parsed);
          return;
        }
      }
    } catch {}

    try {
      const response = await fetch('/cdn-cgi/access/get-identity', {
        credentials: 'include',
        redirect: 'error',
        headers: { Accept: 'application/json' },
      });

      if (!response.ok) return;

      const payload = await response.json().catch(() => null);
      if (!payload || typeof payload !== 'object') return;

      const oidc = typeof payload.oidc_fields === 'object' && payload.oidc_fields ? payload.oidc_fields : {};

      const name =
        payload.name ||
        oidc.name ||
        oidc.given_name ||
        payload.user_name ||
        payload.nickname ||
        payload.email ||
        oidc.email ||
        'Kullanıcı';

      const email =
        payload.email ||
        oidc.email ||
        payload.user_email ||
        '';

      const picture =
        payload.picture ||
        oidc.picture ||
        payload.avatar ||
        payload.avatar_url ||
        payload.image ||
        payload.photo ||
        '';

      const identity = {
        name,
        email,
        picture,
        initials: computeInitials(name),
        role: roleFromEmail(email),
      };

      updateHeaderIdentity(identity);
      sessionStorage.setItem(HEADER_IDENTITY_CACHE_KEY, JSON.stringify(identity));
    } catch (error) {
      console.warn('[Header] Access identity could not be loaded:', error);
    }
  }

  function initHeader() {
    const header = document.getElementById("medicert-header") as HTMLElement | null;
    const headerInner = document.getElementById("header-inner") as HTMLElement | null;
    const mobileBtn = document.getElementById("mobile-menu-button") as HTMLButtonElement | null;
    const mobileCloseBtn = document.getElementById("mobile-menu-close") as HTMLButtonElement | null;
    const mobileMenu = document.getElementById("mobile-menu") as HTMLElement | null;
    const iconOpen = document.getElementById("menu-icon-open") as HTMLElement | null;
    const iconClose = document.getElementById("menu-icon-close") as HTMLElement | null;
    let isCompact = false;
    let scrollRaf: number | null = null;

    const previousController = (window as any).__medicertHeaderController as AbortController | undefined;
    previousController?.abort();
    const controller = new AbortController();
    const { signal } = controller;
    (window as any).__medicertHeaderController = controller;

    const applyHeaderState = () => {
      if (!header || !headerInner) return;
      const shouldCompact = window.scrollY > 15;
      if (isCompact === shouldCompact) return;
      isCompact = shouldCompact;
      if (shouldCompact) {
        header.classList.add("shadow-xl");
        headerInner.classList.replace("h-[90px]", "h-[70px]");
      } else {
        header.classList.remove("shadow-xl");
        headerInner.classList.replace("h-[70px]", "h-[90px]");
      }
    };

    const handleScroll = () => {
      if (scrollRaf !== null) return;
      scrollRaf = window.requestAnimationFrame(() => {
        scrollRaf = null;
        applyHeaderState();
      });
    };

    const onMobileToggle = () => {
      if (!mobileMenu || !iconOpen || !iconClose) return;
      mobileMenu.classList.toggle("hidden");
      iconOpen.classList.toggle("hidden");
      iconClose.classList.toggle("hidden");
      document.body.classList.toggle("overflow-hidden");
    };

    if (mobileBtn) {
      mobileBtn.addEventListener("click", onMobileToggle, { signal });
    }
    if (mobileCloseBtn) {
      mobileCloseBtn.addEventListener("click", onMobileToggle, { signal });
    }

    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (mobileMenu?.classList.contains('hidden')) return;
        mobileMenu.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }, { signal });
    });

    window.addEventListener("scroll", handleScroll, { passive: true, signal });
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && mobileMenu && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }
    }, { signal });

    applyHeaderState();
    hydrateAccessIdentity();
  }

  document.addEventListener("astro:page-load", initHeader);
  initHeader();
</script>
