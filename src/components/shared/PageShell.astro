---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { ArrowLeft } from 'lucide-astro';
import {
  OPERATION_DEFINITIONS,
  type OperationPageKey,
} from '../../features/definitions';

interface Props {
  pageKey: OperationPageKey;
  title: string;
  description: string;
}

const { pageKey, title, description } = Astro.props;
---

<DashboardLayout title={title}>
  <div class="max-w-5xl mx-auto pb-24 space-y-6">
    <div class="flex items-center gap-3">
      <a href="/company" id="op-back-link" class="flex items-center gap-2 text-xs font-bold text-muted hover:text-primary transition-colors group">
        <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
        Firma Profili
      </a>
      <span class="text-border-main">/</span>
      <span class="text-xs font-bold text-muted" id="op-breadcrumb-label">{title}</span>
    </div>

    <section class="bg-surface border border-border-main shadow-xl rounded-[2rem]">
      <div id="op-skeleton" class="p-6 sm:p-8 animate-pulse space-y-4">
        <div class="h-3 w-24 rounded bg-surface-hover"></div>
        <div class="h-8 w-64 rounded bg-surface-hover"></div>
        <div class="h-20 rounded-2xl bg-surface-hover"></div>
      </div>

      <div id="op-select" class="hidden p-6 sm:p-8">
        <slot name="select" />
      </div>

      <div id="op-shell" class="hidden">
        <div class="p-6 sm:p-8 border-b border-border-main space-y-4">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-indigo-500/20 bg-indigo-500/10 text-indigo-400" id="op-company-id">M0</span>
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-border-main bg-surface-hover text-muted" id="op-company-nick">Firma</span>
            <span class="text-[10px] font-black uppercase tracking-[0.24em] px-2.5 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-400" id="op-company-dan">Danışman</span>
          </div>

          <div class="space-y-2">
            <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-main" id="op-company-unvan">Firma yükleniyor...</h1>
            <p class="text-sm leading-relaxed text-muted max-w-3xl">{description}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1">Adres</p>
              <p class="text-sm font-semibold text-main leading-relaxed" id="op-company-address">—</p>
            </div>
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1">Kapsam</p>
              <p class="text-sm font-semibold text-main leading-relaxed line-clamp-4" id="op-company-kapsam">—</p>
            </div>
            <div class="rounded-2xl border border-border-main bg-surface-hover p-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-muted mb-1">Operasyon Özeti</p>
              <p class="text-sm font-semibold text-main leading-relaxed" id="op-company-stats">—</p>
            </div>
          </div>
        </div>

        <div class="px-6 sm:px-8 py-4 border-b border-border-main bg-surface-hover/40">
          <div class="flex flex-wrap gap-2">
            {OPERATION_DEFINITIONS.map((definition) => {
              const active = definition.key === pageKey;
              return (
                <a
                  href={definition.href}
                  data-op-link={definition.key}
                  class:list={[
                    'inline-flex items-center gap-2 rounded-xl px-3 py-2 text-[11px] font-black uppercase tracking-widest transition-colors',
                    active
                      ? 'border border-indigo-500/30 bg-indigo-500/10 text-indigo-300'
                      : 'border border-border-main bg-surface text-main hover:bg-surface-hover',
                  ]}
                >
                  {definition.title}
                </a>
              );
            })}
          </div>
        </div>

        <div class="p-6 sm:p-8">
          <slot />
        </div>
      </div>

      <div id="op-error" class="hidden p-8">
        <p class="text-sm font-bold text-rose-400">Firma bilgileri yüklenemedi.</p>
      </div>
    </section>
  </div>
</DashboardLayout>
