---
import { Icon } from "astro-icon/components";

/**
 * 🔍 Search Overlay - Pure Tailwind Edition
 * Firma odakli, genis komut paleti deneyimi.
 */
---

<dialog id="search-dialog" aria-label="Arama" class="hidden fixed inset-0 w-full h-full m-0 p-0 max-w-none max-h-none bg-transparent border-none items-start justify-center overflow-hidden pt-[5vh] sm:pt-[10vh] outline-none z-[9999] open:flex backdrop:bg-black/55 backdrop:backdrop-blur-sm">
  <div id="search-backdrop" class="absolute inset-0 cursor-default" aria-hidden="true"></div>

  <div class="search-panel bg-surface border border-border-main shadow-[0_30px_70px_rgba(0,0,0,0.6)] relative w-[min(1040px,96vw)] overflow-hidden flex flex-col max-h-[86vh] rounded-2xl transition-all" role="search">
    <div class="h-1 bg-gradient-to-r from-primary/50 via-primary to-primary/50 opacity-50" aria-hidden="true"></div>

    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-5">
      <Icon name="mdi:magnify" class="w-6 h-6 sm:w-7 sm:h-7 text-primary/60 flex-shrink-0" aria-hidden="true" />
      <input
        id="search-input"
        type="search"
        placeholder="Firma adı, no veya şehir ara..."
        autocomplete="off"
        spellcheck="false"
        class="flex-1 bg-transparent border-none outline-none text-xl sm:text-2xl font-bold text-main placeholder:text-muted/40 placeholder:font-medium tracking-tight"
        aria-autocomplete="list"
        aria-controls="search-hits"
      />
      <button id="search-close" type="button" aria-label="Kapat" class="p-2 rounded-xl hover:bg-surface-hover text-muted hover:text-primary transition-all active:scale-95">
        <Icon name="mdi:close" class="w-6 h-6" />
      </button>
    </div>

    <div class="h-px bg-border-main mx-6 opacity-50"></div>

    <div id="search-body" class="flex-1 overflow-y-auto overflow-x-hidden p-3 min-h-[180px] sm:min-h-[350px] [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
      <!-- Başlangıç Durumu -->
      <div id="search-initial" class="flex flex-col items-center justify-center gap-3 py-20 text-center animate-fade-in">
        <div class="w-16 h-16 rounded-3xl bg-primary/5 flex items-center justify-center mb-2">
          <Icon name="mdi:magnify-plus-outline" class="w-8 h-8 text-primary/40" />
        </div>
        <h3 class="text-lg font-bold text-main">Akıllı Firma Araması</h3>
        <p class="text-sm text-muted max-w-xs mx-auto">Tüm veri setinde saniyeler içinde arama yapmak için yazmaya başlayın.</p>
      </div>

      <!-- Yükleniyor Durumu -->
      <div id="search-loading" class="hidden flex flex-col items-center justify-center gap-4 py-20 animate-fade-in">
        <div class="w-10 h-10 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
        <p class="text-xs font-bold text-muted uppercase tracking-widest">Veriler Senkronize Ediliyor...</p>
      </div>

      <!-- Sonuç Listesi -->
      <ul id="search-hits" class="hidden flex flex-col gap-2 list-none m-0 p-0" role="listbox"></ul>

      <!-- Sonuç Bulunamadı -->
      <div id="search-no-results" class="hidden flex flex-col items-center justify-center gap-3 py-20 text-center animate-fade-in">
        <div class="w-16 h-16 rounded-3xl bg-amber-500/5 flex items-center justify-center mb-2">
          <Icon name="mdi:magnify-remove-outline" class="w-8 h-8 text-amber-500/40" />
        </div>
        <h3 class="text-lg font-bold text-main">Eşleşme Bulunamadı</h3>
        <p class="text-sm text-muted">Farklı bir anahtar kelime veya numara denemeyi seçin.</p>
      </div>
    </div>

    <div class="hidden sm:flex items-center gap-5 px-6 py-3.5 bg-surface/30 border-t border-border-main text-[11px] font-bold text-muted uppercase tracking-wider">
      <div class="flex items-center gap-2">
        <kbd class="px-1.5 py-0.5 rounded-md bg-surface border border-border-main text-main font-sans shadow-sm">↑</kbd>
        <kbd class="px-1.5 py-0.5 rounded-md bg-surface border border-border-main text-main font-sans shadow-sm">↓</kbd>
        <span>Seç</span>
      </div>
      <div class="flex items-center gap-2">
        <kbd class="px-1.5 py-0.5 rounded-md bg-surface border border-border-main text-main font-sans shadow-sm">Enter</kbd>
        <span>Git</span>
      </div>
      <div class="flex items-center gap-2">
        <kbd class="px-1.5 py-0.5 rounded-md bg-surface border border-border-main text-main font-sans shadow-sm">Esc</kbd>
        <span>Kapat</span>
      </div>
      <div class="ml-auto hidden sm:flex items-center gap-2 opacity-60">
        <span>CTRL + K</span>
      </div>
    </div>
  </div>
</dialog>

<script>
  import { $companies } from "../lib/store";
  import { SyncManager } from "../lib/sync";

  // Elements
  let dialog: HTMLDialogElement | null, 
      input: HTMLInputElement | null, 
      hitsEl: HTMLElement | null, 
      initialEl: HTMLElement | null, 
      noResultsEl: HTMLElement | null, 
      loadingEl: HTMLElement | null, 
      closeBtn: HTMLButtonElement | null, 
      backdropEl: HTMLElement | null;

  let debounceTimer: number | null = null;
  let companies: any[] = [];
  let renderedResults: any[] = [];
  let activeIndex = -1;

  // Search Logic
  function normalizeText(value: string): string {
    if (!value) return "";
    return value.toString()
      .toLocaleLowerCase("tr-TR")
      .replace(/ı/g, "i")
      .replace(/ğ/g, "g")
      .replace(/ü/g, "u")
      .replace(/ş/g, "s")
      .replace(/ö/g, "o")
      .replace(/ç/g, "c")
      .trim();
  }

  function pickField(company: any, keys: string[], fallback = ""): string {
    for (const key of keys) {
      if (company?.[key] !== undefined && company?.[key] !== null && String(company[key]).trim() !== "") {
        return String(company[key]).trim();
      }
    }
    return fallback;
  }

  function buildCompanyModel(company: any) {
    const idValue = pickField(company, ["id", "ID", "firmaNo", "firma_no", "Firma No", "no"], "");
    const fullName = pickField(company, ["unvan", "Unvan", "UNVAN", "firmaUnvan", "firma_unvan"], "Bilinmeyen Firma");
    const nicknameRaw = pickField(company, ["nickname", "nickName", "nick", "kisaAd", "Firma Adı", "firmaAdi"], "");
    const city = pickField(company, ["city", "City", "il", "İl", "sehir", "şehir"], "Şehir Bilgisi Yok");
    
    let nickname = nicknameRaw;
    if (!nickname) {
      const words = fullName.split(/\s+/).filter(Boolean);
      nickname = words.slice(0, 2).join(" ").toUpperCase();
    }
    
    return { idValue, fullName, nickname, city };
  }

  function filterCompanies(query: string) {
    const normalizedQuery = normalizeText(query);
    if (!normalizedQuery) return [];
    const hasAtOperator = normalizedQuery.includes("@");
    const [namePartRaw, cityPartRaw] = hasAtOperator
      ? normalizedQuery.split("@").map((s) => s.trim())
      : [normalizedQuery, ""];
    const namePart = namePartRaw || "";
    const cityPart = cityPartRaw || "";
    const queryTokens = hasAtOperator
      ? namePart.split(/\s+/).filter(Boolean)
      : normalizedQuery.split(/\s+/).filter(Boolean);

    const scored = companies.map((company) => {
      const model = buildCompanyModel(company);
      const searchStr = normalizeText(`${model.nickname} ${model.fullName} ${model.city} ${model.idValue}`);

      if (hasAtOperator) {
        const cityNorm = normalizeText(model.city);
        const nameMatch = queryTokens.length ? queryTokens.every((token) => searchStr.includes(token)) : true;
        const cityMatch = cityPart ? cityNorm.includes(cityPart) : true;
        if (!(nameMatch && cityMatch)) return null;
      } else {
        if (!queryTokens.every(token => searchStr.includes(token))) return null;
      }

      let score = 0;
      const nNick = normalizeText(model.nickname);
      const nFull = normalizeText(model.fullName);
      const primaryQuery = hasAtOperator ? namePart : normalizedQuery;
      
      if (primaryQuery) {
        if (nNick.startsWith(primaryQuery)) score += 100;
        else if (nNick.includes(primaryQuery)) score += 80;
        if (nFull.startsWith(primaryQuery)) score += 70;
        if (String(model.idValue).includes(primaryQuery)) score += 50;
      }
      if (hasAtOperator && cityPart && normalizeText(model.city).startsWith(cityPart)) score += 40;

      return { model, score };
    }).filter((item): item is { model: any, score: number } => item !== null);

    scored.sort((a, b) => b.score - a.score);
    
    const accentPalette = ["#38bdf8", "#22c55e", "#f59e0b", "#a78bfa", "#06b6d4", "#f43f5e", "#6366f1"];
    function getAccent(seed: string) {
      let hash = 0;
      for (let i = 0; i < seed.length; i++) hash = (hash * 31 + seed.charCodeAt(i)) >>> 0;
      return accentPalette[hash % accentPalette.length];
    }

    return scored.slice(0, 15).map(({ model }) => ({
      ...model,
      url: `/company?id=${encodeURIComponent(model.idValue)}`,
      accent: getAccent(`${model.nickname}-${model.city}`)
    }));
  }

  // Rendering
  function renderResults(results: any[]) {
    if (!hitsEl || !loadingEl || !initialEl || !noResultsEl || !dialog?.open) return;
    
    renderedResults = results;
    activeIndex = -1;
    
    loadingEl.classList.add("hidden");
    initialEl.classList.add("hidden");
    
    if (!results.length) {
      hitsEl.classList.add("hidden");
      noResultsEl.classList.remove("hidden");
      return;
    }
    
    noResultsEl.classList.add("hidden");
    const fragment = document.createDocumentFragment();
    
    results.forEach((result, index) => {
      const li = document.createElement("li");
      li.setAttribute("role", "option");
      li.setAttribute("aria-selected", "false");
      li.setAttribute("data-index", index.toString());
      
      // Pure Tailwind Classes for the li
      li.className = "flex items-center gap-4 p-4 rounded-xl cursor-pointer border border-border-main bg-surface transition-all duration-200 group aria-selected:bg-primary/10 aria-selected:border-primary/50 aria-selected:shadow-lg aria-selected:shadow-primary/5 hover:bg-surface-hover hover:border-border-main/50";
      li.style.borderLeft = `5px solid ${result.accent}`;

      const info = document.createElement("div");
      info.className = "flex-1 min-w-0";
      
      const nick = document.createElement("h4");
      nick.className = "text-sm font-black text-main truncate group-aria-selected:text-primary transition-colors uppercase tracking-tight";
      nick.textContent = result.nickname;
      
      const full = document.createElement("p");
      full.className = "text-[11px] font-bold text-muted truncate mt-0.5 opacity-80";
      full.textContent = result.fullName;
      
      info.append(nick, full);
      
      const meta = document.createElement("div");
      meta.className = "flex items-center gap-3";
      
      const badge = document.createElement("span");
      badge.className = "px-2.5 py-1 rounded-lg bg-surface-hover border border-border-main text-[10px] font-black text-muted group-aria-selected:border-primary/30 group-aria-selected:text-primary transition-all uppercase";
      badge.textContent = result.city;
      
      meta.append(badge);
      
      li.append(info, meta);
      fragment.append(li);
      
      li.addEventListener("mouseenter", () => setActiveIndex(index));
      li.addEventListener("click", () => window.location.href = result.url);
    });
    
    hitsEl.replaceChildren(fragment);
    hitsEl.classList.remove("hidden");
    setActiveIndex(0);
  }

  function setActiveIndex(index: number) {
    if (!hitsEl || !renderedResults.length) { activeIndex = -1; return; }
    
    const items = hitsEl.querySelectorAll("li");
    activeIndex = (index + items.length) % items.length;
    
    items.forEach((item, i) => {
      const isActive = i === activeIndex;
      item.setAttribute("aria-selected", isActive ? "true" : "false");
      if (isActive) item.scrollIntoView({ block: "nearest", behavior: "auto" });
    });
  }

  // Lifecycle
  let unsubCompanies: (() => void) | null = null;
  let boundOnKey: ((e: KeyboardEvent) => void) | null = null;

  function openSearch() {
    if (!dialog) return;
    dialog.showModal();
    document.body.style.overflow = "hidden";
    document.documentElement.style.overflow = "hidden";
    requestAnimationFrame(() => input?.focus());
  }

  function closeSearch() {
    dialog?.close();
    document.body.style.overflow = "";
    document.documentElement.style.overflow = "";
  }

  function cleanup() {
    if (boundOnKey) document.removeEventListener("keydown", boundOnKey);
    if (unsubCompanies) unsubCompanies();
    boundOnKey = null;
    unsubCompanies = null;
  }

  function init() {
    cleanup();

    dialog = document.getElementById("search-dialog") as HTMLDialogElement;
    input = document.getElementById("search-input") as HTMLInputElement;
    hitsEl = document.getElementById("search-hits");
    initialEl = document.getElementById("search-initial");
    noResultsEl = document.getElementById("search-no-results");
    loadingEl = document.getElementById("search-loading");
    closeBtn = document.getElementById("search-close") as HTMLButtonElement;
    backdropEl = document.getElementById("search-backdrop");

    if (!dialog || !input) return;

    unsubCompanies = $companies.subscribe(val => {
      companies = Array.isArray(val) ? val : [];
      if (dialog?.open && input?.value.trim()) {
        renderResults(filterCompanies(input.value));
      }
    });

    input.addEventListener("input", (e) => {
      if (debounceTimer) clearTimeout(debounceTimer);
      const val = (e.target as HTMLInputElement).value;

      debounceTimer = window.setTimeout(() => {
        if (!val.trim()) {
          initialEl?.classList.remove("hidden");
          hitsEl?.classList.add("hidden");
          loadingEl?.classList.add("hidden");
          noResultsEl?.classList.add("hidden");
          return;
        }

        if (!companies.length) {
          loadingEl?.classList.remove("hidden");
          SyncManager.checkAndSync();
        } else {
          renderResults(filterCompanies(val));
        }
      }, 150);
    });

    boundOnKey = (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        dialog?.open ? closeSearch() : openSearch();
        return;
      }
      if (!dialog?.open) return;
      if (e.key === "Escape") { e.preventDefault(); closeSearch(); }
      if (e.key === "ArrowDown") { e.preventDefault(); setActiveIndex(activeIndex + 1); }
      if (e.key === "ArrowUp") { e.preventDefault(); setActiveIndex(activeIndex - 1); }
      if (e.key === "Enter" && activeIndex >= 0) window.location.href = renderedResults[activeIndex].url;
    };

    document.addEventListener("keydown", boundOnKey);

    document.querySelectorAll("[data-search-open], #search-open-btn")
      .forEach(b => b.addEventListener("click", openSearch));
    closeBtn?.addEventListener("click", closeSearch);
    backdropEl?.addEventListener("click", closeSearch);

    dialog.addEventListener("close", () => {
      document.body.style.overflow = "";
      document.documentElement.style.overflow = "";
    });
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-swap", cleanup);
</script>


