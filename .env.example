# 🌍 Medicert Portal: Comprehensive Environment Variables

# --- [PUBLIC] Client-Side Settings (Astro) ---
# The URL of your Cloudflare Worker Proxy.
# Production: https://portalapi.medicert.com.tr
# Local dev: http://localhost:8787
PUBLIC_WORKER_URL=https://portalapi.medicert.com.tr

# --- [SECRET] Cloudflare Worker Secrets ---
# These are set via: wrangler secret put <NAME>
# API_KEY=your_secure_api_key_here
# GAS_API_URL=https://script.google.com/macros/s/.../exec

# --- [SECRET] Google Apps Script Properties ---
# These are set in GAS Project Settings -> Script Properties.
# API_KEY=your_secure_api_key_here
# SPREADSHEET_ID=your_google_sheet_id
# LAST_UPDATE=0 (Initial value)
# ILOVEPDF_PUBLIC_KEY=project_public_...
# LOCAL_CONVERTER_TOKEN=your_token_for_pdf_serdar_cc
